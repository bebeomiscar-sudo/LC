-- ============================================================
--   MAIN LOOP — Heartbeat (Logic) + RenderStepped (Drawing)
-- ============================================================

local _frameCount = 0
local _frameTimer = tick()
local _fps        = 0
local _ping       = 0

-- FPS counter
Track(RunService.Heartbeat:Connect(function(dt)
    cam = Workspace.CurrentCamera

    _frameCount += 1
    local now = tick()
    if now - _frameTimer >= 1 then
        _fps        = _frameCount
        _frameTimer = now
        _frameCount = 0
    end

    -- Target cache refresh
    local cacheNow = tick()
    if cacheNow - _aimbotCacheTime >= CACHE_TTL then
        _aimbotCacheTime = cacheNow
        if AimbotCfg.Enabled then
            _aimbotCache = AimbotFindTarget()
        end

        -- Silent aim cache
        if SilentCfg.Enabled then
            _silentCache  = SilentFindNearest()
            _silentCacheT = cacheNow
        end
    end

    -- Aimbot logic
    if AimbotCfg.Enabled then
        -- React delay
        if aimbotIsReacting then
            aimbotReactTimer = aimbotReactTimer - dt
            if aimbotReactTimer <= 0 then aimbotIsReacting = false end
        end

        if not aimbotIsReacting then
            -- Validate current target
            if aimbotTarget then
                local hum = aimbotTarget.Parent and aimbotTarget.Parent:FindFirstChildOfClass("Humanoid")
                if not hum or hum.Health <= 0 or not InFOV(aimbotTarget, AimbotEffFOV()) then
                    aimbotTarget        = nil
                    aimbotLingerTimer   = 0
                    aimbotCurveStart    = nil
                    aimbotCurveProgress = 0
                    aimbotSpring = Spring.new(AimbotCfg.SpringMass, AimbotCfg.SpringForce, AimbotCfg.SpringDamping, AimbotCfg.SpringSpeed)
                end
            end

            -- Acquire new target from cache
            if not aimbotTarget and _aimbotCache then
                aimbotTarget      = _aimbotCache
                aimbotIsReacting  = true
                aimbotReactTimer  = AimbotCfg.ReactTime
                aimbotPrevPos     = nil
                aimbotLingerTimer = 0
            end

            -- Apply aimbot
            if aimbotTarget and InFOV(aimbotTarget, AimbotEffFOV()) then
                AimbotApply(aimbotTarget, dt)
            end
        end
    end

    -- Update Ragebot HUD
    if RageCfg.Enabled and rageHudVisible then
        UpdateRageHUD()
    end
end))

-- RenderStepped — ONLY drawings
Track(RunService.RenderStepped:Connect(function()
    cam = Workspace.CurrentCamera

    -- Aimbot FOV circle
    do
        local center = GetScreenCenter()
        AimbotFovCircle.Position = center
        AimbotFovCircle.Radius   = AimbotEffFOV()
        AimbotFovCircle.Visible  = AimbotCfg.Enabled
    end

    -- Silent Aim FOV circle
    do
        if SilentCfg.Enabled and SilentCfg.CircleOn then
            local center = GetScreenCenter()
            SilentCircle.Position  = center
            SilentCircle.Radius    = SilentCfg.FOV
            SilentCircle.Visible   = true
            SilentCircle.Color     = _silentCache and SilentCfg.TargetColor or SilentCfg.CircleColor
            SilentCircle.Thickness = SilentCfg.Thickness
        else
            SilentCircle.Visible = false
        end
    end

    -- ESP update
    UpdateESP()

    -- Ping
    local ok, pingVal = pcall(function()
        return math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
    end)
    if ok and pingVal then _ping = pingVal end
end))

