local aimbotCfg = {
    enabled       = false,
    speed         = 1,
    speedAtk      = 1,
    speedScale    = 1,
    maxLockTime   = 3,
    reactionTime  = 0,
    visCheck      = true,
    teamCheck     = true,
    fovSize       = 150,
    useCenter     = false,
    currentTarget = nil,
    lockStart     = 0,
}

local aimbotConn = nil

local function getAimbotTarget()
    local origin = cam.CFrame.Position
    local bestPart  = nil
    local bestDist  = math.huge

    for _, player in pairs(Players:GetPlayers()) do
        if player == lp then continue end
        if aimbotCfg.teamCheck and sameTm(player) then continue end

        local char = player.Character
        if not char then continue end

        local head = char:FindFirstChild("Head")
        local hum  = char:FindFirstChildOfClass("Humanoid")
        if not head or not hum or hum.Health <= 0 then continue end

        if not inFov(head, aimbotCfg.fovSize) then continue end

        if aimbotCfg.visCheck and not isVis(origin, head) then
            continue
        end

        local sp = w2s(head.Position)
        if not sp then continue end

        local center = aimbotCfg.useCenter
            and scr()
            or UserInputService:GetMouseLocation()

        local dist = (sp - center).Magnitude
        if dist < bestDist then
            bestDist    = dist
            bestPart    = head
        end
    end

    return bestPart
end

local function startAimbot()
    if aimbotConn then
        aimbotConn:Disconnect()
        aimbotConn = nil
    end

    aimbotConn = RunService.RenderStepped:Connect(function(dt)
        if not aimbotCfg.enabled then return end
        if not CameraController then return end

        pcall(function()
            local target = getAimbotTarget()
            aimbotCfg.currentTarget = target

            if not target then return end

            -- Max lock time check
            if tick() - aimbotCfg.lockStart > aimbotCfg.maxLockTime then
                aimbotCfg.lockStart = tick()
                return
            end

            -- Reaction time
            if aimbotCfg.reactionTime > 0 then
                if math.random() < aimbotCfg.reactionTime then
                    return
                end
            end

            local headPos = target.Position
            local camPos  = cam.CFrame.Position
            local dir     = (headPos - camPos)

            local yaw   = math.atan2(dir.X, -dir.Z)
            local pitch = math.atan2(
                -dir.Y,
                Vector2.new(dir.X, dir.Z).Magnitude
            )

            local targetRot  = Vector2.new(pitch, yaw)
            local currentRot = CameraController.Rotation

            -- Attack speed check
            local inAtk = false
            pcall(function()
                local lf = getLocalFighter()
                if lf and lf.EquippedItem then
                    inAtk = lf.EquippedItem:Get("IsAiming") or false
                end
            end)

            local spd = (inAtk and aimbotCfg.speedAtk or aimbotCfg.speed)
                * aimbotCfg.speedScale

            local newRot = Vector2.new(
                currentRot.X + (targetRot.X - currentRot.X)
                    * math.clamp(spd * dt * 60, 0, 1),
                currentRot.Y + (targetRot.Y - currentRot.Y)
                    * math.clamp(spd * dt * 60, 0, 1)
            )

            CameraController:SetRotation(newRot)
        end)
    end)
end

local function stopAimbot()
    if aimbotConn then
        aimbotConn:Disconnect()
        aimbotConn = nil
    end
    aimbotCfg.enabled       = false
    aimbotCfg.currentTarget = nil
end

