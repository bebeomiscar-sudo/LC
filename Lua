local lastSlotForce = 0

local function pressSlot(idx)
    if not idx or idx < 1 or idx > 3 then return end
    pcall(function()
        VIM:SendKeyEvent(true,  SLOT_KC[idx], false, game)
        task.wait(0.02)
        VIM:SendKeyEvent(false, SLOT_KC[idx], false, game)
    end)
    if keypress then
        pcall(keypress, SLOT_HEX[idx])
        task.wait(0.02)
        if keyrelease then pcall(keyrelease, SLOT_HEX[idx]) end
    end
end

local function forceEquipSlot()
    if not Cfg.rageMasterOn and not Cfg.enabled then return end
    local want = wantSlot()
    local lf   = getLF()
    if not lf then return end
    local eq = lf.EquippedItem
    if eq and getEquippedSlot(eq) == want then return end
    local now = tick()
    if now - lastSlotForce < 0.06 then return end
    lastSlotForce = now
    local item = getSlotItem(want)
    local oid  = item and getItemOID(item)
    if oid then
        for _, en in ipairs({"Equip","Switch","Select","EquipItem","ChangeItem"}) do
            pcall(function()
                local ev = Mod.Enums:ToEnum(en)
                if ev then UseItem:FireServer(oid, ev, nil, nil) end
            end)
        end
    end
    pcall(function()
        if lf.EquipItem   then lf:EquipItem(want)   end
        if lf.Equip       then lf:Equip(want)       end
        if lf.SwitchToSlot then lf:SwitchToSlot(want) end
    end)
    pressSlot(want)
end

