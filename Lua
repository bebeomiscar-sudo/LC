-- Rebuild vectors from individual Y values
local function rebuildVectors()
    rageCfg.vectors = {
        Vector3.new(rageCfg.v1x, rageCfg.v1y, rageCfg.v1z),
        Vector3.new(rageCfg.v2x, rageCfg.v2y, rageCfg.v2z),
