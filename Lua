local rConfig = {
    target = { enabled = false, character = nil, auto = false, autoshoot = false, hitpart = "Head" },
    prediction = { enabled = false, multiplier = 1.2, velocity = Vector3.zero, lastposition = nil, lasttime = 0 },
    state = { csyncactive = false },
    orbit = { active = false, connection = nil, speed = 9000, height = 1, radius = 0 },
    voidspam = { enabled = false, phase = "shoot", lastswitch = 0, currentduration = 0 },
}
local rPerf = { lastAttackTick = 0 }
local rlocalfighter = FighterController and FighterController.LocalFighter
local rOldPos = nil

-- Weapon helpers
local function rGetWeapon()
    if not rlocalfighter or not rlocalfighter.EquippedItem then return nil end
    return rlocalfighter.EquippedItem:Get("Name")
end

local function rGetAmmo()
    if not rlocalfighter or not rlocalfighter.EquippedItem then return 0, 0, false end
    local current = rlocalfighter.EquippedItem:Get("CurrentAmmo") or 0
    local max = rlocalfighter.EquippedItem:Get("MaxAmmo") or 0
    return current, max, false
end

local function rValid(char)
    if not char or not char.Parent then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if not char:FindFirstChild("HumanoidRootPart") then return false end
    return true
end

local function rNearest()
    local mousePos = getMouse()
    local best, bestDist = nil, 200
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and isValidTarget(p) then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local sp, on = cam:WorldToViewportPoint(root.Position)
                if on then
                    local d = (Vector2.new(sp.X, sp.Y) - mousePos).Magnitude
                    if d < bestDist then bestDist = d; best = p.Character end
                end
            end
        end
    end
    return best
end

local function rHitpart(char, partname)
    if not char then return nil end
    return char:FindFirstChild(partname) or char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
end

local function rPredict(hitpart, origin)
    if not rConfig.prediction.enabled then return hitpart and hitpart.Position or Vector3.zero end
    local base = hitpart.Position
    local dist = (base - origin).Magnitude
    local ping = 0
    pcall(function() ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000 end)
    return base + (rConfig.prediction.velocity * (dist / 3000 + ping) * rConfig.prediction.multiplier)
end

local function rUpdateVel()
    if not rConfig.target.character or not rConfig.prediction.enabled then
        rConfig.prediction.velocity = Vector3.zero
        return
    end
    local root = rConfig.target.character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local now = tick()
    local dt = now - rConfig.prediction.lasttime
    if dt > 0 and dt < 0.1 then
        local current = root.Position
        if rConfig.prediction.lastposition then
            rConfig.prediction.velocity = (current - rConfig.prediction.lastposition) / dt
        end
        rConfig.prediction.lastposition = current
        rConfig.prediction.lasttime = now
    end
end

local function rAutoShoot()
    if not rConfig.target.enabled or not rConfig.target.character or not rConfig.target.autoshoot then return end
    if not rConfig.target.character or not rValid(rConfig.target.character) then return end
    local hitPart = rHitpart(rConfig.target.character, rConfig.target.hitpart)
    if not hitPart then return end
    local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    local shootPos = myRoot and myRoot.Position or cam.CFrame.Position
    local targetPos = rPredict(hitPart, shootPos)
    local data = {
        [utf8.char(1)] = {
            [utf8.char(0)] = util and util:EncodeCFrame(CFrame.new(shootPos, targetPos)) or "",
            [utf8.char(1)] = util and util:EncodeCFrame(CFrame.new(shootPos, targetPos)) or "",
            [utf8.char(2)] = hitPart,
        }
    }
    local item = rlocalfighter and rlocalfighter.EquippedItem
    if item and item:Get("ObjectID") then
        local remote = ReplicatedStorage.Remotes.Replication.Fighter.UseItem
        pcall(function()
            remote:FireServer(item:Get("ObjectID"), enums and enums:ToEnum("StartShooting") or 0, data, nil)
        end)
    end
end

-- Main Heartbeat
RunService.Heartbeat:Connect(function()
    if rConfig.target.auto then
        if not rConfig.target.enabled or not rConfig.target.character or not rValid(rConfig.target.character) then
            local newTarget = rNearest()
            if newTarget then rConfig.target.character = newTarget; rConfig.target.enabled = true end
        end
    end
    if rConfig.target.enabled and rConfig.target.character then
        if not rValid(rConfig.target.character) then
            rConfig.target.enabled = false
            rConfig.target.character = nil
        else
            if rConfig.target.autoshoot then rAutoShoot() end
            if rConfig.prediction.enabled then rUpdateVel() end
        end
    end
end)

