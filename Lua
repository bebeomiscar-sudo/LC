--// Keybind: E = manual lock
game:GetService("UserInputService").InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.E then
        if Cfg.enabled and Cfg.character then
            Ragebot.clearTarget()
            Library:Notification("Ragebot", "Target cleared", 2)
        else
            local near = Ragebot.getNearestTarget()
            if near then
                Ragebot.setTarget(near)
                Cfg.manualKey = true
                local plr = game:GetService("Players"):GetPlayerFromCharacter(near)
                Library:Notification("Ragebot", "Locked: " .. (plr and plr.Name or "?"), 2)
            end
        end
    end
end)

