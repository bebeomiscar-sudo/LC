        obj.label.Visible = true
        obj.label.Text = math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth)
        obj.label.Color = Color3.fromRGB(255, 200, 100)
        obj.label.Position = Vector2.new(cx, by + h + 2)
        obj.label.Size = 10
    end
end

