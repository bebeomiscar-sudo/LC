-- =============================================
--   Helpers
-- =============================================

local function getLocalFighter()
    if not FighterController then return nil end
    local ok, f = pcall(function()
        return FighterController.LocalFighter
    end)
    return ok and f or nil
end

local function getAllFighters()
    if not FighterController then return {} end
    local fighters = {}
    pcall(function()
        for _, f in pairs(FighterController.Objects) do
            table.insert(fighters, f)
        end
    end)
    return fighters
end

local function isTeammate(fighter)
    if not fighter then return false end
    local ok, result = pcall(function()
        local lf = getLocalFighter()
        if not lf then return false end
        return fighter:Get("TeamID") == lf:Get("TeamID")
    end)
    return ok and result or false
end

local function isAlive(fighter)
    local ok, result = pcall(function()
        return fighter:IsAlive()
    end)
    return ok and result or false
end

local function getFighterHRPPos(fighter)
    local ok, result = pcall(function()
        return fighter.Entity.RootPart.Position
    end)
    return ok and result or nil
end

local function getFighterHeadPos(fighter)
    local ok, result = pcall(function()
        local head = fighter.Entity.Model:FindFirstChild("Head")
        return head and head.Position or fighter.Entity.RootPart.Position
    end)
    return ok and result or nil
end

local function isVisible(fromPos, toPos, targetModel)
    if not Utility then return true end
    local ok, result = pcall(function()
        local dir   = (toPos - fromPos)
        local dist  = dir.Magnitude
        local ray   = Utility:Raycast(
            fromPos,
            toPos,
            dist,
            {targetModel},
            Enum.RaycastFilterType.Include
        )
        return ray.Instance ~= nil
    end)
    return ok and result or false
end

