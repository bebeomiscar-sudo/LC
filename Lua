-- FOV circle update loop
local fovAnimClock = 0
RunService.RenderStepped:Connect(function(dt)
    fovAnimClock += dt
    local cam = Workspace.CurrentCamera
    if not cam then return end
    local vp = cam.ViewportSize
    local cx = vp.X * 0.5
    local cy = vp.Y * 0.5
    local r  = aimbot.fovRadius
    local d  = r * 2

    aimbotFOVCircle.Position = UDim2.fromOffset(cx, cy)
    aimbotFOVCircle.Size     = UDim2.fromOffset(d, d)
    aimbotFOVFill.Position   = UDim2.fromOffset(cx, cy)
