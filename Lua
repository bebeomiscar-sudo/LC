local function getWeaponName()
    local vm = Workspace:FindFirstChild("ViewModels")
    if not vm then return nil end
    local fp = vm:FindFirstChild("FirstPerson")
    if not fp then return nil end
    for _, child in ipairs(fp:GetChildren()) do
        local parts = {}
        for p in child.Name:gmatch("[^-]+") do
            table.insert(parts, p:match("^%s*(.-)%s*$"))
        end
        if #parts >= 2 then return parts[2] end
    end
    return nil
end

local function getMuzzlePos()
    local vm = Workspace:FindFirstChild("ViewModels")
    if not vm then return nil end
    local fp = vm:FindFirstChild("FirstPerson")
    if not fp then return nil end
    for _, model in ipairs(fp:GetChildren()) do
        if model.Name:find(LocalPlayer.Name, 1, true) then
            local iv = model:FindFirstChild("ItemVisual")
            if iv then
                local body = iv:FindFirstChild("Body")
                if body then
                    local bp = body:FindFirstChild("BodyPrimary")
                    if bp then
                        local muzzle = bp:FindFirstChild("_muzzle")
                        if muzzle then return muzzle.WorldPosition end
                    end
                end
            end
        end
    end
    return nil
end

local function isInfiniteWeapon()
    local w = getWeaponName()
    return w and INFINITE_WEAPONS[w] == true or false
end

local function isSling(w)
    return w and w:lower():find("slingshot", 1, true) ~= nil
end

local function wantSlot()
    return SLOTS[Cfg.weaponSlot or "primary"] or 1
end

local function pickMelee()
    return (Cfg.weaponSlot or "primary") == "melee"
end

local function getLFItems()
    local lf = getLF()
    return lf and lf.Items or nil
end

local function itemGet(item, key)
    if not item then return nil end
    local ok, v = pcall(function() return item:Get(key) end)
    return ok and v or nil
end

local function getItemOID(item)
    return item and itemGet(item, "ObjectID") or nil
end

local function getItemName(item)
    return tostring(itemGet(item, "Name") or "")
end

local function isMeleeItem(item)
    if not item then return false end
    local nm = getItemName(item)
    if nm:lower():find("melee", 1, true) then return true end
    if MELEE_NAMES[nm] then return true end
    local t = itemGet(item, "ItemType") or itemGet(item, "Type") or ""
    return type(t) == "string" and t:lower():find("melee", 1, true) ~= nil
end

local function getSlotItem(slotIdx)
    local items = getLFItems()
    if not items then return nil end
    if items[slotIdx] then return items[slotIdx] end
    if items[tostring(slotIdx)] then return items[tostring(slotIdx)] end
    for key, it in pairs(items) do
        if it then
            local s = tonumber(itemGet(it, "Slot") or itemGet(it, "Index") or key)
            if s == slotIdx then return it end
            local t = itemGet(it, "ItemType") or itemGet(it, "Type") or ""
            if slotIdx == 3 and (t == "Melee" or (type(t) == "string" and t:lower():find("melee",1,true))) then return it end
            if slotIdx == 1 and (t == "Primary"   or t == 1) then return it end
            if slotIdx == 2 and (t == "Secondary" or t == 2) then return it end
        end
    end
    -- Sort fallback
    local ordered = {}
    for _, it in pairs(items) do if it then ordered[#ordered+1] = it end end
    table.sort(ordered, function(a, b)
        local sa = tonumber(itemGet(a,"Slot") or itemGet(a,"Index")) or 99
        local sb = tonumber(itemGet(b,"Slot") or itemGet(b,"Index")) or 99
        return sa < sb
    end)
    return ordered[slotIdx]
end

local function getEquippedSlot(item)
    if not item then return nil end
    local items = getLFItems()
    local oid   = getItemOID(item)
    if items and oid then
        for i = 1, 3 do
            local it = items[i] or items[tostring(i)]
            if it and getItemOID(it) == oid then return i end
        end
    end
    if isMeleeItem(item) then return 3 end
    return nil
end

