-- ============================================================

local WBCfg = {
    Enabled   = false,
    HitPart   = "Head",
    UseDesync = true,
    TeamCheck = true,
}

local WBHooked       = false
local WBOldFunc      = nil
local wbTargetPlayer = nil
local wbDesyncConn   = nil
local wbDesyncActive = false

-- Find nearest wallbang target
local function WBFindTarget()
    local best, bestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p==lp or not IsValidTarget(p) then continue end
        if WBCfg.TeamCheck and SameTeam(p) then continue end
        local hrp = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        local d = (cam.CFrame.Position - hrp.Position).Magnitude
        if d < bestDist then bestDist=d;best=p end
    end
    return best
end

-- Wallbang desync: teleport shooter near target briefly
local function WBDesyncStart(targetChar)
    if wbDesyncConn then wbDesyncConn:Disconnect();wbDesyncConn=nil end
    wbDesyncActive = true
    local targetHead = targetChar and targetChar:FindFirstChild("Head")
    if not targetHead then return end

    wbDesyncConn = Track(RunService.Heartbeat:Connect(function()
        if not wbDesyncActive then return end
        local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        if not targetHead or not targetHead.Parent then
            wbDesyncActive = false
            if wbDesyncConn then wbDesyncConn:Disconnect();wbDesyncConn=nil end
            return
        end
        -- Team check on desync
        local owner = Players:GetPlayerFromCharacter(targetChar)
        if owner and WBCfg.TeamCheck and SameTeam(owner) then
            wbDesyncActive = false
            if wbDesyncConn then wbDesyncConn:Disconnect();wbDesyncConn=nil end
            return
        end
        -- Save current state
        local savedCF = myRoot.CFrame
        local savedLV = myRoot.AssemblyLinearVelocity
        local savedAV = myRoot.AssemblyAngularVelocity
        -- Teleport to near target
        pcall(function()
            myRoot.CFrame = targetHead.CFrame * CFrame.new(0, -5, 0)
        end)
        -- Restore next render step
        RunService:BindToRenderStep("__WBDesyncRestore", 101, function()
            pcall(function()
                myRoot.CFrame                  = savedCF
                myRoot.AssemblyLinearVelocity  = savedLV
                myRoot.AssemblyAngularVelocity = savedAV
            end)
            RunService:UnbindFromRenderStep("__WBDesyncRestore")
        end)
    end))
end

local function WBDesyncStop()
    wbDesyncActive = false
    if wbDesyncConn then wbDesyncConn:Disconnect();wbDesyncConn=nil end
    pcall(function() RunService:UnbindFromRenderStep("__WBDesyncRestore") end)
end

-- Update target on heartbeat
Track(RunService.Heartbeat:Connect(function()
    if not WBCfg.Enabled then return end
    wbTargetPlayer = WBFindTarget()
end))

local function WBHook()
    if WBHooked or not GunModule then
        warn("[Wallbang] GunModule unavailable");return
    end
    local orig = GunModule.StartShooting
    if not orig then warn("[Wallbang] StartShooting not found");return end
    WBOldFunc = orig

    local ok = pcall(function()
        rawset(GunModule, "StartShooting", function(self2, ...)
            local results = {orig(self2, ...)}

            if not WBCfg.Enabled or not wbTargetPlayer then
                return table.unpack(results)
            end

            if not self2.ClientFighter or not self2.ClientFighter.IsLocalPlayer then
                return table.unpack(results)
            end

            local char = wbTargetPlayer.Character
            if not char then return table.unpack(results) end

            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health <= 0 then return table.unpack(results) end

            local sd = results[3]
            if not sd or type(sd) ~= "table" then return table.unpack(results) end

            local part = WBCfg.HitPart == "Head"
                and char:FindFirstChild("Head")
                or  char:FindFirstChild("UpperTorso")
                or  char:FindFirstChild("HumanoidRootPart")
            if not part then return table.unpack(results) end

            local tPos = part.Position
            local oPos = tPos - Vector3.new(0, 3, 0)

            pcall(function()
                if UtilityModule then
                    sd[utf8.char(0)] = UtilityModule:EncodeCFrame(CFrame.new(oPos, tPos))
                    sd[utf8.char(1)] = UtilityModule:EncodeCFrame(CFrame.new(tPos, oPos))
                    sd[utf8.char(2)] = part
                    sd[utf8.char(3)] = UtilityModule:EncodeCFrame(
                        part.CFrame:ToObjectSpace(CFrame.new(
                            tPos + Vector3.new(
                                math.random(-5,5)*0.01,
                                math.random(-5,5)*0.01,
                                math.random(-5,5)*0.01
                            )
                        ))
                    )
                end
            end)

            -- Optional desync on shot
            if WBCfg.UseDesync then
                WBDesyncStart(char)
                task.delay(0.15, function()
                    WBDesyncStop()
                end)
            end

            return table.unpack(results)
        end)
    end)

    if ok then
        WBHooked = true
        print("[Wallbang] Hooked via GunModule.StartShooting")
    else
        warn("[Wallbang] Hook failed — table may be frozen")
        WBOldFunc = nil
    end
end

local function WBUnhook()
    if not WBHooked or not GunModule then return end
    pcall(function() rawset(GunModule, "StartShooting", WBOldFunc) end)
    WBOldFunc = nil
    WBHooked  = false
    WBDesyncStop()
    print("[Wallbang] Unhooked")
end

