--// ═══════════════════════════════════════════════════════════

local function getAmmo()
    if isInfiniteWeapon() then return nil, nil, false end
    local lf = getLF()
    if not lf or not lf.EquippedItem then return 0, 0, pickMelee() end
    local item = lf.EquippedItem
    local cur, max_, isMelee = 0, 0, false
    pcall(function()
        local nm  = getItemName(item)
        cur    = tonumber(itemGet(item,"CurrentAmmo") or itemGet(item,"Ammo")    or 0)
        max_   = tonumber(itemGet(item,"MaxAmmo")    or itemGet(item,"MaxBullets") or cur)
        isMelee = MELEE_NAMES[nm] or nm:lower():find("melee",1,true) ~= nil
    end)
    if pickMelee() then isMelee = true end
    return cur, max_, isMelee
end

local function isItemReloading()
    if isInfiniteWeapon() then return false end
    local lf = getLF()
    if not lf or not lf.EquippedItem then return false end
    local result = false
    pcall(function()
        for _, k in ipairs({"Reloading","IsReloading","IsReload"}) do
            local v = itemGet(lf.EquippedItem, k)
            if v == true or v == 1 then result = true return end
        end
    end)
    if result then return true end
    local started = Cfg.state.reloadStartAt or 0
    return started > 0 and (tick() - started) < 1.75
end

local function tickAmmo()
    if isInfiniteWeapon() then
        Cfg.state.outOfAmmo   = false
        Cfg.state.reloading   = false
        Cfg.state.reloadStartAt = 0
        return
    end
    local cur, _, melee = getAmmo()
    local wasOut = Cfg.state.outOfAmmo
    Cfg.state.outOfAmmo = not melee and (tonumber(cur) or 0) <= 0
    local reloading = isItemReloading()
    if reloading and not Cfg.state.reloading then
        Cfg.state.reloadStartAt = tick()
    elseif not reloading then
        Cfg.state.reloadStartAt = 0
    end
    Cfg.state.reloading = reloading
    -- Trigger void phase on ammo events
    if Cfg.state.outOfAmmo and not wasOut then
        if isSling(getWeaponName()) then
            Cfg.voidSpam.phase = "hide"
        end
    elseif not Cfg.state.outOfAmmo and wasOut then
        if Cfg.voidSpam.enabled then
            Cfg.voidSpam.phase     = "shoot"
            Cfg.voidSpam.lastSwitch = tick()
        else
            Cfg.voidSpam.phase = nil
        end
    end
end

local function canShoot()
    local char = LocalPlayer.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if isInfiniteWeapon() then return true end
    local cur, _, melee = getAmmo()
    return (cur and cur > 0) or melee
end

