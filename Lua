-- =============================================
--   Void Snap (from source)
-- =============================================

local vfrLim, vfrDead = 2147483646, 1147483646
local vfrSnap = {cf=nil, lv=nil, av=nil}

local function clrVoidSnap()
    vfrSnap.cf, vfrSnap.lv, vfrSnap.av = nil, nil, nil
end

local function rndSkip(mi, ma, dmi, dma)
    local val = math.random(mi, ma)
    while val >= dmi and val <= dma do
        val = math.random(mi, ma)
    end
    return val
end

local function voidHrp()
    local char = lp.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function snapVoid(hrp)
    if not hrp then return end
    vfrSnap.cf = hrp.CFrame
    vfrSnap.lv = hrp.AssemblyLinearVelocity
    vfrSnap.av = hrp.AssemblyAngularVelocity
    pcall(function()
        local lim, dead = vfrLim, vfrDead
        local p = Vector3.new(
            rndSkip(-lim,lim,-dead,dead),
            rndSkip(-lim,lim,-dead,dead),
            rndSkip(-lim,lim,-dead,dead)
        )
        local v = Vector3.new(
            rndSkip(-lim,lim,-dead,dead),
            rndSkip(-lim,lim,-dead,dead),
            rndSkip(-lim,lim,-dead,dead)
        )
        hrp.CFrame                  = CFrame.new(p) * CFrame.Angles(math.pi,math.pi,math.pi)
        hrp.AssemblyLinearVelocity  = v
        hrp.AssemblyAngularVelocity = v
    end)
end

RunService:BindToRenderStep("vfr_csync", Enum.RenderPriority.First.Value, function()
    if not vfrSnap.cf then return end
    local hrp = voidHrp()
    if not hrp then return end
    pcall(function()
        hrp.CFrame                  = vfrSnap.cf
        hrp.AssemblyLinearVelocity  = vfrSnap.lv
        hrp.AssemblyAngularVelocity = vfrSnap.av
    end)
end)

-- =============================================
--   Orbit / Desync (from source)
-- =============================================

local localfighter = FighterController and FighterController.LocalFighter
local oldpos

local function stopsync()
    if not rageCfg.state.csyncactive then return end
    if rageCfg.orbit.connection then
        rageCfg.orbit.connection:Disconnect()
        rageCfg.orbit.connection = nil
    end
    rageCfg.state.csyncactive = false
    rageCfg.orbit.active      = false
    clrVoidSnap()
    rageCfg.voidspam.phase = nil
    if rageCfg.orbit.savedpos and localfighter and localfighter.Entity and localfighter.Entity.RootPart then
        pcall(function()
            localfighter.Entity.RootPart.CFrame = rageCfg.orbit.savedpos
        end)
    end
    rageCfg.orbit.serverpos = nil
    rageCfg.orbit.savedpos  = nil
    oldpos = nil
end

local function orbBase(root)
    if not root then return Vector3.zero end
    return root.Position + Vector3.new(0, rageCfg.orbit.height, 0)
end

local function startsync()
    if rageCfg.state.csyncactive then return end
    if rageCfg.immune then return end
    if not rageCfg.character or not rageValid(rageCfg.character) then return end
    eqSlot()
    rageCfg.state.csyncactive = true
    rageCfg.orbit.active      = true
    if not rageCfg.orbit.savedpos then
        if localfighter and localfighter.Entity and localfighter.Entity.RootPart then
            rageCfg.orbit.savedpos = localfighter.Entity.RootPart.CFrame
        end
    end
    rageCfg.orbit.connection = RunService.Heartbeat:Connect(function(dt)
        if not rageCfg.state.csyncactive then return end
        if rageCfg.immune then stopsync(); return end
        if not rageCfg.character or not rageValid(rageCfg.character) then stopsync(); return end
        if not localfighter or not localfighter.Entity or not localfighter.Entity.RootPart then stopsync(); return end

        eqSlot()
        oldpos = localfighter.Entity.RootPart.CFrame

        if rageCfg.state.outofammo and not isInfiniteWeapon() then
            local hrp = voidHrp()
            if hrp then snapVoid(hrp) end
            return
        end

        local root      = rageCfg.character:FindFirstChild("HumanoidRootPart")
        if not root then stopsync(); return end
        local targetpos = orbBase(root)
        rageCfg.orbit.angle = rageCfg.orbit.angle + (rageCfg.orbit.speed * dt)
        local offset = Vector3.new(
            math.cos(rageCfg.orbit.angle) * rageCfg.orbit.radius,
            rageCfg.orbit.height,
            math.sin(rageCfg.orbit.angle) * rageCfg.orbit.radius
        )
        rageCfg.orbit.serverpos = targetpos + offset

        if localfighter and localfighter.Entity and localfighter.Entity.RootPart then
            local currentPos = localfighter.Entity.RootPart.CFrame
            local newPos     = CFrame.new(rageCfg.orbit.serverpos)
            local distance   = (newPos.Position - currentPos.Position).Magnitude
            if distance < 2000 then
                localfighter.Entity.RootPart.CFrame = newPos
                rageCfg.orbit.savedpos = currentPos
            end
        end
    end)
end

