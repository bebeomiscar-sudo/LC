local function RageCheckImmune(char)
    if not char then return false end
    local root = char:FindFirstChild("HumanoidRootPart")
    return root and root:FindFirstChild("Attachment") ~= nil
end

local function RageTickImmunity()
    for _, p in ipairs(Players:GetPlayers()) do
        if p == lp then continue end
        local char = p.Character
        if not char then continue end
        local isImmune = RageCheckImmune(char)
        local wasImmune = RC.ImmuneList[p.Name]

        if isImmune and not wasImmune then
            RC.ImmuneList[p.Name] = true
            if RC.Target.Player == p then
                RC.Target.Immune = true
                RageIndicator.Color = Color3.fromRGB(180, 0, 255)
                RageStopOrbit()
            end
        elseif not isImmune and wasImmune then
            RC.ImmuneList[p.Name] = nil
            if RC.Target.Player == p then
                RC.Target.Immune = false
                RageIndicator.Color = Color3.fromRGB(255, 50, 50)
                if RC.Enabled and RC.Target.Character and RC.Target.Enabled then
                    RageStartOrbit()
                end
            end
        end
    end
end

