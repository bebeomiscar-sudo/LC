    local vhState = { active=false }

    local vfrLim,vfrDead = 2147483646,1147483646
    local vfrSnap = {cf=nil,lv=nil,av=nil}

    local function clrVoidSnap() vfrSnap.cf=nil;vfrSnap.lv=nil;vfrSnap.av=nil end

    local function voidHrp()
        local char = lp.Character
        return char and char:FindFirstChild("HumanoidRootPart")
    end

    local function rndSkip(mi,ma,dmi,dma)
        local val = math.random(mi,ma)
        while val>=dmi and val<=dma do val=math.random(mi,ma) end
        return val
    end

    local function snapVoid(hrp)
        if not hrp then return end
        if lobbyCache() then return end
        vfrSnap.cf = hrp.CFrame
        vfrSnap.lv = hrp.AssemblyLinearVelocity
        vfrSnap.av = hrp.AssemblyAngularVelocity
        pcall(function()
            local p = Vector3.new(
                rndSkip(-vfrLim,vfrLim,-vfrDead,vfrDead),
                rndSkip(-vfrLim,vfrLim,-vfrDead,vfrDead),
                rndSkip(-vfrLim,vfrLim,-vfrDead,vfrDead)
            )
            hrp.CFrame = CFrame.new(p)*CFrame.Angles(math.pi,math.pi,math.pi)
            hrp.AssemblyLinearVelocity  = p
            hrp.AssemblyAngularVelocity = p
        end)
    end

    RunService:BindToRenderStep("vfr_csync", Enum.RenderPriority.First.Value, function()
        if not vfrSnap.cf then return end
        local hrp = voidHrp()
        if not hrp then return end
        pcall(function()
            hrp.CFrame = vfrSnap.cf
            hrp.AssemblyLinearVelocity  = vfrSnap.lv
            hrp.AssemblyAngularVelocity = vfrSnap.av
        end)
    end)

    local function clampVs(v) return math.clamp(tonumber(v) or 1, 0.1, 2) end
    local function randVs(a,b)
        a,b = clampVs(a),clampVs(b)
        if b<a then a,b=b,a end
        return a==b and a or a+math.random()*(b-a)
    end

    local function atkCfg()
        if rageConfig.attackCustomEnabled then
            return {height=rageConfig.customHeight,front=rageConfig.customFront,side=rageConfig.customSide,vertical=rageConfig.customVertical,radius=rageConfig.customRadius}
        end
        if rageConfig.weaponPick=="melee" then
            return {height=0,front=0,side=0,vertical=-rageConfig.meleeFeetDrop,radius=0}
        end
        local mode = rageConfig.attackPosition or "default"
        if mode=="under" then
            return {height=0,front=0,side=0,vertical=-(rageConfig.underOffset or 4),radius=0}
        end
        local w = getweapon()
        return {height=(w and w:lower():find("sniper")) and 8 or 2,front=0,side=0,vertical=0,radius=0}
    end

    local function orbBase(root)
        if not root then return Vector3.zero end
        local s   = atkCfg()
        local pos  = root.Position
        local look = root.CFrame.LookVector
        local right= root.CFrame.RightVector
        return pos + (look*s.front) + (right*s.side) + Vector3.new(0,s.vertical,0)
    end

    local function refreshAtk()
        local s = atkCfg()
        rageConfig.orbit.height = s.height
        rageConfig.orbit.radius = s.radius or 0
    end

    local function eqSlot()
        if not rageConfig.enabled then return end
        local want = SLOTS[rageConfig.weaponPick or "primary"] or 1
        local lf = FighterController and FighterController.LocalFighter
        if not lf then return end
        local eq = lf.EquippedItem
        if eq and whichSlot(eq)==want then return end
        local now = tick()
        if now-rageLastSlotForce < 0.06 then return end
        rageLastSlotForce = now
        local item = slotItem(want)
        local oid  = item and item:Get("ObjectID")
        if oid then
            pcall(function()
                for _, en in ipairs({"Equip","Switch","Select","EquipItem","ChangeItem"}) do
                    local ev = EnumLibrary:ToEnum(en)
                    if ev then UseItemRemote:FireServer(oid,ev,nil,nil) end
                end
            end)
        end
        pcall(function()
            if lf.EquipItem then lf:EquipItem(want) end
            if lf.Equip     then lf:Equip(want)     end
        end)
        pressSlot(want)
    end

    local function valid(char)
        if not char or not char.Parent then return false end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health<=0 then return false end
        if not char:FindFirstChild("HumanoidRootPart") then return false end
        local tp = Players:GetPlayerFromCharacter(char)
        if not tp then return false end
        if rageConfig.teamCheck and sameTm(tp) then return false end
        return true
    end

    local function nearest()
        local cursor = getMouse()
        local best, bd = nil, math.huge
        for _, p in ipairs(Players:GetPlayers()) do
            if p==lp or not p.Character then continue end
            if not valid(p.Character) then continue end
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            if not root then continue end
            local sp, on = worldToScreen(root.Position)
            if not on then continue end
            local d = (sp-cursor).Magnitude
            if d < bd then best=p.Character; bd=d end
        end
        return best
    end

    -- Prediction
    local function updatevel()
        if not rageConfig.target.character or not rageConfig.prediction.enabled then
            rageConfig.prediction.velocity = Vector3.zero
            return
        end
        local root = rageConfig.target.character:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local now = tick()
        local dt  = now - rageConfig.prediction.lasttime
        if dt>0 and dt<0.1 then
            local cur = root.Position
            if rageConfig.prediction.lastposition then
                local inst = (cur-rageConfig.prediction.lastposition)/dt
                rageConfig.prediction.velocity = rageConfig.prediction.velocity:Lerp(inst, 0.6)
            end
            rageConfig.prediction.lastposition = cur
            rageConfig.prediction.lasttime      = now
        end
    end

    local function predict(targetPart, origin)
        if not rageConfig.prediction.enabled or not targetPart then
            return targetPart and targetPart.Position or Vector3.zero
        end
        local base = targetPart.Position
        local dist = (base-origin).Magnitude
        local ping = 0
        pcall(function()
            ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue()/1000
        end)
        local totalTime = (dist/3000+ping)*rageConfig.prediction.multiplier
        return base + rageConfig.prediction.velocity*totalTime
    end

    -- VoidSpam
    local function tickVoidSpam()
        if not rageConfig.voidspam.enabled then return end
        local vs  = rageConfig.voidspam
        local now = tick()
        local elapsed = now-vs.lastswitch
        if vs.phase=="shoot" then
            if elapsed >= vs.currentduration then
                vs.phase           = "hide"
                vs.currentduration = randVs(vs.hide_min,vs.hide_max)
                vs.lastswitch      = now
            end
        elseif vs.phase=="hide" then
            if elapsed >= vs.currentduration then
                vs.phase           = "shoot"
                vs.currentduration = randVs(vs.shoot_min,vs.shoot_max)
                vs.lastswitch      = now
            end
        else
            vs.phase           = "shoot"
            vs.currentduration = randVs(vs.shoot_min,vs.shoot_max)
            vs.lastswitch      = now
        end
    end

    -- Sync
    local function stopsync()
        if not rageConfig.state.csyncactive then return end
        if rageConfig.orbit.connection then
            rageConfig.orbit.connection:Disconnect()
            rageConfig.orbit.connection = nil
        end
        rageConfig.state.csyncactive = false
        rageConfig.orbit.active      = false
        clrVoidSnap()
        rageConfig.voidspam.phase = nil
        if rageConfig.orbit.savedpos and localfighter and localfighter.Entity and localfighter.Entity.RootPart then
            pcall(function()
                localfighter.Entity.RootPart.CFrame = rageConfig.orbit.savedpos
            end)
        end
        rageConfig.orbit.serverpos = nil
        rageConfig.orbit.savedpos  = nil
        oldpos = nil
    end

    local function startsync()
        if rageConfig.state.csyncactive then return end
        if rageConfig.target.immune then return end
        if not rageConfig.target.character or not valid(rageConfig.target.character) then return end
        eqSlot()
        rageConfig.state.csyncactive = true
        rageConfig.orbit.active      = true
        refreshAtk()
        if not rageConfig.orbit.savedpos then
            if localfighter and localfighter.Entity and localfighter.Entity.RootPart then
                rageConfig.orbit.savedpos = localfighter.Entity.RootPart.CFrame
            end
        end
        rageConfig.orbit.connection = RunService.Heartbeat:Connect(function(dt)
            if not rageConfig.state.csyncactive then return end
            if rageConfig.target.immune then stopsync(); return end
            if not rageConfig.target.character or not valid(rageConfig.target.character) then stopsync(); return end
            if not localfighter or not localfighter.Entity or not localfighter.Entity.RootPart then stopsync(); return end

            refreshAtk()
            oldpos = localfighter.Entity.RootPart.CFrame
            eqSlot()

            local weapon = getweapon()
            local checksling = isSling(weapon)

            -- VoidSpam hide phase
            if not checksling and rageConfig.voidspam.enabled and not rageConfig.target.immune then
                tickVoidSpam()
                if rageConfig.voidspam.phase=="hide" then
                    local rx = math.random(-10000,10000)
                    local rz = math.random(-10000,10000)
                    rageConfig.orbit.serverpos = Vector3.new(rx,-99999999999,rz)
                    pcall(function()
                        localfighter.Entity.RootPart.CFrame = CFrame.new(rageConfig.orbit.serverpos)
                    end)
                    return
                end
            end

            -- Out of ammo hide
            if rageConfig.state.outofammo and not checksling and not isInfiniteWeapon() then
                local hrp = voidHrp()
                if hrp then snapVoid(hrp)
                else
                    local rx = math.random(-10000,10000)
                    local rz = math.random(-10000,10000)
                    rageConfig.orbit.serverpos = Vector3.new(rx,-99999999999,rz)
                    pcall(function()
                        localfighter.Entity.RootPart.CFrame = CFrame.new(rageConfig.orbit.serverpos)
                    end)
                end
                return
            end

            if not rageConfig.target.character then stopsync(); return end
            local root = rageConfig.target.character:FindFirstChild("HumanoidRootPart")
            if not root then stopsync(); return end

            -- Sling position above target
            if checksling and vhState.active then
                local flat = Vector3.new(root.CFrame.LookVector.X,0,root.CFrame.LookVector.Z).Unit
                rageConfig.orbit.serverpos = root.Position + Vector3.new(0,15,0) + (flat*5)
            end

            -- Normal orbit
            local targetpos = orbBase(root)
            rageConfig.orbit.angle += rageConfig.orbit.speed*dt
            local offset = Vector3.new(
                math.cos(rageConfig.orbit.angle)*rageConfig.orbit.radius,
                rageConfig.orbit.height,
                math.sin(rageConfig.orbit.angle)*rageConfig.orbit.radius
            )
            rageConfig.orbit.serverpos = targetpos+offset

            if localfighter and localfighter.Entity and localfighter.Entity.RootPart then
                local newPos = CFrame.new(rageConfig.orbit.serverpos)
                local curPos = localfighter.Entity.RootPart.CFrame
                if (newPos.Position-curPos.Position).Magnitude < 2000 then
                    localfighter.Entity.RootPart.CFrame = newPos
                    rageConfig.orbit.savedpos = curPos
                end
            end
        end)
    end

