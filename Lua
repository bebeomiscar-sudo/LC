-- Checks if weapon has infinite ammo (melee / utility)
local function IsInfiniteWeapon(item)
    if not item then return true end
    local ok, r = pcall(function()
        local maxAmmo = item:Get("MaxAmmo")
        return maxAmmo == nil or maxAmmo <= 0 or maxAmmo == math.huge
    end)
    return ok and r or true
end

-- Get current ammo count
local function GetAmmo(item)
    if not item then return 999, 999 end
    local cur, maxA = 999, 999
    pcall(function()
        cur  = item:Get("Ammo")    or 999
        maxA = item:Get("MaxAmmo") or 999
    end)
    return cur, maxA
end

-- Check if weapon is reloading
local function IsItemReloading(lf)
    if not lf then return false end
    local ok, r = pcall(function()
        return lf:GetState() == "Reloading"
            or (lf.State and lf.State.Value == "Reloading")
    end)
    return ok and r or false
end

-- Katana deflect check
local function KatanaDeflect(targetChar)
    if not RC.AntiKatana.Enabled then return false end
    local owner = Players:GetPlayerFromCharacter(targetChar)
    if not owner then return false end
    return RC.AntiKatana.KatanaUsers[owner.Name] == true
end

-- Scan for players using Katana and register them
local function ScanKatanaUsers()
    table.clear(RC.AntiKatana.KatanaUsers)
    for _, p in ipairs(Players:GetPlayers()) do
        if p == lp then continue end
        local char = p.Character
        if not char then continue end
        -- Check equipped tool name
        for _, tool in ipairs(char:GetChildren()) do
            if tool:IsA("Tool") and tool.Name:lower():find("katana") then
                RC.AntiKatana.KatanaUsers[p.Name] = true
                break
            end
        end
    end
end

-- Get target with immunity and priority checks
local function RageGetTarget()
    local myChar = lp.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end

    -- Refresh katana users
    ScanKatanaUsers()

    -- Priority player first
    if RC.PriorityPlayer ~= "None" then
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name == RC.PriorityPlayer or p.DisplayName == RC.PriorityPlayer then
                if not IsValidTarget(p) then break end
                if RC.TeamCheck and SameTeam(p) then break end
                local char = p.Character
                if not char then break end
                if KatanaDeflect(char) then break end
                return char
            end
        end
    end

    local best, bestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if not IsValidTarget(p) then continue end
        if RC.TeamCheck and SameTeam(p) then continue end
        local char = p.Character
        if not char then continue end
        if KatanaDeflect(char) then continue end

        local hrp  = char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        local dist = (myHRP.Position - hrp.Position).Magnitude
        if dist > RC.MaxDist then continue end
        if RC.VisCheck and not IsVisible(cam.CFrame.Position, hrp) then continue end
        if dist < bestDist then bestDist=dist;best=char end
    end
    return best
end

-- Wallbang position finder
local WRay = RaycastParams.new()
WRay.FilterType = Enum.RaycastFilterType.Exclude

local function RageWallbangPoint(origin, targetPos, targetChar)
    WRay.FilterDescendantsInstances = {lp.Character, targetChar}
    local function canSee(sp)
        local hit = Workspace:Raycast(sp, targetPos-sp, WRay)
        return hit==nil or hit.Instance:IsDescendantOf(targetChar)
    end
    if canSee(origin) then return origin, nil end
    for _, off in ipairs(RC.Vectors) do
        local sp = origin + off
        if canSee(sp) then return sp, off.Y end
    end
    return nil, nil
end

-- Velocity prediction
local prevPositions  = {}
local prevTickTimes  = {}

local function Predict(hitPart, shootPos)
    local now    = tick()
    local id     = tostring(hitPart)
    local pos    = hitPart.Position
    local result = pos

    if prevPositions[id] and prevTickTimes[id] then
        local dt = now - prevTickTimes[id]
        if dt > 0 and dt < 0.5 then
            local vel = (pos - prevPositions[id]) / dt
            -- Lead time based on distance
            local dist = (pos - shootPos).Magnitude
            local leadTime = math.clamp(dist / 200, 0.02, 0.15)
            result = pos + vel * leadTime
        end
    end

    prevPositions[id]  = pos
    prevTickTimes[id]  = now
    return result
end

-- ============================================================
--   VOID SPAM TICK (called every heartbeat)
-- ============================================================

local function TickVoidSpam()
    if not RC.VoidSpam.Enabled then return end
    local now     = tick()
    local elapsed = now - RC.VoidSpam.LastSwitch
    local vs      = RC.VoidSpam

    if vs.Phase == "shoot" then
        if elapsed >= vs.CurrentDuration then
            vs.Phase           = "hide"
            vs.CurrentDuration = RandBetween(vs.HideMin, vs.HideMax)
            vs.LastSwitch      = now
        end
    elseif vs.Phase == "hide" then
        if elapsed >= vs.CurrentDuration then
            vs.Phase           = "shoot"
            vs.CurrentDuration = RandBetween(vs.ShootMin, vs.ShootMax)
            vs.LastSwitch      = now
        end
    end
end

-- ============================================================
--   AMMO TICK
-- ============================================================

local function TickAmmo(item)
    local cur, _ = GetAmmo(item)
    local inf     = IsInfiniteWeapon(item)
    local prevOOA = wasOutOfAmmo

    if inf then
        RC.State.OutOfAmmo = false
        wasOutOfAmmo       = false
    else
        RC.State.OutOfAmmo = (tonumber(cur) or 0) <= 0
        wasOutOfAmmo       = RC.State.OutOfAmmo
    end

    -- If we just ran out, force hide phase
    if RC.State.OutOfAmmo and not prevOOA then
        if RC.VoidSpam.Enabled then
            RC.VoidSpam.Phase       = "hide"
            RC.VoidSpam.LastSwitch  = tick()
            RC.VoidSpam.CurrentDuration = RandBetween(RC.VoidSpam.HideMin, RC.VoidSpam.HideMax)
        end
    elseif not RC.State.OutOfAmmo and prevOOA then
        -- Ammo returned, switch to shoot
        if RC.VoidSpam.Enabled then
            RC.VoidSpam.Phase       = "shoot"
            RC.VoidSpam.LastSwitch  = tick()
            RC.VoidSpam.CurrentDuration = RandBetween(RC.VoidSpam.ShootMin, RC.VoidSpam.ShootMax)
        end
    end
end

-- ============================================================
--   ORBIT (CSync) — moves character around target server-side
-- ============================================================

local function StartOrbit(targetChar)
    if RC.Orbit.Connection then
        RC.Orbit.Connection:Disconnect()
        RC.Orbit.Connection = nil
    end

    RC.Orbit.Angle = 0

    RC.Orbit.Connection = Track(RunService.Heartbeat:Connect(function(dt)
        if not RC.Orbit.Enabled or not RC.Enabled then return end
        if not targetChar or not targetChar:IsDescendantOf(Workspace) then
            RC.Orbit.Connection:Disconnect()
            RC.Orbit.Connection = nil
            return
        end

        local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
        if not targetHRP then return end

        local myChar = lp.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end

        -- If in void spam hide phase — go to random void coords
        if RC.VoidSpam.Enabled and RC.VoidSpam.Phase == "hide" then
            local randX = math.random(-10000, 10000)
            local randZ = math.random(-10000, 10000)
            RC.Orbit.ServerPos = Vector3.new(randX, -999999, randZ)
            pcall(function()
                myRoot.CFrame = CFrame.new(RC.Orbit.ServerPos)
            end)
            return
        end

        -- Normal orbit around target
        RC.Orbit.Angle = RC.Orbit.Angle + (RC.Orbit.Speed * dt)

        local basePos = targetHRP.Position
        local offset  = Vector3.new(
            math.cos(RC.Orbit.Angle) * RC.Orbit.Radius,
            RC.Orbit.Height,
            math.sin(RC.Orbit.Angle) * RC.Orbit.Radius
        )
        RC.Orbit.ServerPos = basePos + offset

        local dist = (RC.Orbit.ServerPos - myRoot.Position).Magnitude
        if dist < 2000 then
            pcall(function()
                myRoot.CFrame = CFrame.new(RC.Orbit.ServerPos)
            end)
        end
    end))
end

local function StopOrbit()
    if RC.Orbit.Connection then
        RC.Orbit.Connection:Disconnect()
        RC.Orbit.Connection = nil
    end
end

