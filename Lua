-- =============================================
--   WALLBANG SYSTEM
--   Ported from source wallbang script
--   Uses Gun.StartShooting hook + desync
--   No Player.Mouse
-- =============================================

local WB = {
    enabled = false,
    hitPart = "Head",
}

-- Wallbang state table (from source)
local wbState = {}

do
    -- Ref the gun module for hooking
    local __gunMod = GunModule
    local __utilMod = util

    -- Character accessors (safe)
    local function wbGetRoot()
        local c = lp.Character
        return c and c:FindFirstChild("HumanoidRootPart")
    end

    local function wbGetHead()
        local c = lp.Character
        return c and c:FindFirstChild("Head")
    end

    function wbState:init()
        self.active           = false
        self.target           = nil
        self.desync           = false
        self.conn1            = nil
        self.conn2            = nil
        self.conn3            = nil
        self.task1            = nil
        self.oldfunc          = nil
        self.autoshootConn    = nil
    end

    function wbState:find()
        local best, bestDist = nil, math.huge
        for _, p in next, Players:GetPlayers() do
            if p == lp then continue end
            if p:GetAttribute("TeamID")
                == lp:GetAttribute("TeamID") then
                continue
            end
            local c = p.Character
            if not c then continue end
            local head = c:FindFirstChild("Head")
            local hum  = c:FindFirstChildWhichIsA("Humanoid")
            if not (head and hum and hum.Health > 0) then
                continue
            end
            local dist = (
                cam.CFrame.Position - head.Position
            ).Magnitude
            if dist < bestDist then
                bestDist = dist
                best     = p
            end
        end
        return best
    end

    function wbState:getHitPart(char)
        if WB.hitPart == "Head" then
            return char:FindFirstChild("Head")
        else
            return char:FindFirstChild("UpperTorso")
                or char:FindFirstChild("Torso")
                or char:FindFirstChild("HumanoidRootPart")
        end
    end

    function wbState:desyncStart(targetPlayer)
        if self.conn2 then self.conn2:Disconnect() end
        self.desync = true
        self.conn2 = RunService.Heartbeat:Connect(function()
            if not self.desync then return end
            local root = wbGetRoot()
            if not root then return end
            local targetChar = targetPlayer.Character
            if not targetChar then
                self:desyncStop()
                return
            end
            local head = targetChar:FindFirstChild("Head")
            if not head then self:desyncStop(); return end

            local savedCF  = root.CFrame
            local savedLV  = root.AssemblyLinearVelocity
            local savedAV  = root.AssemblyAngularVelocity

            root.CFrame = head.CFrame * CFrame.new(0, -5, 0)

            RunService:BindToRenderStep(
                "__wbRestore", 101, function()
                    pcall(function()
                        root.CFrame                  = savedCF
                        root.AssemblyLinearVelocity  = savedLV
                        root.AssemblyAngularVelocity = savedAV
                    end)
                    RunService:UnbindFromRenderStep("__wbRestore")
                end
            )
        end)
    end

    function wbState:desyncStop()
        self.desync = false
        if self.conn2 then
            self.conn2:Disconnect()
            self.conn2 = nil
        end
    end

    function wbState:setup()
        if self.conn1 then self.conn1:Disconnect() end
        self.conn1 = RunService.Heartbeat:Connect(function()
            if not self.active then return end
            self.target = self:find()
        end)

        if not __gunMod then return end

        local origSSFunc = __gunMod.StartShooting
        self.oldfunc = origSSFunc

        __gunMod.StartShooting = function(gunSelf, ...)
            local results = {origSSFunc(gunSelf, ...)}

            -- Only apply to local player's gun
            if not gunSelf.ClientFighter
                or not gunSelf.ClientFighter.IsLocalPlayer then
                return table.unpack(results)
            end

            local shootData = results[3]
            if not shootData
                or typeof(shootData) ~= "table" then
                return table.unpack(results)
            end

            results[4] = true

            local tgPlayer = self.target
            if not self.active
                or not tgPlayer
                or not tgPlayer.Character then
                return table.unpack(results)
            end

            self:desyncStart(tgPlayer)

            task.wait(0.1)

            if self.task1 then
                task.cancel(self.task1)
                self.task1 = nil
            end

            local aimPart = self:getHitPart(
                tgPlayer.Character
            )
            if not aimPart then
                return table.unpack(results)
            end

            local targetPos = aimPart.Position
            local targetCF  = aimPart.CFrame
            local originPos = targetPos - Vector3.new(0, 3, 0)

            -- Encode shoot data using Utility module
            if __utilMod then
                pcall(function()
                    shootData[utf8.char(0)] = __utilMod:EncodeCFrame(
                        CFrame.new(originPos, targetPos)
                    )
                    shootData[utf8.char(1)] = __utilMod:EncodeCFrame(
                        CFrame.new(targetPos)
                    )
                    shootData[utf8.char(2)] = aimPart

                    -- Random offset for natural feel
                    local randOff = targetCF:ToObjectSpace(
                        CFrame.new(targetPos + Vector3.new(
                            math.random(-1, 1) * 0.5,
                            math.random(-1, 1) * 0.5,
                            math.random(-1, 1) * 0.5
                        ))
                    )
                    shootData[utf8.char(3)] = __utilMod:EncodeCFrame(
                        randOff
                    )

                    if shootData.Hitbox then
                        shootData.Hitbox = WB.hitPart == "Head"
                            and "Head"
                            or  "Body"
                    end
                end)
            end

            self.task1 = task.delay(0.15, function()
                self:desyncStop()
            end)

            return table.unpack(results)
        end
    end

    function wbState:Start()
        self.active = true
        self:setup()
        Library:Notify("Wallbang Active!", 2)
    end

    function wbState:Shutdown()
        self.active = false

        if self.autoshootConn then
            self.autoshootConn:Disconnect()
            self.autoshootConn = nil
        end
        if self.conn1 then self.conn1:Disconnect(); self.conn1 = nil end
        if self.conn2 then self.conn2:Disconnect(); self.conn2 = nil end
        if self.task1 then task.cancel(self.task1); self.task1 = nil end
        if self.oldfunc and __gunMod then
            __gunMod.StartShooting = self.oldfunc
            self.oldfunc = nil
        end
        Library:Notify("Wallbang Off", 2)
    end
end

wbState:init()

