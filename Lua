local function getWeaponName()
    local vm = workspace:FindFirstChild("ViewModels")
    if not vm then return nil end
    local fp = vm:FindFirstChild("FirstPerson")
    if not fp then return nil end
    for _, child in ipairs(fp:GetChildren()) do
        local parts = {}
        for p in child.Name:gmatch("[^-]+") do
            table.insert(parts, p:match("^%s*(.-)%s*$"))
        end
        if #parts >= 2 then return parts[2] end
    end
    return nil
end

local function getMuzzlePos()
    local vm = workspace:FindFirstChild("ViewModels")
    if not vm then return nil end
    local fp = vm:FindFirstChild("FirstPerson")
    if not fp then return nil end
    for _, model in pairs(fp:GetChildren()) do
        if model.Name:find(LocalPlayer.Name) then
            local iv = model:FindFirstChild("ItemVisual")
            if iv then
                local body = iv:FindFirstChild("Body")
                if body then
                    local bp = body:FindFirstChild("BodyPrimary")
                    if bp then
                        local muzzle = bp:FindFirstChild("_muzzle")
                        if muzzle then return muzzle.WorldPosition end
                    end
                end
            end
        end
    end
    return nil
end

local function isInfiniteWeapon()
    local w = getWeaponName()
    return w and INFINITE_WEAPONS[w] == true or false
end

local function isSlingshot(weapon)
    return weapon and weapon:lower():find("slingshot", 1, true) ~= nil
end

local function wantedSlot()
    return SLOTS[Config.weaponSlot or "primary"] or 1
end

local function pickMelee()
    return (Config.weaponSlot or "primary") == "melee"
end

local function getLocalFighter()
    return Modules.Fighter and Modules.Fighter.LocalFighter
end

local function getItems()
    local lf = getLocalFighter()
    return lf and lf.Items or nil
end

local function getSlotItem(slotIdx)
    local items = getItems()
    if not items then return nil end
    if items[slotIdx] then return items[slotIdx] end
    for key, it in pairs(items) do
        if it and typeof(it) == "table" then
            local s = tonumber(it:Get("Slot") or it:Get("Index") or key)
            if s == slotIdx then return it end
        end
    end
    return nil
end

local function getAmmo()
    if isInfiniteWeapon() then return nil, nil, false end
    local lf = getLocalFighter()
    if not lf or not lf.EquippedItem then return 0, 0, pickMelee() end
    local item = lf.EquippedItem
    local cur, max_, isMelee = 0, 0, false
    pcall(function()
        local nm = tostring(item:Get("Name") or "")
        cur  = tonumber(item:Get("CurrentAmmo") or item:Get("Ammo") or 0)
        max_ = tonumber(item:Get("MaxAmmo") or item:Get("MaxBullets") or cur)
        isMelee = MELEE_NAMES[nm] or nm:lower():find("melee",1,true) ~= nil
    end)
    if pickMelee() then isMelee = true end
    return cur, max_, isMelee
end

local function pressSlot(slotIdx)
    pcall(function()
        local kc = ({Enum.KeyCode.One, Enum.KeyCode.Two, Enum.KeyCode.Three})[slotIdx]
        if kc then
            VirtualInputManager:SendKeyEvent(true,  kc, false, game)
            task.wait(0.02)
            VirtualInputManager:SendKeyEvent(false, kc, false, game)
        end
    end)
    if keypress then
        pcall(keypress, ({0x31,0x32,0x33})[slotIdx])
        task.wait(0.02)
        if keyrelease then pcall(keyrelease, ({0x31,0x32,0x33})[slotIdx]) end
    end
end

local function equipSlot()
    if not Config.enabled then return end
    local want = wantedSlot()
    local lf = getLocalFighter()
    if not lf then return end
    local eq = lf.EquippedItem
    if eq then
        local s = nil
        pcall(function()
            s = tonumber(eq:Get("Slot") or eq:Get("Index"))
        end)
        if s == want then return end
    end
    local now = tick()
    if now - lastSlotForce < 0.06 then return end
    lastSlotForce = now
    local item = getSlotItem(want)
    local oid = item and pcall(function() return item:Get("ObjectID") end) and item:Get("ObjectID")
    if oid then
        for _, name in ipairs({"Equip","Switch","Select","EquipItem","ChangeItem"}) do
            pcall(function()
                local ev = Modules.Enums:ToEnum(name)
                if ev then
                    ReplicatedStorage.Remotes.Replication.Fighter.UseItem:FireServer(oid, ev, nil, nil)
                end
            end)
        end
    end
    pcall(function()
        if lf.EquipItem then lf:EquipItem(want) end
        if lf.Equip     then lf:Equip(want)     end
    end)
    pressSlot(want)
end

--// ═══════════════════════════════════════════════════════════
--//                   STATE / AMMO TICK
--// ═══════════════════════════════════════════════════════════

local function itemReloading()
    if isInfiniteWeapon() then return false end
    local lf = getLocalFighter()
    if not lf or not lf.EquippedItem then return false end
    local result = false
    pcall(function()
        for _, k in ipairs({"Reloading","IsReloading","IsReload"}) do
            local v = lf.EquippedItem:Get(k)
            if v == true or v == 1 then result = true return end
        end
    end)
    if result then return true end
    local started = Config.state.reloadStartedAt
    return started > 0 and (tick() - started) < 1.75
end

local function tickAmmo()
    if isInfiniteWeapon() then
        Config.state.outOfAmmo    = false
        Config.state.reloading    = false
        Config.state.reloadStartedAt = 0
        return
    end
    local cur, _, melee = getAmmo()
    Config.state.outOfAmmo = not melee and (tonumber(cur) or 0) <= 0
    local reloading = itemReloading()
    if reloading and not Config.state.reloading then
        Config.state.reloadStartedAt = tick()
    elseif not reloading then
        Config.state.reloadStartedAt = 0
    end
    Config.state.reloading = reloading
end

local function canShoot()
    local char = LocalPlayer.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if isInfiniteWeapon() then return true end
    local cur, _, melee = getAmmo()
    return (cur and cur > 0) or melee
end

