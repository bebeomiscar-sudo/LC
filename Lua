    -- HP color
    local function hpColor(pct)
        local hc = GC.Box.HealthLerpColors
        if pct > 0.5 then return lerpc(hc.Color2, hc.Color1, (pct-0.5)*2) end
        return lerpc(hc.Color3, hc.Color2, pct*2)
    end

    local function isTeammate(p)
        if not p or p == LocalPlayer then return true end
        local a = LocalPlayer:GetAttribute("TeamID")
        local b = p:GetAttribute("TeamID")
        if a ~= nil and b ~= nil then return a == b end
        return LocalPlayer.Team and p.Team and LocalPlayer.Team == p.Team
    end

    local function isKnockedDown(p)
        local char = p.Character
        if not char then return false end
        local be = char:FindFirstChild("BodyEffects")
        if not be then return false end
        local ko = be:FindFirstChild("K.O") or be:FindFirstChild("KO")
        return ko and ko.Value
    end

    local function distTo(p)
        local c  = p.Character
        local mc = LocalPlayer.Character
        if not c or not mc then return math.huge end
        local r  = c:FindFirstChild("HumanoidRootPart")
        local mr = mc:FindFirstChild("HumanoidRootPart")
        if r and mr then return (r.Position - mr.Position).Magnitude end
        return math.huge
    end

