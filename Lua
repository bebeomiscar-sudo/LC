    else
        local center=fovCfg.useCenter and screenCenter() or getMouse()
        local myRoot=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        local orig=myRoot and myRoot.Position or cam.CFrame.Position
        fovCircle.Visible=true;fovCircle.Color=fovCfg.color;fovCircle.Position=center
        fovCircle.Radius=(abTgt and isVis(orig,abTgt)) and fovCfg.onTarget
            or (abTgt and fovCfg.onBarrier) or fovCfg.fovSize
        if fovCfg.half then
            fovHalf.Visible=true;fovHalf.Color=fovCfg.color
            fovHalf.Position=center;fovHalf.Radius=fovCircle.Radius*0.5
        else fovHalf.Visible=false end
        abCirc.Position=center;abCirc.Radius=abEffFov();abCirc.Visible=AB.on
    end

    if not silentAim.enabled or not silentAim.circleVisible then
        silentCircle.Visible=false
    else
        silentCircle.Visible=true;silentCircle.Radius=silentAim.fovRadius
        silentCircle.Thickness=silentAim.circleThick;silentCircle.Position=screenCenter()
        silentCircle.Color=silentAim.target and silentAim.targetColor or silentAim.circleColor
    end
end))

