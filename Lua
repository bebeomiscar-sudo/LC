local SkinCfg={Enabled=false,SkinName="Default",RainbowMode=false,RainbowSpeed=1}
local skinConn=nil;local rainbowHue=0

local function ApplySkin(skinName,target)
    local data=SKIN_CATALOG[skinName];if not data or not target then return end
    for _,part in ipairs(target:GetDescendants()) do
        if part:IsA("BasePart") and part.Name~="HumanoidRootPart" then
            pcall(function() part.BrickColor=data.BrickColor;part.Material=data.Material end)
        end
    end
end
local function ApplyRainbowSkin(target)
    if not target then return end
    rainbowHue=(rainbowHue+0.005*SkinCfg.RainbowSpeed)%1
    local color=Color3.fromHSV(rainbowHue,1,1)
    for _,part in ipairs(target:GetDescendants()) do
        if part:IsA("BasePart") and part.Name~="HumanoidRootPart" then
            pcall(function() part.Color=color;part.Material=Enum.Material.Neon end)
        end
    end
end

