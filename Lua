--// ═══════════════════════════════════════════════════════════

local function buildShootData(shootFrom, targetPos, hitPart)
    return {
        [utf8.char(1)] = {
            [utf8.char(0)] = Mod.Utility:EncodeCFrame(CFrame.new(shootFrom, targetPos)),
            [utf8.char(1)] = Mod.Utility:EncodeCFrame(CFrame.new(shootFrom, targetPos)),
            [utf8.char(2)] = hitPart,
            [utf8.char(3)] = Mod.Utility:EncodeCFrame(CFrame.new(0.43, 0.25, 0.42)),
        }
    }
end

local function autoShoot()
    if not Cfg.enabled or not Cfg.autoShoot then return end
    if Cfg.immune then return end
    if not Cfg.character or not validTarget(Cfg.character) then return end

    -- Block during hiding phase (non-sling)
    if not isSling(getWeaponName()) and isHidingPhase() then return end

    local lf = getLF()
    if not lf or not lf.EquippedItem then return end

    if not isInfiniteWeapon() then
        if Cfg.state.reloading or Cfg.state.outOfAmmo then return end
        if not canShoot() then return end
    end

    forceEquipSlot()

    local hitPart = getHitPart(Cfg.character, Cfg.hitPart)
    if not hitPart then return end

    -- Determine shoot origin
    local weapon  = getWeaponName()
    local sling   = isSling(weapon)
    local origin

    if VH.active and sling then
        local hrp = getHRP()
        origin = hrp and hrp.Position or Vector3.zero
    elseif Cfg.state.csyncActive and Cfg.orbit.serverPos then
        origin = Cfg.orbit.serverPos
    else
        local hrp = getHRP()
        origin = hrp and hrp.Position or Vector3.zero
    end

    local targetPos = predictPosition(hitPart, origin)
    local data      = buildShootData(origin, targetPos, hitPart)

    local oid = getItemOID(lf.EquippedItem)
    if not oid then return end

    Perf.lastAttackTick = tick()
    local attempts = math.clamp(math.floor(tonumber(Cfg.shootAttempts) or 1), 1, 3)
    for _ = 1, attempts do
        pcall(function()
            UseItem:FireServer(oid, Mod.Enums:ToEnum("StartShooting"), data, nil)
        end)
    end
end

