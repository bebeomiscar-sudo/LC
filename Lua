local function AimbotEffFOV()
    return AimbotCfg.DynamicFOV
        and AimbotCfg.FOV * (cam.FieldOfView / 70)
        or  AimbotCfg.FOV
end

local function AimbotFindTarget()
    local center  = GetScreenCenter()
    local fov     = AimbotEffFOV()
    local best, bestDist = nil, fov
    for _, p in ipairs(Players:GetPlayers()) do
        if not IsValidTarget(p) then continue end
        if AimbotCfg.TeamCheck and SameTeam(p) then continue end
        local char = p.Character
        local part = GetBestPart(char, AimbotCfg.Part)
        if not part then continue end
        local sp, onScreen = cam:WorldToViewportPoint(part.Position)
        if not onScreen then continue end
        local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if d < bestDist then
            if AimbotCfg.VisCheck and not IsVisible(cam.CFrame.Position, part) then continue end
            bestDist = d
            best     = part
        end
    end
    return best
end

local function AimbotGetPredictedPos(part)
    local now = tick()
    local pos = part.Position
    if aimbotPrevPos and (now - aimbotPrevTick) > 0 then
        local vel = (pos - aimbotPrevPos) / (now - aimbotPrevTick)
        pos = pos + vel * AimbotCfg.Prediction
    end
    aimbotPrevPos  = pos
    aimbotPrevTick = now
    return pos
end

local function AimbotApply(part, dt)
    if not CameraController then return end
    local aimPos = AimbotGetPredictedPos(part)
    local dir    = (aimPos - cam.CFrame.Position).Unit
    local tRot   = Vector2.new(
        math.asin(math.clamp(dir.Y, -1, 1)),
        math.atan2(-dir.X, -dir.Z)
    )
    local cur  = CameraController.Rotation
    local mode = AimbotCfg.Mode

    if mode == "Spring" then
        aimbotSpring.Target = Vector3.new(tRot.X, tRot.Y, 0)
        local newPos = aimbotSpring:Update(dt)
        pcall(function()
            CameraController:ApplyRotationDelta(Vector2.new(
                newPos.X - cur.X,
                AngleDiff(cur.Y, newPos.Y)
            ))
        end)

    elseif mode == "Soft" or mode == "Magnet" then
        local factor = math.clamp(AimbotCfg.SoftSpeed * dt * 6, 0, 1)
        local newX   = cur.X + (tRot.X - cur.X) * factor
        local newY   = cur.Y + AngleDiff(cur.Y, tRot.Y) * factor
        pcall(function()
            CameraController:ApplyRotationDelta(Vector2.new(
                newX - cur.X,
                AngleDiff(cur.Y, newY)
            ))
        end)

    elseif mode == "Curve" then
        local dist = math.sqrt(
            (tRot.X - cur.X)^2 + AngleDiff(cur.Y, tRot.Y)^2
        )
        if not aimbotCurveStart or dist > 0.5 then
            aimbotCurveStart    = cur
            aimbotCurveProgress = 0
        end
        aimbotCurveProgress = math.clamp(
            aimbotCurveProgress
                + (AimbotCfg.CurvePct / 100) * 3 * AimbotCfg.SoftSpeed * dt,
            0, 1
        )
        local t  = aimbotCurveProgress^2 * (3 - 2 * aimbotCurveProgress)
        local nX = aimbotCurveStart.X + (tRot.X - aimbotCurveStart.X) * t
        local nY = aimbotCurveStart.Y + AngleDiff(aimbotCurveStart.Y, tRot.Y) * t
        if aimbotCurveProgress >= 1 then
            aimbotCurveStart    = nil
            aimbotCurveProgress = 0
        end
        pcall(function()
            CameraController:ApplyRotationDelta(Vector2.new(
                nX - cur.X,
                AngleDiff(cur.Y, nY)
            ))
        end)

    elseif mode == "Linger" then
        aimbotLingerTimer = aimbotLingerTimer + dt
        if aimbotLingerTimer < AimbotCfg.LingerTime then
            pcall(function()
                CameraController:ApplyRotationDelta(Vector2.new(
                    tRot.X - cur.X,
                    AngleDiff(cur.Y, tRot.Y)
                ))
            end)
        else
            aimbotTarget      = nil
            aimbotLingerTimer = 0
        end
    end
end

