    local rageConfig = {
        enabled       = false,
        auto          = false,
        autoshoot     = true,
        hitpart       = "Head",
        shootAttempts = 1,
        prediction    = false,
        voidspam      = false,
        teamCheck     = true,
        target        = nil,
        -- Internal running guard
        _running      = false,
    }

    -- Get nearest player to cursor
    local function rageNearestTarget()
        local cursorPos  = getMouse()
        local bestTarget = nil
        local bestDist   = math.huge
        for _, player in ipairs(Players:GetPlayers()) do
            if player == lp then continue end
            if rageConfig.teamCheck and sameTm(player) then continue end
            if not isValidTarget(player) then continue end
            local char = player.Character
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then continue end
            local screenPos, onScreen = worldToScreen(root.Position)
            if not onScreen then continue end
            local dist = (screenPos - cursorPos).Magnitude
            if dist < bestDist then
                bestTarget = char
                bestDist   = dist
            end
        end
        return bestTarget
    end

    -- Get ammo count
    local function getAmmo()
        local equipped = getEquipped()
        if not equipped then return 0, 0 end
        local current = equipped:Get("CurrentAmmo") or equipped:Get("Ammo") or 0
        local maxAmmo = equipped:Get("MaxAmmo") or equipped:Get("MaxBullets") or current
        return current, maxAmmo
    end

    -- Get current weapon name from ViewModels
    local function getCurrentWeapon()
        local viewModels = ws:FindFirstChild("ViewModels")
        if not viewModels then return nil end
        local firstPerson = viewModels:FindFirstChild("FirstPerson")
        if not firstPerson then return nil end
        for _, child in ipairs(firstPerson:GetChildren()) do
            local parts = {}
            for part in child.Name:gmatch("[^-]+") do
                table.insert(parts, part:match("^%s*(.-)%s*$"))
            end
            if #parts >= 2 then return parts[2] end
        end
        return nil
    end

    -- Core shoot function
    local function rageShoot()
        if not rageConfig.enabled or not rageConfig.autoshoot then return end
        if rageConfig._running then return end

        -- Weapon + ammo check
        local weapon = getCurrentWeapon()
        if not weapon then return end
        local currentAmmo, _ = getAmmo()
        if currentAmmo <= 0 then return end

        -- Target check — re-scan if lost
        local targetChar = rageConfig.target
        if not targetChar or not targetChar.Parent then
            rageConfig.target = rageNearestTarget()
            targetChar        = rageConfig.target
            if not targetChar then return end
        end

        -- Humanoid alive check
        local hum = targetChar:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then
            rageConfig.target = nil
            return
        end

        local hitPart = hitpartfromname(targetChar, rageConfig.hitpart)
        if not hitPart then return end

        local myChar = lp.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end

        local equipped = getEquipped()
        if not equipped then return end

        -- Prediction
        local targetPos = hitPart.Position
        if rageConfig.prediction then
            pcall(function()
                local vel      = hum.RootPart and hum.RootPart.AssemblyLinearVelocity or Vector3.zero
                local distance = (hitPart.Position - myRoot.Position).Magnitude
                local travelT  = distance / 3000
                targetPos = hitPart.Position + vel * travelT
            end)
        end

        local data = buildShotData(myRoot.Position, targetPos, hitPart)

        rageConfig._running = true

        task.spawn(function()
            local ok, err = pcall(function()
                -- Multiple attempts if set
                for i = 1, rageConfig.shootAttempts do
                    UseItemRemote:FireServer(
                        equipped:Get("ObjectID"),
                        EnumLibrary:ToEnum("StartShooting"),
                        data,
                        nil
                    )
                    if i < rageConfig.shootAttempts then
                        task.wait(0.02)
                    end
                end

                -- Void spam — rapid re-fire
                if rageConfig.voidspam then
                    for _ = 1, 3 do
                        task.wait(0.01)
                        pcall(function()
                            UseItemRemote:FireServer(
                                equipped:Get("ObjectID"),
                                EnumLibrary:ToEnum("StartShooting"),
                                data,
                                nil
                            )
                        end)
                    end
                end
            end)

            if not ok then
                warn("[Ragebot] Shot error: " .. tostring(err))
            end
            rageConfig._running = false
        end)
    end

