local espObjects = {}
local dummyEspObjects = {}
local espCfg = {
    enabled = false, box = true, boxColor = Color3.fromRGB(255,255,255),
    name = true, nameColor = Color3.fromRGB(255,255,255), nameSize = 12,
    health = true, tracer = true, tracerColor = Color3.fromRGB(0,200,255),
    maxDist = 1000, dummyEnabled = false, dummyBoxColor = Color3.fromRGB(255,165,0)
