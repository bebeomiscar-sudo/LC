    local function removeESP(p)
        local obj = _G.ESPObjects[p]
        if not obj then return end
        obj.box.square:Remove()
        obj.box.outline:Remove()
        obj.box.inline:Remove()
        if obj.filled then obj.filled:Destroy() end
        if obj.glow   then obj.glow:Destroy()   end
        if obj.text then
            if obj.text.studs then obj.text.studs.Parent:Destroy() end
            if obj.text.name  then obj.text.name.Parent:Destroy()  end
            if obj.text.tool  then obj.text.tool.Parent:Destroy()  end
        end
        obj.bars.outline:Remove()
        for _, l in pairs(obj.bars.hp)       do l:Remove() end
        for _, l in pairs(obj.skel.lines)    do l:Remove() end
        for _, l in pairs(obj.skel.outlines) do l:Remove() end
        if obj.tracer then obj.tracer:Remove() end
        if obj.cham   then obj.cham:Destroy()  end
        _G.ESPObjects[p] = nil
    end

