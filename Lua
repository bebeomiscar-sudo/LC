local function hitpartfromname(target,partName)
    if not target then return nil end
    if partName=="Closest" then
        local mypos = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not mypos then return target:FindFirstChild("Head") end
        local closest,dist=nil,math.huge
        for _,part in pairs(target:GetChildren()) do
            if part:IsA("BasePart") then
                local d=(part.Position-mypos.Position).Magnitude
                if d<dist then dist=d;closest=part end
            end
        end
        return closest or target:FindFirstChild("Head")
    elseif partName=="Random" then
        local parts={"Head","HumanoidRootPart","UpperTorso"}
        return target:FindFirstChild(parts[math.random(#parts)]) or target:FindFirstChild("Head")
    else
        return target:FindFirstChild(partName) or target:FindFirstChild("Head")
    end
end

