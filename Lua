    local function getHitboxBounds(char)
        local cam = Workspace.CurrentCamera
        if not cam or not char then return nil, nil end
        local minX, minY =  math.huge,  math.huge
        local maxX, maxY = -math.huge, -math.huge
        local found = false
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") and part.Transparency < 1 then
                local cf = part.CFrame
                local sz = part.Size
                local hx, hy, hz = sz.X/2, sz.Y/2, sz.Z/2
                for _, corner in ipairs({
                    cf*Vector3.new(-hx,-hy,-hz), cf*Vector3.new( hx,-hy,-hz),
                    cf*Vector3.new(-hx, hy,-hz), cf*Vector3.new( hx, hy,-hz),
                    cf*Vector3.new(-hx,-hy, hz), cf*Vector3.new( hx,-hy, hz),
                    cf*Vector3.new(-hx, hy, hz), cf*Vector3.new( hx, hy, hz),
                }) do
                    local sp, ok = w2esp(corner, cam)
                    if ok then
                        found = true
                        minX  = math.min(minX, sp.X) minY = math.min(minY, sp.Y)
                        maxX  = math.max(maxX, sp.X) maxY = math.max(maxY, sp.Y)
                    end
                end
            end
        end
        if not found then return nil, nil end
        return Vector2.new(math.max(maxX-minX,4), math.max(maxY-minY,8)), Vector2.new(minX, minY)
    end

    local function updateESP(p, dt)
        if not p or not _G.ESPObjects[p] then return end
        if not GC.Box.MasterEnabled       then hideESP(p) return end
        if p == LocalPlayer               then hideESP(p) return end
        if isTeammate(p)                  then hideESP(p) return end

        local char = p.Character
        if not char or isKnockedDown(p) then hideESP(p) return end

        local root = char:FindFirstChild("HumanoidRootPart")
        local hum  = char:FindFirstChildWhichIsA("Humanoid")
        if not root or not hum then hideESP(p) return end

        local hrp2d, hrpOk = w2esp(root.Position)
        if not hrpOk then hideESP(p) return end

        local dist         = distTo(p)
        local hitSz, hitPos = getHitboxBounds(char)
        local sz, pos

        if hitSz and hitPos then
            sz  = Vector2.new(math.max(math.floor(hitSz.X),4), math.max(math.floor(hitSz.Y),8))
            pos = Vector2.new(math.floor(hitPos.X), math.floor(hitPos.Y))
        else
            local head        = char:FindFirstChild("Head")
            local topW        = (head and head.Position + Vector3.new(0,0.5,0)) or (root.Position + Vector3.new(0,3,0))
            local botW        = root.Position - Vector3.new(0,3,0)
            local top2d, tOk  = w2esp(topW)
            local bot2d, bOk  = w2esp(botW)
            if not tOk or not bOk then hideESP(p) return end
            local bh = math.abs(bot2d.Y - top2d.Y)
            local bw = math.max(bh*0.55, 8)
            sz  = Vector2.new(math.max(math.floor(bw),4), math.max(math.floor(math.max(bh,10)),8))
            pos = Vector2.new(math.floor(hrp2d.X-sz.X/2), math.floor(math.min(top2d.Y,bot2d.Y)))
        end

        local obj = _G.ESPObjects[p]
        drawFill(obj, sz, pos)
        drawBox(obj, sz, pos)
        drawGlow(obj, sz, pos)
        drawSkeleton(obj, char, hum)
        drawHealthBar(obj, hum, sz, pos, dt)
        drawText(p, obj, sz, pos, dist)
        drawTracer(obj, root)
        updateCham(obj, char)
    end

    -- Render loop
    local espMasterWasOn = false
    local function stepESP(dt)
        dt       = dt or (1/240)
        espClock = os.clock()
        if not GC.Box.MasterEnabled then
            if espMasterWasOn then
                espMasterWasOn = false
                for plr in pairs(_G.ESPObjects) do hideESP(plr) end
            end
            return
        end
        espMasterWasOn = true
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer then updateESP(plr, dt) end
        end
    end

    local espBound = pcall(function()
        RunService:UnbindFromRenderStep("InstanceESPUpdate")
        RunService:BindToRenderStep("InstanceESPUpdate",
            Enum.RenderPriority.Camera.Value + 1, stepESP)
    end)
    if not espBound then RunService.RenderStepped:Connect(stepESP) end

