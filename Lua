-- ✅ FIX: autoshoot uses safeFireShot
local function autoshoot()
    if not rageConfig.target.enabled or not rageConfig.autoshoot then return end
    if rageConfig.target.immune then return end
    if rageConfig.voidspam.enabled and rageConfig.voidspam.phase=="hide" then return end
    if not isInfiniteWeapon() then
        if rageConfig.state.reloading or rageConfig.state.outofammo then return end
    end
    local targetChar=rageConfig.target.character
    if not targetChar or not valid(targetChar) then return end
    local lf=FighterController and FighterController.LocalFighter
    if not lf or not lf.EquippedItem then return end
    local hitPart=hitpartfromname(targetChar,rageConfig.hitpart)
    if not hitPart then return end
    local weapon=getweapon(); local checksling=isSling(weapon)
    local shootPos
    if vhState.active and checksling then
        local myRoot=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        shootPos=myRoot and myRoot.Position or Vector3.zero
    elseif rageConfig.state.csyncactive and rageConfig.orbit.serverpos then
        shootPos=rageConfig.orbit.serverpos
    else
        local myRoot=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        shootPos=myRoot and myRoot.Position or Vector3.zero
    end
    local targetPos=predict(hitPart,shootPos)
    local data=buildShotData(shootPos,targetPos,hitPart)
    if not data then return end
    local equipped=lf.EquippedItem
    if equipped and equipped:Get("ObjectID") then
        ragePerf.lastAttackTick=tick()
        local attempts=math.clamp(math.floor(tonumber(rageConfig.shootAttempts) or 1),1,3)
        for _=1,attempts do
            safeFireShot(equipped,data)
        end
        if getgenv().makebullettracer then
            pcall(getgenv().makebullettracer,shootPos,targetPos)
        end
    end
end

