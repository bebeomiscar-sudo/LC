    local function updateesp(p, dt)
        if not p or not _G.ESPObjects[p] then return end
        if not GC.Box.MasterEnabled then hideesp(p) return end
        if p == LocalPlayer or checkteammate(p) then hideesp(p) return end
        local char = p.Character
        if not char or espknock(p) then hideesp(p) return end
        local root = char:FindFirstChild("HumanoidRootPart")
        local hum  = char:FindFirstChildWhichIsA("Humanoid")
        if not root or not hum then hideesp(p) return end
        local hrp2d, hrpOk = worldToEspScreen(root.Position)
        if not hrpOk then hideesp(p) return end
        local distance       = dist2esp(p)
        local hitboxSize, hitboxPos = getHitboxBounds(char)
        local size, position
        if hitboxSize and hitboxPos then
            size     = Vector2.new(math.max(math.floor(hitboxSize.X),4), math.max(math.floor(hitboxSize.Y),8))
            position = Vector2.new(math.floor(hitboxPos.X), math.floor(hitboxPos.Y))
        else
            local head       = char:FindFirstChild("Head")
            local topWorld   = (head and head.Position + Vector3.new(0, 0.5, 0)) or (root.Position + Vector3.new(0,3,0))
            local bottomWorld = root.Position - Vector3.new(0,3,0)
            local top2d, tOk = worldToEspScreen(topWorld)
            local bot2d, bOk = worldToEspScreen(bottomWorld)
            if not tOk or not bOk then hideesp(p) return end
            local bh  = math.abs(bot2d.Y - top2d.Y)
            local bw  = math.max(bh * 0.55, 8)
            size     = Vector2.new(math.max(math.floor(bw),4), math.max(math.floor(math.max(bh,10)),8))
            position = Vector2.new(math.floor(hrp2d.X - size.X/2), math.floor(math.min(top2d.Y, bot2d.Y)))
        end
        local box = _G.ESPObjects[p]
        drawfill_esp(p, box, size, position)
        drawbox_esp(p, box, size, position)
        drawglow_esp(p, box, size, position)
        drawskeleton_esp(p, box, char, hum, size, position)
        drawhealthbar_esp(p, box, hum, size, position, dt)
        drawtext_esp(p, box, size, position, distance)
        drawtracers_esp(p, box, root)
        updatecham_esp(p, box, char)
    end

