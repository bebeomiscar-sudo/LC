local function setFastCooldowns()
    pcall(function()
        for _, v in pairs(getgc(true)) do
            if type(v) == "table" then
                for _, field in ipairs({"Cooldown", "AttackCooldown", "UseDelay", "FireCooldown"}) do
                    if rawget(v, field) then rawset(v, field, 0.001) end
                end
            end
        end
    end)
    pcall(function()
        local IL = safeRequire(ReplicatedStorage.Modules.ItemLibrary)
        if IL and IL.Items then
            for _, item in pairs(IL.Items) do
                if type(item) == "table" then
                    for _, field in ipairs({"Cooldown", "AttackCooldown", "UseDelay", "FireCooldown"}) do
                        if rawget(item, field) then rawset(item, field, 0.001) end
                    end
                end
            end
        end
    end)
    print("[FastCooldowns] Applied.")
end

