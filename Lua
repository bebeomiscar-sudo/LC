local rageHeartbeatConn = nil

local function startRageHeartbeat()
    if rageHeartbeatConn then rageHeartbeatConn:Disconnect();rageHeartbeatConn=nil end

    rageHeartbeatConn = Track(RunService.Heartbeat:Connect(function()
        if not config.ragestatus.enabled then return end

        -- Refresh localfighter reference
        localfighter = FighterController and FighterController.LocalFighter

        tickAmmo()
        if config.voidspam.enabled then tickVoidSpam() end

        -- Auto target acquisition (from example)
        if config.target.auto and not config.target.manualkey then
            local current,_,melee = getammo()
            local hasammo = current==nil or current>0 or melee
            if hasammo and not config.state.reloading then
                if not config.target.enabled or not config.target.character or not validChar(config.target.character) then
                    local newtarget = nearest()
                    if newtarget then
                        if config.target.enabled then stopsync() end
                        config.target.character = newtarget
                        config.target.enabled   = true
                        config.target.immune    = false
                        if localfighter and localfighter.Entity and localfighter.Entity.RootPart then
                            startsync()
                        end
                    end
                end
            end
        end

        -- Auto-shoot
        if config.target.enabled and config.target.character
        and config.target.autoshoot and not config.target.immune then
            autoshoot()
        end
    end))
end

local function stopRagebot()
    config.ragestatus.enabled = false
    config.target.enabled     = false
    config.target.character   = nil
    stopsync()
    if rageHeartbeatConn then rageHeartbeatConn:Disconnect();rageHeartbeatConn=nil end
end

