-- ============================================================
--   RAGEBOT v3.0 — FULL REWRITE
--   Fixes:
--   - Shooting when no player exists
--   - Shooting wrong/non-player targets
--   - Added desync teleport from Wallbang code
--   - Hide Range: 0.1 to 1s (how long to hide HRP before shooting)
--   - Attack Range: 0.1 to 1s (how long to hold shoot position)
--   - Mutual Kill Fix: double-tap timing system
-- ============================================================

local rageCfg = {
    enabled         = false,
    improvedManip   = false,
    useDesync       = true,    -- Use wallbang desync TP for ragebot
    hideRange       = 0.3,     -- 0.1 to 1s: how long HRP hides
    attackRange     = 0.3,     -- 0.1 to 1s: how long we hold attack pos
    mutualKillFix   = true,    -- Advanced: prevents both dying sometimes
    doubleTap       = false,   -- Fire twice per cycle for mutual kill
    doubleTapDelay  = 0.08,    -- Delay between double taps
    teamCheck       = true,
    visCheck        = false,   -- Off by default for wallbang style
    maxDist         = 500,
    hitPart         = "Head",
    v1y=12,v2y=16,v3y=20,v4y=24,
    v5y=28,v6y=32,v7y=36,v8y=40,
    v1x=0,v2x=0,v3x=0,v4x=0,
    v1z=0,v2z=0,v3z=0,v4z=0,
    vectors         = {},
    improv = {
        scanAngle=15,multiPass=true,
        spiralScan=false,adaptDist=true,
    },
}

-- Ragebot state
local rageConn      = nil
local rageRunning   = false
local rageLastFire  = 0
local rageTarget    = nil  -- cached validated target

-- Desync state (from wallbang code)
local rageDesyncConn   = nil
local rageDesyncActive = false

local ray_p = RaycastParams.new()
ray_p.FilterType = Enum.RaycastFilterType.Exclude

local function rebuildVectors()
    rageCfg.vectors = {
        Vector3.new(rageCfg.v1x,rageCfg.v1y,rageCfg.v1z),
        Vector3.new(rageCfg.v2x,rageCfg.v2y,rageCfg.v2z),
        Vector3.new(rageCfg.v3x,rageCfg.v3y,rageCfg.v3z),
        Vector3.new(rageCfg.v4x,rageCfg.v4y,rageCfg.v4z),
        Vector3.new(0,rageCfg.v5y,0),
        Vector3.new(0,rageCfg.v6y,0),
        Vector3.new(0,rageCfg.v7y,0),
        Vector3.new(0,rageCfg.v8y,0),
    }
end
rebuildVectors()

-- =============================================
--   Find Closest VALID Target
--   FIX: Only returns real alive players
--   Never returns nil parts or workspace objects
-- =============================================

local function rageGetClosest()
    -- Guard: we need our own character
    if not lp.Character then return nil, nil end
    local myHRP = lp.Character:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil, nil end

    local bestTarget = nil
    local bestChar   = nil
    local bestDist   = math.huge

    -- Only iterate Players service — never workspace directly
    -- This prevents targeting random workspace objects
    for _, p in ipairs(Players:GetPlayers()) do
        -- Full validation check
        if not isValidTarget(p) then continue end
        if rageCfg.teamCheck and sameTm(p) then continue end

        local char = p.Character
        local head = char:FindFirstChild("Head")
        if not head then continue end

        -- Distance check
        local dist = (myHRP.Position - head.Position).Magnitude
        if dist > rageCfg.maxDist then continue end
        if dist > bestDist then continue end

        -- Optional visibility check
        if rageCfg.visCheck then
            if not isVis(cam.CFrame.Position, head) then continue end
        end

        bestDist   = dist
        bestTarget = head
        bestChar   = char
    end

    -- Final safety: make sure we got a real player
    if bestTarget then
        -- Verify it's actually in Players service
        local owner = Players:GetPlayerFromCharacter(bestChar)
        if not owner then return nil, nil end  -- not a real player
        if owner == lp then return nil, nil end
    end

    return bestTarget, bestChar
end

-- =============================================
--   Calc Manip Point (Standard)
-- =============================================

local function rageCalcPoint(orig2, targetPos, targetChar)
    ray_p.FilterDescendantsInstances = {lp.Character, targetChar}
    if not ws:Raycast(orig2, targetPos-orig2, ray_p) then
        return orig2, nil
    end
    for _, offset in next, rageCfg.vectors do
        local sp = orig2 + offset
        if not ws:Raycast(sp, targetPos-sp, ray_p) then
            return sp, offset.Y
        end
    end
    return nil, nil
end

-- =============================================
--   Calc Manip Point (Improved)
-- =============================================

local function improvedCalcPoint(orig2, targetPos, targetChar)
    ray_p.FilterDescendantsInstances = {lp.Character, targetChar}

    local function tryPoint(sp)
        local r = ws:Raycast(sp, targetPos-sp, ray_p)
        return r==nil or r.Instance:IsDescendantOf(targetChar)
    end

    if tryPoint(orig2) then return orig2, nil end

    for _, offset in next, rageCfg.vectors do
        local sp = orig2 + offset
        if tryPoint(sp) then return sp, offset.Y end
    end

    if rageCfg.improv.multiPass then
        local step = rageCfg.improv.scanAngle
        for _, offset in next, rageCfg.vectors do
            for angle = -45, 45, step do
                local rad = math.rad(angle)
                local rx = offset.X*math.cos(rad)-offset.Z*math.sin(rad)
                local rz = offset.X*math.sin(rad)+offset.Z*math.cos(rad)
                local sp = orig2 + Vector3.new(rx, offset.Y, rz)
                if tryPoint(sp) then return sp, offset.Y end
            end
        end
    end

    if rageCfg.improv.spiralScan then
        for layer = 1, 4 do
            local h = layer * 8
            for step2 = 0, 11 do
                local a = (step2/12)*math.pi*2
                local sp = orig2 + Vector3.new(
                    math.cos(a)*2*layer, h, math.sin(a)*2*layer
                )
                if tryPoint(sp) then return sp, h end
            end
        end
    end

    local sides = {
        Vector3.new(2,0,0),Vector3.new(-2,0,0),
        Vector3.new(0,0,2),Vector3.new(0,0,-2),
        Vector3.new(3,8,0),Vector3.new(-3,8,0),
        Vector3.new(0,8,3),Vector3.new(0,8,-3),
    }
    for _, side in next, sides do
        local sp = orig2 + side
        if tryPoint(sp) then return sp, side.Y end
    end

    if rageCfg.improv.adaptDist then
        local dist2 = (orig2-targetPos).Magnitude
        local scale = math.clamp(dist2/50, 0.5, 3)
        for _, offset in next, rageCfg.vectors do
            local sc = Vector3.new(offset.X*scale,offset.Y*scale,offset.Z*scale)
            local sp = orig2 + sc
            if tryPoint(sp) then return sp, sc.Y end
        end
    end

    return nil, nil
end

-- =============================================
--   DESYNC TELEPORT (from Wallbang code)
--   Moves HRP to target position so server
--   thinks we are next to them when we shoot
--   This is what makes wallbang hits register
--   AND prevents mutual kills in some cases
-- =============================================

local function startRageDesync(targetChar)
    if rageDesyncConn then
        rageDesyncConn:Disconnect()
        rageDesyncConn = nil
    end

    rageDesyncActive = true
    local head = targetChar and targetChar:FindFirstChild("Head")
    if not head then return end

    rageDesyncConn = RunService.Heartbeat:Connect(function()
        if not rageDesyncActive then return end
        local root = lp.Character
            and lp.Character:FindFirstChild("HumanoidRootPart")
        if not root then return end

        -- Verify target still valid
        if not head or not head.Parent then
            rageDesyncActive = false
            if rageDesyncConn then
                rageDesyncConn:Disconnect()
                rageDesyncConn = nil
            end
            return
        end

        -- Save current client position
        local sCF = root.CFrame
        local sLV = root.AssemblyLinearVelocity
        local sAV = root.AssemblyAngularVelocity

        -- Teleport HRP to 5 studs below target head
        -- Server sees us there — registers hit
        root.CFrame = head.CFrame * CFrame.new(0, -5, 0)

        -- Restore on next render so client never sees us move
        RunService:BindToRenderStep("__rageDesyncRestore", 101, function()
            pcall(function()
                root.CFrame                  = sCF
                root.AssemblyLinearVelocity  = sLV
                root.AssemblyAngularVelocity = sAV
            end)
            RunService:UnbindFromRenderStep("__rageDesyncRestore")
        end)
    end)
end

local function stopRageDesync()
    rageDesyncActive = false
    if rageDesyncConn then
        rageDesyncConn:Disconnect()
        rageDesyncConn = nil
    end
    pcall(function()
        RunService:UnbindFromRenderStep("__rageDesyncRestore")
    end)
end

-- =============================================
--   FIRE SHOT (core shooting logic)
--   Sends UseItem remote with encoded CFrames
--   Mutual Kill Fix:
--   - When doubleTap is on, fires twice
--   - Second shot slightly offset in time
--   - This ensures server processes our shot
--     BEFORE enemy's shot — we die second
--   - If both shots land = enemy dies first
-- =============================================

local function rageFireShot(item, targetPart, targetChar, manip, height)
    local ok = pcall(function()
        local camCF = cam.CFrame
        local so = height ~= nil
            and Vector3.new(camCF.Position.X, camCF.Position.Y+height, camCF.Position.Z)
            or camCF.Position

        local tPos = targetPart.Position

        -- Build shoot CFrames
        local cf1 = CFrame.lookAt(so, tPos)
        local cf2 = CFrame.lookAt(tPos, so)
        local rel  = targetPart.CFrame:ToObjectSpace(CFrame.new(tPos))

        -- Encode shot data
        local cd = {}
        cd[utf8.char(1)] = {
            [utf8.char(0)] = util:EncodeCFrame(cf1),
            [utf8.char(1)] = util:EncodeCFrame(cf2),
            [utf8.char(2)] = targetPart,
            [utf8.char(3)] = util:EncodeCFrame(rel),
        }

        -- Fire first shot
        UseItemRemote:FireServer(
            item:Get("ObjectID"),
            enums:ToEnum("StartShooting"),
            cd, nil
        )

        -- Mutual Kill Fix — double tap
        -- Second shot gives server two damage packets
        -- Ensures enemy registers dead before we do
        if rageCfg.doubleTap and rageCfg.mutualKillFix then
            task.delay(rageCfg.doubleTapDelay, function()
                -- Re-validate target still alive
                if not targetPart or not targetPart.Parent then return end
                local hum = targetChar:FindFirstChildOfClass("Humanoid")
                if not hum or hum.Health <= 0 then return end

                -- Slightly randomize offset for second shot
                -- so server doesn't de-dup as same packet
                local offset = Vector3.new(
                    math.random(-10,10)*0.01,
                    math.random(-10,10)*0.01,
                    math.random(-10,10)*0.01
                )
                local cd2 = {}
                cd2[utf8.char(1)] = {
                    [utf8.char(0)] = util:EncodeCFrame(CFrame.lookAt(so+offset, tPos)),
                    [utf8.char(1)] = util:EncodeCFrame(CFrame.lookAt(tPos, so+offset)),
                    [utf8.char(2)] = targetPart,
                    [utf8.char(3)] = util:EncodeCFrame(rel),
                }
                pcall(function()
                    UseItemRemote:FireServer(
                        item:Get("ObjectID"),
                        enums:ToEnum("StartShooting"),
                        cd2, nil
                    )
                end)
            end)
        end
    end)
    return ok
end

-- =============================================
--   RAGEBOT MAIN LOOP
--   Full rewrite — strict validation before
--   every single action
-- =============================================

local function startRagebot()
    if rageConn then rageConn:Disconnect(); rageConn=nil end
    rageRunning = false

    rageConn = RunService.Heartbeat:Connect(function()
        -- Guard 1: ragebot must be on
        if not rageCfg.enabled then return end

        -- Guard 2: must not already be running a shot cycle
        if rageRunning then return end

        -- Guard 3: must have our character
        if not lp.Character then return end
        local myHRP = lp.Character:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end

        -- Guard 4: must have FighterController
        if not FighterController then return end
        local lf = FighterController.LocalFighter
        if not lf then return end

        -- Guard 5: must have equipped item
        local item = lf.EquippedItem
        if not item then return end

        -- Guard 6: Find a VALID target — strict check
        -- If this returns nil = do nothing, don't shoot
        local tp, tc = rageGetClosest()
        if not tp or not tc then
            -- No valid target — stop desync if running
            if rageDesyncActive then stopRageDesync() end
            return
        end

        -- Guard 7: Double check target part is still valid
        if not tp.Parent then return end
        if not tp.Parent:FindFirstChildOfClass("Humanoid") then return end
        local hum = tp.Parent:FindFirstChildOfClass("Humanoid")
        if hum.Health <= 0 then return end

        -- All guards passed — start shot cycle
        rageRunning = true

        task.spawn(function()
            -- =============================================
            --   PHASE 1: HIDE PHASE (hideRange seconds)
            --   Desync teleport begins
            --   Server thinks we are next to target
            --   We are "hidden" from server perspective
            -- =============================================
            if rageCfg.useDesync then
                startRageDesync(tc)
                safeWait(rageCfg.hideRange)
            end

            -- Re-validate after hide phase
            if not rageCfg.enabled then
                stopRageDesync()
                rageRunning = false
                return
            end
            if not tp or not tp.Parent then
                stopRageDesync()
                rageRunning = false
                return
            end
            local hum2 = tc:FindFirstChildOfClass("Humanoid")
            if not hum2 or hum2.Health <= 0 then
                stopRageDesync()
                rageRunning = false
                return
            end

            -- =============================================
            --   PHASE 2: ATTACK PHASE (attackRange seconds)
            --   Find best shot position
            --   Fire shot(s)
            -- =============================================

            local camCF = cam.CFrame
            local manip, height

            if rageCfg.improvedManip then
                manip, height = improvedCalcPoint(camCF.Position, tp.Position, tc)
            else
                manip, height = rageCalcPoint(camCF.Position, tp.Position, tc)
            end

            -- Only fire if we have a valid position OR target is visible
            if manip or isVis(camCF.Position, tp) then
                rageFireShot(item, tp, tc, manip, height)
            end

            -- Hold attack position for attackRange seconds
            safeWait(rageCfg.attackRange)

            -- =============================================
            --   PHASE 3: CLEANUP
            --   Stop desync, reset state
            -- =============================================
            if rageCfg.useDesync then
                stopRageDesync()
            end

            rageRunning = false
        end)
    end)
end

local function stopRagebot()
    if rageConn then rageConn:Disconnect(); rageConn=nil end
    stopRageDesync()
    rageCfg.enabled = false
    rageRunning     = false
    rageTarget      = nil
end

