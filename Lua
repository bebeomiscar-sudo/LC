local hitSoundConfig = {
    enabled = false,
    sound   = "click",
    volume  = 0.5,
}

local hitSoundConn = nil

local function playHitSound()
    local sid = SIDS[hitSoundConfig.sound]
    if not sid then return end
    local sound = Instance.new("Sound")
    sound.SoundId  = sid
    sound.Volume   = hitSoundConfig.volume
    sound.Parent   = workspace
    sound:Play()
    game:GetService("Debris"):AddItem(sound, 3)
end

local function hookHitSound()
    if hitSoundConn then
        hitSoundConn:Disconnect()
        hitSoundConn = nil
    end

    -- Hook damage by watching fighter health
    hitSoundConn = RunService.Heartbeat:Connect(function()
        if not hitSoundConfig.enabled then return end
        pcall(function()
            for _, fighter in pairs(getAllFighters()) do
                local lf = getLocalFighter()
                if fighter == lf then continue end
                if isTeammate(fighter) then continue end
                if not isAlive(fighter) then continue end

                if not fighter._lastHealth then
                    fighter._lastHealth = fighter:Get("Health") or 100
                end

                local currentHealth = fighter:Get("Health") or 100
                if currentHealth < fighter._lastHealth then
                    playHitSound()
                end
                fighter._lastHealth = currentHealth
            end
        end)
    end)
end

