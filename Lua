local function zeroCooldowns(item)
    for _, field in ipairs(COOLDOWN_FIELDS) do
        if item[field] ~= nil then rawset(item, field, 0) end
    end
end

local function setFastCooldowns()
    if getgc then
        local ok, gc = pcall(getgc, true)
        if ok and gc then
            for _, v in pairs(gc) do
                if type(v) == "table" then
                    if rawget(v,"AttackCooldown")      then rawset(v,"AttackCooldown",      0.001) end
                    if rawget(v,"UseDelay")            then rawset(v,"UseDelay",            0.001) end
                    if rawget(v,"SpinCooldown")        then rawset(v,"SpinCooldown",        0.001) end
                    if rawget(v,"Cooldown")            then rawset(v,"Cooldown",            0.001) end
                    if rawget(v,"HeavyAttackCooldown") then rawset(v,"HeavyAttackCooldown", 0.001) end
                    if rawget(v,"AbilityCooldown")     then rawset(v,"AbilityCooldown",     0.001) end
                    if rawget(v,"FireCooldown")        then rawset(v,"FireCooldown",        0.001) end
                end
            end
        end
    end
    pcall(function()
        local Mods = ReplicatedStorage:FindFirstChild("Modules")
        if not Mods then return end
        local itemLibScript = Mods:FindFirstChild("ItemLibrary")
        if not itemLibScript then return end
        local ok, ItemLibrary = pcall(require, itemLibScript)
        if not ok or type(ItemLibrary) ~= "table" then return end
        local items = ItemLibrary.Items or ItemLibrary.Weapons or ItemLibrary.Utilities
        if type(items) ~= "table" then return end
        for _, item in pairs(items) do
            if type(item) == "table" then zeroCooldowns(item) end
        end
    end)
end

local function patchWarHorn()
    local ok2, result = pcall(function()
        local Mods = ReplicatedStorage:FindFirstChild("Modules")
        if not Mods then return false end
        local ils = Mods:FindFirstChild("ItemLibrary")
        if not ils then return false end
        local ok, IL = pcall(require, ils)
        if not ok or type(IL) ~= "table" then return false end
        local items = IL.Items or IL.Weapons or IL.Utilities
        if type(items) ~= "table" then return false end
        local patched = false
        for name, item in pairs(items) do
            if type(item) == "table" then
                local itemName = item.Name or name
                if WAR_HORN_KEYS[name] or WAR_HORN_KEYS[itemName] then
                    zeroCooldowns(item)
                    patched = true
                end
            end
        end
        return patched
    end)
    return ok2 and result or false
end

local cooldownLoopTask = nil
local function startCooldownLoop()
    cooldownCfg.loopActive = true
    cooldownLoopTask = task.spawn(function()
        while cooldownCfg.loopActive do
            if cooldownCfg.warHornOnly then patchWarHorn() else setFastCooldowns() end
            task.wait(cooldownCfg.loopInterval)
        end
    end)
end

local function stopCooldownLoop()
    cooldownCfg.loopActive = false
    if cooldownLoopTask then task.cancel(cooldownLoopTask); cooldownLoopTask=nil end
end

