local function getAttackCfg()
    if pickMelee() and not Cfg.attackCustom then
        return { height=0, front=0, side=0, vertical=-(Cfg.meleeFeetDrop or 3.5), radius=0 }
    end
    if Cfg.attackCustom then
        return {
            height   = Cfg.customHeight   or 2,
            front    = Cfg.customFront    or 0,
            side     = Cfg.customSide     or 0,
            vertical = Cfg.customVertical or 0,
            radius   = Cfg.customRadius   or 0,
        }
    end
    local mode   = Cfg.attackMode or "default"
    local weapon = getWeaponName()
    if mode == "under" then
        return { height=0, front=0, side=0, vertical=-(Cfg.underOffset or 4), radius=0 }
    end
    return {
        height   = (weapon and weapon:lower():find("sniper")) and 8 or 2,
        front=0, side=0, vertical=0, radius=0,
    }
end

local function orbitBase(targetRoot)
    if not targetRoot then return Vector3.zero end
    local s   = getAttackCfg()
    local pos = targetRoot.Position
    return pos
        + targetRoot.CFrame.LookVector  * s.front
        + targetRoot.CFrame.RightVector * s.side
        + Vector3.new(0, s.vertical, 0)
end

local function refreshOrbitSettings()
    local s = getAttackCfg()
    Cfg.orbit.height = s.height
    Cfg.orbit.radius = s.radius or 0
end

