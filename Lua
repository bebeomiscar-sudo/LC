abCirc.Visible      = false

local function abEffFov()
    local f = AB.fov
    if AB.dynFov then f = f * (cam.FieldOfView / 70) end
    return f
end

local function abTgtValid(pt)
    if not pt or not pt.Parent then return false end
    local h = pt.Parent:FindFirstChildOfClass("Humanoid")
    if not h or h.Health <= 0 then return false end
    if not inFov(pt, abEffFov()) then return false end
    if AB.vis and not isVis(cam.CFrame.Position, pt) then
        return false
    end
    if AB.team then
        local p = Players:GetPlayerFromCharacter(pt.Parent)
        if p and sameTm(p) then return false end
    end
    return true
end

local function abFind()
    -- Uses getMousePos() instead of Player.Mouse
    local center = AB.useCenter
        and scr()
        or getMousePos()

    local fv   = abEffFov()
    local best = nil
    local bd   = fv

    for _, p in ipairs(Players:GetPlayers()) do
        if p == lp then continue end
        if AB.team and sameTm(p) then continue end
        local chr = p.Character
        if not chr then continue end
        local hm = chr:FindFirstChildOfClass("Humanoid")
        if not hm or hm.Health <= 0 then continue end
        local pt = bPart(chr, AB.part)
        if not pt then continue end
        local sp, on = cam:WorldToViewportPoint(pt.Position)
        if not on then continue end
        -- WorldToViewportPoint — no Mouse needed
        local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if d < bd then
            if AB.vis and not isVis(cam.CFrame.Position, pt) then
                continue
            end
            bd   = d
            best = pt
        end
    end

    return best
end

local function getPredictedPos(pt)
    local now = tick()
    local pos = pt.Position
    if abPrevPos and (now - abPrevTick) > 0 then
        local el  = now - abPrevTick
        local vel = (pos - abPrevPos) / el
        pos = pos + vel * (0.08 * AB.speedAttack)
    end
    abPrevPos  = pt.Position
    abPrevTick = now
    return pos
end

local function applySmartLock(tRot, cur, dt, screenDist, fovRadius)
    local distFactor = AB.speed
    if fovRadius > 0 then
        local normalized = math.clamp(
            screenDist / fovRadius, 0, 1
        )
        distFactor = AB.speed
            + (AB.speedScaleFov / 100)
            * (1 - normalized)
            * math.max(AB.speedAttack - AB.speed, 0)
    end

    local eff    = math.clamp(distFactor, 0.01, 5)
    local factor = math.clamp(eff * dt * 6, 0, 1)

    if AB.lockMode == "Soft" or AB.lockMode == "Magnet" then
        return Vector2.new(
            cur.X + (tRot.X - cur.X) * factor,
            cur.Y + angDiff(cur.Y, tRot.Y) * factor
        )
    else
        local distP = math.abs(tRot.X - cur.X)
        local distY = math.abs(angDiff(cur.Y, tRot.Y))
        local dist  = math.sqrt(distP^2 + distY^2)

        if abCurveStart == nil or dist > 0.5 then
            abCurveStart    = cur
            abCurveProgress = 0
        end

        abCurveEnd = tRot
        local speed2 = (AB.curvePct / 100) * 3 * eff
        abCurveProgress = math.clamp(
            abCurveProgress + speed2 * dt, 0, 1
        )

        local t      = abCurveProgress
        local curved = t * t * (3 - 2 * t)

        local nP = abCurveStart.X
            + (abCurveEnd.X - abCurveStart.X) * curved
        local nY = abCurveStart.Y
            + angDiff(abCurveStart.Y, abCurveEnd.Y) * curved

        if abCurveProgress >= 1 then
            abCurveStart    = nil
            abCurveProgress = 0
        end

        return Vector2.new(nP, nY)
    end
end

