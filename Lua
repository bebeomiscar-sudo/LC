local function rageGetClosest()
    if not lp.Character
        or not lp.Character:FindFirstChild("HumanoidRootPart") then
        return nil, nil
    end

    local target, char, dist = nil, nil, math.huge

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character
            and v.Character:FindFirstChild("Head") then
            local mag = (
                lp.Character.HumanoidRootPart.Position
                - v.Character.Head.Position
            ).Magnitude
            if mag < dist then
                dist   = mag
                target = v.Character.Head
                char   = v.Character
            end
        end
    end

    return target, char
end

-- Standard wall scan
local function rageCalcPoint(origin, targetPos, targetChar)
    ray_params.FilterDescendantsInstances = {
        lp.Character, targetChar
    }

    if not ws:Raycast(
        origin, targetPos - origin, ray_params
    ) then
        return origin, nil
    end

    for _, offset in next, rageCfg.vectors do
        local scanPos = origin + offset
        if not ws:Raycast(
            scanPos, targetPos - scanPos, ray_params
        ) then
            return scanPos, offset.Y
        end
    end

    return nil, nil
end

-- IMPROVED MANIPULATION SYSTEM
-- More advanced wall detection using:
-- 1. Multi-pass scan with angle offsets
-- 2. Spiral scan pattern
-- 3. Adaptive distance scaling
-- 4. Side-step scan for thin walls
local function improvedCalcPoint(origin, targetPos, targetChar)
    ray_params.FilterDescendantsInstances = {
        lp.Character, targetChar
    }

    local function tryPoint(scanPos)
        local dir = targetPos - scanPos
        local result = ws:Raycast(scanPos, dir, ray_params)
        return result == nil
            or result.Instance:IsDescendantOf(targetChar)
    end

    -- Pass 1: Direct LOS check
    if tryPoint(origin) then
        return origin, nil
    end

    -- Pass 2: Standard vector offset scan
    for _, offset in next, rageCfg.vectors do
        local scanPos = origin + offset
        if tryPoint(scanPos) then
            return scanPos, offset.Y
        end
    end

    -- Pass 3: Multi-pass angle scan
    if rageCfg.improv.multiPass then
        local angleStep = rageCfg.improv.scanAngle
        for _, offset in next, rageCfg.vectors do
            -- Try rotated offsets
            for angle = -45, 45, angleStep do
                local rad = math.rad(angle)
                local rotX = offset.X * math.cos(rad)
                    - offset.Z * math.sin(rad)
                local rotZ = offset.X * math.sin(rad)
                    + offset.Z * math.cos(rad)
                local scanPos = origin + Vector3.new(
                    rotX, offset.Y, rotZ
                )
                if tryPoint(scanPos) then
                    return scanPos, offset.Y
                end
            end
        end
    end

    -- Pass 4: Spiral scan around target position
    if rageCfg.improv.spiralScan then
        local radius  = 2
        local steps   = 12
        local layers  = 4
        for layer = 1, layers do
            local height = layer * 8
            for step = 0, steps - 1 do
                local angle  = (step / steps) * math.pi * 2
                local spiral = origin + Vector3.new(
                    math.cos(angle) * radius * layer,
                    height,
                    math.sin(angle) * radius * layer
                )
                if tryPoint(spiral) then
                    return spiral, height
                end
            end
        end
    end

    -- Pass 5: Side-step scan (for thin walls)
    local sideOffsets = {
        Vector3.new(2, 0, 0),  Vector3.new(-2, 0, 0),
        Vector3.new(0, 0, 2),  Vector3.new(0, 0, -2),
        Vector3.new(3, 8, 0),  Vector3.new(-3, 8, 0),
        Vector3.new(0, 8, 3),  Vector3.new(0, 8, -3),
    }

    for _, side in next, sideOffsets do
        local scanPos = origin + side
        if tryPoint(scanPos) then
            return scanPos, side.Y
        end
    end

    -- Pass 6: Adaptive distance scan
    -- Scales scan positions based on distance to target
    if rageCfg.improv.adaptDist then
        local dist    = (origin - targetPos).Magnitude
        local scale   = math.clamp(dist / 50, 0.5, 3)
        for _, offset in next, rageCfg.vectors do
            local scaledOffset = Vector3.new(
                offset.X * scale,
                offset.Y * scale,
                offset.Z * scale
            )
            local scanPos = origin + scaledOffset
            if tryPoint(scanPos) then
                return scanPos, scaledOffset.Y
            end
        end
    end

    return nil, nil
end

local function startRagebot()
    if rageConn then
        rageConn:Disconnect()
        rageConn = nil
    end

    rageRunning = false

    rageConn = RunService.Heartbeat:Connect(function()
        if not rageCfg.enabled then return end
        if not lp.Character then return end
        if rageRunning then return end

        local root = lp.Character:FindFirstChild(
            "HumanoidRootPart"
        )
        if not root then return end

        if not FighterController
            or not FighterController.LocalFighter then
            return
        end

        local item = FighterController.LocalFighter.EquippedItem
        if not item then return end

        local targetPart, targetChar = rageGetClosest()
        if not targetPart or not targetChar then return end

        local camCF = cam.CFrame

        -- Choose scan method
        local manip, height
        if rageCfg.improvedManip then
            manip, height = improvedCalcPoint(
                camCF.Position,
                targetPart.Position,
                targetChar
            )
        else
            manip, height = rageCalcPoint(
                camCF.Position,
                targetPart.Position,
                targetChar
            )
        end

        if not manip then return end

        rageRunning = true

        task.spawn(function()
            pcall(function()
                local shootOrigin = height ~= nil
                    and Vector3.new(
                        camCF.Position.X,
                        camCF.Position.Y + height,
                        camCF.Position.Z
                    )
                    or camCF.Position

                -- FIXED: CFrame.lookAt (Bug #3 fix)
                local cf1 = CFrame.lookAt(
                    shootOrigin,
                    targetPart.Position
                )
                local cf2 = CFrame.lookAt(
                    targetPart.Position,
                    shootOrigin
                )

                local relativeCF = targetPart.CFrame:ToObjectSpace(
                    CFrame.new(targetPart.Position)
                )

                local cameraData = {}
                cameraData[utf8.char(1)] = {
                    [utf8.char(0)] = util:EncodeCFrame(cf1),
                    [utf8.char(1)] = util:EncodeCFrame(cf2),
                    [utf8.char(2)] = targetPart,
                    [utf8.char(3)] = util:EncodeCFrame(relativeCF),
                }

                UseItemRemote:FireServer(
                    item:Get("ObjectID"),
                    enums:ToEnum("StartShooting"),
                    cameraData,
                    nil
                )
            end)

            rageRunning = false
        end)
    end)
end

local function stopRagebot()
    if rageConn then
        rageConn:Disconnect()
        rageConn = nil
    end
    rageCfg.enabled = false
    rageRunning     = false
end

