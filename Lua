local function hudAmmo()
    if isInfiniteWeapon() then return "∞" end
    local cur, maxAmmo, melee = getammo()
    if cur == nil then return "∞" end
    if melee then return "melee" end
    return string.format("%d/%d", math.floor(cur or 0), math.max(math.floor(maxAmmo or 0), 0))
end

local function rageActive()
    return rageCfg.enabled or rageCfg.auto or rageCfg.voidspam.enabled
end

local function inVoid()
    if rageCfg.vhState.active then return true end
    if rageCfg.state.reloading and rageCfg.ragestatus.hideOnReload then return true end
    return false
end

local function isKilling()
    if not rageActive() then return false end
    if rageCfg.state.reloading or inVoid() then return false end
    if rageCfg.immune then return false end
    if not rageCfg.enabled or not rageCfg.character or not rageValid(rageCfg.character) then return false end
    if rageCfg.state.csyncactive then return true end
    if tick() - (ragePerf.lastAttackTick or 0) < 0.45 then return true end
    return false
end

local function killNm()
    if rageCfg.lastplayer then return rageCfg.lastplayer.Name end
    if rageCfg.character then
        local tp = Players:GetPlayerFromCharacter(rageCfg.character)
        if tp then return tp.Name end
    end
    return "target"
end

local function rageLines()
    local now = tick()
    if isKilling() then
        if not ragePerf.killStartAt then ragePerf.killStartAt = now end
    else
        ragePerf.killStartAt = nil
    end
    if rageCfg.state.reloading then
        return "ragebot: void hide", "reloading"
    end
    if inVoid() then
        return "ragebot: void hide", ""
    end
    if isKilling() then
        local name    = killNm()
        local elapsed = now - (ragePerf.killStartAt or now)
        local hum     = rageCfg.character and rageCfg.character:FindFirstChildOfClass("Humanoid")
        local main    = string.format("ragebot : attacking (%s) · %.1fs", name, elapsed)
        local hpBit   = hum and string.format("%.0f hp", hum.Health) or "hp ?"
        return main, hpBit
    end
    if rageActive() and rageCfg.enabled and rageCfg.character then
        local hum   = rageCfg.character:FindFirstChildOfClass("Humanoid")
        local hpBit = hum and string.format("%.0f hp", hum.Health) or "locked"
        return "ragebot: ready", hpBit
    end
    return "ragebot: idle", ""
end

local function drawStatus()
    if not rageCfg.ragestatus.enabled then
        rageStatusLine1.Visible = false
        rageStatusLine2.Visible = false
        return
    end
    local anchor   = statusAnchor()
    local gap      = rageCfg.ragestatus.lineGap or 14
    local showAmmo = rageCfg.ragestatus.showAmmo ~= false

    if ragePerf.lastRageColor ~= rageCfg.ragestatus.color then
        ragePerf.lastRageColor = rageCfg.ragestatus.color
        styleStatusLbl(rageStatusLine1)
        styleStatusLbl(rageStatusLine2)
    end

    local mainLine, detailLine = rageLines()
    local ammoLine = showAmmo and hudAmmo() or ""
    local line2Text = detailLine
    if line2Text ~= "" and ammoLine ~= "" then
        line2Text = line2Text .. " · " .. ammoLine
    elseif line2Text == "" then
        line2Text = ammoLine
    end

    local lineCount = 1 + (line2Text ~= "" and 1 or 0)
    local topOffset = -(lineCount - 1) * (gap / 2)

    if mainLine ~= ragePerf.lastRageStatusText then
        ragePerf.lastRageStatusText = mainLine
        rageStatusLine1.Text = mainLine
    end
    rageStatusLine1.Position = anchor + Vector2.new(0, topOffset)
    rageStatusLine1.Visible  = true

    if line2Text ~= "" then
        if line2Text ~= ragePerf.lastRageDetailText then
            ragePerf.lastRageDetailText = line2Text
            rageStatusLine2.Text = line2Text
        end
        rageStatusLine2.Position = anchor + Vector2.new(0, topOffset + gap)
        rageStatusLine2.Visible  = true
    else
        ragePerf.lastRageDetailText = ""
        rageStatusLine2.Visible     = false
    end
end

local function hideRageStatus()
    rageStatusLine1.Visible = false
    rageStatusLine2.Visible = false
end

