--   ✅ FIX: Safe ToEnum wrapper
--   Prevents nil call error from the screenshot
-- =============================================

local function safeToEnum(name)
    if not EnumLibrary then return nil end
    local ok, result = pcall(function()
        return EnumLibrary:ToEnum(name)
    end)
    if not ok or result == nil then
        warn(("[Rivals] ToEnum failed for: %s"):format(tostring(name)))
        return nil
    end
    return result
end

-- Cache enums after first successful call
local _enumCache = {}
local function getEnum(name)
    if _enumCache[name] then return _enumCache[name] end
    local e = safeToEnum(name)
    if e then _enumCache[name] = e end
    return e
end

