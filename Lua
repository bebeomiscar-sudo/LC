    local function getammo()
        if isInfiniteWeapon() then return nil, nil, false end
        local equipped = getEquipped()
        if not equipped then return 0, 0, false end
        local current, maxAmmo, isMelee = 0, 0, false
        local itemName = ""
        pcall(function()
            itemName = tostring(equipped:Get("Name") or equipped.Name or "")
            current  = equipped:Get("CurrentAmmo") or equipped:Get("Ammo") or 0
            maxAmmo  = equipped:Get("MaxAmmo") or equipped:Get("MaxBullets") or current
            if MELEE_NMS[itemName] then isMelee = true end
        end)
        return tonumber(current) or 0, tonumber(maxAmmo) or 0, isMelee
    end

    local function itemReload()
        if isInfiniteWeapon() then return false end
        local equipped = getEquipped()
        if not equipped then return false end
        local result = false
        pcall(function()
            for _, key in ipairs({"Reloading","IsReloading","IsReload"}) do
                local v = equipped:Get(key)
                if v==true or v==1 or v=="true" then result=true; return end
            end
        end)
        return result
    end

