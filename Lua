makeKeybind("Ragebot")
local rageCfg = { enabled=false, hitpart="Head", shootAttempts=1, hideRange=0.3, attackRange=0.3, teamCheck=true, maxDist=500, onPlayerEnabled=false, onPlayerTarget=nil, onPlayerPart="Head", onPlayerDelay=0.1 }
local ragePerf = { lastAttackTick=0, killStartAt=nil, targetName="", targetHP=0, state="idle" }
local vfrSnap = {cf=nil, lv=nil, av=nil}
local function clrVoidSnap() vfrSnap.cf, vfrSnap.lv, vfrSnap.av = nil, nil, nil end
local vfrLim, vfrDead = 2147483646, 1147483646

local function rndSkip(mi, ma, dmi, dma)
    local val = math.random(mi, ma)
    while val >= dmi and val <= dma do val = math.random(mi, ma) end
    return val
end

local function voidHrp() local char = lp.Character return char and char:FindFirstChild("HumanoidRootPart") end

RunService:BindToRenderStep("vfr_csync", Enum.RenderPriority.First.Value, function()
    if not vfrSnap.cf then return end
    local hrp = voidHrp()
    if not hrp then return end
    pcall(function()
        hrp.CFrame = vfrSnap.cf
        hrp.AssemblyLinearVelocity = vfrSnap.lv
        hrp.AssemblyAngularVelocity = vfrSnap.av
    end)
end)

local function snapVoid(hrp)
    if not hrp then return end
    vfrSnap.cf, vfrSnap.lv, vfrSnap.av = hrp.CFrame, hrp.AssemblyLinearVelocity, hrp.AssemblyAngularVelocity
    pcall(function()
        local lim, dead = vfrLim, vfrDead
        local p = Vector3.new(rndSkip(-lim,lim,-dead,dead), rndSkip(-lim,lim,-dead,dead), rndSkip(-lim,lim,-dead,dead))
        local v = Vector3.new(rndSkip(-lim,lim,-dead,dead), rndSkip(-lim,lim,-dead,dead), rndSkip(-lim,lim,-dead,dead))
        hrp.CFrame = CFrame.new(p) * CFrame.Angles(math.pi,math.pi,math.pi)
        hrp.AssemblyLinearVelocity = v
        hrp.AssemblyAngularVelocity = v
    end)
end

local function rageValid(char)
    if not char or not char.Parent then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 or not char:FindFirstChild("HumanoidRootPart") then return false end
    local tp = Players:GetPlayerFromCharacter(char)
    if not tp then return false end
    if rageCfg.teamCheck and sameTm(tp) then return false end
    return true
end

local function rageNearest()
    local cursor = getMouse()
    local best, bestd = nil, math.huge
    for _, p in Players:GetPlayers() do
        if p == lp or not p.Character or not rageValid(p.Character) then continue end
        local root = p.Character:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        local sp, on = cam:WorldToViewportPoint(root.Position)
        if not on then continue end
        local d = (Vector2.new(sp.X,sp.Y) - cursor).Magnitude
        if d < bestd then bestd=d; best=p.Character end
    end
    return best
end

local function hitpartfromname(character, partname)
    if not character then return nil end
    if partname == "Closest" then
        local mypos = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not mypos then return character:FindFirstChild("Head") end
        local closest, dist = nil, math.huge
        for _, part in pairs(character:GetChildren()) do
            if part:IsA("BasePart") then
                local d = (part.Position - mypos.Position).Magnitude
                if d < dist then dist=d; closest=part end
            end
        end
        return closest or character:FindFirstChild("Head")
    elseif partname == "Random" then
        local parts = {"Head","HumanoidRootPart","UpperTorso"}
        return character:FindFirstChild(parts[math.random(#parts)]) or character:FindFirstChild("Head")
    else
        return character:FindFirstChild(partname) or character:FindFirstChild("Head")
    end
end

local function rageShoot(targetChar)
    if not util or not enums or not UseItemRemote then notify("Ragebot", "Missing game modules!", 3); return end
    local lf = FighterController and FighterController.LocalFighter
    if not lf or not lf.EquippedItem then return end
    local oid = lf.EquippedItem:Get("ObjectID")
    if not oid then return end
    local hitPart = hitpartfromname(targetChar, rageCfg.hitpart)
    if not hitPart then return end
    local myChar = lp.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    local offsets = {
        Vector3.new(0,  2, 0), Vector3.new(0,  4, 0), Vector3.new(0,  6, 0),
        Vector3.new(2,  2, 0), Vector3.new(-2, 2, 0), Vector3.new(0,  2, 2),
        Vector3.new(0,  2,-2),
    }
    local tPos = hitPart.Position
    local attempts = math.clamp(rageCfg.shootAttempts, 1, 5)
    for attempt = 1, attempts do
        local off = offsets[((attempt - 1) % #offsets) + 1]
        local shootOrigin = myHRP.Position + off
        local cf1 = CFrame.lookAt(shootOrigin, tPos)
        local cf2 = CFrame.lookAt(tPos, shootOrigin)
        local rel = hitPart.CFrame:ToObjectSpace(CFrame.new(tPos))
        local data = {
            [utf8.char(1)] = {
                [utf8.char(0)] = util:EncodeCFrame(cf1),
                [utf8.char(1)] = util:EncodeCFrame(cf2),
                [utf8.char(2)] = hitPart,
                [utf8.char(3)] = util:EncodeCFrame(rel),
            },
        }
        pcall(function() UseItemRemote:FireServer(oid, enums:ToEnum("StartShooting"), data, nil) end)
    end
    ragePerf.lastAttackTick = tick()
end

local rageConn, rageRunning = nil, false
local function startRageLoop()
    if rageConn then rageConn:Disconnect(); rageConn=nil end
    rageRunning = false
    rageConn = trackConn(RunService.Heartbeat:Connect(function()
        if not rageCfg.enabled or not isKeybindActive("Ragebot") or rageRunning then return end
        local targetChar = rageNearest()
        if not targetChar or not rageValid(targetChar) then
            ragePerf.state, ragePerf.targetName, ragePerf.targetHP = "idle", "", 0
            return
        end
        local tp = Players:GetPlayerFromCharacter(targetChar)
        local hum = targetChar:FindFirstChildOfClass("Humanoid")
        ragePerf.targetName = tp and tp.Name or "?"
        ragePerf.targetHP = hum and math.floor(hum.Health) or 0
        local hrp = voidHrp()
        if not hrp then return end
        rageRunning = true
        task.spawn(function()
            local ok, err = pcall(function()
                ragePerf.state = "hiding"
                snapVoid(hrp)
                task.wait(rageCfg.hideRange)
                if not rageValid(targetChar) then clrVoidSnap(); ragePerf.state = "idle"; return end
                ragePerf.state = "attacking"
                if not isKeybindActive("Ragebot") then clrVoidSnap(); ragePerf.state = "idle"; return end
                rageShoot(targetChar)
                task.wait(rageCfg.attackRange)
                clrVoidSnap()
                ragePerf.state = "idle"
            end)
            if not ok then warn("[Ragebot] Error: "..tostring(err)); clrVoidSnap(); ragePerf.state = "idle" end
            rageRunning = false
        end)
    end))
end

local function stopRageLoop()
    if rageConn then rageConn:Disconnect(); rageConn=nil end
    clrVoidSnap()
    rageRunning, ragePerf.state, ragePerf.targetName, ragePerf.targetHP = false, "idle", "", 0
end

local onPlayerConn, onPlayerRunning = nil, false
local function getPlayerNames()
    local names = {"None"}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= lp then table.insert(names, p.Name) end
    end
    return names
end

local function rageGetPlayerByName(name)
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name == name or p.DisplayName == name then
            if not isValidTarget(p) then return nil,nil end
            local char = p.Character
            if not char then return nil,nil end
            local part = bPart(char, rageCfg.onPlayerPart) or char:FindFirstChild("Head")
            return part, char
        end
    end
    return nil, nil
end

local function startOnPlayer()
    if onPlayerConn then onPlayerConn:Disconnect(); onPlayerConn=nil end
    onPlayerRunning = false
    onPlayerConn = trackConn(RunService.Heartbeat:Connect(function()
        if not rageCfg.onPlayerEnabled or onPlayerRunning then return end
        if not rageCfg.onPlayerTarget or rageCfg.onPlayerTarget == "None" then return end
        if not isKeybindActive("Ragebot") then return end
        local lf = FighterController and FighterController.LocalFighter
        if not lf or not lf.EquippedItem then return end
        local tp, tc = rageGetPlayerByName(rageCfg.onPlayerTarget)
        if not tp or not tc then return end
        local hum = tc:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return end
        onPlayerRunning = true
        task.spawn(function()
            local ok, err = pcall(function()
                local myChar = lp.Character
                local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
                local so     = myHRP and myHRP.Position or cam.CFrame.Position
                local tPos   = tp.Position
                local rel    = tp.CFrame:ToObjectSpace(CFrame.new(tPos))
                local data   = {
                    [utf8.char(1)] = {
                        [utf8.char(0)] = util:EncodeCFrame(CFrame.lookAt(so,tPos)),
                        [utf8.char(1)] = util:EncodeCFrame(CFrame.lookAt(tPos,so)),
                        [utf8.char(2)] = tp,
                        [utf8.char(3)] = util:EncodeCFrame(rel),
                    },
                }
                pcall(function() UseItemRemote:FireServer(lf.EquippedItem:Get("ObjectID"), enums:ToEnum("StartShooting"), data, nil) end)
                task.wait(rageCfg.onPlayerDelay)
            end)
            if not ok then warn("[OnPlayer] "..tostring(err)) end
            onPlayerRunning = false
        end)
    end))
end

local function stopOnPlayer()
    if onPlayerConn then onPlayerConn:Disconnect(); onPlayerConn=nil end
    rageCfg.onPlayerEnabled, onPlayerRunning = false, false
end

