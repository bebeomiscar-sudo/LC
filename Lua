-- ============================================================
--[[
    How it works:
    1. Check equipped weapon via FighterController.LocalFighter.EquippedItem
    2. Check state — if reloading or out of ammo, skip (unless infinite weapon)
    3. Find nearest valid target
    4. Calculate shootPos (void pos if hiding, else cam position)
    5. Build data table with utf8 keys matching the game's format
    6. FireServer UseItem with ObjectID, StartShooting enum, data
    7. Hide phase — teleport into void to avoid getting hit
    8. Attack phase — come back up and shoot
    9. Priority system — lock onto specific player (rager)
    10. Show HUD: Hiding / Attacking state
]]

local RageCfg = {
    Enabled       = false,
    TeamCheck     = true,
    VisCheck      = false,
    MaxDist       = 800,
    HideRange     = 0.5,   -- seconds in void
    AttackRange   = 0.5,   -- seconds exposed to shoot
    DoubleTap     = false,
    DoubleTapDelay = 0.08,
    ShootAttempts  = 1,
    PriorityPlayer = "None",
    Phase          = "idle",  -- idle / hiding / attacking

    -- Vectors for wallbang positions
    Vectors = {
        Vector3.new(0, 12, 0),
        Vector3.new(0, 16, 0),
        Vector3.new(0, 20, 0),
        Vector3.new(0, 24, 0),
        Vector3.new(0, 28, 0),
        Vector3.new(0, 32, 0),
        Vector3.new(2, 16, 0),
        Vector3.new(-2, 16, 0),
        Vector3.new(0, 16, 2),
        Vector3.new(0, 16, -2),
    },
}

local rageConn         = nil
local rageRunning      = false
local rageDesyncConn   = nil
local rageDesyncActive = false
local rageHudVisible   = false

-- Void position for hide phase
local VOID_Y = -500

local RRay = RaycastParams.new()
RRay.FilterType = Enum.RaycastFilterType.Exclude

-- State check helpers
local function IsReloading(lf)
    if not lf then return false end
    local ok, r = pcall(function()
        return lf:GetState() == "Reloading"
            or (lf.State and lf.State.Value == "Reloading")
    end)
    return ok and r or false
end

local function IsOutOfAmmo(item)
    if not item then return false end
    local ok, r = pcall(function()
        local ammo = item:Get("Ammo")
        return ammo ~= nil and ammo <= 0
    end)
    return ok and r or false
end

local function IsInfiniteWeapon(item)
    if not item then return false end
    local ok, r = pcall(function()
        local maxAmmo = item:Get("MaxAmmo")
        return maxAmmo == nil or maxAmmo <= 0 or maxAmmo == math.huge
    end)
    return ok and r or false
end

local function GetEquipped()
    if not FighterController then return nil, nil end
    local lf = FighterController.LocalFighter
    if not lf then return nil, nil end
    local item = lf.EquippedItem
    if not item then return nil, nil end
    return lf, item
end

local function RageGetTarget()
    local myChar = lp.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end

    -- Priority player first
    if RageCfg.PriorityPlayer ~= "None" then
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name == RageCfg.PriorityPlayer or p.DisplayName == RageCfg.PriorityPlayer then
                if not IsValidTarget(p) then break end
                if RageCfg.TeamCheck and SameTeam(p) then break end
                return p.Character
            end
        end
    end

    -- Closest valid target
    local best, bestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if not IsValidTarget(p) then continue end
        if RageCfg.TeamCheck and SameTeam(p) then continue end
        local char = p.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        local dist = (myHRP.Position - hrp.Position).Magnitude
        if dist > RageCfg.MaxDist then continue end
        if RageCfg.VisCheck and not IsVisible(cam.CFrame.Position, hrp) then continue end
        if dist < bestDist then
            bestDist = dist
            best     = char
        end
    end
    return best
end

local function RageWallbangPoint(origin, targetPos, targetChar)
    RRay.FilterDescendantsInstances = {lp.Character, targetChar}
    local function canSee(sp)
        local hit = Workspace:Raycast(sp, targetPos - sp, RRay)
        return hit == nil or hit.Instance:IsDescendantOf(targetChar)
    end
    if canSee(origin) then return origin, nil end
    for _, off in ipairs(RageCfg.Vectors) do
        local sp = origin + off
        if canSee(sp) then return sp, off.Y end
    end
    return nil, nil
end

-- Desync teleport helpers
local function RageDesyncStart(targetChar)
    if rageDesyncConn then rageDesyncConn:Disconnect();rageDesyncConn=nil end
    rageDesyncActive = true
    local targetHead = targetChar and targetChar:FindFirstChild("Head")
    if not targetHead then return end

    rageDesyncConn = Track(RunService.Heartbeat:Connect(function()
        if not rageDesyncActive then return end
        local myChar = lp.Character
        local root   = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not root or not targetHead or not targetHead.Parent then
            rageDesyncActive = false
            if rageDesyncConn then rageDesyncConn:Disconnect();rageDesyncConn=nil end
            return
        end

        -- Team check on desync
        local owner = Players:GetPlayerFromCharacter(targetChar)
        if owner and RageCfg.TeamCheck and SameTeam(owner) then
            rageDesyncActive = false
            if rageDesyncConn then rageDesyncConn:Disconnect();rageDesyncConn=nil end
            return
        end

        local savedCF  = root.CFrame
        local savedLV  = root.AssemblyLinearVelocity
        local savedAV  = root.AssemblyAngularVelocity

        -- Teleport to near target
        root.CFrame = targetHead.CFrame * CFrame.new(0, -5, 0)

        RunService:BindToRenderStep("__RageDesyncRestore", 101, function()
            pcall(function()
                root.CFrame                 = savedCF
                root.AssemblyLinearVelocity  = savedLV
                root.AssemblyAngularVelocity = savedAV
            end)
            RunService:UnbindFromRenderStep("__RageDesyncRestore")
        end)
    end))
end

local function RageDesyncStop()
    rageDesyncActive = false
    if rageDesyncConn then rageDesyncConn:Disconnect();rageDesyncConn=nil end
    pcall(function() RunService:UnbindFromRenderStep("__RageDesyncRestore") end)
end

-- Hide phase — move into void
local function RageHide()
    RageCfg.Phase = "hiding"
    local myChar = lp.Character
    local root   = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not root then return end
    pcall(function()
        root.CFrame = CFrame.new(root.Position.X, VOID_Y, root.Position.Z)
    end)
end

-- The actual shot
local function RageFireShot(item, targetPart, targetChar, shootPos)
    local targetPos = targetPart.Position

    -- Simple velocity prediction
    pcall(function()
        local hrp = targetChar:FindFirstChild("HumanoidRootPart")
        if hrp then
            local vel = hrp.AssemblyLinearVelocity
            targetPos = targetPos + vel * 0.05
        end
    end)

    local cf1 = CFrame.lookAt(shootPos, targetPos)
    local cf2 = CFrame.lookAt(targetPos, shootPos)
    local rel  = CFrame.new(0.43, 0.25, 0.42) -- standard offset

    local data = {
        [utf8.char(1)] = {
            [utf8.char(0)] = UtilityModule:EncodeCFrame(cf1),
            [utf8.char(1)] = UtilityModule:EncodeCFrame(cf2),
            [utf8.char(2)] = targetPart,
            [utf8.char(3)] = UtilityModule:EncodeCFrame(rel),
        },
    }

    local objectId = item:Get("ObjectID")
    if not objectId then return end

    local attempts = math.clamp(RageCfg.ShootAttempts, 1, 3)
    for _ = 1, attempts do
        pcall(function()
            ReplicatedStorage.Remotes.Replication.Fighter.UseItem:FireServer(
                objectId,
                EnumsModule:ToEnum("StartShooting"),
                data,
                nil
            )
        end)
    end

    -- Double tap
    if RageCfg.DoubleTap then
        task.delay(RageCfg.DoubleTapDelay, function()
            if not targetPart or not targetPart.Parent then return end
            local hum = targetChar:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health <= 0 then return end
            local offset = Vector3.new(
                math.random(-5,5)*0.01,
                math.random(-5,5)*0.01,
                math.random(-5,5)*0.01
            )
            local data2 = {
                [utf8.char(1)] = {
                    [utf8.char(0)] = UtilityModule:EncodeCFrame(CFrame.lookAt(shootPos+offset, targetPos)),
                    [utf8.char(1)] = UtilityModule:EncodeCFrame(CFrame.lookAt(targetPos, shootPos+offset)),
                    [utf8.char(2)] = targetPart,
                    [utf8.char(3)] = UtilityModule:EncodeCFrame(rel),
                },
            }
            pcall(function()
                ReplicatedStorage.Remotes.Replication.Fighter.UseItem:FireServer(
                    objectId,
                    EnumsModule:ToEnum("StartShooting"),
                    data2,
                    nil
                )
            end)
        end)
    end
end

-- Main ragebot loop
local function StartRagebot()
    if rageConn then rageConn:Disconnect();rageConn=nil end
    rageRunning = false

    rageConn = Track(RunService.Heartbeat:Connect(function()
        if not RageCfg.Enabled or rageRunning then return end

        local lf, item = GetEquipped()
        if not lf or not item then return end

        -- State checks
        if not IsInfiniteWeapon(item) then
            if IsReloading(lf) then return end
            if IsOutOfAmmo(item) then
                -- Fire reload remote
                pcall(function()
                    local objectId = item:Get("ObjectID")
                    if objectId then
                        ReplicatedStorage.Remotes.Replication.Fighter.UseItem:FireServer(
                            objectId,
                            EnumsModule:ToEnum("Reloading"),
                            {},
                            nil
                        )
                    end
                end)
                return
            end
        end

        local targetChar = RageGetTarget()
        if not targetChar then
            RageCfg.Phase = "idle"
            RageDesyncStop()
            return
        end

        local targetHRP  = targetChar:FindFirstChild("HumanoidRootPart")
        local targetHead = targetChar:FindFirstChild("Head")
        if not targetHRP or not targetHead then return end

        local hum = targetChar:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return end

        rageRunning = true

        task.spawn(function()
            local ok, err2 = pcall(function()
                -- HIDE PHASE
                RageCfg.Phase = "hiding"
                RageHide()
                task.wait(RageCfg.HideRange)

                -- Recheck target still alive
                if not targetChar or not targetHead or not targetHead.Parent then
                    RageCfg.Phase = "idle"
                    return
                end
                local hum2 = targetChar:FindFirstChildOfClass("Humanoid")
                if not hum2 or hum2.Health <= 0 then
                    RageCfg.Phase = "idle"
                    return
                end

                -- ATTACK PHASE
                RageCfg.Phase = "attacking"

                -- Move back up (approximate original Y)
                local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if myRoot then
                    pcall(function()
                        myRoot.CFrame = CFrame.new(myRoot.Position.X, 5, myRoot.Position.Z)
                    end)
                end

                -- Start desync + wallbang
                RageDesyncStart(targetChar)
                task.wait(0.05)

                local shootPos = cam.CFrame.Position
                local manipPos, height = RageWallbangPoint(shootPos, targetHead.Position, targetChar)

                local finalShootPos = manipPos
                    and Vector3.new(manipPos.X, manipPos.Y, manipPos.Z)
                    or  shootPos

                RageFireShot(item, targetHead, targetChar, finalShootPos)

                task.wait(RageCfg.AttackRange)
                RageDesyncStop()
            end)

            if not ok then
                warn("[Ragebot] Error: " .. tostring(err2))
                pcall(RageDesyncStop)
            end

            RageCfg.Phase = "idle"
            rageRunning   = false
        end)
    end))
end

local function StopRagebot()
    if rageConn then rageConn:Disconnect();rageConn=nil end
    RageDesyncStop()
    RageCfg.Enabled = false
    RageCfg.Phase   = "idle"
    rageRunning     = false
end

