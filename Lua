-- Bypass 7: Fake ClientAlert + namecall block
task.spawn(function()
    task.wait(6)
    local ok = pcall(function()
        local plrs = game:GetService("Players")
        local lp3  = plrs.LocalPlayer

        local fake = Instance.new("RemoteEvent")
        fake.Name   = "ClientAlert"
        fake.Parent = lp3

        local pmt   = getrawmetatable(lp3)
        local oldnc = pmt.__namecall
        setreadonly(pmt, false)
        pmt.__namecall = newcclosure(function(self, ...)
            if getnamecallmethod() == "WaitForChild"
                and select(1, ...) == "ClientAlert" then
                return fake
            end
            return oldnc(self, ...)
        end)
        setreadonly(pmt, true)

        local mt  = getrawmetatable(game)
        local old = mt.__namecall
        setreadonly(mt, false)
        mt.__namecall = newcclosure(function(self, ...)
            local m = getnamecallmethod()
            if self == lp3
                and (m == "Kick" or m == "kick") then
                return
            end
            if m:lower():find("kick")
                or m == "Shutdown" then return end
            if m == "FireServer" and self == fake then
                return
            end
            return old(self, ...)
        end)
        setreadonly(mt, true)
    end)
    acDone.step7 = true
    setStatus(
        "AC Bypass 7/8 Done",
        7,
        "Step 8/8: Neutering LocalScript3..."
    )
    print("[AC] Step 7 " .. (ok and "OK" or "SKIP"))
end)

-- Bypass 8: LocalScript3 / LoadingScreen neuter
task.spawn(function()
    task.wait(7)
    local ok = pcall(function()
        local rf  = game:GetService("ReplicatedFirst")
        local ls3 = rf:WaitForChild("LocalScript3", 10)
        local c   = 0
        if ls3 then
            for _, f in getgc(false) do
                if typeof(f) == "function" then
                    local ok2, e = pcall(getfenv, f)
                    if ok2 and e then
                        local scr = rawget(e, "script")
                        if scr and (
                            scr == ls3
                            or tostring(scr):find("LoadingScreen")
                        ) then
                            local ok3, cs = pcall(
                                debug.getconstants, f
                            )
                            if ok3 then
                                for _, k in cs do
                                    if typeof(k) == "string"
                                        and (
                                            k:find("TakeTheL")
                                            or k:find("ban")
                                            or k:find("kick")
                                        ) then
                                        hookfunction(f, function() end)
                                        c = c + 1
                                        break
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
        print("[AC] Neutered " .. c .. " AC closures")
    end)
    acDone.step8 = true
    setStatus(
        "AC Bypass 8/8 Done ✓",
        8,
        "All bypasses active — waiting for timer..."
    )
    print("[AC] Step 8 " .. (ok and "OK" or "SKIP"))
end)

