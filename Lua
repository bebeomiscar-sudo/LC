local function statusAnchor()
    if rageCfg.ragestatus.mode == "muzzle" then
        local mp = muzzlepos()
        if mp then
            local sp, on = cam:WorldToViewportPoint(mp)
            if on then return Vector2.new(sp.X, sp.Y) end
        end
    end
    return (cam.ViewportSize / 2) + Vector2.new(
