local function isHidingPhase()
    return Cfg.voidSpam.enabled and Cfg.voidSpam.phase == "hide"
end

local function randVs(a, b)
    local lo = math.clamp(tonumber(a) or 1, 0.05, 5)
    local hi = math.clamp(tonumber(b) or 1, 0.05, 5)
    if hi < lo then lo, hi = hi, lo end
    if lo == hi then return lo end
    return lo + math.random() * (hi - lo)
end

local function tickVoidSpam()
    if not Cfg.voidSpam.enabled then return end
    local now     = tick()
    local elapsed = now - Cfg.voidSpam.lastSwitch

    if Cfg.voidSpam.phase == "shoot" then
        if elapsed >= Cfg.voidSpam.currentDur then
            Cfg.voidSpam.phase      = "hide"
            Cfg.voidSpam.currentDur = randVs(Cfg.voidSpam.hideMin, Cfg.voidSpam.hideMax)
            Cfg.voidSpam.lastSwitch = now
        end
    elseif Cfg.voidSpam.phase == "hide" then
        if elapsed >= Cfg.voidSpam.currentDur then
            Cfg.voidSpam.phase      = "shoot"
            Cfg.voidSpam.currentDur = randVs(Cfg.voidSpam.shootMin, Cfg.voidSpam.shootMax)
            Cfg.voidSpam.lastSwitch = now
        end
    else
        Cfg.voidSpam.phase      = "shoot"
        Cfg.voidSpam.currentDur = randVs(Cfg.voidSpam.shootMin, Cfg.voidSpam.shootMax)
        Cfg.voidSpam.lastSwitch = now
    end
end

