        local function buildSilentWrapper(originalFunc)
            return function(self, origin, direction, distance, ...)
                if silentCfg.enabled then
                    if math.random(1,100) <= silentCfg.hitChance then
                        local myRoot = lp.Character
                            and lp.Character:FindFirstChild(
                                "HumanoidRootPart"
                            )
                        local orig = myRoot
                            and myRoot.Position
                            or cam.CFrame.Position
                        local target = getSilentTarget(orig)
                        if target then
                            local predicted = target.Position
                            if silentCfg.prediction > 0 then
                                pcall(function()
                                    local hrp = target.Parent
                                        and target.Parent
                                            :FindFirstChild(
                                                "HumanoidRootPart"
                                            )
                                    local vel = hrp
                                        and hrp.AssemblyLinearVelocity
                                        or Vector3.zero
                                    predicted = target.Position
                                        + vel * (
                                            silentCfg.prediction * 0.05
                                        )
                                end)
                            end
                            return originalFunc(
                                self, origin,
                                predicted - origin,
                                distance, ...
                            )
                        end
                    end
                end
                return originalFunc(
                    self, origin, direction, distance, ...
                )
            end
        end

        local function hookSilent()
            if silentHooked or not util then return end
            local ok, mt = pcall(getrawmetatable, util)
            if ok and mt then
                local canSet = pcall(setrawmetatable, util, mt)
                if canSet then
                    origMeta   = mt
                    origIndex2 = rawget(mt, "__index")
                    rawset(mt, "__index", function(t, k)
                        if k == "Raycast" then
                            local rf2 = nil
                            if type(origIndex2) == "function" then
                                rf2 = origIndex2(t, k)
                            elseif type(origIndex2) == "table" then
                                rf2 = origIndex2[k]
                            else
                                rf2 = rawget(t, k)
                            end
                            if rf2 then
                                return buildSilentWrapper(rf2)
                            end
                        end
                        if type(origIndex2) == "function" then
                            return origIndex2(t, k)
                        elseif type(origIndex2) == "table" then
                            return origIndex2[k]
                        end
                        return rawget(t, k)
                    end)
                    silentHooked = true
                    return
                end
            end
            origRaycast = rawget(util,"Raycast") or util.Raycast
            if origRaycast then
                rawset(util,"Raycast",buildSilentWrapper(origRaycast))
                silentHooked = true
            end
        end

        local function unhookSilent()
            if not silentHooked then return end
            if origMeta and origIndex2 then
                pcall(function()
                    rawset(origMeta,"__index",origIndex2)
                end)
                origMeta=nil; origIndex2=nil
            elseif origRaycast and util then
                pcall(function()
                    rawset(util,"Raycast",origRaycast)
                end)
                origRaycast=nil
            end
            silentHooked=false
        end

