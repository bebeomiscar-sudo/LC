-- ══════════════════════════════════════════════════════════════
--
--                   BULLET TRACERS SYSTEM
--
-- ══════════════════════════════════════════════════════════════

do
    -- State
    local tracerEnabled      = false
    local tracerColor        = Color3.fromRGB(255, 255, 255)
    local tracerDuration     = 3
    local tracerSize         = 1
    local tracerFadeTime     = 0.5
    local tracerLerpSpeed    = 0
    local tracerStyle        = "Line"
    local tracers            = {}
    local tracerConn         = nil
    local tracerHooked       = false

    -- Dedup
    local lastCreations   = {}
    local DEDUP_INTERVAL  = 0.1
    local DEDUP_EXPIRY    = 1.0
    local DEDUP_PRUNE     = 120
    local frameCount      = 0

    -- Texture IDs
    local TEXTURES = {
        Line      = "",
        Beam      = "rbxassetid://12781852245",
        Lightning = "rbxassetid://446111271",
        Heartrate = "rbxassetid://5830549480",
        Chain     = "rbxassetid://9632168658",
        Glitch    = "rbxassetid://8089467613",
        Swirl     = "rbxassetid://5638168605",
        Neon      = "rbxassetid://6361963422",
        Plasma    = "rbxassetid://8993645509",
        Laser     = "rbxassetid://14549123968",
    }

    -- Muzzle position
    local function getMuzzle()
        local vm = Workspace:FindFirstChild("ViewModels")
        if not vm then return nil end
        local fp = vm:FindFirstChild("FirstPerson")
        if not fp then return nil end
        for _, model in ipairs(fp:GetChildren()) do
            if model:IsA("Model") and model.Name:find("^"..LocalPlayer.Name) then
                local iv = model:FindFirstChild("ItemVisual")
                if iv then
                    local body = iv:FindFirstChild("Body")
                    if body then
                        local bp = body:FindFirstChild("BodyPrimary")
                        if bp then
                            local muzzle = bp:FindFirstChild("_muzzle")
                            if muzzle and muzzle:IsA("Attachment") then
                                return muzzle.WorldPosition
                            end
                        end
                    end
                end
            end
        end
        return nil
    end

    -- Draw end with lerp
    local function getDrawEnd(tr, age)
        if tracerLerpSpeed <= 0 then return tr.endPos end
        local t = math.clamp(age / math.max(tracerLerpSpeed*0.25, 0.001), 0, 1)
        return tr.startPos:Lerp(tr.endPos, t)
    end

    -- Create line tracer
    local function mkLineTracer(s, e)
        local ol = Drawing.new("Line")
        ol.Thickness=4*tracerSize ol.Color=Color3.new(0,0,0)
        ol.Transparency=1 ol.Visible=false
        local ln = Drawing.new("Line")
        ln.Thickness=2*tracerSize ln.Color=tracerColor
        ln.Transparency=1 ln.Visible=false
        table.insert(tracers, {
            isLine=true, outline=ol, line=ln,
            startPos=s, endPos=e,
            lifetime=tracerDuration, fadeTime=tracerFadeTime,
            createdAt=tick(),
        })
    end

    -- Create beam tracer
    local function mkBeamTracer(s, e)
        local a0 = Instance.new("Attachment") a0.Parent = Workspace.Terrain
        local a1 = Instance.new("Attachment") a1.Parent = Workspace.Terrain
        local beam = Instance.new("Beam")
        beam.Attachment0    = a0
        beam.Attachment1    = a1
        beam.Color          = ColorSequence.new(tracerColor)
        local bw            = tracerStyle == "Laser" and 0.02 or 0.15
        beam.Width0         = bw * tracerSize
        beam.Width1         = bw * tracerSize
        beam.Transparency   = NumberSequence.new(0)
        beam.FaceCamera     = true
        beam.LightEmission  = 0.8
        beam.LightInfluence = 0.2
        local tex = TEXTURES[tracerStyle]
        if tex and tex ~= "" then
            beam.Texture=tex beam.TextureLength=4 beam.TextureSpeed=1
        else
            beam.Texture="" beam.TextureLength=1 beam.TextureSpeed=0
        end
        beam.Parent      = Workspace.Terrain
        a0.WorldPosition = s
        a1.WorldPosition = e
        table.insert(tracers, {
            isLine=false, beam=beam, a0=a0, a1=a1,
            startPos=s, endPos=e,
            lifetime=tracerDuration, fadeTime=tracerFadeTime,
            createdAt=tick(),
        })
    end

    -- Spawn tracer with dedup
    local function spawnTracer(s, e)
        if not s or not e then return end
        local kx = math.floor(s.X*5+0.5)
        local ky = math.floor(s.Y*5+0.5)
        local kz = math.floor(s.Z*5+0.5)
        local ex = math.floor(e.X*5+0.5)
        local ey = math.floor(e.Y*5+0.5)
        local ez = math.floor(e.Z*5+0.5)
        local key = kx*1e9 + ky*1e6 + kz*1e3 + ex + ey*1e-3 + ez*1e-6
        local now = tick()
        if lastCreations[key] and (now - lastCreations[key]) < DEDUP_INTERVAL then return end
        lastCreations[key] = now
        if tracerStyle == "Line" then mkLineTracer(s, e) else mkBeamTracer(s, e) end
    end

    -- Destroy tracer
    local function destroyTracer(tr)
        if tr.isLine then
            if tr.outline then tr.outline:Remove() end
            if tr.line    then tr.line:Remove()    end
        else
            if tr.beam then tr.beam:Destroy() end
            if tr.a0   then tr.a0:Destroy()   end
            if tr.a1   then tr.a1:Destroy()   end
        end
    end

    -- Update all tracers
    local function updateTracers()
        if #tracers == 0 then return end
        frameCount = frameCount + 1
        local now  = tick()
        local cam  = Workspace.CurrentCamera

        -- Prune dedup cache
        if frameCount % DEDUP_PRUNE == 0 then
            for k, t in next, lastCreations do
                if (now-t) > DEDUP_EXPIRY then lastCreations[k]=nil end
            end
        end

        local i = #tracers
        while i >= 1 do
            local tr  = tracers[i]
            local age = now - tr.createdAt
            if age >= tr.lifetime then
                destroyTracer(tr)
                tracers[i]        = tracers[#tracers]
                tracers[#tracers] = nil
            else
                -- Fade alpha
                local fadeStart = tr.lifetime - tr.fadeTime
                local alpha     = age >= fadeStart
                    and (1 - math.clamp((age-fadeStart)/tr.fadeTime, 0, 1))
                    or  1

                if tr.isLine then
                    local drawEnd = getDrawEnd(tr, age)
                    local s2, sOk = cam:WorldToViewportPoint(tr.startPos)
                    local e2, eOk = cam:WorldToViewportPoint(drawEnd)
                    local sv = Vector2.new(s2.X, s2.Y)
                    local ev = Vector2.new(e2.X, e2.Y)
                    local len = (ev-sv).Magnitude
                    if sOk and eOk and len > 0.1 and len < 3000 then
                        tr.outline.From=sv tr.outline.To=ev tr.outline.Transparency=alpha tr.outline.Visible=true
                        tr.line.From=sv   tr.line.To=ev   tr.line.Transparency=alpha   tr.line.Visible=true
                    else
                        tr.outline.Visible=false tr.line.Visible=false
                    end
                else
                    local drawEnd = getDrawEnd(tr, age)
                    if tr.a0 then tr.a0.WorldPosition = tr.startPos end
                    if tr.a1 then tr.a1.WorldPosition = drawEnd     end
                    tr.beam.Transparency = NumberSequence.new(1-alpha)
                end
            end
            i = i - 1
        end
    end

    -- Hook TracerEffect module
    local function hookTracerEffect()
        if tracerHooked then return end
        pcall(function()
            local TE      = require(LocalPlayer.PlayerScripts.Modules.TracerEffect)
            local origPlay = TE.Play
            TE.Play = function(self, data, c, extra)
                if tracerEnabled and data and data.IsLocal and data.RaycastResults then
                    local mpos = getMuzzle()
                    if mpos then
                        for _, hit in ipairs(data.RaycastResults) do
                            if hit.Position then spawnTracer(mpos, hit.Position) end
                        end
                    end
                end
                return origPlay(self, data, c, extra)
            end
            tracerHooked = true
        end)
    end

    local function startTracers()
        hookTracerEffect()
        if not tracerConn then
            tracerConn = RunService.RenderStepped:Connect(updateTracers)
        end
    end

    local function stopTracers()
        if tracerConn then tracerConn:Disconnect() tracerConn=nil end
        for _, tr in ipairs(tracers) do destroyTracer(tr) end
        tracers = {}
    end

    -- ── Tracer UI ──────────────────────────────────────────────

    TracerSec:Toggle({
        Name     = "enable",
        Flag     = "TracerEnabled",
        Default  = false,
        Callback = function(val)
            tracerEnabled = val
            if val then startTracers() else stopTracers() end
        end,
    }):Colorpicker({
        Flag     = "TracerColor",
        Default  = Color3.fromRGB(255, 255, 255),
        Callback = function(c)
            tracerColor = c
            for _, tr in ipairs(tracers) do
                if tr.isLine then
                    if tr.line then tr.line.Color = c end
                elseif tr.beam then
                    tr.beam.Color = ColorSequence.new(c)
                end
            end
        end,
    })

    TracerSec:Dropdown({
        Name     = "style",
        Flag     = "TracerStyle",
        Default  = "Line",
        Items    = { "Line","Beam","Lightning","Heartrate","Chain","Glitch","Swirl","Neon","Plasma","Laser" },
        Callback = function(val) tracerStyle = val end,
    })

    TracerSec:Slider({
        Name     = "duration",
        Flag     = "TracerDuration",
        Min=0.1, Max=10, Default=3, Decimals=1,
        Callback = function(val)
            tracerDuration = val
            for _, tr in ipairs(tracers) do tr.lifetime = val end
        end,
    })

    TracerSec:Slider({
        Name     = "size",
        Flag     = "TracerSize",
        Min=0.5, Max=5, Default=1, Decimals=1,
        Callback = function(val)
            tracerSize = val
            for _, tr in ipairs(tracers) do
                if tr.isLine then
                    if tr.outline then tr.outline.Thickness = 4*val end
                    if tr.line    then tr.line.Thickness    = 2*val end
                elseif tr.beam then
                    local bw = tracerStyle=="Laser" and 0.02 or 0.15
                    tr.beam.Width0 = bw*val
                    tr.beam.Width1 = bw*val
                end
            end
        end,
    })

    TracerSec:Slider({
        Name     = "fade time",
        Flag     = "TracerFade",
        Min=0, Max=2, Default=0.5, Decimals=1,
        Callback = function(val)
            tracerFadeTime = val
            for _, tr in ipairs(tracers) do tr.fadeTime = val end
        end,
    })

    TracerSec:Slider({
        Name     = "lerp speed",
        Flag     = "TracerLerp",
        Min=0, Max=5, Default=0, Decimals=1,
        Callback = function(val) tracerLerpSpeed = val end,
    })

    -- Hook on load
    task.defer(function()
        for _ = 1, 30 do
            if tracerHooked then break end
            hookTracerEffect()
            task.wait(0.5)
        end
    end)
end

