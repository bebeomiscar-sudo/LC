local function pushHitNotif(msg, color)
    local cfg = Cfg.hitNotif
    if not cfg.enabled then return end
    if #HitNotifs >= (cfg.maxVisible or 8) then
        pcall(function() HitNotifs[1].lbl:Remove() end)
        table.remove(HitNotifs, 1)
    end
    local lbl = Drawing.new("Text")
    lbl.Size         = cfg.textSize or 13
    lbl.Font         = 2
    lbl.Outline      = true
    lbl.OutlineColor = Color3.new()
    lbl.Color        = color or cfg.color
    lbl.Text         = msg
    lbl.Visible      = true
    lbl.Transparency = 1
    table.insert(HitNotifs, { lbl = lbl, t = tick(), dur = cfg.duration or 3 })
end

