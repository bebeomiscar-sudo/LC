local function isTeammate(plr)
    if not plr then return false end
    return LocalPlayer:GetAttribute("TeamID") == plr:GetAttribute("TeamID")
end

local function validTarget(char)
    if not char or not char.Parent then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if not char:FindFirstChild("HumanoidRootPart") then return false end
    local plr = Players:GetPlayerFromCharacter(char)
    if not plr or plr == LocalPlayer then return false end
    if isTeammate(plr) then return false end
    return true
end

local function getHitPart(char, partName)
    if not char then return nil end
    if partName == "Closest" then
        local myHRP = getHRP()
        if not myHRP then return char:FindFirstChild("Head") end
        local best, bestD = nil, math.huge
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then
                local d = (p.Position - myHRP.Position).Magnitude
                if d < bestD then best = p bestD = d end
            end
        end
        return best or char:FindFirstChild("Head")
    elseif partName == "Random" then
        local pool = {}
        for _, n in ipairs({"Head","HumanoidRootPart","UpperTorso","LeftUpperArm","RightUpperArm"}) do
            local p = char:FindFirstChild(n)
            if p then table.insert(pool, p) end
        end
        return pool[math.random(#pool)]
    else
        return char:FindFirstChild(partName) or char:FindFirstChild("Head")
    end
end

-- FOV-based nearest target
local function getNearestTarget(fovSize)
    local cursor  = UIS:GetMouseLocation()
    local best, bestDist = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer or not plr.Character then continue end
        if not validTarget(plr.Character) then continue end
        local root = plr.Character:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        local sp, onScreen = Camera:WorldToViewportPoint(root.Position)
        if onScreen then
            local d = (Vector2.new(sp.X, sp.Y) - cursor).Magnitude
            local withinFOV = (not fovSize) or d <= fovSize
            if d < bestDist and withinFOV then
                best     = plr.Character
                bestDist = d
            end
        end
    end
    return best
end

