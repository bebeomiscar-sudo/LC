        if SilentCfg.VisCheck then
            local orig = myRoot and myRoot.Position or cam.CFrame.Position
            if not IsVisible(orig, hitPart) then continue end
        end
        local sp, onScreen = cam:WorldToViewportPoint(hitPart.Position)
        if not onScreen then continue end
        local screenDist = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if screenDist > SilentCfg.FOV then continue end
        if screenDist < bestDist then bestDist=screenDist;best=entity end
    end
    return best
end

local function SilentHook()
    if _silentHooked or not GunModule then warn("[SilentAim] GunModule unavailable");return end
    local orig = GunModule.StartShooting
    if not orig then warn("[SilentAim] StartShooting not found");return end
    _silentOldFunc = orig
    local ok = pcall(function()
        rawset(GunModule, "StartShooting", function(self2, ...)
            local results = {orig(self2, ...)}
            if not self2.ClientFighter or not self2.ClientFighter.IsLocalPlayer then return table.unpack(results) end
            if not SilentCfg.Enabled or math.random(1,100) > SilentCfg.HitChance then return table.unpack(results) end
            local sd = results[3]
            if not sd or type(sd) ~= "table" then return table.unpack(results) end
            local entity = _silentCache
            if not entity then return table.unpack(results) end
            local hitPart = entity:FindFirstChild(SilentCfg.Part) or entity:FindFirstChild("Head")
            if not hitPart then return table.unpack(results) end
            local targetPos = hitPart.Position
            if SilentCfg.Prediction > 0 then
                pcall(function()
                    local hrp = entity:FindFirstChild("HumanoidRootPart")
                    if hrp then targetPos = targetPos + hrp.AssemblyLinearVelocity*(SilentCfg.Prediction*0.05) end
                end)
            end
            local myRoot    = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            local shootFrom = myRoot and myRoot.Position or cam.CFrame.Position
            local tCF       = hitPart.CFrame
            pcall(function()
                if UtilityModule then
                    sd[utf8.char(0)] = UtilityModule:EncodeCFrame(CFrame.lookAt(shootFrom, targetPos))
                    sd[utf8.char(1)] = UtilityModule:EncodeCFrame(CFrame.lookAt(targetPos, shootFrom))
                    sd[utf8.char(2)] = hitPart
                    sd[utf8.char(3)] = UtilityModule:EncodeCFrame(
                        tCF:ToObjectSpace(CFrame.new(targetPos+Vector3.new(
                            math.random(-3,3)*0.01,math.random(-3,3)*0.01,math.random(-3,3)*0.01
                        )))
                    )
                end
            end)
            return table.unpack(results)
        end)
    end)
    if ok then _silentHooked=true;print("[SilentAim] Hooked")
    else warn("[SilentAim] Hook failed");_silentOldFunc=nil end
end

local function SilentUnhook()
    if not _silentHooked or not GunModule then return end
    pcall(function() rawset(GunModule,"StartShooting",_silentOldFunc) end)
    _silentOldFunc=nil;_silentHooked=false
end

