        local function findViewModel()
            local result=nil
            pcall(function()
                local m=lp.PlayerScripts:WaitForChild("Modules",5)
                if not m then return end
                local cc=m:WaitForChild("ClientReplicatedClasses",5)
                if not cc then return end
                local cf2=cc:WaitForChild("ClientFighter",5)
                if not cf2 then return end
                local ci=cf2:WaitForChild("ClientItem",5)
                if not ci then return end
                result=ci:WaitForChild("ClientViewModel",5)
            end)
            if not result then
                pcall(function()
                    for _,v in pairs(
                        lp.PlayerScripts:GetDescendants()
                    ) do
                        if v.Name=="ClientViewModel" then
                            result=v; break
                        end
                    end
                end)
            end
            return result
        end

        local function applyHitSound(sId,vol,pit)
            if hitSoundConn then
                hitSoundConn:Disconnect(); hitSoundConn=nil
            end
            task.spawn(function()
                local vm=findViewModel()
                if not vm then
                    Library:Notify("Hit Sound: VM not found!",3)
                    return
                end
                for _,v in pairs(vm:GetChildren()) do
                    if v:IsA("Sound")
                        and v.SoundId~="rbxassetid://16537449730" then
                        pcall(function()
                            v.SoundId=sId; v.Pitch=pit; v.Volume=vol
                        end)
                    end
                end
                hitSoundConn=vm.ChildAdded:Connect(function(v)
                    if not hitSoundCfg.enabled then return end
                    if not v:IsA("Sound") then return end
                    if v.SoundId=="rbxassetid://16537449730" then
                        return
                    end
                    task.defer(function()
                        pcall(function()
                            v.SoundId=sId; v.Pitch=pit; v.Volume=vol
                        end)
                    end)
                end)
            end)
        end

        local function stopHitSound()
            if hitSoundConn then
                hitSoundConn:Disconnect(); hitSoundConn=nil
            end
            hitSoundCfg.enabled=false
        end

