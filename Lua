-- =============================================
--   HELPER FUNCTIONS
-- =============================================

local function scr()
    return Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
end

local function getMouse()
    return UserInputService:GetMouseLocation()
end

local function inFov(part, fovSize)
    if not part then return false end
    local sp, on = cam:WorldToViewportPoint(part.Position)
    if not on then return false end
    return (Vector2.new(sp.X, sp.Y) - scr()).Magnitude <= fovSize
end

local function isVis(orig, part)
    if not part then return false end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {lp.Character, part.Parent}
    local result = ws:Raycast(orig, (part.Position - orig).Unit * 2000, params)
    return result == nil or result.Instance:IsDescendantOf(part.Parent)
end

local function isValidTarget(p)
    if not p or p == lp then return false end
    local char = p.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if not char:FindFirstChild("HumanoidRootPart") then return false end
    return true
end

