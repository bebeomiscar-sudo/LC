do
    local guiinset = GuiService:GetGuiInset()

    -- Helpers
    local function w2esp(pos, cam)
        cam = cam or Workspace.CurrentCamera
        local sp, vis = cam:WorldToViewportPoint(pos)
        return Vector3.new(sp.X, sp.Y, sp.Z), vis
    end

    local function screenAnchor(xp, yp)
        local vp = Workspace.CurrentCamera.ViewportSize
        return Vector2.new(vp.X * xp, vp.Y * yp)
    end

    local function lerpc(a, b, t)
        return Color3.new(
            a.R+(b.R-a.R)*t,
            a.G+(b.G-a.G)*t,
            a.B+(b.B-a.B)*t
        )
    end

    -- Config
    _G.Config = _G.Config or {}
    local GC  = _G.Config

    GC.Box = GC.Box or {
        MasterEnabled = false,
        Enable        = false,
        OutlineColor  = Color3.fromRGB(255, 255, 255),
        OutlineColor2 = Color3.fromRGB(255, 255, 255),
        Healthbar     = { Enable=false, Thickness=4 },
        HealthLerpColors = {
            Color1 = Color3.fromRGB(0,   255, 0  ),
            Color2 = Color3.fromRGB(255, 255, 0  ),
            Color3 = Color3.fromRGB(255, 0,   0  ),
        },
