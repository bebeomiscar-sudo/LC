local function GetScreenCenter()
    return Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
end

local function GetBestPart(char, partName)
    local list = PART_MAP[partName] or {"Head"}
    if list[1] == "Random" then
        local available = {}
        for _, n in ipairs({"Head","UpperTorso","LowerTorso","HumanoidRootPart"}) do
            local p = char:FindFirstChild(n)
            if p then table.insert(available, p) end
        end
        return #available > 0 and available[math.random(1, #available)] or nil
    end
    for _, n in ipairs(list) do
        local p = char:FindFirstChild(n)
        if p then return p end
    end
end

local RayParams = RaycastParams.new()
RayParams.FilterType = Enum.RaycastFilterType.Exclude

local function IsVisible(origin, part)
    if not part then return false end
    local ok, result = pcall(function()
        RayParams.FilterDescendantsInstances = {lp.Character, part.Parent}
        local dir = part.Position - origin
        local hit = Workspace:Raycast(origin, dir, RayParams)
        return hit == nil or hit.Instance:IsDescendantOf(part.Parent)
    end)
    return ok and result or false
end

local function InFOV(part, fovRadius, center)
    if not part then return false end
    local sp, onScreen = cam:WorldToViewportPoint(part.Position)
    if not onScreen then return false end
    local screenPos = Vector2.new(sp.X, sp.Y)
    local refPoint  = center or GetScreenCenter()
    return (screenPos - refPoint).Magnitude <= fovRadius
end

local function IsValidTarget(player)
    if not player or player == lp then return false end
    local char = player.Character
    if not char or not char:IsDescendantOf(Workspace) then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if hum:GetState() == Enum.HumanoidStateType.Dead then return false end
    if not char:FindFirstChild("HumanoidRootPart") then return false end
    return true
end

local function SameTeam(player)
    local ok, result = pcall(function()
        local a = lp:GetAttribute("TeamID")
        local b = player:GetAttribute("TeamID")
        return a ~= nil and b ~= nil and a == b
    end)
    return ok and result or false
end

local function AngleDiff(from, to)
    local d = to - from
    return ((d + math.pi) % (math.pi * 2)) - math.pi
end

local function Notify(title, desc, dur)
    Library:Notify({
        Title       = tostring(title),
        Description = tostring(desc),
        Duration    = dur or 3,
    })
end

-- ============================================================
--   SPRING SYSTEM  (for smooth aimbot)
-- ============================================================

local Spring = {}
Spring.__index = Spring

function Spring.new(mass, force, damping, speed)
    return setmetatable({
        Target   = Vector3.new(),
        Position = Vector3.new(),
        Velocity = Vector3.new(),
        Mass     = mass   or 5,
        Force    = force  or 50,
        Damping  = damping or 4,
        Speed    = speed  or 4,
    }, Spring)
end

function Spring:Update(dt)
    local scaledDt = math.min(dt, 0.1) * self.Speed
    local acc = (self.Target - self.Position) * self.Force / self.Mass
    local vel = self.Velocity + acc * scaledDt
    vel = vel - vel * math.min(self.Damping * scaledDt, 1)
    self.Velocity = vel
    self.Position = self.Position + vel * scaledDt
    return self.Position
end

function Spring:Impulse(force)
    self.Velocity = self.Velocity + force
end

