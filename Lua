}

local ray_params = RaycastParams.new()
ray_params.FilterType = Enum.RaycastFilterType.Exclude

local function rageGetClosest()
    if not lp.Character
        or not lp.Character:FindFirstChild("HumanoidRootPart") then
        return nil, nil
    end

    local target, char, dist = nil, nil, math.huge

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= lp and v.Character
            and v.Character:FindFirstChild("Head") then
            local mag = (
                lp.Character.HumanoidRootPart.Position
                - v.Character.Head.Position
            ).Magnitude
            if mag < dist then
                dist   = mag
                target = v.Character.Head
                char   = v.Character
            end
        end
    end

    return target, char
end

local function rageCalcPoint(origin, targetPos, targetChar)
    ray_params.FilterDescendantsInstances = {lp.Character, targetChar}

    if not ws:Raycast(origin, targetPos - origin, ray_params) then
        return origin, nil
    end

    for _, offset in next, offsets do
        local scanPos = origin + offset
        if not ws:Raycast(scanPos, targetPos - scanPos, ray_params) then
            return scanPos, offset.Y
        end
    end

    return nil, nil
end

local function startRagebot()
    if rageConn then
        rageConn:Disconnect()
        rageConn = nil
    end

    rageConn = RunService.Heartbeat:Connect(function()
        if not rageCfg.enabled then return end
        if not lp.Character then return end

        local root = lp.Character:FindFirstChild("HumanoidRootPart")
        if not root then return end
        if not FighterController or not FighterController.LocalFighter then
            return
        end

        local item = FighterController.LocalFighter.EquippedItem
        if not item then return end

        local targetPart, targetChar = rageGetClosest()
        if not targetPart or not targetChar then return end

        local camCF = cam.CFrame
        local manip, height = rageCalcPoint(
            camCF.Position,
            targetPart.Position,
            targetChar
        )
        if not manip then return end

        local shootPos = (height == nil and manip) or camCF.Position

        pcall(function()
            local cameraData = {}
            local cf1 = CFrame.new(
                shootPos.X,
                shootPos.Y + (height or 0),
                shootPos.Z
            ) * CFrame.Angles(
                CFrame.lookAt(shootPos, targetPart.Position):ToOrientation()
            )

            local cf2 = height
                and CFrame.new(targetPart.Position) * CFrame.Angles(
                    CFrame.lookAt(shootPos, targetPart.Position):ToOrientation()
                )
                or cf1

            cameraData[utf8.char(1)] = {
                [utf8.char(0)] = util:EncodeCFrame(cf1),
                [utf8.char(1)] = util:EncodeCFrame(cf2),
                [utf8.char(2)] = targetPart,
                [utf8.char(3)] = util:EncodeCFrame(
                    targetPart.CFrame:ToObjectSpace(
                        CFrame.new(targetPart.Position)
                    )
                ),
            }

            UseItemRemote:FireServer(
                item:Get("ObjectID"),
                enums:ToEnum("StartShooting"),
                cameraData,
                nil
            )
        end)
    end)
end

local function stopRagebot()
    if rageConn then
        rageConn:Disconnect()
        rageConn = nil
    end
    rageCfg.enabled = false
end

