local hitSoundCfg = {
    enabled = false,
    soundId = "rbxassetid://4764109000",
    volume  = 1,
    pitch   = 1,
}

local hitSoundConn = nil

local function findViewModel()
    local result = nil

    local ok = pcall(function()
        local modules = lp.PlayerScripts
            :WaitForChild("Modules", 5)
        if not modules then return end

        local clientClasses = modules
            :WaitForChild("ClientReplicatedClasses", 5)
        if not clientClasses then return end

        local clientFighter = clientClasses
            :WaitForChild("ClientFighter", 5)
        if not clientFighter then return end

        local clientItem = clientFighter
            :WaitForChild("ClientItem", 5)
        if not clientItem then return end

        result = clientItem:WaitForChild(
            "ClientViewModel", 5
        )
    end)

    if not ok or not result then
        pcall(function()
            for _, v in pairs(
                lp.PlayerScripts:GetDescendants()
            ) do
                if v.Name == "ClientViewModel" then
                    result = v
                    break
                end
            end
        end)
    end

    return result
end

local function applyHitSound(soundId, volume, pitch)
    if hitSoundConn then
        hitSoundConn:Disconnect()
        hitSoundConn = nil
    end

    task.spawn(function()
        local vm = findViewModel()

        if not vm then
            Library:Notify(
                "Hit Sound: ViewModel not found!", 3
            )
            return
        end

        for _, v in pairs(vm:GetChildren()) do
            if v:IsA("Sound")
                and v.SoundId ~= "rbxassetid://16537449730" then
                pcall(function()
                    v.SoundId = soundId
                    v.Pitch   = pitch
                    v.Volume  = volume
                end)
            end
        end

        hitSoundConn = vm.ChildAdded:Connect(function(v)
            if not hitSoundCfg.enabled then return end
            if not v:IsA("Sound") then return end
            if v.SoundId == "rbxassetid://16537449730" then
                return
            end
            task.defer(function()
                pcall(function()
                    v.SoundId = soundId
                    v.Pitch   = pitch
                    v.Volume  = volume
                end)
            end)
        end)
    end)
end

local function stopHitSound()
    if hitSoundConn then
        hitSoundConn:Disconnect()
        hitSoundConn = nil
    end
    hitSoundCfg.enabled = false
end

