        for _, child in ipairs(fp:GetChildren()) do
            local parts = {}
            for p in child.Name:gmatch("[^-]+") do
                table.insert(parts, p:match("^%s*(.-)%s*$"))
            end
            if #parts >= 2 then return parts[2] end
        end
        return nil
    end

    local function getMuzzlePos()
        local vm = ws:FindFirstChild("ViewModels")
        if not vm then return nil end
        local fp = vm:FindFirstChild("FirstPerson")
        if not fp then return nil end
        for _, model in pairs(fp:GetChildren()) do
            if model.Name:find(lp.Name) then
                local iv = model:FindFirstChild("ItemVisual")
                if iv then
                    local body = iv:FindFirstChild("Body")
                    if body then
                        local bp = body:FindFirstChild("BodyPrimary")
                        if bp then
                            local muzzle = bp:FindFirstChild("_muzzle")
                            if muzzle then return muzzle.WorldPosition end
                        end
                    end
                end
            end
        end
        return nil
    end

    local function isInfinite()
        local w = getWeapon()
        return w and INFINITE_WEAPONS[w] == true
    end

    local function wantSlot()
        return SLOTS[cfg.target.weaponPick or "primary"] or 1
    end

    local function isMeleeMode()
        return cfg.target.weaponPick == "melee"
    end

    local function isSling(w)
        return w and w:lower():find("slingshot", 1, true) ~= nil
    end

    local function getAmmo()
        if isInfinite() then return nil, nil, false end
        local ok, fc = pcall(function()
            return instanceSafeRequire(lp.PlayerScripts.Controllers.FighterController)
        end)
        if ok and fc and fc.LocalFighter and fc.LocalFighter.EquippedItem then
            local item     = fc.LocalFighter.EquippedItem
            local cur, max = 0, 0
            local isMelee  = false
            local nm       = ""
            pcall(function()
                nm      = tostring(item:Get("Name") or item.Name or "")
                cur     = item:Get("CurrentAmmo") or item:Get("Ammo") or 0
                max     = item:Get("MaxAmmo") or item:Get("MaxBullets") or cur
                if MELEE_NMS[nm] then isMelee = true end
            end)
            if isMeleeMode() then isMelee = true end
            return tonumber(cur) or 0, tonumber(max) or 0, isMelee
        end
        return 0, 0, isMeleeMode()
    end

    local function isTeammate(tp)
        if not tp then return false end
        return lp:GetAttribute("TeamID") == tp:GetAttribute("TeamID")
    end

    local function isValid(char)
        if not char or not char.Parent then return false end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return false end
        if not char:FindFirstChild("HumanoidRootPart") then return false end
        local tp = plrs:GetPlayerFromCharacter(char)
        if not tp or isTeammate(tp) then return false end
        return true
    end

    local function getHitPart(char, name)
        if not char then return nil end
        if name == "Closest" then
            local myHrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not myHrp then return char:FindFirstChild("Head") end
            local best, bestD = nil, math.huge
            for _, p in pairs(char:GetChildren()) do
                if p:IsA("BasePart") then
                    local d = (p.Position - myHrp.Position).Magnitude
                    if d < bestD then bestD=d best=p end
                end
            end
            return best or char:FindFirstChild("Head")
        elseif name == "Random" then
            local pool = { "Head", "HumanoidRootPart", "UpperTorso" }
            return char:FindFirstChild(pool[math.random(#pool)])
                or char:FindFirstChild("Head")
        else
            return char:FindFirstChild(name) or char:FindFirstChild("Head")
        end
    end

    local function getNearestRage()
        local cursor  = input:GetMouseLocation()
        local best    = nil
        local bestD   = math.huge
        for _, tp in plrs:GetPlayers() do
            if tp ~= lp and tp.Character and isValid(tp.Character) then
                local root = tp.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    local cam = ws.CurrentCamera
                    local sp  = cam:WorldToViewportPoint(root.Position)
                    local d   = (Vector2.new(sp.X, sp.Y) - cursor).Magnitude
                    if d < bestD then bestD=d best=tp.Character end
                end
            end
        end
        return best
    end

    local function predict(part, origin)
        if not cfg.prediction.enabled or not part then
            return part and part.Position or Vector3.zero
        end
        local base = part.Position
        local dist = (base - origin).Magnitude
        local ping = 0
        pcall(function()
            ping = game:GetService("Stats")
                .Network.ServerStatsItem["Data Ping"]:GetValue() / 1000
        end)
        return base + (cfg.prediction.velocity * ((dist/3000 + ping) * cfg.prediction.multiplier))
    end

    local function canFire()
        local char = lp.Character
        if not char then return false end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return false end
        if isInfinite() then return true end
        local cur, _, melee = getAmmo()
        if cur == nil then return true end
        return cur > 0 or melee
    end

    local lf   = mods.fighter.LocalFighter
    local oldp = nil

    local function equipSlot()
        if not (cfg.target.enabled or cfg.target.rageMasterOn) then return end
        local want = wantSlot()
        local lfr  = mods.fighter and mods.fighter.LocalFighter
        if not lfr then return end
        pcall(function()
            if lfr.EquipItem then lfr:EquipItem(want) end
            if lfr.Equip     then lfr:Equip(want)     end
        end)
        pcall(function()
            local vim = game:GetService("VirtualInputManager")
            local kc  = ({ Enum.KeyCode.One, Enum.KeyCode.Two, Enum.KeyCode.Three })[want]
            if kc then
                vim:SendKeyEvent(true,  kc, false, game)
                task.wait(0.02)
                vim:SendKeyEvent(false, kc, false, game)
            end
        end)
    end

    local function getAtkCfg()
        if isMeleeMode() and not cfg.target.attackCustomEnabled then
            return { height=0, front=0, side=0, vertical=-(cfg.target.meleeFeetDrop), radius=0 }
        end
        if cfg.target.attackCustomEnabled then
            return {
                height   = cfg.target.customHeight,
                front    = cfg.target.customFront,
                side     = cfg.target.customSide,
                vertical = cfg.target.customVertical,
                radius   = cfg.target.customRadius,
            }
        end
        local w = getWeapon()
        if cfg.target.attackPosition == "under" then
            return { height=0, front=0, side=0, vertical=-cfg.target.underOffset, radius=0 }
        end
        return {
            height = (w and w:lower():find("sniper")) and 8 or 2,
            front=0, side=0, vertical=0, radius=0,
        }
    end

    local function refreshOrbit()
        local s = getAtkCfg()
        cfg.orbit.height = s.height
        cfg.orbit.radius = s.radius or 0
    end

    local function getOrbitBase(root)
        if not root then return Vector3.zero end
        local s = getAtkCfg()
        return root.Position
            + (root.CFrame.LookVector  * s.front)
            + (root.CFrame.RightVector * s.side)
            + Vector3.new(0, s.vertical, 0)
    end

    local function stopSync()
        if not cfg.state.csyncactive then return end
        if cfg.orbit.connection then
            cfg.orbit.connection:Disconnect()
            cfg.orbit.connection = nil
        end
        cfg.state.csyncactive = false
        cfg.orbit.active      = false
        clrSnap()
        cfg.voidspam.phase = nil
        if cfg.orbit.savedpos and lf and lf.Entity and lf.Entity.RootPart then
            pcall(function() lf.Entity.RootPart.CFrame = cfg.orbit.savedpos end)
        end
        cfg.orbit.serverpos = nil
        cfg.orbit.savedpos  = nil
        oldp = nil
    end

    local function tickVoidSpam()
        if not cfg.voidspam.enabled then return end
        local now = tick()
        local el  = now - cfg.voidspam.lastswitch
        if cfg.voidspam.phase == "shoot" then
            if el >= cfg.voidspam.currentduration then
                cfg.voidspam.phase           = "hide"
                cfg.voidspam.currentduration = randVs(cfg.voidspam.hide_min, cfg.voidspam.hide_max)
                cfg.voidspam.lastswitch      = now
            end
        elseif cfg.voidspam.phase == "hide" then
            if el >= cfg.voidspam.currentduration then
                cfg.voidspam.phase           = "shoot"
                cfg.voidspam.currentduration = randVs(cfg.voidspam.shoot_min, cfg.voidspam.shoot_max)
                cfg.voidspam.lastswitch      = now
            end
        else
            cfg.voidspam.phase           = "shoot"
            cfg.voidspam.currentduration = randVs(cfg.voidspam.shoot_min, cfg.voidspam.shoot_max)
            cfg.voidspam.lastswitch      = now
        end
    end

    local function startSync()
        if cfg.state.csyncactive or cfg.target.immune then return end
        if not cfg.target.character or not isValid(cfg.target.character) then return end
        equipSlot()
        cfg.state.csyncactive = true
        cfg.orbit.active      = true
        refreshOrbit()
        if not cfg.orbit.savedpos and lf and lf.Entity and lf.Entity.RootPart then
            cfg.orbit.savedpos = lf.Entity.RootPart.CFrame
        end
        cfg.orbit.connection = runsvc.Heartbeat:Connect(function(dt)
            if not cfg.state.csyncactive then return end
            if cfg.target.immune then stopSync() return end
            if not cfg.target.character or not isValid(cfg.target.character) then stopSync() return end
            if not lf or not lf.Entity or not lf.Entity.RootPart then stopSync() return end

            refreshOrbit()
            oldp = lf.Entity.RootPart.CFrame
            equipSlot()

            local weapon = getWeapon()
            local sling  = isSling(weapon)

            -- VoidSpam phase
            if cfg.voidspam.enabled and not cfg.target.immune and not sling then
                tickVoidSpam()
                if cfg.voidspam.phase == "hide" then
                    local rx = math.random(-10000, 10000)
                    local rz = math.random(-10000, 10000)
                    cfg.orbit.serverpos = Vector3.new(rx, -99999999999, rz)
                    pcall(function()
                        lf.Entity.RootPart.CFrame = CFrame.new(cfg.orbit.serverpos)
                    end)
                    return
                end
            end

            -- Out of ammo → void
            if cfg.state.outofammo and not sling and weapon and not isInfinite() then
                local hrp = getHrp()
                if hrp then
                    snapToVoid(hrp)
                else
                    local rx = math.random(-10000, 10000)
                    local rz = math.random(-10000, 10000)
                    cfg.orbit.serverpos = Vector3.new(rx, -99999999999, rz)
                    pcall(function()
                        lf.Entity.RootPart.CFrame = CFrame.new(cfg.orbit.serverpos)
                    end)
                end
                return
            end

            -- Orbit target
            local root = cfg.target.character:FindFirstChild("HumanoidRootPart")
            if not root then stopSync() return end

            cfg.orbit.angle    = cfg.orbit.angle + (cfg.orbit.speed * dt)
            cfg.orbit.serverpos = getOrbitBase(root) + Vector3.new(
                math.cos(cfg.orbit.angle) * cfg.orbit.radius,
                cfg.orbit.height,
                math.sin(cfg.orbit.angle) * cfg.orbit.radius
            )

            if lf.Entity.RootPart then
                local newCF = CFrame.new(cfg.orbit.serverpos)
                if (newCF.Position - oldp.Position).Magnitude < 2000 then
                    lf.Entity.RootPart.CFrame = newCF
                    cfg.orbit.savedpos        = oldp
                end
            end
        end)
    end

    local function autoShoot()
        if cfg.voidspam.enabled and cfg.voidspam.phase == "hide" then return end
        if not cfg.target.enabled or not cfg.target.character
            or not cfg.target.autoshoot or cfg.target.immune then return end

        equipSlot()
        local lfr = mods.fighter and mods.fighter.LocalFighter
        if not lfr or not lfr.EquippedItem then return end
        if not isInfinite() then
            if cfg.state.reloading or cfg.state.outofammo then return end
            if not canFire() then return end
        end
        if not isValid(cfg.target.character) then return end

        local hitPart = getHitPart(cfg.target.character, cfg.target.hitpart)
        if not hitPart then return end

        local shootPos
        if cfg.state.csyncactive and cfg.orbit.serverpos then
            shootPos = cfg.orbit.serverpos
        else
            local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            shootPos   = root and root.Position or Vector3.zero
        end

        local targetPos = predict(hitPart, shootPos)
        local data = {
            [utf8.char(1)] = {
                [utf8.char(0)] = mods.util:EncodeCFrame(CFrame.new(shootPos, targetPos)),
                [utf8.char(1)] = mods.util:EncodeCFrame(CFrame.new(shootPos, targetPos)),
                [utf8.char(2)] = hitPart,
                [utf8.char(3)] = mods.util:EncodeCFrame(CFrame.new(0.43, 0.25, 0.42)),
            },
        }

        local eq = lfr.EquippedItem
        if eq and eq:Get("ObjectID") then
            perf.lastAttackTick = tick()
            local attempts = math.clamp(math.floor(cfg.target.shootAttempts), 1, 3)
            for _ = 1, attempts do
                pcall(function()
                    RS.Remotes.Replication.Fighter.UseItem:FireServer(
                        eq:Get("ObjectID"),
                        mods.enums:ToEnum("StartShooting"),
                        data, nil
                    )
                end)
            end
        end
    end

    local function tickAmmo()
        if isInfinite() then
            cfg.state.outofammo = false
            cfg.state.reloading = false
            return
        end
        local cur, _, melee = getAmmo()
        cfg.state.outofammo = not melee and (tonumber(cur) or 0) <= 0
    end

    -- ── Immune Detection ───────────────────────────────────────

    local immuneList   = {}
    local onImmune     = {}
    local onVulnerable = {}

    runsvc.Heartbeat:Connect(function()
        for _, tp in pairs(plrs:GetPlayers()) do
            if tp == lp then continue end
            local char  = tp.Character
            local root  = char and char:FindFirstChild("HumanoidRootPart")
            local imm   = root and root:FindFirstChild("Attachment") ~= nil
            if imm and not immuneList[tp.Name] then
                immuneList[tp.Name] = true
                for _, cb in pairs(onImmune) do cb(tp) end
            elseif not imm and immuneList[tp.Name] then
                immuneList[tp.Name] = nil
                for _, cb in pairs(onVulnerable) do cb(tp) end
            end
        end
    end)

    table.insert(onImmune, function(tp)
        if cfg.target.lastplayer == tp then
            cfg.target.immune  = true
            cfg.voidspam.phase = nil
            clrSnap()
            stopSync()
        end
    end)

    table.insert(onVulnerable, function(tp)
        if cfg.target.lastplayer == tp then
            cfg.target.immune = false
            if cfg.target.enabled and cfg.target.character
                and isValid(cfg.target.character) then
                startSync()
            end
        end
    end)

    -- ── Target Management ──────────────────────────────────────

    local function clearTarget()
        cfg.target.enabled    = false
        stopSync()
        cfg.target.character  = nil
        cfg.target.lastchar   = nil
        cfg.target.lastplayer = nil
        cfg.target.manualkey  = false
        cfg.target.immune     = false
    end

    local function setTarget(char)
        if not char then return end
        local tp = plrs:GetPlayerFromCharacter(char)
        cfg.target.enabled    = true
        cfg.target.character  = char
        cfg.target.lastchar   = char
        cfg.target.lastplayer = tp
        cfg.target.immune     = false
        local root = char:FindFirstChild("HumanoidRootPart")
        if root and root:FindFirstChild("Attachment") then
            cfg.target.immune = true
        else
            equipSlot()
            startSync()
        end
    end

    -- ── Main Loop ──────────────────────────────────────────────

    runsvc.Heartbeat:Connect(function()
        tickAmmo()

        if cfg.target.auto and not cfg.target.manualkey then
            local cur, _, melee = getAmmo()
            local hasAmmo = cur == nil or cur > 0 or melee
            if hasAmmo and not cfg.state.reloading then
                if not cfg.target.enabled
                    or not cfg.target.character
                    or not isValid(cfg.target.character) then
                    local t = getNearestRage()
                    if t then
                        if cfg.target.enabled then stopSync() end
                        setTarget(t)
                    end
                end
            end
        end

        if cfg.target.enabled and cfg.target.character then
            if not isValid(cfg.target.character) then clearTarget() return end
            equipSlot()
            if cfg.target.autoshoot and not cfg.target.immune then
                autoShoot()
            end
        end
    end)

    -- Camera hook
    local oldCamUpdate = mods.cam.Update
    mods.cam.Update = function(...)
        if cfg.state.csyncactive and lf and lf.Entity and lf.Entity.RootPart and oldp then
            lf.Entity.RootPart.CFrame = oldp
        end
        return oldCamUpdate(...)
    end

    -- Export
    ragebot.cfg        = cfg
    ragebot.perf       = perf
    ragebot.setTarget  = setTarget
    ragebot.clearTarget = clearTarget
    ragebot.getNearestRage = getNearestRage
    ragebot.clrSnap    = clrSnap

    -- ── Ragebot UI ─────────────────────────────────────────────

    local function toggleRageKey()
        if cfg.target.auto then return end
        if cfg.target.enabled and cfg.target.character then
            clearTarget()
        else
            local t = getNearestRage()
            if t then cfg.target.manualkey = true setTarget(t) end
        end
    end

    RagebotSec:Toggle({
        Name     = "enable",
        Flag     = "RagebotToggle",
        Default  = false,
        Callback = function(val)
            cfg.target.rageMasterOn = val
            if cfg.target.auto then return end
            if val then
                local t = getNearestRage()
                if t then cfg.target.manualkey = true setTarget(t) end
            else
                clearTarget()
            end
        end,
    }):Keybind({
        Flag     = "RagebotKey",
        Default  = Enum.KeyCode.Unknown,
        Mode     = "Toggle",
        Callback = function() toggleRageKey() end,
    })

    RagebotSec:Toggle({
        Name     = "auto target",
        Flag     = "AutoTarget",
        Default  = false,
        Callback = function(val) cfg.target.auto = val end,
    })

    RagebotSec:Dropdown({
        Name     = "weapon",
        Flag     = "RageWeapon",
        Default  = "primary",
        Items    = { "primary", "secondary", "melee" },
        Callback = function(val)
            cfg.target.weaponPick = val
            if cfg.state.csyncactive then refreshOrbit() end
            equipSlot()
        end,
    })

    RagebotSec:Dropdown({
        Name     = "hit part",
        Flag     = "RageHitPart",
        Default  = "Head",
        Items    = { "Head","HumanoidRootPart","Torso","UpperTorso","Closest","Random" },
        Callback = function(val) cfg.target.hitpart = val end,
    })

    RagebotSec:Dropdown({
        Name     = "attack position",
        Flag     = "RageAttackPos",
        Default  = "default",
        Items    = { "default", "under" },
        Callback = function(val)
            cfg.target.attackPosition = val
            if cfg.state.csyncactive then refreshOrbit() end
        end,
    })

    RagebotSec:Slider({
        Name     = "shoot attempts",
        Flag     = "RageShootAttempts",
        Min      = 1, Max = 3, Default = 1, Decimals = 0,
        Suffix   = "x",
        Callback = function(val)
            cfg.target.shootAttempts = math.clamp(math.floor(val), 1, 3)
        end,
    })

    RagebotSec:Toggle({
        Name     = "prediction",
        Flag     = "RagePrediction",
        Default  = false,
        Callback = function(val) cfg.prediction.enabled = val end,
    })

    RagebotSec:Slider({
        Name     = "prediction mult",
        Flag     = "RagePredMult",
        Min      = 0.1, Max = 3.0, Default = 1.2, Decimals = 1,
        Callback = function(val) cfg.prediction.multiplier = val end,
    })

    RagebotSec:Toggle({
        Name     = "voidspam",
        Flag     = "VoidSpam",
        Default  = false,
        Callback = function(val)
            cfg.voidspam.enabled = val
            if val then
                cfg.voidspam.phase           = "shoot"
                cfg.voidspam.lastswitch      = tick()
                cfg.voidspam.currentduration = randVs(cfg.voidspam.shoot_min, cfg.voidspam.shoot_max)
            else
                cfg.voidspam.phase = nil
                clrSnap()
            end
        end,
    })

    RagebotSec:Slider({
        Name     = "attack time",
        Flag     = "VoidShootTime",
        Min      = 0.1, Max = 2, Default = 1, Decimals = 1,
        Suffix   = "s",
        Callback = function(val)
            cfg.voidspam.shoot_min = val
            cfg.voidspam.shoot_max = val
        end,
    })

    RagebotSec:Slider({
        Name     = "hide time",
        Flag     = "VoidHideTime",
        Min      = 0.1, Max = 2, Default = 1, Decimals = 1,
        Suffix   = "s",
        Callback = function(val)
            cfg.voidspam.hide_min = val
            cfg.voidspam.hide_max = val
        end,
    })

    -- ── Rage Visuals UI ────────────────────────────────────────

    RageVisSec:Toggle({
        Name     = "rage status",
        Flag     = "RageStatus",
        Default  = false,
        Callback = function(val) cfg.ragestatus.enabled = val end,
    }):Colorpicker({
        Flag     = "RageStatusColor",
        Default  = Color3.fromRGB(235, 235, 235),
        Callback = function(c) cfg.ragestatus.color = c end,
    })

    RageVisSec:Toggle({
        Name     = "hit notifications",
        Flag     = "HitNotif",
        Default  = true,
        Callback = function(val) cfg.hitNotif.enabled = val end,
    }):Colorpicker({
        Flag     = "HitNotifColor",
        Default  = Color3.fromRGB(235, 235, 235),
        Callback = function(c) cfg.hitNotif.color = c end,
    })

    RageVisSec:Slider({
        Name     = "notif duration",
        Flag     = "HitNotifDuration",
        Min      = 1, Max = 8, Default = 3, Decimals = 1,
        Suffix   = "s",
        Callback = function(val) cfg.hitNotif.duration = val end,
    })

    RageVisSec:Dropdown({
        Name     = "notif position",
        Flag     = "HitNotifPos",
        Default  = "Top Left",
        Items    = {
            "Top Left","Top Center","Top Right",
            "Center Left","Center","Center Right",
            "Bottom Left","Bottom Center","Bottom Right",
        },
        Callback = function(val) cfg.hitNotif.position = val end,
    })

    RageVisSec:Dropdown({
        Name     = "in animation",
        Flag     = "HitNotifInAnim",
        Default  = "fade bounce",
        Items    = { "fade","slide left","slide right","slide down","bounce","fade bounce","scale" },
        Callback = function(val) cfg.hitNotif.inAnimation = val end,
    })

    RageVisSec:Dropdown({
        Name     = "out animation",
        Flag     = "HitNotifOutAnim",
        Default  = "fade",
        Items    = { "fade","slide left","slide right","slide down","bounce","fade bounce","scale" },
        Callback = function(val) cfg.hitNotif.outAnimation = val end,
    })
end

