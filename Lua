        local rageConn=nil; local rageRunning=false

        local ray_p = RaycastParams.new()
        ray_p.FilterType = Enum.RaycastFilterType.Exclude

        local function rebuildVectors()
            rageCfg.vectors = {
                Vector3.new(rageCfg.v1x,rageCfg.v1y,rageCfg.v1z),
                Vector3.new(rageCfg.v2x,rageCfg.v2y,rageCfg.v2z),
                Vector3.new(rageCfg.v3x,rageCfg.v3y,rageCfg.v3z),
                Vector3.new(rageCfg.v4x,rageCfg.v4y,rageCfg.v4z),
                Vector3.new(0,rageCfg.v5y,0),
                Vector3.new(0,rageCfg.v6y,0),
                Vector3.new(0,rageCfg.v7y,0),
                Vector3.new(0,rageCfg.v8y,0),
            }
        end
        rebuildVectors()

        local function rageGetClosest()
            if not lp.Character
                or not lp.Character:FindFirstChild(
                    "HumanoidRootPart"
                ) then return nil,nil end
            local target,char,dist=nil,nil,math.huge
            for _,v in pairs(Players:GetPlayers()) do
                if v~=lp and v.Character
                    and v.Character:FindFirstChild("Head") then
                    local mag=(
                        lp.Character.HumanoidRootPart.Position
                        -v.Character.Head.Position
                    ).Magnitude
                    if mag<dist then
                        dist=mag
                        target=v.Character.Head
                        char=v.Character
                    end
                end
            end
            return target,char
        end

        local function rageCalcPoint(orig2,targetPos,targetChar)
            ray_p.FilterDescendantsInstances={
                lp.Character,targetChar
            }
            if not ws:Raycast(
                orig2,targetPos-orig2,ray_p
            ) then return orig2,nil end
            for _,offset in next,rageCfg.vectors do
                local sp=orig2+offset
                if not ws:Raycast(
                    sp,targetPos-sp,ray_p
                ) then return sp,offset.Y end
            end
            return nil,nil
        end

        local function improvedCalcPoint(
            orig2,targetPos,targetChar
        )
            ray_p.FilterDescendantsInstances={
                lp.Character,targetChar
            }
            local function tryPoint(sp)
                local r=ws:Raycast(sp,targetPos-sp,ray_p)
                return r==nil
                    or r.Instance:IsDescendantOf(targetChar)
            end
            if tryPoint(orig2) then return orig2,nil end
            for _,offset in next,rageCfg.vectors do
                local sp=orig2+offset
                if tryPoint(sp) then return sp,offset.Y end
            end
            if rageCfg.improv.multiPass then
                local step=rageCfg.improv.scanAngle
                for _,offset in next,rageCfg.vectors do
                    for angle=-45,45,step do
                        local rad=math.rad(angle)
                        local rx=offset.X*math.cos(rad)
                            -offset.Z*math.sin(rad)
                        local rz=offset.X*math.sin(rad)
                            +offset.Z*math.cos(rad)
                        local sp=orig2+Vector3.new(rx,offset.Y,rz)
                        if tryPoint(sp) then return sp,offset.Y end
                    end
                end
            end
            if rageCfg.improv.spiralScan then
                for layer=1,4 do
                    local h=layer*8
                    for step2=0,11 do
                        local a=(step2/12)*math.pi*2
                        local sp=orig2+Vector3.new(
                            math.cos(a)*2*layer,h,
                            math.sin(a)*2*layer
                        )
                        if tryPoint(sp) then return sp,h end
                    end
                end
            end
            local sides={
                Vector3.new(2,0,0),Vector3.new(-2,0,0),
                Vector3.new(0,0,2),Vector3.new(0,0,-2),
                Vector3.new(3,8,0),Vector3.new(-3,8,0),
                Vector3.new(0,8,3),Vector3.new(0,8,-3),
            }
            for _,side in next,sides do
                local sp=orig2+side
                if tryPoint(sp) then return sp,side.Y end
            end
            if rageCfg.improv.adaptDist then
                local dist2=(orig2-targetPos).Magnitude
                local scale=math.clamp(dist2/50,0.5,3)
                for _,offset in next,rageCfg.vectors do
                    local sc=Vector3.new(
                        offset.X*scale,
                        offset.Y*scale,
                        offset.Z*scale
                    )
                    local sp=orig2+sc
                    if tryPoint(sp) then return sp,sc.Y end
                end
            end
            return nil,nil
        end

        local function startRagebot()
            if rageConn then rageConn:Disconnect(); rageConn=nil end
            rageRunning=false
            rageConn=RunService.Heartbeat:Connect(function()
                if not rageCfg.enabled then return end
                if not lp.Character then return end
                if rageRunning then return end
                local root=lp.Character:FindFirstChild(
                    "HumanoidRootPart"
                )
                if not root then return end
                if not FighterController
                    or not FighterController.LocalFighter then
                    return
                end
                local item=FighterController.LocalFighter.EquippedItem
                if not item then return end
                local tp,tc=rageGetClosest()
                if not tp or not tc then return end
                local camCF=cam.CFrame
                local manip,height
                if rageCfg.improvedManip then
                    manip,height=improvedCalcPoint(
                        camCF.Position,tp.Position,tc
                    )
                else
                    manip,height=rageCalcPoint(
                        camCF.Position,tp.Position,tc
                    )
                end
                if not manip then return end
                rageRunning=true
                task.spawn(function()
                    pcall(function()
                        local so=height~=nil
                            and Vector3.new(
                                camCF.Position.X,
                                camCF.Position.Y+height,
                                camCF.Position.Z
                            ) or camCF.Position
                        local cf1=CFrame.lookAt(so,tp.Position)
                        local cf2=CFrame.lookAt(tp.Position,so)
                        local rel=tp.CFrame:ToObjectSpace(
                            CFrame.new(tp.Position)
                        )
                        local cd={}
                        cd[utf8.char(1)]={
                            [utf8.char(0)]=util:EncodeCFrame(cf1),
                            [utf8.char(1)]=util:EncodeCFrame(cf2),
                            [utf8.char(2)]=tp,
                            [utf8.char(3)]=util:EncodeCFrame(rel),
                        }
                        UseItemRemote:FireServer(
                            item:Get("ObjectID"),
                            enums:ToEnum("StartShooting"),
                            cd,nil
                        )
                    end)
                    rageRunning=false
                end)
            end)
        end

