local function UpdateRageHUD()
    local vp    = cam.ViewportSize
    local halfW = RageHudCfg.Width / 2
    local hudX  = (vp.X/2) - halfW + RageHudCfg.OffsetX
    local hudY  = RageHudCfg.OffsetY

    RageHudBg.Position     = Vector2.new(hudX, hudY)
    RageHudStroke.Position = Vector2.new(hudX, hudY)
    RageHudText.Position   = Vector2.new((vp.X/2)+RageHudCfg.OffsetX, hudY+(RageHudCfg.Height/2)-7)
    RageAmmoText.Position  = Vector2.new((vp.X/2)+RageHudCfg.OffsetX, hudY+RageHudCfg.Height+4)

    local voidTag = RageCfg.VoidSpamEnabled and (" [VS:"..rageVoidPhase.."]") or ""
    local phase   = RageCfg.Phase

    if phase == "hiding" then
        RageHudText.Text="⬇  HIDING"..voidTag;RageHudText.Color=Color3.fromRGB(80,160,255)
        RageHudBg.Color=Color3.fromRGB(10,10,40);RageHudStroke.Color=Color3.fromRGB(80,160,255)
    elseif phase == "attacking" then
        RageHudText.Text="⚡  ATTACKING"..voidTag;RageHudText.Color=Color3.fromRGB(255,80,60)
        RageHudBg.Color=Color3.fromRGB(40,10,10);RageHudStroke.Color=Color3.fromRGB(255,80,60)
    else
        RageHudText.Text="●  Idle"..voidTag;RageHudText.Color=Color3.fromRGB(180,180,180)
        RageHudBg.Color=Color3.fromRGB(14,14,20);RageHudStroke.Color=Color3.fromRGB(100,80,255)
    end

    local lf, item = GetEquipped()
    if item then
        pcall(function()
            local ammo    = item:Get("Ammo")
            local maxAmmo = item:Get("MaxAmmo")
            if ammo~=nil and maxAmmo~=nil then
                RageAmmoText.Text    = "Ammo: "..tostring(ammo).." / "..tostring(maxAmmo)
                RageAmmoText.Color   = (ammo<=0) and Color3.fromRGB(255,80,80) or Color3.fromRGB(200,200,200)
                RageAmmoText.Visible = rageHudVisible and RageCfg.Enabled
            else RageAmmoText.Visible=false end
        end)
    else RageAmmoText.Visible=false end
end

