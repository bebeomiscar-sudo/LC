local function updatevel()
    if not rageCfg.character or not rageCfg.prediction.enabled then
        rageCfg.prediction.velocity     = Vector3.new(0,0,0)
        rageCfg.prediction.lastposition = nil
        return
    end
    local root = rageCfg.character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local now = tick()
    local dt  = now - rageCfg.prediction.lasttime
    if dt > 0 and dt < 0.1 then
        local currentpos = root.Position
        if rageCfg.prediction.lastposition then
            local instantvel = (currentpos - rageCfg.prediction.lastposition) / dt
            rageCfg.prediction.velocity = rageCfg.prediction.velocity:Lerp(instantvel, 0.6)
        end
        rageCfg.prediction.lastposition = currentpos
        rageCfg.prediction.lasttime     = now
    end
end

local function predict(targetpart, origin)
    if not rageCfg.prediction.enabled or not targetpart then
        return targetpart and targetpart.Position or Vector3.new()
    end
    local basepos  = targetpart.Position
    local distance = (basepos - origin).Magnitude
    local ping = 0
    pcall(function()
        ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000
    end)
    local traveltime = distance / 3000
    local totaltime  = (traveltime + ping) * rageCfg.prediction.multiplier
    return basepos + (rageCfg.prediction.velocity * totaltime)
end

