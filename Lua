local function getammo()
    if isInfiniteWeapon() then return nil, nil, false end
    local lf = FighterController and FighterController.LocalFighter
    if not lf or not lf.EquippedItem then return 0, 0, pickMelee() end
    local item    = lf.EquippedItem
    local current, maxAmmo, isMelee = 0, 0, false
    local ok = pcall(function()
        local nm = tostring(item:Get("Name") or "")
        current  = item:Get("CurrentAmmo") or item:Get("Ammo") or 0
        maxAmmo  = item:Get("MaxAmmo") or item:Get("MaxBullets") or current
        if nm:lower():find("melee",1,true) then isMelee = true end
        if MELEE_NMS[nm] then isMelee = true end
    end)
    if not ok then return 0, 0, pickMelee() end
    if pickMelee() then isMelee = true end
    return tonumber(current) or 0, tonumber(maxAmmo) or 0, isMelee
end

local function itemReload()
    if isInfiniteWeapon() then return false end
    local lf = FighterController and FighterController.LocalFighter
    if not lf or not lf.EquippedItem then return false end
    local result = false
    pcall(function()
        local item = lf.EquippedItem
        for _, key in ipairs({"Reloading","IsReloading","IsReload"}) do
            local value = item:Get(key)
            if value == true or value == 1 or value == "true" then
                result = true
                return
            end
        end
    end)
    if result then return true end
    local started = rageCfg.state.reloadStartedAt or 0
    return started > 0 and (tick() - started) < 1.75
end

local function tickAmmo()
    if isInfiniteWeapon() then
        rageCfg.state.outofammo       = false
        rageCfg.state.reloading       = false
        rageCfg.state.reloadStartedAt = 0
        return
    end
    local current, _, melee = getammo()
    local wasOut = rageCfg.state.outofammo
    rageCfg.state.outofammo = (not melee) and ((tonumber(current) or 0) <= 0)
    local reloading = itemReload()
    if reloading and not rageCfg.state.reloading then
        rageCfg.state.reloadStartedAt = tick()
    elseif not reloading then
        rageCfg.state.reloadStartedAt = 0
    end
    rageCfg.state.reloading = reloading
end

local function canuse()
    local char = lp.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if isInfiniteWeapon() then return true end
    local current, _, melee = getammo()
    if current == nil then return true end
    return current > 0 or melee
end

