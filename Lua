local trigCfg = { enabled=false, delay=0.05, hitpart="Head", teamCheck=true, fovSize=20, visCheck=true }
local trigLastFire, trigConn = 0, nil

local function trigGetCrosshairTarget()
    local center  = scr()
    local unitRay = cam:ScreenPointToRay(center.X, center.Y)
    local origin, dir = unitRay.Origin, unitRay.Direction * 1000
    local rp = RaycastParams.new()
    rp.FilterType = Enum.RaycastFilterType.Exclude
    rp.FilterDescendantsInstances = {lp.Character}
    local result = ws:Raycast(origin, dir, rp)
    if not result or not result.Instance then return nil end
    local hit, char = result.Instance, result.Instance:FindFirstAncestorOfClass("Model")
    if not char then return nil end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return nil end
    local tp = Players:GetPlayerFromCharacter(char)
    if not tp or tp == lp then return nil end
    if trigCfg.teamCheck and sameTm(tp) then return nil end
    if trigCfg.visCheck and not isVis(cam.CFrame.Position, hit) then return nil end
    return char
end

local function trigShoot(targetChar)
    if not util or not enums or not UseItemRemote then notify("Triggerbot", "Missing game modules!", 3); return end
    local lf = FighterController and FighterController.LocalFighter
    if not lf or not lf.EquippedItem then return end
    local oid = lf.EquippedItem:Get("ObjectID")
    if not oid then return end
    local hitPart = hitpartfromname(targetChar, trigCfg.hitpart)
    if not hitPart then return end
    local myChar = lp.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    local shootOrigin = myHRP.Position + Vector3.new(0,2,0)
    local tPos = hitPart.Position
    local cf1, cf2 = CFrame.lookAt(shootOrigin, tPos), CFrame.lookAt(tPos, shootOrigin)
    local rel = hitPart.CFrame:ToObjectSpace(CFrame.new(tPos))
    local data = {
        [utf8.char(1)] = {
            [utf8.char(0)] = util:EncodeCFrame(cf1),
            [utf8.char(1)] = util:EncodeCFrame(cf2),
            [utf8.char(2)] = hitPart,
            [utf8.char(3)] = util:EncodeCFrame(rel),
        },
    }
    pcall(function() UseItemRemote:FireServer(oid, enums:ToEnum("StartShooting"), data, nil) end)
end

local function startTriggerbot()
    if trigConn then trigConn:Disconnect(); trigConn=nil end
    trigConn = trackConn(RunService.Heartbeat:Connect(function()
        if not trigCfg.enabled or not isKeybindActive("Triggerbot") then return end
        local now = tick()
