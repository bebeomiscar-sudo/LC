local function isTeammate(plr)
    if not plr then return false end
    return LocalPlayer:GetAttribute("TeamID") == plr:GetAttribute("TeamID")
end

local function validTarget(char)
    if not char or not char.Parent then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if not char:FindFirstChild("HumanoidRootPart") then return false end
    local plr = Players:GetPlayerFromCharacter(char)
    if not plr or plr == LocalPlayer then return false end
    if isTeammate(plr) then return false end
    return true
end

local function getNearestTarget()
    local cursor = UserInputService:GetMouseLocation()
    local best, bestDist = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer or not plr.Character then continue end
        if not validTarget(plr.Character) then continue end
        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
        if onScreen then
            local dist = (Vector2.new(pos.X, pos.Y) - cursor).Magnitude
            if dist < bestDist and dist <= (Config.visuals.fovCircle and Config.visuals.fovSize or math.huge) then
                best = plr.Character
                bestDist = dist
            end
        end
    end
    return best
end

local function getHitPart(char, partName)
    if not char then return nil end
    if partName == "Closest" then
        local myHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not myHrp then return char:FindFirstChild("Head") end
        local closest, closestDist = nil, math.huge
        for _, part in ipairs(char:GetChildren()) do
            if part:IsA("BasePart") then
                local d = (part.Position - myHrp.Position).Magnitude
                if d < closestDist then
                    closest = part
                    closestDist = d
                end
            end
        end
        return closest or char:FindFirstChild("Head")
    elseif partName == "Random" then
        local pool = {"Head","HumanoidRootPart","UpperTorso","LeftUpperArm","RightUpperArm"}
        return char:FindFirstChild(pool[math.random(#pool)]) or char:FindFirstChild("Head")
    else
        return char:FindFirstChild(partName) or char:FindFirstChild("Head")
    end
end

--// ═══════════════════════════════════════════════════════════
--//                   PREDICTION
--// ═══════════════════════════════════════════════════════════

local function updateVelocity()
    if not Config.character or not Config.prediction.enabled then
        Config.prediction.velocity = Vector3.zero
        Config.prediction.lastPos  = nil
        return
    end
    local hrp = Config.character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local now = tick()
    local dt  = now - Config.prediction.lastTime
    if dt > 0 and dt < 0.1 and Config.prediction.lastPos then
        local instVel = (hrp.Position - Config.prediction.lastPos) / dt
        Config.prediction.velocity = Config.prediction.velocity:Lerp(instVel, 0.6)
    end
    Config.prediction.lastPos  = hrp.Position
    Config.prediction.lastTime = now
end

local function predictPosition(targetPart, origin)
    if not Config.prediction.enabled or not targetPart then
        return targetPart and targetPart.Position or Vector3.zero
    end
    local ping = 0
    pcall(function()
        ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000
    end)
    local dist    = (targetPart.Position - origin).Magnitude
    local travel  = dist / 3000
    local total   = (travel + ping) * Config.prediction.multiplier
    return targetPart.Position + Config.prediction.velocity * total
end

