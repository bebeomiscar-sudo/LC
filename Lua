    -- Spin
    if aimbotFOVCfg.SpinOn then
        aimbotFOVStrokeGrad.Rotation = (fovAnimClock * aimbotFOVCfg.SpinSpd * 45) % 360
    end

    -- Animated fill
    if aimbotFOVCfg.FilledAnimated then
        aimbotFOVFillGrad.Rotation =
            (math.sin(fovAnimClock * aimbotFOVCfg.FilledSpeed) * 90)
            + aimbotFOVCfg.FilledRotation
    end
end)

local function clearAimbotLock()
    aimbot.lockedTarget = nil
