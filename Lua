local function getAttackCfg()
    if pickMelee() and not Config.customEnabled then
        return {height=0, front=0, side=0, vertical=-(Config.meleeFeetDrop or 3.5), radius=0}
    end
    if Config.customEnabled then
        return {
            height   = Config.customHeight   or 2,
            front    = Config.customFront    or 0,
            side     = Config.customSide     or 0,
            vertical = Config.customVertical or 0,
            radius   = Config.customRadius   or 0,
        }
    end
    local mode = Config.attackMode or "default"
    if mode == "under" then
        return {height=0, front=0, side=0, vertical=-(Config.underOffset or 4), radius=0}
    end
    local weapon = getWeaponName()
    return {
        height   = (weapon and weapon:lower():find("sniper")) and 8 or 2,
        front=0, side=0, vertical=0, radius=0,
    }
end

local function getOrbitBase(targetHRP)
    if not targetHRP then return Vector3.zero end
    local cfg = getAttackCfg()
    return targetHRP.Position
        + targetHRP.CFrame.LookVector  * cfg.front
        + targetHRP.CFrame.RightVector * cfg.side
        + Vector3.new(0, cfg.vertical, 0)
end

--// ═══════════════════════════════════════════════════════════
--//                   STOP SYNC
--// ═══════════════════════════════════════════════════════════

local function stopSync()
    if not Config.state.csyncActive then return end
    if Config.orbit.connection then
        Config.orbit.connection:Disconnect()
        Config.orbit.connection = nil
    end
    Config.state.csyncActive    = false
    Config.orbit.active         = false
    Config.voidspam.phase       = nil
    clearVoidSnap()
    local saved = Config.orbit.savedPos
    local lf    = getLocalFighter()
    if saved and lf and lf.Entity and lf.Entity.RootPart then
        pcall(function() lf.Entity.RootPart.CFrame = saved end)
    end
    Config.orbit.savedPos  = nil
    Config.orbit.serverPos = nil
    oldPos = nil
end

--// ═══════════════════════════════════════════════════════════
--//                   START SYNC (Orbit)
--// ═══════════════════════════════════════════════════════════

local function startSync()
    if Config.state.csyncActive then return end
    if Config.immune then return end
    if not Config.character or not validTarget(Config.character) then return end

    equipSlot()
    Config.state.csyncActive = true
    Config.orbit.active      = true

    local lf = getLocalFighter()
    if lf and lf.Entity and lf.Entity.RootPart and not Config.orbit.savedPos then
        Config.orbit.savedPos = lf.Entity.RootPart.CFrame
    end

    local attackCfg = getAttackCfg()
    Config.orbit.height = attackCfg.height
    Config.orbit.radius = attackCfg.radius

    Config.orbit.connection = RunService.Heartbeat:Connect(function(dt)
        if not Config.state.csyncActive then return end
        if Config.immune then stopSync() return end
        if not Config.character or not validTarget(Config.character) then stopSync() return end

        local lf2 = getLocalFighter()
        if not lf2 or not lf2.Entity or not lf2.Entity.RootPart then stopSync() return end

        local weapon    = getWeaponName()
        local isSling   = isSlingshot(weapon)

        oldPos = lf2.Entity.RootPart.CFrame

        equipSlot()

        -- Reload hiding
        if Config.state.reloading and not isSling then
            local hrp = getLocalHRP()
            if hrp then snapToVoid(hrp) return end
        end

        -- Void spam handling
        if not isSling and Config.voidspam.enabled and not Config.immune then
            local now = tick()
            local elapsed = now - Config.voidspam.lastSwitch
            if Config.voidspam.phase == "shoot" and elapsed >= Config.voidspam.currentDur then
                Config.voidspam.phase      = "hide"
                Config.voidspam.currentDur = Config.voidspam.hideMin + math.random() * (Config.voidspam.hideMax - Config.voidspam.hideMin)
                Config.voidspam.lastSwitch = now
            elseif Config.voidspam.phase == "hide" and elapsed >= Config.voidspam.currentDur then
                Config.voidspam.phase      = "shoot"
                Config.voidspam.currentDur = Config.voidspam.shootMin + math.random() * (Config.voidspam.shootMax - Config.voidspam.shootMin)
                Config.voidspam.lastSwitch = now
            elseif not Config.voidspam.phase then
                Config.voidspam.phase      = "shoot"
                Config.voidspam.currentDur = Config.voidspam.shootMin
                Config.voidspam.lastSwitch = now
            end
            if Config.voidspam.phase == "hide" then
                local hrp = getLocalHRP()
                if hrp then
                    snapToVoid(hrp)
                else
                    local rx = math.random(-10000, 10000)
                    local rz = math.random(-10000, 10000)
                    Config.orbit.serverPos = Vector3.new(rx, -99999999, rz)
                    pcall(function() lf2.Entity.RootPart.CFrame = CFrame.new(Config.orbit.serverPos) end)
                end
                return
            end
        end

        -- Out of ammo hiding
        if Config.state.outOfAmmo and not isSling and not isInfiniteWeapon() then
            local hrp = getLocalHRP()
            if hrp then
                snapToVoid(hrp)
            else
                local rx = math.random(-10000, 10000)
                local rz = math.random(-10000, 10000)
                Config.orbit.serverPos = Vector3.new(rx, -99999999, rz)
                pcall(function() lf2.Entity.RootPart.CFrame = CFrame.new(Config.orbit.serverPos) end)
            end
            return
        end

        -- Orbit around target
        local targetHRP = Config.character:FindFirstChild("HumanoidRootPart")
        if not targetHRP then stopSync() return end

        local base = getOrbitBase(targetHRP)
        Config.orbit.angle = Config.orbit.angle + Config.orbit.speed * dt

        local offset = Vector3.new(
            math.cos(Config.orbit.angle) * Config.orbit.radius,
            Config.orbit.height,
            math.sin(Config.orbit.angle) * Config.orbit.radius
        )
        Config.orbit.serverPos = base + offset

        local newCF = CFrame.new(Config.orbit.serverPos)
        local dist  = (newCF.Position - lf2.Entity.RootPart.CFrame.Position).Magnitude
        if dist < 2000 then
            clearVoidSnap()
            pcall(function()
                lf2.Entity.RootPart.CFrame = newCF
                Config.orbit.savedPos = oldPos
            end)
        end
    end)
end

--// ═══════════════════════════════════════════════════════════
--//                   AUTO SHOOT
--// ═══════════════════════════════════════════════════════════

local function fireShot()
    if not Config.enabled or not Config.autoShoot then return end
    if Config.immune then return end
    if not Config.character or not validTarget(Config.character) then return end
    if Config.voidspam.enabled and Config.voidspam.phase == "hide" then return end
    if Config.state.reloading or Config.state.outOfAmmo then
        if not isInfiniteWeapon() then return end
    end
    if not canShoot() then return end

    local lf = getLocalFighter()
    if not lf or not lf.EquippedItem then return end

    local hitPart = getHitPart(Config.character, Config.hitpart)
    if not hitPart then return end

    local weapon   = getWeaponName()
    local isSling  = isSlingshot(weapon)

    local shootPos
    if Config.state.csyncActive and Config.orbit.serverPos then
        shootPos = Config.orbit.serverPos
    else
        local hrp = getLocalHRP()
        shootPos  = hrp and hrp.Position or Vector3.zero
    end

    local targetPos = predictPosition(hitPart, shootPos)

    local oid = nil
    pcall(function() oid = lf.EquippedItem:Get("ObjectID") end)
    if not oid then return end

    local data = {
        [utf8.char(1)] = {
            [utf8.char(0)] = Modules.Utility:EncodeCFrame(CFrame.new(shootPos, targetPos)),
            [utf8.char(1)] = Modules.Utility:EncodeCFrame(CFrame.new(shootPos, targetPos)),
            [utf8.char(2)] = hitPart,
            [utf8.char(3)] = Modules.Utility:EncodeCFrame(CFrame.new(0.43, 0.25, 0.42)),
        }
    }

    Perf.lastAttackTick = tick()
    local attempts = math.clamp(math.floor(tonumber(Config.shootAttempts) or 1), 1, 3)
    for _ = 1, attempts do
        pcall(function()
            ReplicatedStorage.Remotes.Replication.Fighter.UseItem:FireServer(
                oid,
                Modules.Enums:ToEnum("StartShooting"),
                data,
                nil
            )
        end)
    end
end

