local function instanceSafeRequire(path)
    if not path then return nil end
    local ok, r = pcall(require, path)
    return ok and r or nil
end

-- ✅ Safe EncodeCFrame — never crashes on nil util
local function safeEncodeCFrame(utilModule, cf)
    if not utilModule then
        warn("[NilGuard] utility module nil — EncodeCFrame skipped")
        return CFrame.identity
    end
    if type(utilModule.EncodeCFrame) ~= "function" then
        warn("[NilGuard] EncodeCFrame not a function")
        return CFrame.identity
    end
    local ok, result = pcall(utilModule.EncodeCFrame, utilModule, cf)
    if not ok then
        warn("[NilGuard] EncodeCFrame failed: " .. tostring(result))
        return CFrame.identity
    end
    return result
end

-- ✅ Safe ToEnum — never crashes on nil enums
local function safeToEnum(enumsModule, enumName)
    if not enumsModule then
        warn("[NilGuard] enums module nil — ToEnum skipped")
        return nil
    end
    if type(enumsModule.ToEnum) ~= "function" then
        warn("[NilGuard] ToEnum not a function")
        return nil
    end
    local ok, result = pcall(enumsModule.ToEnum, enumsModule, enumName)
    if not ok then
        warn("[NilGuard] ToEnum failed: " .. tostring(result))
        return nil
    end
    return result
end

-- ✅ Safe build shot data — returns nil if any part is missing
local function buildShotData(utilModule, shootPos, targetPos, hitPart)
    if not utilModule then
        warn("[buildShotData] utility module is nil")
        return nil
    end
    if type(utilModule.EncodeCFrame) ~= "function" then
        warn("[buildShotData] EncodeCFrame is not a function")
        return nil
    end
    if not hitPart or not hitPart.Parent then
        warn("[buildShotData] hitPart is nil or destroyed")
        return nil
    end
    if typeof(shootPos) ~= "Vector3" or typeof(targetPos) ~= "Vector3" then
        warn("[buildShotData] invalid positions")
        return nil
    end

    local cf1 = safeEncodeCFrame(utilModule, CFrame.new(shootPos, targetPos))
    local cf2 = safeEncodeCFrame(utilModule, CFrame.new(shootPos, targetPos))
    local rel = safeEncodeCFrame(utilModule, CFrame.new(0.43, 0.25, 0.42))

    return {
        [utf8.char(1)] = {
            [utf8.char(0)] = cf1,
            [utf8.char(1)] = cf2,
            [utf8.char(2)] = hitPart,
            [utf8.char(3)] = rel,
        }
    }
end

-- ✅ Safe FireServer — nil checks before every fire
local function safeFireShot(remote, enumsModule, objectId, data)
    if not remote then
        warn("[safeFireShot] UseItemRemote is nil")
        return false
    end
    if not objectId then
        warn("[safeFireShot] objectId is nil")
        return false
    end
    if not data then
        warn("[safeFireShot] shot data is nil")
        return false
    end
    local enumVal = safeToEnum(enumsModule, "StartShooting")
    if not enumVal then
        warn("[safeFireShot] StartShooting enum is nil")
        return false
    end
    local ok, err = pcall(function()
        remote:FireServer(objectId, enumVal, data, nil)
    end)
    if not ok then
        warn("[safeFireShot] FireServer failed: " .. tostring(err))
        return false
    end
    return true
end

