trackConn(RunService.Heartbeat:Connect(function()
    tickAmmo()

    -- Auto target
    if rageCfg.auto then
        local current, _, melee = getammo()
        local hasammo = current == nil or current > 0 or melee
        if hasammo and not rageCfg.state.reloading then
            if not rageCfg.enabled or not rageCfg.character or not rageValid(rageCfg.character) then
                local newtarget = rageNearest()
                if newtarget then
                    if rageCfg.enabled then stopsync() end
                    settarget(newtarget)
                end
            end
        end
    end

    -- Active target loop
    if rageCfg.enabled and rageCfg.character then
        if not rageValid(rageCfg.character) then
            cleartarget()
            return
        end
        eqSlot()
        if rageCfg.autoshoot and not rageCfg.immune then
            autoshoot()
        end
    end

    -- Prediction velocity update
    if rageCfg.enabled and rageCfg.character and rageCfg.prediction.enabled then
        updatevel()
    end
end))

