local function RageOrbBase(root)
    if not root then return Vector3.zero end
    local cfg   = RageGetAtkCfg()
    local pos   = root.Position
    local look  = root.CFrame.LookVector
    local right = root.CFrame.RightVector
    return pos
        + look  * cfg.front
        + right * cfg.side
        + Vector3.new(0, cfg.vertical, 0)
end

-- ============================================================
--   PREDICTION (multi-sample velocity buffer)
-- ============================================================

local function RageUpdateVel()
    local pred = RC.Prediction
    if not pred.Enabled or not RC.Target.Character then
        pred.Velocity = Vector3.new()
        pred.LastPos  = nil
        return
    end
    local root = RC.Target.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local now = tick()
    local dt  = now - pred.LastTime
    if dt > 0 and dt < 0.1 and pred.LastPos then
        local instVel = (root.Position - pred.LastPos) / dt
        -- Push to buffer
        table.insert(pred.VelBuffer, instVel)
        if #pred.VelBuffer > pred.MaxSamples then
            table.remove(pred.VelBuffer, 1)
        end
        -- Average
        local sum = Vector3.new()
        for _, v in ipairs(pred.VelBuffer) do sum = sum + v end
        pred.Velocity = sum / #pred.VelBuffer
    end
    pred.LastPos  = root.Position
    pred.LastTime = now
end

local function RagePredict(hitPart, shootPos)
    if not RC.Prediction.Enabled or not hitPart then
        return hitPart and hitPart.Position or Vector3.new()
    end
    local basePos = hitPart.Position
    local dist    = (basePos - shootPos).Magnitude
    local ping    = 0
    pcall(function()
        ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000
    end)
    local travel  = dist / 3000
    local total   = (travel + ping) * RC.Prediction.Multiplier
    return basePos + (RC.Prediction.Velocity * total)
end

