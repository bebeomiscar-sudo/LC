local function getRageStatusLines()
    if not Cfg.rageStatus.enabled then return nil, nil, nil end
    local phase    = Cfg.voidSpam.phase or "off"
    local targetNm = Cfg.lastPlayer and Cfg.lastPlayer.Name or "none"
    local weapon   = getWeaponName() or "none"
    local cur, max_, melee = getAmmo()
    local ammoStr  = isInfiniteWeapon() and "∞"
        or melee    and "melee"
        or string.format("%d/%d", cur or 0, max_ or 0)

    local statusColor
    local mainLine

    if Cfg.immune then
        mainLine    = "ragebot: immune"
        statusColor = Color3.fromRGB(180, 0, 255)
    elseif Cfg.state.reloading then
        mainLine    = "ragebot: reloading"
        statusColor = Color3.fromRGB(255, 200, 0)
    elseif Cfg.state.outOfAmmo then
        mainLine    = "ragebot: out of ammo"
        statusColor = Color3.fromRGB(255, 100, 0)
    elseif isHidingPhase() then
        mainLine    = "ragebot: void hiding"
        statusColor = Color3.fromRGB(255, 165, 0)
    elseif Cfg.enabled and Cfg.state.csyncActive then
        if not Perf.killStartAt then Perf.killStartAt = tick() end
        local elapsed = tick() - Perf.killStartAt
        mainLine    = string.format("ragebot: attacking · %.1fs", elapsed)
        statusColor = Color3.fromRGB(0, 255, 100)
    elseif Cfg.enabled then
        mainLine    = "ragebot: locked"
        statusColor = Cfg.rageStatus.color
    else
        Perf.killStartAt = nil
        mainLine    = "ragebot: idle"
        statusColor = Color3.fromRGB(150, 150, 150)
    end

    if not Cfg.enabled then Perf.killStartAt = nil end

    local detailParts = {}
    if Cfg.rageStatus.showTarget then
        table.insert(detailParts, "target: " .. targetNm)
    end
    if Cfg.rageStatus.showAmmo then
        table.insert(detailParts, "ammo: " .. ammoStr)
    end
    if Cfg.rageStatus.showPhase and Cfg.voidSpam.enabled then
        table.insert(detailParts, "phase: " .. phase)
    end

    local detailLine = table.concat(detailParts, " · ")
    local weaponLine = "weapon: " .. weapon

    return mainLine, detailLine, weaponLine, statusColor
end

RunService.RenderStepped:Connect(function()
    local center    = Camera.ViewportSize / 2
    local myHRP     = getHRP()
    local hasTarget = Cfg.enabled
        and Cfg.character
        and Cfg.character.Parent ~= nil

    --// FOV Circle
    local showFov = Cfg.visualizer.fovEnabled and Cfg.enabled
    fovCircle.Visible  = showFov
    fovOutline.Visible = showFov
    if showFov then
        fovCircle.Position   = center
        fovCircle.Radius     = Cfg.visualizer.fovSize
        fovCircle.Color      = Cfg.visualizer.fovColor
        fovOutline.Position  = center
        fovOutline.Radius    = Cfg.visualizer.fovSize
    end

    --// Target dot + tracer
    if hasTarget and Cfg.visualizer.indicator then
        local hitPart = getHitPart(Cfg.character, Cfg.hitPart)
        if hitPart then
            local sp, onScreen = Camera:WorldToViewportPoint(hitPart.Position)
            if onScreen then
                local sv  = Vector2.new(sp.X, sp.Y)
                local col = Cfg.immune and Color3.fromRGB(180, 0, 255)
                    or isHidingPhase() and Color3.fromRGB(255, 165, 0)
                    or Cfg.visualizer.espColor
                tDot.Position    = sv ; tDot.Color   = col ; tDot.Visible    = true
                tDotOut.Position = sv ;                       tDotOut.Visible = true

                if Cfg.visualizer.tracer then
                    local from = Vector2.new(center.X, Camera.ViewportSize.Y)
                    tracerLine.From    = from ; tracerLine.To    = sv
                    tracerOutline.From = from ; tracerOutline.To = sv
                    tracerLine.Color   = Cfg.visualizer.tracerColor
                    tracerLine.Thickness    = Cfg.visualizer.tracerThick
                    tracerLine.Visible      = true
                    tracerOutline.Visible   = true
                else
                    tracerLine.Visible    = false
                    tracerOutline.Visible = false
                end
            else
                tDot.Visible = false ; tDotOut.Visible = false
                tracerLine.Visible = false ; tracerOutline.Visible = false
            end
        end
    else
        tDot.Visible = false ; tDotOut.Visible = false
        tracerLine.Visible = false ; tracerOutline.Visible = false
    end

    --// ESP
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local e    = ESPObjects[plr]
        if not e   then continue end
        local char = plr.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        local head = char and char:FindFirstChild("Head")

        if not Cfg.visualizer.espEnabled or not hrp or not hum or not head then
            for k, d in pairs(e) do if typeof(d) ~= "number" then pcall(function() d.Visible = false end) end end
            continue
        end

        local rootSP, vis = Camera:WorldToViewportPoint(hrp.Position)
        local headSP      = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))

        if not vis then
            for k, d in pairs(e) do if typeof(d) ~= "number" then pcall(function() d.Visible = false end) end end
            continue
        end

        local dist  = myHRP and math.floor((hrp.Position - myHRP.Position).Magnitude) or 0
        local hDiff = math.abs(rootSP.Y - headSP.Y)
        local w     = hDiff * 0.6
        local bx    = rootSP.X - w/2
        local by    = headSP.Y
        local bh    = hDiff * 1.1
        local isTarget = Cfg.character == char
        local col      = isTarget and Color3.fromRGB(255, 165, 0) or Cfg.visualizer.espColor
        local hp       = hum.Health / math.max(hum.MaxHealth, 1)

        e.box.Size     = Vector2.new(w, bh)  ; e.box.Position    = Vector2.new(bx, by)           ; e.box.Color  = col    ; e.box.Visible = true
        e.boxOut.Size  = Vector2.new(w, bh)  ; e.boxOut.Position = Vector2.new(bx, by)           ;                          e.boxOut.Visible = true
        e.name.Text    = plr.DisplayName     ; e.name.Position   = Vector2.new(rootSP.X, by-16)  ; e.name.Color = col    ; e.name.Visible = true
        e.dist.Text    = dist.."m"           ; e.dist.Position   = Vector2.new(rootSP.X, by+bh+2);                          e.dist.Visible = true

        -- HP bar
        local barW  = 4
        local barX  = bx - 7
        e.hpBg.Size     = Vector2.new(barW, bh)        ; e.hpBg.Position    = Vector2.new(barX, by)              ; e.hpBg.Visible    = true
        e.hpFill.Size   = Vector2.new(barW, bh*hp)     ; e.hpFill.Position  = Vector2.new(barX, by+bh-bh*hp)    ; e.hpFill.Visible  = true
        e.hpFill.Color  = Color3.fromRGB(255*(1-hp), 255*hp, 0)

        -- HP text
        e.healthText.Text     = string.format("%.0f%%", hp * 100)
        e.healthText.Position = Vector2.new(barX, by + bh + 14)
        e.healthText.Color    = e.hpFill.Color
        e.healthText.Visible  = true

        -- Hit notification on HP change
        local prevHP = e._lastHP or hum.Health
        if hum.Health < prevHP then
            local dmg = math.floor(prevHP - hum.Health)
            if dmg > 0 then
                local hitColor = dmg >= 50 and Color3.fromRGB(255,50,50)
                    or dmg >= 20 and Color3.fromRGB(255,165,0)
                    or Color3.fromRGB(235,235,235)
                pushHitNotif(
                    string.format("💥 %s  -%d hp  (%.0f left)", plr.Name, dmg, hum.Health),
                    hitColor
                )
            end
        end
        e._lastHP = hum.Health
    end

    --// Rage Status HUD
    if Cfg.rageStatus.enabled then
        local anchor = center + Vector2.new(Cfg.rageStatus.offsetX, Cfg.rageStatus.offsetY)
        local main, detail, weapon, statusColor = getRageStatusLines()

        hudText1.Text     = main or "ragebot: idle"
        hudText1.Color    = statusColor or Cfg.rageStatus.color
        hudText1.Position = anchor
        hudText1.Visible  = true

        hudText2.Text     = detail or ""
        hudText2.Position = anchor + Vector2.new(0, 16)
        hudText2.Visible  = detail and detail ~= ""

        hudText3.Text     = weapon or ""
        hudText3.Position = anchor + Vector2.new(0, 30)
        hudText3.Visible  = weapon and weapon ~= ""

        -- Phase label
        if Cfg.voidSpam.enabled and Cfg.voidSpam.phase then
            local phase = Cfg.voidSpam.phase
            phaseLabel.Text     = phase == "hide" and "[ VOID HIDING ]" or "[ SHOOTING ]"
            phaseLabel.Color    = phase == "hide" and Color3.fromRGB(255,165,0) or Color3.fromRGB(0,255,100)
            phaseLabel.Position = Vector2.new(center.X, 28)
            phaseLabel.Visible  = true
        else
            phaseLabel.Visible = false
        end
    else
        hudText1.Visible = false
        hudText2.Visible = false
        hudText3.Visible = false
        phaseLabel.Visible = false
    end

    --// Hit notifications
    local now   = tick()
    local toRm  = {}
    for i, n in ipairs(HitNotifs) do
        local el    = now - n.t
        local alpha = 1 - math.clamp((el - (n.dur - 0.5)) / 0.5, 0, 1)
        n.lbl.Transparency = alpha
        n.lbl.Position     = Vector2.new(
            Cfg.hitNotif.offsetX,
            Cfg.hitNotif.offsetY + (i-1) * (Cfg.hitNotif.stackGap or 18)
        )
        if el >= n.dur then table.insert(toRm, i) end
    end
    for i = #toRm, 1, -1 do
        pcall(function() HitNotifs[toRm[i]].lbl:Remove() end)
        table.remove(HitNotifs, toRm[i])
    end
end)

