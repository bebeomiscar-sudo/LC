local bulletTracer={
    enabled=false,color=Color3.fromRGB(255,255,255),
    style="Line",glow=0,size=1,duration=3,fadeTime=0.5,
}
local bulletTracers={}
local lastTracerCreations={}
local DEDUPE_INTERVAL=0.1
local tracerConn=nil

local function round5(v) return math.floor(v*5+0.5) end

local function makeLineTracer(startPos,endPos)
    local outline=Drawing.new("Line")
    outline.Thickness=4*bulletTracer.size; outline.Color=Color3.new(0,0,0)
    outline.Transparency=1; outline.Visible=false
    local line=Drawing.new("Line")
    line.Thickness=2*bulletTracer.size; line.Color=bulletTracer.color
    line.Transparency=1; line.Visible=false
    table.insert(bulletTracers,{
        IsLine=true,Outline=outline,Line=line,
        StartPos=startPos,EndPos=endPos,
        Lifetime=bulletTracer.duration,FadeTime=bulletTracer.fadeTime,
        CreatedTime=tick(),
    })
end

local function makeBeamTracer(startPos,endPos)
    local a0=Instance.new("Attachment"); a0.Parent=ws.Terrain
    local a1=Instance.new("Attachment"); a1.Parent=ws.Terrain
    local beam=Instance.new("Beam")
    beam.Attachment0=a0; beam.Attachment1=a1
    beam.Color=ColorSequence.new(bulletTracer.color)
    local baseW=bulletTracer.style=="Laser" and 0.02 or 0.15
    beam.Width0=baseW*bulletTracer.size; beam.Width1=baseW*bulletTracer.size
    beam.Transparency=NumberSequence.new(0); beam.FaceCamera=true
    beam.LightEmission=math.clamp(bulletTracer.glow,0,1)*0.8; beam.LightInfluence=0.2
    local tex=TRACER_TEXTURES[bulletTracer.style]
    if tex and tex~="" then beam.Texture=tex;beam.TextureLength=4;beam.TextureSpeed=1
    else beam.Texture="";beam.TextureLength=1;beam.TextureSpeed=0 end
    beam.Parent=ws.Terrain
    a0.WorldPosition=startPos; a1.WorldPosition=endPos
    table.insert(bulletTracers,{
        IsLine=false,Beam=beam,Attachment0=a0,Attachment1=a1,
        StartPos=startPos,EndPos=endPos,
        Lifetime=bulletTracer.duration,FadeTime=bulletTracer.fadeTime,
        CreatedTime=tick(),
    })
end

local function makebullettracer(startPos,endPos)
    if not bulletTracer.enabled or not startPos or not endPos then return end
    local kx,ky,kz=round5(startPos.X),round5(startPos.Y),round5(startPos.Z)
    local ex,ey,ez=round5(endPos.X),round5(endPos.Y),round5(endPos.Z)
    local posKey=kx*1e9+ky*1e6+kz*1e3+ex+ey*1e-3+ez*1e-6
    local now=tick()
    if lastTracerCreations[posKey] and (now-lastTracerCreations[posKey])<DEDUPE_INTERVAL then return end
    lastTracerCreations[posKey]=now
    if bulletTracer.style=="Line" then makeLineTracer(startPos,endPos)
    else makeBeamTracer(startPos,endPos) end
end
getgenv().makebullettracer = makebullettracer

local function updateTracers()
    if #bulletTracers==0 then return end
    local now=tick()
    for i=#bulletTracers,1,-1 do
        local tr=bulletTracers[i]; local age=now-tr.CreatedTime
        if age>=tr.Lifetime then
            if tr.IsLine then tr.Outline:Remove();tr.Line:Remove()
            else tr.Beam:Destroy();tr.Attachment0:Destroy();tr.Attachment1:Destroy() end
            table.remove(bulletTracers,i); continue
        end
        local fadeStart=tr.Lifetime-tr.FadeTime
        local alpha=age>=fadeStart and 1-math.clamp((age-fadeStart)/tr.FadeTime,0,1) or 1
        if tr.IsLine then
            local sp,son=worldToScreen(tr.StartPos); local ep,eon=worldToScreen(tr.EndPos)
            if son and eon then
                local len=(ep-sp).Magnitude
                if len>0.1 and len<3000 then
                    tr.Outline.From=sp;tr.Outline.To=ep;tr.Outline.Transparency=alpha;tr.Outline.Visible=true
                    tr.Line.From=sp;tr.Line.To=ep;tr.Line.Transparency=alpha;tr.Line.Visible=true
                else tr.Outline.Visible=false;tr.Line.Visible=false end
            else tr.Outline.Visible=false;tr.Line.Visible=false end
        else
            if tr.Attachment0 then tr.Attachment0.WorldPosition=tr.StartPos end
            if tr.Attachment1 then tr.Attachment1.WorldPosition=tr.EndPos   end
            tr.Beam.Transparency=NumberSequence.new(1-alpha)
            if bulletTracer.glow>0 then tr.Beam.LightEmission=bulletTracer.glow*alpha end
        end
    end
end

local function startTracers()
    if tracerConn then return end
    tracerConn=trackConn(RunService.RenderStepped:Connect(function()
        if not bulletTracer.enabled then
            for _,tr in ipairs(bulletTracers) do
                if tr.IsLine then tr.Outline:Remove();tr.Line:Remove()
                else tr.Beam:Destroy();tr.Attachment0:Destroy();tr.Attachment1:Destroy() end
            end
            bulletTracers={}; return
        end
        updateTracers()
    end))
end

local function stopTracers()
    if tracerConn then tracerConn:Disconnect();tracerConn=nil end
    for _,tr in ipairs(bulletTracers) do
        if tr.IsLine then tr.Outline:Remove();tr.Line:Remove()
        else tr.Beam:Destroy();tr.Attachment0:Destroy();tr.Attachment1:Destroy() end
    end
    bulletTracers={}; lastTracerCreations={}
end

