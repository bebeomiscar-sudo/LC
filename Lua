-- ── Aimbot Core ────────────────────────────────────────────────

local function clearAimbotLock()
    aimbot.lockedTarget = nil
    aimbot.smoothCF     = nil
end

local function getAimbotCenter()
    if aimbot.followMuzzle and type(aimbotfovcenter) == "function" then
        return aimbotfovcenter()
    end
    local loc = UserInputService:GetMouseLocation()
    return Vector2.new(loc.X, loc.Y)
end

local function w2s(pos, cam)
    cam = cam or Workspace.CurrentCamera
    local sp, vis = cam:WorldToViewportPoint(pos)
    return Vector2.new(sp.X, sp.Y), vis
end

local function getNearestToCursor()
    local center   = getAimbotCenter()
    local best     = nil
    local bestDist = aimbot.fovRadius
    local cam      = Workspace.CurrentCamera
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local part = p.Character:FindFirstChild(aimbot.targetPart)
            if part and part:IsDescendantOf(Workspace) then
                local sp, on = w2s(part.Position, cam)
                if on then
                    local dist = (sp - center).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        best     = part
                    end
                end
            end
        end
    end
    return best
end

local function getAimbotAlpha(dt)
    local sm    = math.clamp(aimbot.smoothness, 0.1, 10)
    local curve = aimbot.aimCurve
    local speed = 6 / sm
    local t     = math.clamp(speed * dt, 0, 1)
    if curve == "Instant"   then return 1
    elseif curve == "Expo"  then return 1 - math.exp(-(4/sm)*dt)
    elseif curve == "EaseIn" then return t*t
    elseif curve == "EaseOut" then return 1-(1-t)^2
    elseif curve == "EaseInOut" then
        if t < 0.5 then return 2*t*t end
        return 1-((-2*t+2)^2)/2
    elseif curve == "Cubic" then return t^3
    end
    return t -- Linear
end

local camController
pcall(function()
    camController = require(
        LocalPlayer.PlayerScripts.Controllers.CameraController
    )
end)

local AIMBOT_BIND   = "InstanceAimbotUpdate"
local aimbotConn    = nil
local aimbotIsBound = false

local function stepAimbot(dt)
    dt = dt or (1/240)
    if not aimbot.enabled then clearAimbotLock() return end

    local cam = Workspace.CurrentCamera
    if not cam then return end
    Camera = cam

    if not aimbot.lockedTarget then
        aimbot.lockedTarget = getNearestToCursor()
        aimbot.smoothCF     = cam.CFrame
        if not aimbot.lockedTarget then return end
    end

    if not aimbot.lockedTarget.Parent
        or not aimbot.lockedTarget:IsDescendantOf(Workspace) then
        clearAimbotLock() return
    end

    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("Head") then
        clearAimbotLock() return
    end
    if not camController then return end

    aimbot.smoothCF = aimbot.smoothCF or cam.CFrame

    local lookCF    = CFrame.lookAt(cam.CFrame.Position, aimbot.lockedTarget.Position)
    aimbot.smoothCF = aimbot.smoothCF:Lerp(lookCF, getAimbotAlpha(dt))

    pcall(function() camController:MimicRotation(aimbot.smoothCF) end)
end

local function updateAimbot()
    -- Cleanup old connection
    if aimbotConn then
        aimbotConn:Disconnect()
        aimbotConn = nil
    end
    if aimbotIsBound then
        pcall(function() RunService:UnbindFromRenderStep(AIMBOT_BIND) end)
        aimbotIsBound = false
    end

    fovContainer.Visible = aimbot.showFov

    if not aimbot.enabled then
        clearAimbotLock()
        return
    end

    local ok = pcall(function()
        RunService:UnbindFromRenderStep(AIMBOT_BIND)
        RunService:BindToRenderStep(
            AIMBOT_BIND,
            Enum.RenderPriority.Camera.Value + 1,
            stepAimbot
        )
    end)
    if ok then
        aimbotIsBound = true
    else
        aimbotConn = RunService.RenderStepped:Connect(stepAimbot)
    end
end

-- ── Hold / Always polling ──────────────────────────────────────

RunService.RenderStepped:Connect(function()
    if aimbot.keyMode == "always" then
        local want = aimbot.masterEnabled
        if aimbot.enabled ~= want then
            aimbot.enabled = want
            if not want then clearAimbotLock() end
            updateAimbot()
        end
        return
    end

    if aimbot.keyMode == "hold" and aimbot.masterEnabled then
        local opts   = getgenv().Options or {}
        local picker = opts.AimbotKey
        if not picker then return end
        local held = picker:GetState()
        if held ~= aimbot.enabled then
            aimbot.enabled = held
            if not held then clearAimbotLock() end
            updateAimbot()
        end
    end
end)

