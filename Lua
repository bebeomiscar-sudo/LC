    -- ── Weapon Helpers ───────────────────────────────────────────

    local RSLOTS    = {primary=1,secondary=2,melee=3}
    local MELEE_NMS = {["Battle Axe"]=true,["Chainsaw"]=true,["Daggers"]=true,["Fists"]=true,["Gunblade"]=true,["Katana"]=true,["Knife"]=true,["Scythe"]=true,["Trowel"]=true}
    local INF_AMMO  = {["Energy Rifle"]=true,["Energy Pistols"]=true}

    local function rGetWeapon()
        local lf=rageModules.fighter and rageModules.fighter.LocalFighter
        if not lf or not lf.EquippedItem then return nil end
        local ok,nm=pcall(function() return lf.EquippedItem:Get("Name") end)
        return ok and nm or nil
    end

    local function rIsInfinite()
        local w=rGetWeapon();return w and INF_AMMO[w]==true or false
    end

    local function rWantSlot() return RSLOTS[rConfig.target.weaponPick or "primary"] or 1 end
    local function rPickMelee() return (rConfig.target.weaponPick or "primary")=="melee" end
    local function rIsSling(w) return w and w:lower():find("slingshot",1,true)~=nil end

    local function rGetAmmo()
        if rIsInfinite() then return nil,nil,false end
        local lf=rageModules.fighter and rageModules.fighter.LocalFighter
        if not lf or not lf.EquippedItem then return 0,0,rPickMelee() end
        local itemName,current,maxAmmo,isMelee="",0,0,false
        pcall(function()
            itemName=tostring(lf.EquippedItem:Get("Name") or "")
            current=lf.EquippedItem:Get("CurrentAmmo") or lf.EquippedItem:Get("Ammo") or 0
            maxAmmo=lf.EquippedItem:Get("MaxAmmo") or current
            if MELEE_NMS[itemName] then isMelee=true end
        end)
        if rPickMelee() then isMelee=true end
        return tonumber(current) or 0,tonumber(maxAmmo) or 0,isMelee
    end

    local function rlfItems()
        local lf=rageModules.fighter and rageModules.fighter.LocalFighter
        if not lf then return nil end;return lf.Items
    end

    local function rSlotItem(slotIdx)
        local items=rlfItems();if not items then return nil end
        if items[slotIdx] then return items[slotIdx] end
        for key,it in pairs(items) do
            if it and typeof(it)=="table" then
                local s=tonumber(it:Get("Slot") or it:Get("Index") or key)
                if s==slotIdx then return it end
            end
        end
        return nil
    end

    local rLastSlotForce=0
    local function rEqSlot()
        if not rConfig.target.rageMasterOn then return end
        local want=rWantSlot()
        local lf=rageModules.fighter and rageModules.fighter.LocalFighter
        if not lf then return end
        local now=tick();if now-rLastSlotForce<0.06 then return end
        rLastSlotForce=now
        local item=rSlotItem(want)
        local oid=item and item:Get("ObjectID")
        if oid then
            -- ✅ FIX: Use safeToEnum for equip events
            local rm=ReplicatedStorage.Remotes.Replication.Fighter.UseItem
            for _,en in ipairs({"Equip","Switch","Select","EquipItem"}) do
                pcall(function()
                    local ev=safeToEnum(rageModules.enums,en)
                    if ev then rm:FireServer(oid,ev,nil,nil) end
                end)
            end
        end
        pcall(function()
            if lf.EquipItem then lf:EquipItem(want) end
            if lf.SwitchToSlot then lf:SwitchToSlot(want) end
        end)
    end

    -- ── Void / Snap ───────────────────────────────────────────────

    local vfrLim,vfrDead=2147483646,1147483646
    local vfrSnap={cf=nil,lv=nil,av=nil}

    local function clrVoidSnap() vfrSnap.cf,vfrSnap.lv,vfrSnap.av=nil,nil,nil end
    local function rVoidHrp()
        local char=lp.Character;return char and char:FindFirstChild("HumanoidRootPart")
    end
    local function rndSkip(mi,ma,dmi,dma)
        local val=math.random(mi,ma)
        while val>=dmi and val<=dma do val=math.random(mi,ma) end
        return val
    end
    local function snapVoid(hrp)
        if not hrp then return end
        if lobbyCache() then return end
        vfrSnap.cf=hrp.CFrame;vfrSnap.lv=hrp.AssemblyLinearVelocity;vfrSnap.av=hrp.AssemblyAngularVelocity
        pcall(function()
            local p=Vector3.new(
                rndSkip(-vfrLim,vfrLim,-vfrDead,vfrDead),
                rndSkip(-vfrLim,vfrLim,-vfrDead,vfrDead),
                rndSkip(-vfrLim,vfrLim,-vfrDead,vfrDead)
            )
            hrp.CFrame=CFrame.new(p)*CFrame.Angles(math.pi,math.pi,math.pi)
            hrp.AssemblyLinearVelocity=p;hrp.AssemblyAngularVelocity=p
        end)
    end

    RunService:BindToRenderStep("vfr_csync",Enum.RenderPriority.First.Value,function()
        if not vfrSnap.cf then return end
        local hrp=rVoidHrp();if not hrp then return end
        pcall(function()
            hrp.CFrame=vfrSnap.cf
            hrp.AssemblyLinearVelocity=vfrSnap.lv
            hrp.AssemblyAngularVelocity=vfrSnap.av
        end)
    end)

    -- ── Prediction ────────────────────────────────────────────────

    local function rUpdateVel()
        if not rConfig.target.character or not rConfig.prediction.enabled then
            rConfig.prediction.velocity=Vector3.new(0,0,0);return
        end
        local root=rConfig.target.character:FindFirstChild("HumanoidRootPart");if not root then return end
        local now=tick();local dt=now-rConfig.prediction.lasttime
        if dt>0 and dt<0.1 then
            local currentpos=root.Position
            if rConfig.prediction.lastposition then
                local instantvel=(currentpos-rConfig.prediction.lastposition)/dt
                rConfig.prediction.velocity=rConfig.prediction.velocity:Lerp(instantvel,0.6)
            end
            rConfig.prediction.lastposition=root.Position;rConfig.prediction.lasttime=now
        end
    end

    local function rPredict(targetpart,origin)
        if not rConfig.prediction.enabled or not targetpart then
            return targetpart and targetpart.Position or Vector3.new()
        end
        local basepos=targetpart.Position
        local distance=(basepos-origin).Magnitude
        local ping=0
        pcall(function()
            ping=Stats.Network.ServerStatsItem["Data Ping"]:GetValue()/1000
        end)
        local traveltime=distance/3000
        local totaltime=(traveltime+ping)*rConfig.prediction.multiplier
        return basepos+(rConfig.prediction.velocity*totaltime)
    end

    -- ── Target Valid / Find ───────────────────────────────────────

    local function rIsteammate(targetplayer)
        if not targetplayer then return false end
        return lp:GetAttribute("TeamID")==targetplayer:GetAttribute("TeamID")
    end

    local function rValid(char)
        if not char or not char.Parent then return false end
        local humanoid=char:FindFirstChildOfClass("Humanoid")
        if not humanoid or humanoid.Health<=0 then return false end
        if not char:FindFirstChild("HumanoidRootPart") then return false end
        local targetplayer=Players:GetPlayerFromCharacter(char)
        if not targetplayer or rIsteammate(targetplayer) then return false end
        return true
    end

    local function rNearest()
        local cursorpos=UserInputService:GetMouseLocation()
        local besttarget,bestdistance=nil,math.huge
        for _,targetplayer in Players:GetPlayers() do
            if targetplayer~=lp and targetplayer.Character then
                local char=targetplayer.Character
                if rValid(char) then
                    local root=char:FindFirstChild("HumanoidRootPart")
                    if root then
                        local sp,on=cam:WorldToViewportPoint(root.Position)
                        if on then
                            local distance=(Vector2.new(sp.X,sp.Y)-cursorpos).Magnitude
                            if distance<bestdistance then besttarget=char;bestdistance=distance end
                        end
                    end
                end
            end
        end
        return besttarget
    end

    local function rHitpartFromName(character,partname)
        if not character then return nil end
        if partname=="Closest" then
            local mypos=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not mypos then return character:FindFirstChild("Head") end
            local closest,dist=nil,math.huge
            for _,part in pairs(character:GetChildren()) do
                if part:IsA("BasePart") then
                    local d=(part.Position-mypos.Position).Magnitude
                    if d<dist then dist=d;closest=part end
                end
            end
            return closest or character:FindFirstChild("Head")
        elseif partname=="Random" then
            local parts={"Head","HumanoidRootPart","UpperTorso"}
            return character:FindFirstChild(parts[math.random(#parts)]) or character:FindFirstChild("Head")
        else
            return character:FindFirstChild(partname) or character:FindFirstChild("Head")
        end
    end

    -- ── Orbit / Sync ──────────────────────────────────────────────

    local function rAtkCfg()
        if rPickMelee() and not rConfig.target.attackCustomEnabled then
            return {height=0,front=0,side=0,vertical=-(rConfig.target.meleeFeetDrop or 3.5),radius=0}
        end
        if rConfig.target.attackCustomEnabled then
            return {
                height=rConfig.target.customHeight or 2,front=rConfig.target.customFront or 0,
                side=rConfig.target.customSide or 0,vertical=rConfig.target.customVertical or 0,
                radius=rConfig.target.customRadius or 0,
            }
        end
        local mode=rConfig.target.attackPosition or "default"
        local weapon=rGetWeapon()
        if mode=="under" then
            return {height=0,front=0,side=0,vertical=-(rConfig.target.underOffset or 4),radius=0}
        end
        return {height=(weapon and weapon:lower():find("sniper")) and 8 or 2,front=0,side=0,vertical=0,radius=0}
    end

    local function rOrbBase(root)
        if not root then return Vector3.zero end
        local settings=rAtkCfg()
        return root.Position
            +(root.CFrame.LookVector*settings.front)
            +(root.CFrame.RightVector*settings.side)
            +Vector3.new(0,settings.vertical,0)
    end

    local function randVs(a,b)
        a=math.clamp(a,0.1,2);b=math.clamp(b,0.1,2)
        if b<a then a,b=b,a end
        return a==b and a or a+math.random()*(b-a)
    end

    local function rVoidSpamTick()
        if not rConfig.voidspam.enabled then return end
        local now=tick();local elapsed=now-rConfig.voidspam.lastswitch
        if rConfig.voidspam.phase=="shoot" then
            if elapsed>=rConfig.voidspam.currentduration then
                rConfig.voidspam.phase="hide"
                rConfig.voidspam.currentduration=randVs(rConfig.voidspam.hide_min,rConfig.voidspam.hide_max)
                rConfig.voidspam.lastswitch=now
            end
        elseif rConfig.voidspam.phase=="hide" then
            if elapsed>=rConfig.voidspam.currentduration then
                rConfig.voidspam.phase="shoot"
                rConfig.voidspam.currentduration=randVs(rConfig.voidspam.shoot_min,rConfig.voidspam.shoot_max)
                rConfig.voidspam.lastswitch=now
            end
        else
            rConfig.voidspam.phase="shoot"
            rConfig.voidspam.currentduration=randVs(rConfig.voidspam.shoot_min,rConfig.voidspam.shoot_max)
            rConfig.voidspam.lastswitch=now
        end
    end

    local function rIsHiding() return rConfig.voidspam.enabled and rConfig.voidspam.phase=="hide" end

    local function rStopSync()
        if not rConfig.state.csyncactive then return end
        if rConfig.orbit.connection then rConfig.orbit.connection:Disconnect();rConfig.orbit.connection=nil end
        rConfig.state.csyncactive=false;rConfig.orbit.active=false;clrVoidSnap()
        rConfig.voidspam.phase=nil
        if rConfig.orbit.savedpos and rlocalfighter and rlocalfighter.Entity and rlocalfighter.Entity.RootPart then
            pcall(function() rlocalfighter.Entity.RootPart.CFrame=rConfig.orbit.savedpos end)
        end
        rConfig.orbit.serverpos=nil;rConfig.orbit.savedpos=nil;rOldPos=nil
    end

    local function rStartSync()
        if rConfig.state.csyncactive then return end
        if rConfig.target.immune then return end
        if not rConfig.target.character or not rValid(rConfig.target.character) then return end
        rEqSlot();rConfig.state.csyncactive=true;rConfig.orbit.active=true
        local settings=rAtkCfg()
        rConfig.orbit.height=settings.height;rConfig.orbit.radius=settings.radius or 0
        if not rConfig.orbit.savedpos then
            if rlocalfighter and rlocalfighter.Entity and rlocalfighter.Entity.RootPart then
                rConfig.orbit.savedpos=rlocalfighter.Entity.RootPart.CFrame
            end
        end
        rConfig.orbit.connection=trackConn(RunService.Heartbeat:Connect(function(dt)
            if not rConfig.state.csyncactive then return end
            if rConfig.target.immune then rStopSync();return end
            if not rConfig.target.character or not rValid(rConfig.target.character) then rStopSync();return end
            if not rlocalfighter or not rlocalfighter.Entity or not rlocalfighter.Entity.RootPart then rStopSync();return end
            rOldPos=rlocalfighter.Entity.RootPart.CFrame
            local _weapon=rGetWeapon();local checksling=rIsSling(_weapon)
            rEqSlot()
            if not checksling and rConfig.voidspam.enabled and not rConfig.target.immune then
                rVoidSpamTick()
                if rConfig.voidspam.phase=="hide" then
                    local rx=math.random(-10000,10000);local rz=math.random(-10000,10000)
                    rConfig.orbit.serverpos=Vector3.new(rx,-99999999999,rz)
                    pcall(function() rlocalfighter.Entity.RootPart.CFrame=CFrame.new(rConfig.orbit.serverpos) end)
                    return
                end
            end
            if not rConfig.target.character then rStopSync();return end
            local root=rConfig.target.character:FindFirstChild("HumanoidRootPart")
            if not root then rStopSync();return end
            if not checksling and rIsHiding() then
                local rx=math.random(-10000,10000);local rz=math.random(-10000,10000)
                rConfig.orbit.serverpos=Vector3.new(rx,-99999999999,rz)
                pcall(function() rlocalfighter.Entity.RootPart.CFrame=CFrame.new(rConfig.orbit.serverpos) end)
                return
            end
            local targetpos=rOrbBase(root)
            rConfig.orbit.angle=rConfig.orbit.angle+(rConfig.orbit.speed*dt)
            local offset=Vector3.new(
                math.cos(rConfig.orbit.angle)*rConfig.orbit.radius,
                rConfig.orbit.height,
                math.sin(rConfig.orbit.angle)*rConfig.orbit.radius
            )
            rConfig.orbit.serverpos=targetpos+offset
            pcall(function()
                local currentPos=rlocalfighter.Entity.RootPart.CFrame
                local newPos=CFrame.new(rConfig.orbit.serverpos)
                if (newPos.Position-currentPos.Position).Magnitude<2000 then
                    rlocalfighter.Entity.RootPart.CFrame=newPos
                    rConfig.orbit.savedpos=currentPos
                end
            end)
        end))
    end

    -- ── Ammo Tick ─────────────────────────────────────────────────

    local function rTickAmmo()
        if rIsInfinite() then rConfig.state.outofammo=false;rConfig.state.reloading=false;return end
        local current,_,melee=rGetAmmo()
        if melee then rConfig.state.outofammo=false
        else rConfig.state.outofammo=(tonumber(current) or 0)<=0 end
        local reloading=false
        local lf=rageModules.fighter and rageModules.fighter.LocalFighter
        if lf and lf.EquippedItem then
            pcall(function()
                for _,key in ipairs({"Reloading","IsReloading","IsReload"}) do
                    local v=lf.EquippedItem:Get(key)
                    if v==true or v==1 then reloading=true;return end
                end
            end)
        end
        if reloading and not rConfig.state.reloading then rConfig.state.reloadStartedAt=tick()
        elseif not reloading then rConfig.state.reloadStartedAt=0 end
        rConfig.state.reloading=reloading
    end

    local function rCanUse()
        local char=lp.Character;if not char then return false end
        local hum=char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health<=0 then return false end
        if rIsInfinite() then return true end
        local current,_,melee=rGetAmmo()
        if current==nil then return true end
        return current>0 or melee
    end

    -- ── Auto Shoot — FULLY NIL GUARDED ───────────────────────────

    local function rAutoShoot()
        -- Guard: hiding phase
        if rIsHiding() and not rIsSling(rGetWeapon()) then return end
        if not rConfig.target.enabled or not rConfig.target.character or not rConfig.target.autoshoot then return end
        if rConfig.target.immune then return end

        -- ✅ Guard: modules must exist
        if not rageModules.utility then
            warn("[rAutoShoot] utility module nil — skipping shot")
            return
        end
        if not rageModules.enums then
            warn("[rAutoShoot] enums module nil — skipping shot")
            return
        end

        local lf=rageModules.fighter and rageModules.fighter.LocalFighter
        if not lf or not lf.EquippedItem then return end

        if not rIsInfinite() then
            if rConfig.state.reloading or rConfig.state.outofammo then return end
            if not rCanUse() then return end
        end

        local targetChar=rConfig.target.character
        if not rValid(targetChar) then return end

        local hitPart=rHitpartFromName(targetChar,rConfig.target.hitpart)
        if not hitPart or not hitPart.Parent then return end

        -- Build shoot position
        local shootPos
        local myRoot=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if rConfig.state.csyncactive and rConfig.orbit.serverpos then
            shootPos=rConfig.orbit.serverpos
        else
            shootPos=myRoot and myRoot.Position or Vector3.new()
        end

        local targetPos=rPredict(hitPart,shootPos)

        -- ✅ FIX: Use buildShotData — full nil guard
        local data=buildShotData(rageModules.utility,shootPos,targetPos,hitPart)
        if not data then
            warn("[rAutoShoot] buildShotData returned nil — skipping shot")
            return
        end

        local equipped=lf.EquippedItem
        local objectId=nil
        pcall(function() objectId=equipped:Get("ObjectID") end)

        if not objectId then
            warn("[rAutoShoot] ObjectID is nil — skipping shot")
            return
        end

        -- ✅ FIX: Use safeFireShot — full nil guard
        local UseItem=ReplicatedStorage.Remotes.Replication.Fighter.UseItem
        local attempts=math.clamp(math.floor(rConfig.target.shootAttempts or 1),1,3)
        for _=1,attempts do
            safeFireShot(UseItem,rageModules.enums,objectId,data)
        end
    end

    -- ── Camera Hook ───────────────────────────────────────────────

    if rageModules.camcontrol and rageModules.camcontrol.Update then
        local oldcamupdate=rageModules.camcontrol.Update
        rageModules.camcontrol.Update=function(...)
            if rConfig.state.csyncactive
                and rlocalfighter
                and rlocalfighter.Entity
                and rlocalfighter.Entity.RootPart
                and rOldPos
            then
                pcall(function() rlocalfighter.Entity.RootPart.CFrame=rOldPos end)
            end
            return oldcamupdate(...)
        end
    end

    -- ── Immune System ─────────────────────────────────────────────

    local immuneList={}
    trackConn(RunService.Heartbeat:Connect(function()
        for _,plr in pairs(Players:GetPlayers()) do
            if plr==lp then continue end
            local char=plr.Character
            local root=char and char:FindFirstChild("HumanoidRootPart")
            local immune=root and root:FindFirstChild("Attachment")~=nil
            if immune and not immuneList[plr.Name] then
                immuneList[plr.Name]=true
                if rConfig.target.lastplayer==plr then
                    rConfig.target.immune=true;clrVoidSnap();rStopSync()
                end
            elseif not immune and immuneList[plr.Name] then
                immuneList[plr.Name]=nil
                if rConfig.target.lastplayer==plr then
                    rConfig.target.immune=false
                    if rConfig.target.enabled
                        and rConfig.target.character
                        and rValid(rConfig.target.character)
                    then rStartSync() end
                end
            end
        end
    end))

    -- ── Target Management ─────────────────────────────────────────

    local function rClearTarget()
        rConfig.target.enabled=false;rStopSync()
        rConfig.target.character=nil;rConfig.target.lastchar=nil
        rConfig.target.lastplayer=nil;rConfig.target.immune=false
    end

    local function rSetTarget(char)
        if not char then return end
        local targetplr=Players:GetPlayerFromCharacter(char)
        rConfig.target.enabled=true;rConfig.target.character=char
        rConfig.target.lastchar=char;rConfig.target.lastplayer=targetplr
        rConfig.target.immune=false
        local root=char:FindFirstChild("HumanoidRootPart")
        if root and root:FindFirstChild("Attachment") then
            rConfig.target.immune=true
        else
            rEqSlot();rStartSync()
        end
    end

    -- ── Main Heartbeat ────────────────────────────────────────────

    trackConn(RunService.Heartbeat:Connect(function()
        -- ✅ Always tick ammo safely
        pcall(rTickAmmo)

        if rConfig.target.auto and not rConfig.target.manualkey then
            local current,_,melee=rGetAmmo()
            local hasammo=current==nil or current>0 or melee
            if hasammo and not rConfig.state.reloading then
                if not rConfig.target.enabled
                    or not rConfig.target.character
                    or not rValid(rConfig.target.character)
                then
                    local newtarget=rNearest()
                    if newtarget then
                        if rConfig.target.enabled then rStopSync() end
                        rSetTarget(newtarget)
                    end
                end
            end
        end

        if rConfig.target.enabled and rConfig.target.character then
            if not rValid(rConfig.target.character) then rClearTarget();return end
            rEqSlot()
            if rConfig.target.autoshoot and not rConfig.target.immune then
                -- ✅ Wrapped in pcall so one shot failure doesnt break loop
                pcall(rAutoShoot)
            end
            if rConfig.prediction.enabled then pcall(rUpdateVel) end
        end
    end))

