-- Player ESP
local function makeEspObj(p)
    return {
        player = p,
        box = Drawing.new("Square"),
        boxFill = Drawing.new("Square"),
        name = Drawing.new("Text"),
        health = Drawing.new("Square"),
        healthFg = Drawing.new("Square"),
        tracer = Drawing.new("Line"),
    }
end

local function updateEsp()
    if not espCfg.enabled then
        for _, obj in pairs(espObjects) do
            for _, d in pairs(obj) do if typeof(d) == "table" and d.Visible ~= nil then d.Visible = false end end
        end
        return
    end
    for _, p in pairs(Players:GetPlayers()) do
        if p == lp or not isValidTarget(p) then continue end
        if not espObjects[p] then espObjects[p] = makeEspObj(p) end
        local obj = espObjects[p]
        local char = p.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then
            for _, d in pairs(obj) do if typeof(d) == "table" and d.Visible ~= nil then d.Visible = false end end
            continue
        end
        local sp, on = cam:WorldToViewportPoint(hrp.Position)
        if not on then
            for _, d in pairs(obj) do if typeof(d) == "table" and d.Visible ~= nil then d.Visible = false end end
            continue
        end
        local head = char:FindFirstChild("Head")
        local headSP, headOn = head and cam:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
        local footSP, footOn = cam:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
        if not headOn or not footOn then continue end
        local h = math.abs(headSP.Y - footSP.Y)
        local w = h * 0.5
        local cx = sp.X
        local cy = (headSP.Y + footSP.Y) / 2
        local bx = cx - w / 2
        local by = headSP.Y

        if espCfg.box then
            obj.box.Visible = true
            obj.box.Color = espCfg.boxColor
            obj.box.Position = Vector2.new(bx, by)
            obj.box.Size = Vector2.new(w, h)
        else obj.box.Visible = false end

        if espCfg.name then
            obj.name.Visible = true
            obj.name.Text = p.Name
            obj.name.Color = espCfg.nameColor
            obj.name.Size = espCfg.nameSize
            obj.name.Position = Vector2.new(cx, by - espCfg.nameSize - 2)
        else obj.name.Visible = false end

        if espCfg.health then
            local hp = hum.Health / math.max(hum.MaxHealth, 1)
            obj.health.Visible = true
            obj.health.Position = Vector2.new(bx - 5, by)
            obj.health.Size = Vector2.new(3, h)
            obj.health.Color = Color3.fromRGB(30, 30, 30)
            obj.healthFg.Visible = true
            obj.healthFg.Position = Vector2.new(bx - 5, by + h * (1 - hp))
            obj.healthFg.Size = Vector2.new(3, h * hp)
            obj.healthFg.Color = Color3.fromRGB(math.floor((1 - hp) * 255), math.floor(hp * 255), 0)
        else obj.health.Visible = false; obj.healthFg.Visible = false end

        if espCfg.tracer then
            obj.tracer.Visible = true
            obj.tracer.Color = espCfg.tracerColor
            obj.tracer.From = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y)
            obj.tracer.To = Vector2.new(sp.X, sp.Y)
        else obj.tracer.Visible = false end
    end
end

