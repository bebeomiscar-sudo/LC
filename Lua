local ESPCfg = {
    Enabled      = false,
    TeamCheck    = true,
    ShowBox      = true,
    ShowName     = true,
    ShowHealth   = true,
    ShowDist     = true,
    BoxColor     = Color3.fromRGB(255, 80, 80),
