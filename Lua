local function getHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function clearVFR()
    VFR.cf = nil
    VFR.lv = nil
    VFR.av = nil
end

local function randSkip(mi, ma, dmi, dma)
    local v = math.random(mi, ma)
    while v >= dmi and v <= dma do v = math.random(mi, ma) end
    return v
end

local function snapVoid(hrp)
    if not hrp then return end
    if isInLobby() then return end
    VFR.cf = hrp.CFrame
    VFR.lv = hrp.AssemblyLinearVelocity
    VFR.av = hrp.AssemblyAngularVelocity
    pcall(function()
        local p = Vector3.new(
            randSkip(-LIM, LIM, -DEAD, DEAD),
            randSkip(-LIM, LIM, -DEAD, DEAD),
            randSkip(-LIM, LIM, -DEAD, DEAD)
        )
        hrp.CFrame = CFrame.new(p) * CFrame.Angles(math.pi, math.pi, math.pi)
        hrp.AssemblyLinearVelocity  = p
        hrp.AssemblyAngularVelocity = p
    end)
end

-- VFR restore: runs every render frame to keep position while voided
RunService:BindToRenderStep("rb_vfr_restore", Enum.RenderPriority.First.Value, function()
    if not VFR.cf then return end
    local hrp = getHRP()
    if not hrp then return end
    pcall(function()
        hrp.CFrame = VFR.cf
        hrp.AssemblyLinearVelocity  = VFR.lv
        hrp.AssemblyAngularVelocity = VFR.av
    end)
end)

