local function rsAnchor() return (cam.ViewportSize/2) + Vector2.new(rsStatusCfg.x, rsStatusCfg.y) end
local function rsStateColor()
    if ragePerf.state == "hiding" then return Color3.fromRGB(255,200,0)
    elseif ragePerf.state == "attacking" then return Color3.fromRGB(255,50,50)
    else return rsStatusCfg.color end
end

local function rsStateText()
    if not rageCfg.enabled and not rageCfg.onPlayerEnabled then return "ragebot: off", "" end
    if ragePerf.state == "hiding" then return "ragebot: hiding", "teleporting to void"
    elseif ragePerf.state == "attacking" then
        local name = ragePerf.targetName ~= "" and ragePerf.targetName or "target"
        return "ragebot: attacking ("..name..")", ragePerf.targetHP.." hp"
    else
        if ragePerf.targetName ~= "" then return "ragebot: ready", ragePerf.targetName.." — "..ragePerf.targetHP.." hp" end
        return "ragebot: idle", "no target"
    end
end

local function drawRageStatus()
    if not rsStatusCfg.enabled then rsLine1.Visible, rsLine2.Visible = false, false return end
    local anchor = rsAnchor()
    local col = rsStateColor()
    local line1, line2 = rsStateText()
    rsLine1.Color, rsLine1.Text, rsLine1.Position, rsLine1.Visible = col, line1, anchor, true
    if line2 ~= "" then
        rsLine2.Color, rsLine2.Text, rsLine2.Position, rsLine2.Visible = rsStatusCfg.color, line2, anchor + Vector2.new(0, rsStatusCfg.gap), true
    else rsLine2.Visible = false end
end

