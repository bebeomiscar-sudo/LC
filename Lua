local TracerCfg = {
    Enabled      = false,
    Style        = "Line",
    Color        = Color3.fromRGB(255, 255, 255),
    Duration     = 3,
    Size         = 1,
    FadeTime     = 0.5,
    LerpSpeed    = 0,
    OutlineOn    = true,
    OutlineColor = Color3.fromRGB(0, 0, 0),
}

local tracers             = {}
local tracerConn          = nil
local tracerEffectHooked  = false
local _tracerGunHooked    = false
local _tracerGunOldFunc   = nil
local lastTracerCreations = {}
local tracerFrameCount    = 0
local DEDUPE_INTERVAL     = 0.1
local DEDUPE_EXPIRY       = 1.0
local DEDUPE_PRUNE_INT    = 120

local function GetMuzzlePosition()
    local viewModels = Workspace:FindFirstChild("ViewModels")
    if not viewModels then return nil end
    local firstPerson = viewModels:FindFirstChild("FirstPerson")
    if not firstPerson then return nil end
    for _, model in ipairs(firstPerson:GetChildren()) do
        if model:IsA("Model") and model.Name:find("^" .. lp.Name) then
            local iv = model:FindFirstChild("ItemVisual")
            if iv then
                local body = iv:FindFirstChild("Body")
                if body then
                    local bp = body:FindFirstChild("BodyPrimary")
                    if bp then
                        local muzzle = bp:FindFirstChild("_muzzle")
                        if muzzle and muzzle:IsA("Attachment") then
                            return muzzle.WorldPosition
                        end
                    end
                end
            end
        end
    end
    return nil
end

local function GetTracerDrawEnd(tr, age)
    if TracerCfg.LerpSpeed <= 0 then return tr.EndPos end
    local drawTime = math.max(TracerCfg.LerpSpeed * 0.25, 0.001)
    local progress = math.clamp(age / drawTime, 0, 1)
    return tr.StartPos:Lerp(tr.EndPos, progress)
end

local function MakeLineTracer(startPos, endPos)
    local outline = Drawing.new("Line")
    outline.Thickness    = 4 * TracerCfg.Size
    outline.Color        = TracerCfg.OutlineColor
    outline.Transparency = 1
    outline.Visible      = false

    local line = Drawing.new("Line")
    line.Thickness    = 2 * TracerCfg.Size
    line.Color        = TracerCfg.Color
    line.Transparency = 1
    line.Visible      = false

    table.insert(tracers, {
        IsLine      = true,
        Outline     = outline,
        Line        = line,
        StartPos    = startPos,
        EndPos      = endPos,
        Lifetime    = TracerCfg.Duration,
        FadeTime    = TracerCfg.FadeTime,
        CreatedTime = tick(),
    })
end

local function MakeBeamTracer(startPos, endPos)
    local a0 = Instance.new("Attachment"); a0.Parent = Workspace.Terrain
    local a1 = Instance.new("Attachment"); a1.Parent = Workspace.Terrain

    local beam = Instance.new("Beam")
    beam.Attachment0    = a0
    beam.Attachment1    = a1
    beam.Color          = ColorSequence.new(TracerCfg.Color)
    local baseW         = TracerCfg.Style == "Laser" and 0.02 or 0.15
    beam.Width0         = baseW * TracerCfg.Size
    beam.Width1         = baseW * TracerCfg.Size
    beam.Transparency   = NumberSequence.new(0)
    beam.FaceCamera     = true
    beam.LightEmission  = 0.8
    beam.LightInfluence = 0.2

    local tex = TRACER_TEXTURE_ASSETS[TracerCfg.Style]
    if tex and tex ~= "" then
        beam.Texture       = tex
        beam.TextureLength = 4
        beam.TextureSpeed  = 1
    else
        beam.Texture       = ""
        beam.TextureLength = 1
        beam.TextureSpeed  = 0
    end

    beam.Parent          = Workspace.Terrain
    a0.WorldPosition     = startPos
    a1.WorldPosition     = endPos

    table.insert(tracers, {
        IsLine      = false,
        Beam        = beam,
        Attachment0 = a0,
        Attachment1 = a1,
        StartPos    = startPos,
        EndPos      = endPos,
        Lifetime    = TracerCfg.Duration,
        FadeTime    = TracerCfg.FadeTime,
        CreatedTime = tick(),
    })
end

local function CreateTracer(startPos, endPos)
    if not TracerCfg.Enabled or not startPos or not endPos then return end
    local kx = math.floor(startPos.X*5+0.5)
    local ky = math.floor(startPos.Y*5+0.5)
    local kz = math.floor(startPos.Z*5+0.5)
    local ex = math.floor(endPos.X*5+0.5)
    local ey = math.floor(endPos.Y*5+0.5)
    local ez = math.floor(endPos.Z*5+0.5)
    local posKey = kx*1e9 + ky*1e6 + kz*1e3 + ex + ey*1e-3 + ez*1e-6
    local now    = tick()
    local last   = lastTracerCreations[posKey]
    if last and (now - last) < DEDUPE_INTERVAL then return end
    lastTracerCreations[posKey] = now
    if TracerCfg.Style == "Line" then MakeLineTracer(startPos, endPos)
    else MakeBeamTracer(startPos, endPos) end
end

local function DestroyTracer(t)
    if t.IsLine then
        if t.Outline then pcall(t.Outline.Remove, t.Outline) end
        if t.Line    then pcall(t.Line.Remove,    t.Line)    end
    else
        if t.Beam        then pcall(t.Beam.Destroy,        t.Beam)        end
        if t.Attachment0 then pcall(t.Attachment0.Destroy, t.Attachment0) end
        if t.Attachment1 then pcall(t.Attachment1.Destroy, t.Attachment1) end
    end
end

local function UpdateTracers()
    if #tracers == 0 then return end
    tracerFrameCount = tracerFrameCount + 1
    local now    = tick()
    local camera = cam or Workspace.CurrentCamera
    local myChar = lp.Character
    local myPos  = myChar and myChar:FindFirstChild("HumanoidRootPart")
                   and myChar.HumanoidRootPart.Position

    if tracerFrameCount % DEDUPE_PRUNE_INT == 0 then
        for k, t in next, lastTracerCreations do
            if (now - t) > DEDUPE_EXPIRY then lastTracerCreations[k]=nil end
        end
    end

    local i = #tracers
    while i >= 1 do
        local tr  = tracers[i]
        local age = now - tr.CreatedTime

        if age >= tr.Lifetime then
            DestroyTracer(tr)
            tracers[i]=tracers[#tracers];tracers[#tracers]=nil
        else
            local fadeAlpha
            local fadeStart = tr.Lifetime - tr.FadeTime
            if age >= fadeStart then
                fadeAlpha = 1 - math.clamp((age-fadeStart)/tr.FadeTime, 0, 1)
            else
                fadeAlpha = 1
            end

            if tr.IsLine then
                local drawEnd = GetTracerDrawEnd(tr, age)
                local camPos  = camera and camera.CFrame.Position
                local nearCam = camPos and (tr.StartPos-camPos).Magnitude <= 12
                local visible = false

                if nearCam or not myPos or (tr.StartPos-myPos).Magnitude > 2 then
                    local s2, onS = WorldToScreen(tr.StartPos, camera)
                    local e2, onE = WorldToScreen(drawEnd,      camera)
                    if onS and onE then
                        local sx,sy   = s2.X, s2.Y
                        local ex2,ey2 = e2.X, e2.Y
                        if sx==sx and sy==sy and ex2==ex2 and ey2==ey2
                        and math.abs(sx)<20000 and math.abs(sy)<20000
                        and math.abs(ex2)<20000 and math.abs(ey2)<20000 then
                            local dx  = ex2-sx
                            local dy  = ey2-sy
                            local len = math.sqrt(dx*dx+dy*dy)
                            if len > 0.1 and len < 3000 then
                                local fv2s = Vector2.new(sx,sy)
                                local fv2e = Vector2.new(ex2,ey2)
                                if TracerCfg.OutlineOn then
                                    tr.Outline.From=fv2s;tr.Outline.To=fv2e
                                    tr.Outline.Transparency=fadeAlpha;tr.Outline.Visible=true
                                else
                                    tr.Outline.Visible=false
                                end
                                tr.Line.From=fv2s;tr.Line.To=fv2e
                                tr.Line.Transparency=fadeAlpha;tr.Line.Visible=true
                                visible=true
                            end
                        end
                    end
                end

                if not visible then tr.Outline.Visible=false;tr.Line.Visible=false end
            else
                local drawEnd = GetTracerDrawEnd(tr, age)
                if tr.Attachment0 then tr.Attachment0.WorldPosition=tr.StartPos end
                if tr.Attachment1 then tr.Attachment1.WorldPosition=drawEnd     end
                if tr.Beam        then tr.Beam.Transparency=NumberSequence.new(1-fadeAlpha) end
            end
        end
        i = i - 1
    end
end

local function HookTracerEffect()
    if tracerEffectHooked then return end
    pcall(function()
        if not TracerEffectModule then
            TracerEffectModule = require(lp.PlayerScripts.Modules.TracerEffect)
        end
        if not TracerEffectModule then return end
        local origPlay = TracerEffectModule.Play
        if not origPlay then return end
        TracerEffectModule.Play = function(self2, tracerData, config2, extraData)
            if TracerCfg.Enabled and tracerData and tracerData.IsLocal and tracerData.RaycastResults then
                local mPos = GetMuzzlePosition() or cam.CFrame.Position
                for _, hit in ipairs(tracerData.RaycastResults) do
                    if hit and hit.Position then CreateTracer(mPos, hit.Position) end
                end
            end
            return origPlay(self2, tracerData, config2, extraData)
        end
        tracerEffectHooked = true
        print("[Tracers] TracerEffect hook applied")
    end)
end

local function HookTracerGun()
    if _tracerGunHooked or not GunModule then return end
    local orig = GunModule.StartShooting
    if not orig then return end
    _tracerGunOldFunc = orig
    local ok = pcall(function()
        rawset(GunModule,"StartShooting",function(self2,...)
            local results = {orig(self2,...)}
            if TracerCfg.Enabled then
                local sd = results[3]
                if sd and type(sd)=="table" then
                    local mPos = GetMuzzlePosition() or cam.CFrame.Position
                    pcall(function()
                        local encodedEnd = sd[utf8.char(1)]
                        if encodedEnd and UtilityModule then
                            local cf = UtilityModule:DecodeCFrame(encodedEnd)
                            if cf then CreateTracer(mPos, cf.Position) end
                        end
                    end)
                end
            end
            return table.unpack(results)
        end)
    end)
    if ok then _tracerGunHooked=true;print("[Tracers] GunModule hook applied") end
end

local function StartTracers()
    HookTracerEffect()
    HookTracerGun()
    if not tracerConn then
        tracerConn = Track(RunService.RenderStepped:Connect(UpdateTracers))
    end
    Notify("Tracers","Enabled — Style: "..TracerCfg.Style,2)
end

local function StopTracers()
    if tracerConn then tracerConn:Disconnect();tracerConn=nil end
    for _, tr in ipairs(tracers) do DestroyTracer(tr) end
    tracers = {}
    Notify("Tracers","Disabled",2)
end

