-- ============================================================
--   MAIN AUTO-SHOOT — The core fire function
-- ============================================================

local function AutoShoot(lf, item, targetChar)
    if not RC.AutoShoot then return end
    if not RC.Target.Enabled then return end
    if RC.Target.Immune then return end
    if RC.VoidSpam.Enabled and RC.VoidSpam.Phase == "hide" then return end

    if not IsInfiniteWeapon(item) then
        if RC.State.Reloading or RC.State.OutOfAmmo then return end
    end

    if not targetChar or not targetChar:IsDescendantOf(Workspace) then return end

    local hum = targetChar:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return end

    -- Get hit part
    local hitPart = GetBestPart(targetChar, RC.HitPart)
    if not hitPart then return end

    -- Determine shoot position:
    -- If orbiting use orbit server pos, else use camera position
    local shootPos = RC.Orbit.Enabled and RC.Orbit.ServerPos or cam.CFrame.Position

    -- If no orbit, try wallbang manip
    if not RC.Orbit.Enabled then
        local manip, _ = RageWallbangPoint(shootPos, hitPart.Position, targetChar)
        if manip then shootPos = manip end
    end

    -- Predict target position
    local targetPos = Predict(hitPart, shootPos)

    -- Build shot data (exact format the server expects)
    local data = {
        [utf8.char(1)] = {
            [utf8.char(0)] = UtilityModule:EncodeCFrame(CFrame.new(shootPos, targetPos)),
            [utf8.char(1)] = UtilityModule:EncodeCFrame(CFrame.new(shootPos, targetPos)),
            [utf8.char(2)] = hitPart,
            [utf8.char(3)] = UtilityModule:EncodeCFrame(CFrame.new(0.43, 0.25, 0.42)),
        },
    }

    local objectId = item:Get("ObjectID")
    if not objectId then return end

    local attempts = math.clamp(RC.ShootAttempts, 1, 3)
    for _ = 1, attempts do
        pcall(function()
            ReplicatedStorage.Remotes.Replication.Fighter.UseItem:FireServer(
                objectId,
                EnumsModule:ToEnum("StartShooting"),
                data,
                nil
            )
        end)
    end

    -- Double tap
    if RC.DoubleTap then
        task.delay(RC.DoubleTapDelay, function()
            if not hitPart or not hitPart.Parent then return end
            local hum2 = targetChar:FindFirstChildOfClass("Humanoid")
            if not hum2 or hum2.Health <= 0 then return end
            local off = Vector3.new(math.random(-5,5)*0.01,math.random(-5,5)*0.01,math.random(-5,5)*0.01)
            local data2 = {
                [utf8.char(1)] = {
                    [utf8.char(0)] = UtilityModule:EncodeCFrame(CFrame.new(shootPos+off,targetPos)),
                    [utf8.char(1)] = UtilityModule:EncodeCFrame(CFrame.new(shootPos+off,targetPos)),
                    [utf8.char(2)] = hitPart,
                    [utf8.char(3)] = UtilityModule:EncodeCFrame(CFrame.new(0.43,0.25,0.42)),
                },
            }
            pcall(function()
                ReplicatedStorage.Remotes.Replication.Fighter.UseItem:FireServer(
                    objectId,
                    EnumsModule:ToEnum("StartShooting"),
                    data2,
                    nil
                )
            end)
        end)
    end
end

-- ============================================================
--   RAGEBOT MAIN LOOP
-- ============================================================

local function StartRagebot()
    if rageConn then rageConn:Disconnect();rageConn=nil end

    -- Initialize void spam
    RC.VoidSpam.Phase           = "shoot"
    RC.VoidSpam.LastSwitch      = tick()
    RC.VoidSpam.CurrentDuration = RandBetween(RC.VoidSpam.ShootMin, RC.VoidSpam.ShootMax)

    rageConn = Track(RunService.Heartbeat:Connect(function(dt)
        if not RC.Enabled then return end

        -- Get equipped item
        local lf, item = GetEquipped()
        if not lf or not item then return end

        -- Tick ammo state
        TickAmmo(item)

        -- Tick void spam timing
        TickVoidSpam()

        -- Update reload state
        RC.State.Reloading = IsItemReloading(lf)

        -- If out of ammo, send reload
        if RC.State.OutOfAmmo and not RC.State.Reloading then
            SendReload(item)
        end

        -- Get target
        local targetChar = RageGetTarget()
        RC.Target.Character = targetChar

        if not targetChar then
            if RC.Orbit.Enabled then StopOrbit() end
            return
        end

        -- Start/update orbit if enabled
        if RC.Orbit.Enabled then
            if not RC.Orbit.Connection then
                StartOrbit(targetChar)
            end
        else
            StopOrbit()
        end

        -- Fire shot
        AutoShoot(lf, item, targetChar)

        -- Update HUD
        if rageHudVisible then UpdateRageHUD() end
    end))
end

local function StopRagebot()
    if rageConn then rageConn:Disconnect();rageConn=nil end
    StopOrbit()
    RC.Enabled          = false
    RC.Target.Character = nil
end

