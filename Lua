local _frameCount    = 0
local _frameTimer    = tick()
local _fps           = 0

Track(RunService.Heartbeat:Connect(function(dt)
    cam = Workspace.CurrentCamera

    -- FPS
    _frameCount+=1
    local now=tick()
    if now-_frameTimer>=1 then _fps=_frameCount;_frameTimer=now;_frameCount=0 end

    -- Target cache
    if now-_aimbotCacheTime>=CACHE_TTL then
        _aimbotCacheTime=now
        if AimbotCfg.Enabled then _aimbotCache=AimbotFindTarget() end
        if SilentCfg.Enabled then _silentCache=SilentFindNearest() end
    end

    -- Aimbot — VisCheck every frame while locked
    if AimbotCfg.Enabled then
        if aimbotIsReacting then
            aimbotReactTimer-=dt
            if aimbotReactTimer<=0 then aimbotIsReacting=false end
        end
        if not aimbotIsReacting then
            if aimbotTarget then
                local parentChar=aimbotTarget.Parent
                local hum=parentChar and parentChar:FindFirstChildOfClass("Humanoid")
                local stillVisible=true
                if AimbotCfg.VisCheck then
                    stillVisible=IsVisible(cam.CFrame.Position,aimbotTarget)
                end
                local inFovNow=InFOV(aimbotTarget,AimbotEffFOV())
                local alive=hum and hum.Health>0
                if not alive or not inFovNow or not stillVisible then
                    aimbotTarget=nil;aimbotLingerTimer=0
                    aimbotCurveStart=nil;aimbotCurveProgress=0
                    aimbotSpring=Spring.new(AimbotCfg.SpringMass,AimbotCfg.SpringForce,AimbotCfg.SpringDamping,AimbotCfg.SpringSpeed)
                end
            end
            if not aimbotTarget and _aimbotCache then
                local cacheVis=true
                if AimbotCfg.VisCheck then cacheVis=IsVisible(cam.CFrame.Position,_aimbotCache) end
                if cacheVis then
                    aimbotTarget=_aimbotCache;aimbotIsReacting=true
                    aimbotReactTimer=AimbotCfg.ReactTime;aimbotPrevPos=nil;aimbotLingerTimer=0
                end
            end
            if aimbotTarget and InFOV(aimbotTarget,AimbotEffFOV()) then
                AimbotApply(aimbotTarget,dt)
            end
        end
    end

    -- Ragebot HUD
    if config.ragestatus.enabled and rageHudVisible then UpdateRageHUD() end
end))

