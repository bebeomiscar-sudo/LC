    -- FOV scan — finds closest player in screen FOV radius
    local function saClosestInFov(radius, center)
        local closest, closestDist = nil, math.huge
        for _, player in ipairs(Players:GetPlayers()) do
            if player == lp then continue end
            if silentAim.teamCheck and sameTm(player) then continue end
            if not isValidTarget(player) then continue end
            local char = player.Character
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then continue end
            local pos, onScreen = worldToScreen(root.Position)
            if not onScreen then continue end
            local dist = (pos - center).Magnitude
            if dist <= radius and dist < closestDist then
                -- Optional vis check
                if silentAim.visCheck then
                    local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                    local orig   = myRoot and myRoot.Position or cam.CFrame.Position
                    if not isVis(orig, root) then continue end
                end
                closest     = char
                closestDist = dist
            end
        end
        return closest
    end

    -- Fire silent shot at cached target
    local function firesilent()
        if not silentAim.enabled then return end
        if math.random(1, 100) > silentAim.hitChance then return end

        local target = silentAim.target
        if not target or not target.Parent then
            -- Re-scan if target lost
            silentAim.target = saClosestInFov(silentAim.fovRadius, screenCenter())
            target = silentAim.target
            if not target then return end
        end

        -- Validate target still alive
        local hum = target:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then
            silentAim.target = nil
            return
        end

        local hitPart = hitpartfromname(target, silentAim.hitPart)
        if not hitPart then return end

        local myChar = lp.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end

        local equipped = getEquipped()
        if not equipped then return end

        local data = buildShotData(myRoot.Position, hitPart.Position, hitPart)

        pcall(function()
            UseItemRemote:FireServer(
                equipped:Get("ObjectID"),
                EnumLibrary:ToEnum("StartShooting"),
                data,
                nil
            )
        end)
    end

