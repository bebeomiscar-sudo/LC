local fovConfig = {
    visible      = true,
    half         = false,
    color        = Color3.fromRGB(255, 255, 255),
    fovSize      = 80,
    fovOnTarget  = 60,
    fovOnBarrier = 100,
    useCenter    = false, -- false = mouse, true = screen center
}

local fovCircle = Drawing.new("Circle")
fovCircle.Visible     = false
fovCircle.Thickness   = 1.5
fovCircle.Color       = Color3.fromRGB(255, 255, 255)
fovCircle.Filled      = false
fovCircle.NumSides    = 64
fovCircle.Radius      = 80

local function updateFOVCircle()
    if not fovConfig.visible then
        fovCircle.Visible = false
        return
    end

    fovCircle.Visible = true
    fovCircle.Color   = fovConfig.color

    -- Position: mouse or screen center
    local screenCenter = Vector2.new(
        workspace.CurrentCamera.ViewportSize.X / 2,
        workspace.CurrentCamera.ViewportSize.Y / 2
    )

    if fovConfig.useCenter then
        fovCircle.Position = screenCenter
    else
        -- Use mouse position (no Player.Mouse - use UIS)
        local mousePos = UserInputService:GetMouseLocation()
        fovCircle.Position = mousePos
    end

    -- Dynamic FOV based on target
    local hasTarget = aimbotConfig.currentTarget ~= nil
        or silentConfig.enabled

    if hasTarget then
        fovCircle.Radius = fovConfig.fovOnTarget
    else
        fovCircle.Radius = fovConfig.fovSize
    end
end

-- FOV half circle logic
local fovHalfCircle = Drawing.new("Circle")
fovHalfCircle.Visible   = false
fovHalfCircle.Thickness = 1.5
fovHalfCircle.Color     = Color3.fromRGB(255, 255, 255)
fovHalfCircle.Filled    = false
fovHalfCircle.NumSides  = 32
fovHalfCircle.Radius    = 80

-- Update FOV every frame
RunService.RenderStepped:Connect(function()
    pcall(updateFOVCircle)

    if fovConfig.visible and fovConfig.half then
        fovHalfCircle.Visible  = true
        fovHalfCircle.Color    = fovConfig.color
        fovHalfCircle.Radius   = fovCircle.Radius * 0.5
        fovHalfCircle.Position = fovCircle.Position
    else
        fovHalfCircle.Visible = false
    end
end)

