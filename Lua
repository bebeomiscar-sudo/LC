    -- Slingshot TP
    local slingConn = nil
    local function slingshotTP()
        if slingConn then return end
        slingConn = ws.DescendantAdded:Connect(function(d)
            if d:IsA("BasePart") or d:IsA("Model") then
                if d.Name=="Slingshot" or d.Name=="CoreProjectile" or d.Name=="OuterProjectile" then
                    task.spawn(function()
                        task.wait(0.06)
                        local part = d:IsA("BasePart") and d or d:FindFirstChildWhichIsA("BasePart")
                        if not part then return end
                        part.CanTouch = true
                        for _ = 1, 60 do
                            if not part.Parent then break end
                            local found, best = nil, math.huge
                            local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                            if myRoot then
                                for _, p in ipairs(Players:GetPlayers()) do
                                    if p==lp or not p.Character then continue end
                                    local head = p.Character:FindFirstChild("HitboxHead") or p.Character:FindFirstChild("Head")
                                    if not head then continue end
                                    local d2 = (head.Position-myRoot.Position).Magnitude
                                    if d2<best then found=head; best=d2 end
                                end
                            end
                            if found then
                                pcall(firetouchinterest, found, part, 0)
                                pcall(firetouchinterest, found, part, 1)
                            end
                            task.wait()
                        end
                    end)
                end
            end
        end)
    end

    local function stopslingTP()
        if slingConn then slingConn:Disconnect(); slingConn=nil end
    end

    local function updatesling()
        local weapon     = getweapon()
        local checksling = isSling(weapon)
        local hastarget  = rageConfig.target.enabled and rageConfig.target.character ~= nil
        if checksling then
            slingshotTP()
            vhState.active = hastarget
            if hastarget and not rageConfig.state.csyncactive then startsync() end
        else
            stopslingTP()
            vhState.active = false
        end
    end

    -- Ammo tick
    local function tickAmmo()
        if isInfiniteWeapon() then
            rageConfig.state.outofammo      = false
            rageConfig.state.reloading      = false
            rageConfig.state.reloadStartedAt = 0
            return
        end
        local cur, _, melee = getammo()
        local wasOut = rageConfig.state.outofammo
        rageConfig.state.outofammo = not melee and (tonumber(cur) or 0) <= 0
        local reloading = itemReload()
        if reloading and not rageConfig.state.reloading then
            rageConfig.state.reloadStartedAt = tick()
        elseif not reloading then
            rageConfig.state.reloadStartedAt = 0
        end
        rageConfig.state.reloading = reloading
        if rageConfig.state.outofammo and not wasOut then
            if isSling(getweapon()) then rageConfig.voidspam.phase="hide" end
        elseif not rageConfig.state.outofammo and wasOut then
            if rageConfig.voidspam.enabled then
                rageConfig.voidspam.phase = "shoot"
                rageConfig.voidspam.lastswitch = tick()
            end
        end
    end

    -- Set + clear target
    local function settarget(char)
        if not char then return end
        local tp = Players:GetPlayerFromCharacter(char)
        rageConfig.target.enabled   = true
        rageConfig.target.character = char
        rageConfig.target.lastplayer = tp
        rageConfig.target.immune    = false
        local root = char:FindFirstChild("HumanoidRootPart")
        if root and root:FindFirstChild("Attachment") then
            rageConfig.target.immune = true
        else
            eqSlot()
            startsync()
        end
    end

    local function cleartarget()
        rageConfig.target.enabled   = false
        rageConfig.target.character = nil
        rageConfig.target.lastplayer = nil
        rageConfig.target.immune    = false
        stopsync()
    end

    -- Autoshoot
    local function autoshoot()
        if not rageConfig.target.enabled or not rageConfig.target.autoshoot then return end
        if rageConfig.target.immune then return end
        if rageConfig.voidspam.enabled and rageConfig.voidspam.phase=="hide" then return end
        if not isInfiniteWeapon() then
            if rageConfig.state.reloading or rageConfig.state.outofammo then return end
        end
        local targetChar = rageConfig.target.character
        if not targetChar or not valid(targetChar) then return end
        local lf = FighterController and FighterController.LocalFighter
        if not lf or not lf.EquippedItem then return end
        local hitPart = hitpartfromname(targetChar, rageConfig.hitpart)
        if not hitPart then return end

        local weapon = getweapon()
        local checksling = isSling(weapon)

        local shootPos
        if vhState.active and checksling then
            local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            shootPos = myRoot and myRoot.Position or Vector3.zero
        elseif rageConfig.state.csyncactive and rageConfig.orbit.serverpos then
            shootPos = rageConfig.orbit.serverpos
        else
            local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            shootPos = myRoot and myRoot.Position or Vector3.zero
        end

        local targetPos = predict(hitPart, shootPos)
        local data      = buildShotData(shootPos, targetPos, hitPart)
        local equipped  = lf.EquippedItem

        if equipped and equipped:Get("ObjectID") then
            ragePerf.lastAttackTick = tick()
            local attempts = math.clamp(math.floor(tonumber(rageConfig.shootAttempts) or 1), 1, 3)
            for _ = 1, attempts do
                pcall(function()
                    UseItemRemote:FireServer(
                        equipped:Get("ObjectID"),
                        EnumLibrary:ToEnum("StartShooting"),
                        data, nil
                    )
                end)
            end

            -- Fire tracer from shoot position to target
            if getgenv().makebullettracer then
                pcall(getgenv().makebullettracer, shootPos, targetPos)
            end
        end
    end

