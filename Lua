local function fetchEntities()
    local entities = {}
    for _, v in pairs(ws:GetChildren()) do
        if v:FindFirstChildOfClass("Humanoid") then
            table.insert(entities, v)
        elseif v.Name == "HurtEffect" then
            for _, child in pairs(v:GetChildren()) do
                if child.ClassName ~= "Highlight" then
                    table.insert(entities, child)
                end
            end
        end
    end
    return entities
end

local function fetchNearest(part)
    local center = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
    local target, dist = nil, math.huge
    for _, entity in pairs(fetchEntities()) do
        if entity == lp.Character then continue end
        if not entity:FindFirstChild("HumanoidRootPart") then continue end
        local hum = entity:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local hitPart = entity:FindFirstChild(part or silentCfg.part)
        if not hitPart then continue end
        local pos, visible = cam:WorldToViewportPoint(hitPart.Position)
        if not visible then continue end
        local mag = (center - Vector2.new(pos.X, pos.Y)).Magnitude
        if mag < dist and mag < silentCfg.fovSize then
            if silentCfg.visCheck then
                local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                local orig   = myRoot and myRoot.Position or cam.CFrame.Position
                if not isVis(orig, hitPart) then continue end
            end
            dist   = mag
            target = entity
        end
    end
    return target
end

local function hookSilent()
    if silentHooked or not util then return end
    local writeOk = pcall(function()
        local test = rawget(util, "__writeTest")
        rawset(util, "__writeTest", true)
        rawset(util, "__writeTest", test)
    end)
    if not writeOk then
        notify("Silent Aim","Hook failed — frozen table",3)
        return
    end
    silentOldFunc = util.Raycast
    util.Raycast = function(self, origin, direction, distance, ...)
        if silentCfg.enabled and math.random(1,100) <= silentCfg.hitChance then
            local aim  = fetchNearest(silentCfg.part)
            local node = aim and aim:FindFirstChild(silentCfg.part)
            if node then
                local targetPos = node.Position
                if silentCfg.prediction > 0 then
                    pcall(function()
                        local hrp = aim:FindFirstChild("HumanoidRootPart")
                        local vel = hrp and hrp.AssemblyLinearVelocity or Vector3.zero
                        targetPos = targetPos + vel * (silentCfg.prediction * 0.05)
                    end)
                end
                direction = targetPos - origin
            end
        end
        return silentOldFunc(self, origin, direction, distance, ...)
    end
    silentHooked = true
end

local function unhookSilent()
    if not silentHooked or not util then return end
    pcall(function() util.Raycast = silentOldFunc end)
    silentOldFunc = nil
    silentHooked  = false
end

