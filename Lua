-- =============================================
--   Crash Prevention — Heartbeat Safe Wait
--   Same fix as VoidSpam — no task.wait spam
-- =============================================

local function safeWait(t)
    local start = tick()
    while tick() - start < t do
        RunService.Heartbeat:Wait()
    end
end

