local HitNotifs  = {}
local MAX_NOTIFS = 8

local function pushHitNotif(msg)
    if not Config.hitNotify.enabled then return end
    if #HitNotifs >= MAX_NOTIFS then
        HitNotifs[1].label:Remove()
        table.remove(HitNotifs, 1)
    end
    local lbl = Drawing.new("Text")
    lbl.Size         = 13
    lbl.Font         = 2
    lbl.Outline      = true
    lbl.Color        = Config.hitNotify.color
    lbl.OutlineColor = Color3.new()
    lbl.Text         = msg
    lbl.Visible      = true
    lbl.Transparency = 1

    table.insert(HitNotifs, {
        label    = lbl,
        spawnAt  = tick(),
        duration = Config.hitNotify.duration,
    })
end

RunService.RenderStepped:Connect(function()
    local baseY  = 12
    local now    = tick()
    local toRemove = {}

    for i, entry in ipairs(HitNotifs) do
        local elapsed  = now - entry.spawnAt
        local alpha    = 1 - math.clamp((elapsed - (entry.duration - 0.5)) / 0.5, 0, 1)
        entry.label.Transparency = alpha
        entry.label.Position     = Vector2.new(12, baseY + (i - 1) * 18)
        if elapsed >= entry.duration then
            table.insert(toRemove, i)
        end
    end

    for i = #toRemove, 1, -1 do
        local idx = toRemove[i]
        HitNotifs[idx].label:Remove()
        table.remove(HitNotifs, idx)
    end
end)

--// Monitor enemy HP for hit notifications
RunService.Heartbeat:Connect(function()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local char = plr.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then continue end

        local prevHP = (ESPData[plr] and ESPData[plr]._lastHP) or hum.Health
        if ESPData[plr] then
            if hum.Health < prevHP then
                local dmg = math.floor(prevHP - hum.Health)
                if dmg > 0 and Config.hitNotify.enabled then
                    pushHitNotif(string.format("💥 %s  -%d hp  (%.0f left)", plr.Name, dmg, hum.Health))
                end
            end
            ESPData[plr]._lastHP = hum.Health
        end
    end
end)

