local function inLive(plr)
    if not plr then return false end
    local live = Workspace:FindFirstChild("Live")
    if not live then return false end
    if live:FindFirstChild(plr.Name) or live:FindFirstChild(tostring(plr.UserId)) then
        return true
    end
    local char = plr.Character
    if char and char:IsDescendantOf(live) then return true end
    local fc = Mod.Fighter
    if fc and type(fc.GetFighter) == "function" then
        local ok, f = pcall(fc.GetFighter, fc, plr)
        if ok and f and f.Entity and f.Entity.Parent then
            if f.Entity:IsDescendantOf(live) then return true end
        end
    end
    return false
end

local function getMatchId(plr)
    if not plr then return nil end
    for _, k in ipairs(MATCH_ATTRS) do
        local v = plr:GetAttribute(k)
        if v and v ~= "" and v ~= 0 and v ~= false then return tostring(v) end
    end
    local char = plr.Character
    if char then
        for _, k in ipairs(MATCH_ATTRS) do
            local v = char:GetAttribute(k)
            if v and v ~= "" and v ~= 0 and v ~= false then return tostring(v) end
        end
    end
    return nil
end

local function isLiveMatch()
    local lp = LocalPlayer
    if not lp then return false end

    for _, k in ipairs(SAFE_ATTRS) do
        local v = lp:GetAttribute(k)
        if v == true or v == 1 or v == "true" then return false end
    end

    local char = lp.Character
    if not char then return false end

    for _, k in ipairs(SAFE_ATTRS) do
        local v = char:GetAttribute(k)
        if v == true or v == 1 or v == "true" then return false end
    end

    local hum  = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or hum.Health <= 0 or not root then return false end

    for _, k in ipairs(DUEL_ATTRS) do
        if lp:GetAttribute(k) == true  then return true end
        if char:GetAttribute(k) == true then return true end
    end

    if inLive(lp) then return true end

    local fc = Mod.Fighter
    if fc and fc.LocalFighter and fc.LocalFighter.Entity and fc.LocalFighter.Entity.Parent then
        return true
    end

    local myMid = getMatchId(lp)
    if myMid then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= lp and getMatchId(p) == myMid then return true end
        end
    end

    if fc then
        for _, list in ipairs({fc.Fighters, fc.AllFighters}) do
            if list then
                for _, f in pairs(list) do
                    if f and f.Player and f.Player ~= lp and (f.IsEnemy or f.Enemy) then
                        local fhum = f.Player.Character and f.Player.Character:FindFirstChildOfClass("Humanoid")
                        if fhum and fhum.Health > 0 then return true end
                    end
                end
            end
        end
    end

    return false
end

-- Cached lobby check (150ms TTL)
local _lobbyCache = { t = 0, v = true }
local function isInLobby()
    local now = os.clock()
    if now - _lobbyCache.t < 0.15 then return _lobbyCache.v end
    _lobbyCache.t = now
    _lobbyCache.v = not isLiveMatch()
    return _lobbyCache.v
end

getgenv().InstanceIsInActiveMatch = isLiveMatch
getgenv().InstanceIsInLobby       = isInLobby

