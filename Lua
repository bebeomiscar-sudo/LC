local function RageGetWeaponName()
    local viewModels = Workspace:FindFirstChild("ViewModels")
    if not viewModels then return nil end
    local firstPerson = viewModels:FindFirstChild("FirstPerson")
    if not firstPerson then return nil end
    for _, child in ipairs(firstPerson:GetChildren()) do
        local parts = {}
        for part in child.Name:gmatch("[^%-]+") do
            table.insert(parts, part:match("^%s*(.-)%s*$"))
        end
        if #parts >= 2 then return parts[2] end
    end
    return nil
end

local function RageIsSling(weapon)
    weapon = weapon or RageGetWeaponName()
    return weapon and weapon:lower():find("slingshot", 1, true) ~= nil
end

local function RageIsInfiniteWeapon()
    local w = RageGetWeaponName()
    if not w then return false end
    return INFINITE_AMMO_WEAPONS[w] == true
end

local function RageIsMelee(weaponName)
    if not weaponName then return false end
    return MELEE_NAMES[weaponName] == true
        or weaponName:lower():find("melee", 1, true) ~= nil
end

local WEAPON_SLOTS = {primary=1, secondary=2, melee=3}

local function RageWantSlot()
    return WEAPON_SLOTS[RC.WeaponPick or "primary"] or 1
end

local function RageGetEquipped()
    if not FighterController then return nil, nil end
    local lf = FighterController.LocalFighter
    if not lf then return nil, nil end
    return lf, lf.EquippedItem
end

local function RageGetAmmo()
    if RageIsInfiniteWeapon() then return nil, nil, false end
    local lf, item = RageGetEquipped()
    if not lf or not item then return 0, 0, false end
    local cur, maxA, isMelee = 0, 0, false
    pcall(function()
        local nm = tostring(item:Get("Name") or "")
        cur   = item:Get("CurrentAmmo") or item:Get("Ammo") or 0
        maxA  = item:Get("MaxAmmo") or item:Get("MaxBullets") or cur
        if RageIsMelee(nm) then isMelee = true end
    end)
    if RC.WeaponPick == "melee" then isMelee = true end
    return tonumber(cur) or 0, tonumber(maxA) or 0, isMelee
end

local function RageIsReloading(lf)
    if not lf then return false end
    if RageIsInfiniteWeapon() then return false end
    local ok, r = pcall(function()
        local item = lf.EquippedItem
        if not item then return false end
        for _, key in ipairs({"Reloading","IsReloading","IsReload"}) do
            local v = item:Get(key)
            if v == true or v == 1 or v == "true" then return true end
        end
        return false
    end)
    if ok and r then return true end
    local started = RC.State.ReloadStartAt or 0
    return started > 0 and (tick()-started) < 1.75
end

-- ============================================================
--   AMMO TICK
-- ============================================================

local function RageTickAmmo()
    if RageIsInfiniteWeapon() then
        RC.State.OutOfAmmo    = false
        RC.State.Reloading    = false
        RC.State.ReloadStartAt = 0
        return
    end
    local cur, _, isMelee = RageGetAmmo()
    local wasOOA          = RC.State.OutOfAmmo
    RC.State.OutOfAmmo    = not isMelee and (tonumber(cur) or 0) <= 0

    local lf, _ = RageGetEquipped()
    local reloading = RageIsReloading(lf)
    if reloading and not RC.State.Reloading then
        RC.State.ReloadStartAt = tick()
    elseif not reloading then
        RC.State.ReloadStartAt = 0
    end
    RC.State.Reloading = reloading

    -- Out of ammo → force hide
    if RC.State.OutOfAmmo and not wasOOA then
        if RC.VoidSpam.Enabled then
            RC.VoidSpam.Phase      = "hide"
            RC.VoidSpam.LastSwitch = tick()
            RC.VoidSpam.Duration   = RandBetween(RC.VoidSpam.HideMin, RC.VoidSpam.HideMax)
        end
    elseif not RC.State.OutOfAmmo and wasOOA then
        if RC.VoidSpam.Enabled then
            RC.VoidSpam.Phase      = "shoot"
            RC.VoidSpam.LastSwitch = tick()
            RC.VoidSpam.Duration   = RandBetween(RC.VoidSpam.ShootMin, RC.VoidSpam.ShootMax)
        end
    end
end

-- ============================================================
--   VOID FRAME SNAP (csync hide)
-- ============================================================

local function ClearVoidSnap()
    vfrSnap.cf = nil
    vfrSnap.lv = nil
    vfrSnap.av = nil
end

local function RandSkip(mi, ma, dmi, dma)
    local val = math.random(mi, ma)
    local tries = 0
    while val >= dmi and val <= dma and tries < 20 do
        val = math.random(mi, ma)
        tries += 1
    end
    return val
end

local function SnapToVoid(hrp)
    if not hrp then return end
    vfrSnap.cf = hrp.CFrame
    vfrSnap.lv = hrp.AssemblyLinearVelocity
    vfrSnap.av = hrp.AssemblyAngularVelocity
    local lim, dead = VFR_LIM, VFR_DEAD
    pcall(function()
        local p = Vector3.new(
            RandSkip(-lim, lim, -dead, dead),
            RandSkip(-lim, lim, -dead, dead),
            RandSkip(-lim, lim, -dead, dead)
        )
        local v = Vector3.new(
            RandSkip(-lim, lim, -dead, dead),
            RandSkip(-lim, lim, -dead, dead),
            RandSkip(-lim, lim, -dead, dead)
        )
        hrp.CFrame                 = CFrame.new(p) * CFrame.Angles(math.pi, math.pi, math.pi)
        hrp.AssemblyLinearVelocity = v
        hrp.AssemblyAngularVelocity = v
    end)
end

