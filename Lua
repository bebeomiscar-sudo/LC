    NameColor    = Color3.fromRGB(255, 255, 255),
    HealthColor  = Color3.fromRGB(80, 255, 80),
    MaxDist      = 1000,
    Filled       = false,
    FilledOpacity = 0.1,
}

-- Each player gets a table of drawings
local ESPObjects = {}

local function CreateESPForPlayer(player)
    if ESPObjects[player] then return end

    local function NewLine()
        local l = Drawing.new("Line")
        l.Thickness = 1.5
        l.Color     = ESPCfg.BoxColor
        l.Visible   = false
        return l
    end

    -- 3D box needs 12 lines (12 edges of a cube)
    local lines = {}
    for _ = 1, 12 do table.insert(lines, NewLine()) end

    local filledBox = Drawing.new("Square")
    filledBox.Filled  = true
    filledBox.Color   = ESPCfg.BoxColor
    filledBox.Transparency = 1 - ESPCfg.FilledOpacity
    filledBox.Visible = false

    local nameLabel = Drawing.new("Text")
    nameLabel.Size    = 14
    nameLabel.Center  = true
    nameLabel.Outline = true
    nameLabel.Color   = ESPCfg.NameColor
    nameLabel.Visible = false
    nameLabel.Text    = player.Name

    local healthLabel = Drawing.new("Text")
    healthLabel.Size    = 12
    healthLabel.Center  = true
    healthLabel.Outline = true
    healthLabel.Color   = ESPCfg.HealthColor
    healthLabel.Visible = false

    local distLabel = Drawing.new("Text")
    distLabel.Size    = 11
    distLabel.Center  = true
    distLabel.Outline = true
    distLabel.Color   = Color3.fromRGB(200, 200, 200)
    distLabel.Visible = false

    ESPObjects[player] = {
        Lines      = lines,
        FilledBox  = filledBox,
        NameLabel  = nameLabel,
        HealthLabel = healthLabel,
        DistLabel  = distLabel,
    }
end

local function RemoveESPForPlayer(player)
    local obj = ESPObjects[player]
    if not obj then return end
    for _, l in ipairs(obj.Lines) do pcall(l.Remove, l) end
    pcall(obj.FilledBox.Remove,    obj.FilledBox)
    pcall(obj.NameLabel.Remove,    obj.NameLabel)
    pcall(obj.HealthLabel.Remove,  obj.HealthLabel)
    pcall(obj.DistLabel.Remove,    obj.DistLabel)
    ESPObjects[player] = nil
end

local function HideESP(obj)
    for _, l in ipairs(obj.Lines) do l.Visible = false end
    obj.FilledBox.Visible   = false
    obj.NameLabel.Visible   = false
    obj.HealthLabel.Visible = false
    obj.DistLabel.Visible   = false
end

-- Project 3D box corners onto screen
local function GetBoundingBox2D(char)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    -- Approximate character bounding box in world space
    local center = hrp.Position
    local width  = 2.2
    local height = 3.0
    local halfW  = width  / 2
    local halfH  = height / 2

    -- 8 corners of a 3D box
    local corners3D = {
        center + Vector3.new(-halfW, -halfH, -halfW),
        center + Vector3.new( halfW, -halfH, -halfW),
        center + Vector3.new( halfW, -halfH,  halfW),
        center + Vector3.new(-halfW, -halfH,  halfW),
        center + Vector3.new(-halfW,  halfH, -halfW),
        center + Vector3.new( halfW,  halfH, -halfW),
        center + Vector3.new( halfW,  halfH,  halfW),
        center + Vector3.new(-halfW,  halfH,  halfW),
    }

    local screen = {}
    for _, c in ipairs(corners3D) do
        local sp, onScreen = cam:WorldToViewportPoint(c)
        if not onScreen then return nil end
        table.insert(screen, Vector2.new(sp.X, sp.Y))
    end
    return screen, corners3D
end

-- Draw 12 edges of the box
local EDGES = {
    -- Bottom face
    {1,2},{2,3},{3,4},{4,1},
    -- Top face
    {5,6},{6,7},{7,8},{8,5},
    -- Vertical edges
    {1,5},{2,6},{3,7},{4,8},
}

local function UpdateESP()
    local myChar = lp.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")

    for _, player in ipairs(Players:GetPlayers()) do
        if player == lp then continue end
        local obj = ESPObjects[player]
        if not obj then continue end

        if not ESPCfg.Enabled or not IsValidTarget(player) then
            HideESP(obj)
            continue
        end

        local char = player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then HideESP(obj);continue end

        -- Distance
        local dist = myHRP and (myHRP.Position - hrp.Position).Magnitude or 0
        if dist > ESPCfg.MaxDist then HideESP(obj);continue end

        -- Team color
        local isTeam = SameTeam(player)
        if ESPCfg.TeamCheck and isTeam then HideESP(obj);continue end
        local boxColor = isTeam and ESPCfg.TeamColor or ESPCfg.BoxColor

        local screenCorners = GetBoundingBox2D(char)
        if not screenCorners then HideESP(obj);continue end

        -- Update 12 edge lines
        if ESPCfg.ShowBox then
            for i, edge in ipairs(EDGES) do
                local line = obj.Lines[i]
                line.From    = screenCorners[edge[1]]
                line.To      = screenCorners[edge[2]]
                line.Color   = boxColor
                line.Visible = true
            end
        else
            for _, line in ipairs(obj.Lines) do line.Visible = false end
        end

        -- Filled box (2D bounding rect)
        if ESPCfg.Filled and ESPCfg.ShowBox then
            local minX, minY = math.huge, math.huge
            local maxX, maxY = -math.huge, -math.huge
            for _, sc in ipairs(screenCorners) do
                minX = math.min(minX, sc.X)
                minY = math.min(minY, sc.Y)
                maxX = math.max(maxX, sc.X)
                maxY = math.max(maxY, sc.Y)
            end
            obj.FilledBox.Position    = Vector2.new(minX, minY)
            obj.FilledBox.Size        = Vector2.new(maxX - minX, maxY - minY)
            obj.FilledBox.Color       = boxColor
            obj.FilledBox.Transparency = 1 - ESPCfg.FilledOpacity
            obj.FilledBox.Visible     = true
        else
            obj.FilledBox.Visible = false
        end

        -- Name
        local topCorner = screenCorners[5]
        local namePos   = topCorner - Vector2.new(0, 18)
        if ESPCfg.ShowName then
            obj.NameLabel.Text     = player.DisplayName
            obj.NameLabel.Position = namePos
            obj.NameLabel.Color    = ESPCfg.NameColor
            obj.NameLabel.Visible  = true
        else
            obj.NameLabel.Visible = false
        end

        -- Health
        if ESPCfg.ShowHealth then
            local hp    = math.floor(hum.Health)
            local maxHp = math.floor(hum.MaxHealth)
            local hpRatio = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
            local hpColor = Color3.fromRGB(
                math.floor((1 - hpRatio) * 255),
                math.floor(hpRatio * 255),
                0
            )
            obj.HealthLabel.Text     = hp .. " / " .. maxHp
            obj.HealthLabel.Position = namePos - Vector2.new(0, 14)
            obj.HealthLabel.Color    = hpColor
            obj.HealthLabel.Visible  = true
        else
            obj.HealthLabel.Visible = false
        end

        -- Distance
        if ESPCfg.ShowDist then
            local bottomCorner = screenCorners[1]
            obj.DistLabel.Text     = math.floor(dist) .. " studs"
            obj.DistLabel.Position = bottomCorner + Vector2.new(0, 4)
            obj.DistLabel.Visible  = true
        else
            obj.DistLabel.Visible = false
        end
    end
end

