        -- ==========================================
        --   UNIFIED RenderStepped Loop
        --   Aimbot + FOV Circles + Watermark
        --   All NO Player.Mouse
        -- ==========================================

        local frameTimer=tick(); local frameCount=0
        local currentFPS=60

        RunService.RenderStepped:Connect(function(dt)
            cam=ws.CurrentCamera

            -- FPS + Watermark
            frameCount+=1
            if tick()-frameTimer>=1 then
                currentFPS=frameCount
                frameTimer=tick(); frameCount=0
            end
            local ping=0
            pcall(function()
                ping=math.floor(
                    Stats.Network
                        .ServerStatsItem["Data Ping"]:GetValue()
                )
            end)
            Library:SetWatermark(
                ("Rivals | %d fps | %d ms"):format(
                    currentFPS, ping
                )
            )

            -- Aimbot (v3)
            if AB.on and CameraController then
                if abDoReact then
                    abReactT=abReactT-dt
                    if abReactT<=0 then abDoReact=false end
                end
                if not abDoReact then
                    if abTgt and not abTgtValid(abTgt) then
                        abTgt=nil; abLockT=0; abPrevPos=nil
                        abCurveStart=nil; abCurveProgress=0
                    end
                    if not abTgt then
                        abTgt=abFind()
                        if abTgt then
                            abLockT=0; abDoReact=true
                            abReactT=AB.reactTime/1000
                            abPrevPos=nil; abCurveStart=nil
                            abCurveProgress=0
                        end
                    end
                    if abTgt then
                        abLockT=abLockT+dt
                        if abLockT>AB.maxLock then
                            abTgt=nil; abLockT=0; abPrevPos=nil
                            abCurveStart=nil; abCurveProgress=0
                        elseif inFov(abTgt,abEffFov()) then
                            pcall(function()
                                local aimPos=getPredictedPos(abTgt)
                                local cp=cam.CFrame.Position
                                local du=(aimPos-cp).Unit
                                local tp2=math.asin(
                                    math.clamp(du.Y,-1,1)
                                )
                                local ty=math.atan2(-du.X,-du.Z)
                                local tRot=Vector2.new(tp2,ty)
                                local cur=CameraController.Rotation
                                local sp2,_=cam:WorldToViewportPoint(
                                    aimPos
                                )
                                local sd2=(
                                    Vector2.new(sp2.X,sp2.Y)-scr()
                                ).Magnitude
                                local newRot=applySmartLock(
                                    tRot,cur,dt,sd2,abEffFov()
                                )
                                CameraController:ApplyRotationDelta(
                                    Vector2.new(
                                        newRot.X-cur.X,
                                        angDiff(cur.Y,newRot.Y)
                                    )
                                )
                            end)
                        else
                            abTgt=nil; abLockT=0; abPrevPos=nil
                            abCurveStart=nil; abCurveProgress=0
                        end
                    end
                end
            end

            -- Aimbot FOV Circle (getMousePos — no Mouse)
            if not fovCfg.visible then
                fovCircle.Visible=false
                fovHalf.Visible=false
                abCirc.Visible=false
            else
                local center=fovCfg.useCenter
                    and scr() or getMousePos()
                fovCircle.Visible=true
                fovCircle.Color=fovCfg.color
                fovCircle.Position=center
                local myRoot=lp.Character
                    and lp.Character:FindFirstChild(
                        "HumanoidRootPart"
                    )
                local orig2=myRoot
                    and myRoot.Position
                    or cam.CFrame.Position
                if abTgt~=nil then
                    local vis=isVis(orig2,abTgt)
                    fovCircle.Radius=vis
                        and fovCfg.onTarget or fovCfg.onBarrier
                else
                    fovCircle.Radius=fovCfg.fovSize
                end
                if fovCfg.half then
                    fovHalf.Visible=true
                    fovHalf.Color=fovCfg.color
                    fovHalf.Position=center
                    fovHalf.Radius=fovCircle.Radius*0.5
                else
                    fovHalf.Visible=false
                end
                abCirc.Position=center
                abCirc.Radius=abEffFov()
                abCirc.Visible=AB.on and AB.drawFov
            end

            -- Silent FOV Circle (getMousePos — no Mouse)
            if not silentCfg.enabled
                or not silentCfg.circleVisible then
                silentCircle.Visible=false
            else
                silentCircle.Visible=true
                silentCircle.Radius=silentCfg.fovSize
                silentCircle.Thickness=silentCfg.circleThick
                local center=silentCfg.useCenter
                    and scr() or getMousePos()
                silentCircle.Position=center
                local myRoot=lp.Character
                    and lp.Character:FindFirstChild(
                        "HumanoidRootPart"
                    )
                local orig2=myRoot
                    and myRoot.Position
                    or cam.CFrame.Position
                local target=getSilentTarget(orig2)
                silentCircle.Color=target
                    and silentCfg.targetColor
                    or silentCfg.circleColor
            end
        end)

        Library:SetWatermarkVisibility(true)
        Library:OnUnload(function() Library.Unloaded=true end)

        -- Save / Theme
        if ThemeManager then
            ThemeManager:SetLibrary(Library)
        end
        if SaveManager then
            SaveManager:SetLibrary(Library)
            SaveManager:IgnoreThemeSettings()
            SaveManager:SetIgnoreIndexes({"MenuKeybind"})
            SaveManager:SetFolder("RivalsScript/Rivals")
            SaveManager:BuildConfigSection(Tabs.UISettings)
            if ThemeManager then
                ThemeManager:SetFolder("RivalsScript")
                ThemeManager:ApplyToTab(Tabs.UISettings)
            end
            SaveManager:LoadAutoloadConfig()
        end

        Library:Notify(
            "Rivals v1.5 Ready! AC Active | RightShift toggle",
            6
        )

        print("[v1.5] Script fully loaded — no freeze")
        print("[v1.5] AC: 8 bypass layers active")
        print("[v1.5] Mouse: UserInputService only")

    end) -- end task.spawn main script

