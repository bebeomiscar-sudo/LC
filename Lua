local function inLive(plr)
    if not plr then return false end
    local live = workspace:FindFirstChild("Live")
    if not live then return false end
    if live:FindFirstChild(plr.Name) or live:FindFirstChild(tostring(plr.UserId)) then
        return true
    end
    local char = plr.Character
    if char and char:IsDescendantOf(live) then return true end
    local fc = Modules.Fighter
    if fc and type(fc.GetFighter) == "function" then
        local ok, fighter = pcall(fc.GetFighter, fc, plr)
        if ok and fighter and fighter.Entity and fighter.Entity.Parent then
            if fighter.Entity:IsDescendantOf(live) then return true end
        end
    end
    return false
end

local function liveMatch()
    local lp = LocalPlayer
    if not lp then return false end
    for _, k in ipairs(SAFE_ATTRS) do
        local v = lp:GetAttribute(k)
        if v == true or v == 1 then return false end
    end
    local char = lp.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hum or hum.Health <= 0 or not hrp then return false end
    for _, k in ipairs(DUEL_ATTRS) do
        local v = lp:GetAttribute(k) or char:GetAttribute(k)
        if v == true or v == 1 then return true end
    end
    if inLive(lp) then return true end
    local fc = Modules.Fighter
    if fc and fc.LocalFighter and fc.LocalFighter.Entity and fc.LocalFighter.Entity.Parent then
        return true
    end
    return false
end

local function isInLobby()
    local now = os.clock()
    if now - Perf.lobbyCacheTime < 0.15 then return Perf.lobbyCache end
    Perf.lobbyCacheTime = now
    Perf.lobbyCache = not liveMatch()
    return Perf.lobbyCache
end

