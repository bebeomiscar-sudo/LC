local silentCfg = {
    enabled    = false,
    hitChance  = 100,
    prediction = 0,
    visCheck   = true,
    useCenter  = false,
    fovSize    = 150,
    maxDist    = 200,
}

local silentConn    = nil
local origRaycast   = nil
local origParticles = nil
local silentHooked  = false

-- Silent aim FOV circle
local silentCircle = Drawing.new("Circle")
silentCircle.Thickness = 1.5
silentCircle.Filled    = false
silentCircle.NumSides  = 64
silentCircle.Visible   = false
silentCircle.Radius    = 150
silentCircle.Color     = Color3.fromRGB(0, 200, 255)

local function getSilentTarget(origin)
    local center = aimbotCfg.useCenter
        and scr()
        or UserInputService:GetMouseLocation()

    local best, bestDist = nil, math.huge

    local myChar = lp.Character
    for _, p in pairs(Players:GetPlayers()) do
        if p == lp then continue end
        local char = p.Character
        if not char or char == myChar then continue end

        local head = char:FindFirstChild("Head")
        local hum  = char:FindFirstChildOfClass("Humanoid")
        if not head or not hum or hum.Health <= 0 then continue end

        if (origin - head.Position).Magnitude > silentCfg.maxDist then
            continue
        end

        if silentCfg.visCheck and not isVis(origin, head) then
            continue
        end

        local sp, vis = cam:WorldToViewportPoint(head.Position)
        if not vis then continue end

        local screenPos = Vector2.new(sp.X, sp.Y)
        local d = (screenPos - center).Magnitude

        if d < silentCfg.fovSize and d < bestDist then
            bestDist = d
            best = head
        end
    end

    return best
end

local function hookSilent()
    if silentHooked or not util then return end
    silentHooked = true

    -- Hook Raycast
    origRaycast = util.Raycast
    util.Raycast = function(self, origin, direction, distance, ...)
        if silentCfg.enabled then
            if math.random(1, 100) <= silentCfg.hitChance then
                local myRoot = lp.Character
                    and lp.Character:FindFirstChild("HumanoidRootPart")
                local orig   = myRoot and myRoot.Position
                    or cam.CFrame.Position

                local target = getSilentTarget(orig)
                if target then
                    -- Apply prediction
                    local predictedPos = target.Position
                    if silentCfg.prediction > 0 then
                        pcall(function()
                            local vel = target.Parent
                                and target.Parent:FindFirstChild("HumanoidRootPart")
                                and target.Parent.HumanoidRootPart.AssemblyLinearVelocity
                                or Vector3.zero
                            predictedPos = target.Position
                                + vel * (silentCfg.prediction * 0.05)
                        end)
                    end

                    local fakeDir = predictedPos - origin
                    return origRaycast(self, origin, fakeDir, distance, ...)
                end
            end
        end
        return origRaycast(self, origin, direction, distance, ...)
    end

    -- Hook PlayParticles (anti-flash/smoke)
    origParticles = util.PlayParticles
    util.PlayParticles = function(self, obj)
        if typeof(obj) == "Instance" then
            local n = obj.Name:lower()
            if n:find("flash") or n:find("smoke") or n:find("blind") then
                return
            end
        end
        return origParticles(self, obj)
    end
end

local function unhookSilent()
    if not silentHooked or not util then return end
    if origRaycast   then util.Raycast       = origRaycast   end
    if origParticles then util.PlayParticles = origParticles end
    origRaycast   = nil
    origParticles = nil
    silentHooked  = false
end

-- FOV circle update
RunService.RenderStepped:Connect(function()
    if not silentCfg.enabled then
        silentCircle.Visible = false
        return
    end

    silentCircle.Visible = true
    silentCircle.Radius  = silentCfg.fovSize

    local center = silentCfg.useCenter
        and scr()
        or UserInputService:GetMouseLocation()

    silentCircle.Position = center

    local myRoot = lp.Character
        and lp.Character:FindFirstChild("HumanoidRootPart")
    local orig = myRoot and myRoot.Position or cam.CFrame.Position
    local target = getSilentTarget(orig)

    silentCircle.Color = target
        and Color3.fromRGB(255, 50, 50)
        or  Color3.fromRGB(0, 200, 255)
end)

