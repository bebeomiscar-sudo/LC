local skinCfg={enabled=false,userid="1"}

local function applyskin(char)
    if not (skinCfg.enabled and char) then return end
    local h=char:WaitForChild("Humanoid",5)
    local targetId=tonumber(skinCfg.userid)
    if not h or not targetId then return end
    pcall(function()
        local model=Players:CreateHumanoidModelFromUserId(targetId)
        if not model then return end
        for _,obj in ipairs(char:GetChildren()) do
            if obj:IsA("Accessory") or obj:IsA("Shirt") or obj:IsA("Pants")
                or obj:IsA("BodyColors") or obj:IsA("CharacterMesh") or obj:IsA("ShirtGraphic") then
                obj:Destroy()
            end
        end
        local head=char:FindFirstChild("Head")
        if head then local face=head:FindFirstChildOfClass("Decal"); if face then face:Destroy() end end
        for _,obj in ipairs(model:GetChildren()) do
            if obj:IsA("Accessory") or obj:IsA("Shirt") or obj:IsA("Pants")
                or obj:IsA("BodyColors") or obj:IsA("CharacterMesh") or obj:IsA("ShirtGraphic") then
                obj:Clone().Parent=char
            elseif obj.Name=="Head" then
                local tf=obj:FindFirstChildOfClass("Decal")
                if tf and head then tf:Clone().Parent=head end
            end
        end
        model:Destroy()
    end)
end

