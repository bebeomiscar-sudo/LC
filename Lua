--//                   VOID SNAP / CSync
--// ═══════════════════════════════════════════════════════════

local function getLocalHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function clearVoidSnap()
    vfrSnap.cf = nil
    vfrSnap.lv = nil
    vfrSnap.av = nil
end

local LIM, DEAD = 2147483646, 1147483646

local function randSkip(mi, ma, dmi, dma)
    local v = math.random(mi, ma)
    while v >= dmi and v <= dma do v = math.random(mi, ma) end
    return v
end

local function snapToVoid(hrp)
    if not hrp then return end
    if isInLobby() then return end
    vfrSnap.cf = hrp.CFrame
    vfrSnap.lv = hrp.AssemblyLinearVelocity
    vfrSnap.av = hrp.AssemblyAngularVelocity
    pcall(function()
        local p = Vector3.new(
            randSkip(-LIM,LIM,-DEAD,DEAD),
            randSkip(-LIM,LIM,-DEAD,DEAD),
            randSkip(-LIM,LIM,-DEAD,DEAD)
        )
        hrp.CFrame = CFrame.new(p) * CFrame.Angles(math.pi, math.pi, math.pi)
        hrp.AssemblyLinearVelocity = p
        hrp.AssemblyAngularVelocity = p
    end)
end

-- VFR restore: runs every frame to counteract physics
RunService:BindToRenderStep("rivals_vfr", Enum.RenderPriority.First.Value, function()
    if not vfrSnap.cf then return end
    local hrp = getLocalHRP()
    if not hrp then return end
    pcall(function()
        hrp.CFrame = vfrSnap.cf
        hrp.AssemblyLinearVelocity = vfrSnap.lv
        hrp.AssemblyAngularVelocity = vfrSnap.av
    end)
end)

