local function ZeroCooldownsGC()
    pcall(function()
        for _, v in pairs(getgc(true)) do
            if type(v) ~= "table" then continue end
            for _, field in ipairs(COOLDOWN_FIELDS) do
                if rawget(v, field) ~= nil then
                    rawset(v, field, 0.001)
                end
            end
        end
    end)
end

local function ZeroCooldownsLib()
    if not ItemLibrary then return end
    local items = ItemLibrary.Items or ItemLibrary.Weapons or ItemLibrary.Utilities
    if type(items) ~= "table" then return end
    for _, item in pairs(items) do
        if type(item) ~= "table" then continue end
        for _, field in ipairs(COOLDOWN_FIELDS) do
            if item[field] ~= nil then
                pcall(function() rawset(item, field, 0.001) end)
            end
        end
    end
end

-- Katana no cooldown
local function ZeroKatanaCooldown()
    if not ItemLibrary then return false end
    local items = ItemLibrary.Items or ItemLibrary.Weapons
    if type(items) ~= "table" then return false end
    local found = false
    for name, item in pairs(items) do
        if type(item) == "table" then
            local iName = tostring(item.Name or name)
            if iName:lower():find("katana") then
                for _, field in ipairs(COOLDOWN_FIELDS) do
                    if item[field] ~= nil then
                        pcall(function() rawset(item, field, 0) end)
                        found = true
                    end
                end
            end
        end
    end
    -- Also GC scan for Katana tables
    pcall(function()
        for _, v in pairs(getgc(true)) do
            if type(v) == "table" and rawget(v, "Name") == "Katana" then
                for _, field in ipairs(COOLDOWN_FIELDS) do
                    if rawget(v, field) ~= nil then rawset(v, field, 0) end
                end
                found = true
            end
        end
    end)
    return found
end

-- War Horn zero cooldown
local function ZeroWarHornCooldown()
    if not ItemLibrary then return false end
    local items = ItemLibrary.Items or ItemLibrary.Utilities
    if type(items) ~= "table" then return false end
    local found = false
    local horns = {"War Horn","WarHorn","war horn","warhorn"}
    for name, item in pairs(items) do
        if type(item) == "table" then
            local iName = tostring(item.Name or name)
            for _, hn in ipairs(horns) do
                if iName == hn or name == hn then
                    for _, field in ipairs(COOLDOWN_FIELDS) do
                        if item[field] ~= nil then
                            pcall(function() rawset(item, field, 0) end)
                            found = true
                        end
                    end
                    break
                end
            end
        end
    end
    -- GC scan
    pcall(function()
        for _, v in pairs(getgc(true)) do
            if type(v) == "table" then
                local nm = rawget(v, "Name")
                if nm == "War Horn" or nm == "WarHorn" then
                    for _, field in ipairs(COOLDOWN_FIELDS) do
                        if rawget(v, field) ~= nil then rawset(v, field, 0) end
                    end
                    found = true
                end
            end
        end
    end)
    return found
end

local function SpoofDevice(deviceType)
    local target = DeviceSpoofs[deviceType]
    if not target then Notify("Device Spoofer","Unknown type",3);return end
    if not SetControlsRemote then
        SetControlsRemote = FighterRemotes:FindFirstChild("SetControls")
    end
    if not SetControlsRemote then
        Notify("Device Spoofer","Remote not found!",3)
        return
    end
    local ok, err2 = pcall(function()
        SetControlsRemote:FireServer(target)
    end)
    Notify("Device Spoofer", ok and ("Spoofed: " .. deviceType) or ("Error: " .. tostring(err2)), 3)
end

