local function stopSync()
    if not Cfg.state.csyncActive then return end
    if Cfg.orbit.connection then
        Cfg.orbit.connection:Disconnect()
        Cfg.orbit.connection = nil
    end
    Cfg.state.csyncActive  = false
    Cfg.orbit.active       = false
    Cfg.voidSpam.phase     = nil
    clearVFR()

    local saved = Cfg.orbit.savedPos
    local lf    = getLF()
    if saved and lf and lf.Entity and lf.Entity.RootPart
        and not (getgenv().InstanceUndergroundEnabled)
    then
        pcall(function() lf.Entity.RootPart.CFrame = saved end)
    end

    Cfg.orbit.savedPos  = nil
    Cfg.orbit.serverPos = nil
    oldCamPos           = nil
end

--// ═══════════════════════════════════════════════════════════
--//                     START SYNC
--// ═══════════════════════════════════════════════════════════

local function startSync()
    if Cfg.state.csyncActive then return end
    if Cfg.immune then return end
    if not Cfg.character then return end

    forceEquipSlot()
    Cfg.state.csyncActive = true
    Cfg.orbit.active      = true
    refreshOrbitSettings()

    local lf = getLF()
    if lf and lf.Entity and lf.Entity.RootPart and not Cfg.orbit.savedPos then
        Cfg.orbit.savedPos = lf.Entity.RootPart.CFrame
    end

    Cfg.orbit.connection = RunService.Heartbeat:Connect(function(dt)
        if not Cfg.state.csyncActive then return end
        if Cfg.immune then stopSync() return end
        if not Cfg.character then stopSync() return end

        local lf2 = getLF()
        if not lf2 or not lf2.Entity or not lf2.Entity.RootPart then stopSync() return end

        -- Save cam-sync position
        oldCamPos = lf2.Entity.RootPart.CFrame

        local weapon   = getWeaponName()
        local slingOn  = isSling(weapon)

        -- Skip if quick swap active (fists/utility)
        if not pickMelee() then
            local eq = lf2.EquippedItem
            if eq then
                local nm = getItemName(eq):lower()
                if nm:find("fist",1,true) or nm:find("utility",1,true) then return end
            end
        end

        forceEquipSlot()
        refreshOrbitSettings()

        -- Reload hide
        if Cfg.state.reloading and Cfg.rageStatus.hideOnReload then
            local hrp = getHRP()
            if hrp and not slingOn then
                snapVoid(hrp)
            else
                local rx = math.random(-10000, 10000)
                local rz = math.random(-10000, 10000)
                Cfg.orbit.serverPos = Vector3.new(rx, -9999999999, rz)
                if slingOn then
                    pcall(function() lf2.Entity.RootPart.CFrame = CFrame.new(Cfg.orbit.serverPos) end)
                end
            end
            return
        end

        -- Void spam (non-sling)
        if not slingOn and Cfg.voidSpam.enabled and not Cfg.immune then
            tickVoidSpam()
            if Cfg.voidSpam.phase == "hide" then
                local hrp = getHRP()
                if hrp then
                    snapVoid(hrp)
                else
                    local rx = math.random(-10000, 10000)
                    local rz = math.random(-10000, 10000)
                    Cfg.orbit.serverPos = Vector3.new(rx, -9999999999, rz)
                    pcall(function() lf2.Entity.RootPart.CFrame = CFrame.new(Cfg.orbit.serverPos) end)
                end
                return
            end
        end

        -- Out of ammo hide
        if Cfg.state.outOfAmmo and not slingOn and not isInfiniteWeapon() then
            local hrp = getHRP()
            if hrp then
                snapVoid(hrp)
            else
                local rx = math.random(-10000, 10000)
                local rz = math.random(-10000, 10000)
                Cfg.orbit.serverPos = Vector3.new(rx, -9999999999, rz)
                pcall(function() lf2.Entity.RootPart.CFrame = CFrame.new(Cfg.orbit.serverPos) end)
            end
            return
        end

        clearVFR()

        -- Validate target
        local targetChar = Cfg.character
        if not targetChar or not targetChar.Parent then stopSync() return end
        local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
        if not targetRoot then stopSync() return end

        -- Slingshot: position above + behind target
        if slingOn and VH.active then
            local flat = Vector3.new(
                targetRoot.CFrame.LookVector.X, 0,
                targetRoot.CFrame.LookVector.Z
            ).Unit
            Cfg.orbit.serverPos = targetRoot.Position + Vector3.new(0, 15, 0) + flat * 5
        end

        -- Compute orbit position
        local base   = orbitBase(targetRoot)
        Cfg.orbit.angle = Cfg.orbit.angle + Cfg.orbit.speed * dt
        local offset = Vector3.new(
            math.cos(Cfg.orbit.angle) * Cfg.orbit.radius,
            Cfg.orbit.height,
            math.sin(Cfg.orbit.angle) * Cfg.orbit.radius
        )
        Cfg.orbit.serverPos = base + offset

        -- Apply to entity
        if not getgenv().InstanceUndergroundEnabled then
            local newCF   = CFrame.new(Cfg.orbit.serverPos)
            local curCF   = lf2.Entity.RootPart.CFrame
            local moveDist = (newCF.Position - curCF.Position).Magnitude
            if moveDist < 2000 then
                pcall(function()
                    lf2.Entity.RootPart.CFrame = newCF
                    Cfg.orbit.savedPos = curCF
                end)
            end
        end
    end)
end

--// ═══════════════════════════════════════════════════════════
--//           IMPROVED PREDICTION (Ring Buffer + Accel)
--// ═══════════════════════════════════════════════════════════

local function pushVelBuf(vel)
    local buf = Cfg.pred.velBuf
    table.insert(buf, vel)
    if #buf > Cfg.pred.maxBuf then table.remove(buf, 1) end
end

local function avgVel()
    local buf = Cfg.pred.velBuf
    if #buf == 0 then return Vector3.zero end
    local sum = Vector3.zero
    for _, v in ipairs(buf) do sum = sum + v end
    return sum / #buf
end

local function updatePrediction()
    if not Cfg.character or not Cfg.pred.enabled then
        Cfg.pred.velocity = Vector3.zero
        Cfg.pred.accel    = Vector3.zero
        Cfg.pred.lastPos  = nil
        Cfg.pred.lastVel  = nil
        return
    end
    local root = Cfg.character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local now = tick()
    local dt  = now - Cfg.pred.lastTime

    if dt > 0 and dt < 0.1 then
        local curPos = root.Position
        if Cfg.pred.lastPos then
            local instVel = (curPos - Cfg.pred.lastPos) / dt
            pushVelBuf(instVel)
            local smoothVel = avgVel()

            -- Compute acceleration from velocity delta
            if Cfg.pred.lastVel then
                local instAccel = (smoothVel - Cfg.pred.lastVel) / dt
                Cfg.pred.accel  = Cfg.pred.accel:Lerp(instAccel, 0.4)
            end
            Cfg.pred.lastVel = smoothVel
            Cfg.pred.velocity = smoothVel
        end
        Cfg.pred.lastPos  = curPos
        Cfg.pred.lastTime = now
    elseif dt >= 0.1 then
        -- Gap detected, reset buffer
        Cfg.pred.velBuf  = {}
        Cfg.pred.lastPos = root.Position
        Cfg.pred.lastVel = nil
        Cfg.pred.lastTime = now
    end
end

local function getPing()
    local ping = 0
    pcall(function()
        ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000
    end)
    return math.clamp(ping, 0, 0.5)
end

local function predictPosition(part, origin)
    if not Cfg.pred.enabled or not part then
        return part and part.Position or Vector3.zero
    end
    local ping    = getPing()
    local dist    = (part.Position - origin).Magnitude
    local travel  = dist / 3000
    local total   = (travel + ping) * Cfg.pred.multiplier
    -- Apply velocity + 0.5 * accel * t^2 (kinematic extrapolation)
    local pos = part.Position
        + Cfg.pred.velocity * total
        + Cfg.pred.accel    * (0.5 * total * total)
    return pos
end

