--   AIMBOT
-- =============================================

local aimbotConfig = {
    enabled        = false,
    speed          = 1,
    speedInAttack  = 1,
    speedScale     = 1,
    maxLockTime    = 3,
    reactionTime   = 0,
    visibleCheck   = true,
    teamCheck      = true,
    currentTarget  = nil,
    lockStartTime  = 0,
}

local aimbotConn = nil

local function getAimbotTarget()
    local camPos  = workspace.CurrentCamera.CFrame.Position
    local camLook = workspace.CurrentCamera.CFrame.LookVector
    local lf      = getLocalFighter()

    local bestFighter = nil
    local bestAngle   = math.huge

    for _, fighter in pairs(getAllFighters()) do
        pcall(function()
            if fighter == lf then return end
            if not isAlive(fighter) then return end
            if aimbotConfig.teamCheck and isTeammate(fighter) then return end

            local headPos = getFighterHeadPos(fighter)
            if not headPos then return end

            if aimbotConfig.visibleCheck then
                local model = fighter.Entity.Model
                if not isVisible(camPos, headPos, model) then return end
            end

            local toEnemy = (headPos - camPos).Unit
            local angle   = Utility and
                Utility:AngleBetweenVectors(camLook, toEnemy) or
                math.acos(math.clamp(camLook:Dot(toEnemy), -1, 1))

            if angle < bestAngle then
                bestAngle   = angle
                bestFighter = fighter
            end
        end)
    end

    return bestFighter
end

local function startAimbot()
    if aimbotConn then
        aimbotConn:Disconnect()
        aimbotConn = nil
    end

    aimbotConn = RunService.RenderStepped:Connect(function(dt)
        if not aimbotConfig.enabled then return end
        if not CameraController then return end

        pcall(function()
            -- Reaction time delay
            if aimbotConfig.reactionTime > 0 then
                -- reactionTime is in ms converted to seconds
                -- handled by locking after delay
            end

            local target = getAimbotTarget()
            aimbotConfig.currentTarget = target

            if not target then return end

            -- Check max lock time
            if tick() - aimbotConfig.lockStartTime > aimbotConfig.maxLockTime then
                aimbotConfig.lockStartTime = tick()
                return
            end

            local headPos = getFighterHeadPos(target)
            if not headPos then return end

            local camPos  = workspace.CurrentCamera.CFrame.Position
            local dir     = (headPos - camPos)

            -- Calculate pitch and yaw
            local yaw   = math.atan2(dir.X, -dir.Z)
            local pitch = math.atan2(
                -dir.Y,
                Vector2.new(dir.X, dir.Z).Magnitude
            )

            local targetRot = Vector2.new(pitch, yaw)
            local currentRot = CameraController.Rotation

            -- Check if in attack
            local lf = getLocalFighter()
            local inAttack = false
            pcall(function()
                if lf and lf.EquippedItem then
                    inAttack = lf.EquippedItem:Get("IsAiming") or false
                end
            end)

            local speed = inAttack
                and aimbotConfig.speedInAttack
                or  aimbotConfig.speed

            -- Apply speed scale
            speed = speed * aimbotConfig.speedScale

            -- Smooth lerp toward target
            local newRot = Vector2.new(
                currentRot.X + (targetRot.X - currentRot.X)
                    * math.clamp(speed * dt * 60, 0, 1),
                currentRot.Y + (targetRot.Y - currentRot.Y)
                    * math.clamp(speed * dt * 60, 0, 1)
            )

            CameraController:SetRotation(newRot)
        end)
    end)
end

local function stopAimbot()
    if aimbotConn then
        aimbotConn:Disconnect()
        aimbotConn = nil
    end
    aimbotConfig.currentTarget = nil
end

