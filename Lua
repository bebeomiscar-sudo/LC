            }
        end
        local obj = dummyEspObjects[dummy]
        local hrp = dummy:FindFirstChild("HumanoidRootPart")
        local hum = dummy:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then continue end
        local sp, on = cam:WorldToViewportPoint(hrp.Position)
        if not on then continue end
        local headSP, headOn = cam:WorldToViewportPoint(hrp.Position + Vector3.new(0, 2, 0))
        local footSP, footOn = cam:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
        if not headOn or not footOn then continue end
        local h = math.abs(headSP.Y - footSP.Y)
