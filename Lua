    -- ============================================================

    local cooldownCfg={enabled=false,warHornOnly=false,loopActive=false,loopInterval=2}
    local cooldownLoop=nil

    local function zeroCooldowns(item)
        for _,f in ipairs(COOLDOWN_FIELDS) do
            if item[f]~=nil then rawset(item,f,0) end
        end
    end

    local function setFastCooldowns()
        pcall(function()
            for _,v in pairs(getgc(true)) do
                if type(v)=="table" then
                    for _,f in ipairs(COOLDOWN_FIELDS) do
                        if rawget(v,f) then rawset(v,f,0.001) end
                    end
                end
            end
        end)
    end

    local function patchWarHorn()
        local ok,res=pcall(function()
            local Modules=ReplicatedStorage:FindFirstChild("Modules"); if not Modules then return false end
            local il=Modules:FindFirstChild("ItemLibrary"); if not il then return false end
            local ok2,IL=pcall(require,il); if not ok2 or type(IL)~="table" then return false end
            local items=IL.Items or IL.Weapons or IL.Utilities; if type(items)~="table" then return false end
            local patched=false
            for name,item in pairs(items) do
                if type(item)=="table" and (WAR_HORN_KEYS[name] or WAR_HORN_KEYS[item.Name or ""]) then
                    zeroCooldowns(item); patched=true
                end
            end
            return patched
        end)
        return ok and res or false
    end

    local function startCooldownLoop()
        cooldownCfg.loopActive=true
        cooldownLoop=task.spawn(function()
            while cooldownCfg.loopActive do
                if cooldownCfg.warHornOnly then patchWarHorn() else setFastCooldowns() end
                task.wait(cooldownCfg.loopInterval)
            end
        end)
    end

