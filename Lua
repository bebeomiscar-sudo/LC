    -- Draw functions
    local function drawBox(obj, sz, pos)
        local cfg = GC.Box
        if not (cfg.MasterEnabled and cfg.Enable) then
            obj.box.square.Visible  = false
            obj.box.outline.Visible = false
            obj.box.inline.Visible  = false
            return
        end
        local w = math.max(math.floor(sz.X), 4)
        local h = math.max(math.floor(sz.Y), 8)
        sz  = Vector2.new(w, h)
        pos = Vector2.new(math.floor(pos.X), math.floor(pos.Y))
        local c2 = cfg.OutlineColor2 or cfg.OutlineColor

        obj.box.square.Visible   = true
        obj.box.square.Position  = pos
        obj.box.square.Size      = sz
        obj.box.square.Color     = lerpc(cfg.OutlineColor, c2, 0.5)
        obj.box.square.Thickness = 1
        obj.box.square.Filled    = false

        obj.box.outline.Visible   = true
        obj.box.outline.Position  = pos - Vector2.new(1,1)
        obj.box.outline.Size      = sz + Vector2.new(2,2)
        obj.box.outline.Color     = Color3.new(0,0,0)
        obj.box.outline.Thickness = 1
        obj.box.outline.Filled    = false

        obj.box.inline.Visible   = true
        obj.box.inline.Position  = pos + Vector2.new(1,1)
        obj.box.inline.Size      = Vector2.new(math.max(w-2,2), math.max(h-2,4))
        obj.box.inline.Color     = Color3.new(0,0,0)
        obj.box.inline.Thickness = 1
        obj.box.inline.Filled    = false
    end

    local espClock = 0
    local function drawFill(obj, sz, pos)
        local cfg = GC.Filled
        if not cfg.Enable then obj.filled.Visible = false return end
        obj.filled.Visible              = true
        obj.filled.BackgroundTransparency = cfg.Transparency
        obj.filled.Position             = UDim2.fromOffset(pos.X, pos.Y)
        obj.filled.Size                 = UDim2.fromOffset(sz.X, sz.Y)
        obj.filledGrad.Color = ColorSequence.new({
