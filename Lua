local function acSafeTrace()
    local ok,t = _ENV.pcall(debug.traceback)
    return ok and t or ""
end

local function isACTrace(trace)
    if trace=="" then return false,nil end
    for _,t in _ENV.ipairs(AC_TARGETS) do
        if trace:find(t,1,true) then return true,t end
    end
    return false,nil
end

local function isFlagKey(key)
    if _ENV.type(key)~="string" then return false end
    return FLAG_KEYS[key:lower()]==true
end

local function isSpoofKey(key)
    if _ENV.type(key)~="string" then return false end
    return SPOOF_KEYS[key:lower()]==true
end

local function buildHookedWeakTable(originalTable, mode, controller)
    local storage = {}
    if _ENV.type(originalTable)=="table" then
        for k,v in _ENV.next, originalTable do
            _ENV.rawset(storage, k, v)
        end
    end
    local proxyMeta = {
        __mode = mode,
        __newindex = function(t,k,v)
            if isFlagKey(k) then ACState.blockedWrites+=1; return end
            _ENV.rawset(storage,k,v)
        end,
        __index = function(t,k)
            if isFlagKey(k)  then ACState.spoofedReads+=1; return nil end
            if isSpoofKey(k) then ACState.spoofedReads+=1; return 0   end
            return _ENV.rawget(storage,k)
        end,
        __len   = function() return 0 end,
        __pairs = function(t)
            local function filtered(_,k)
                local nk,nv = _ENV.next(storage,k)
                while nk~=nil and isFlagKey(nk) do nk,nv=_ENV.next(storage,nk) end
                return nk,nv
            end
            return filtered,t,nil
        end,
    }
    ACState.hookedTables[controller] = {proxy=storage,meta=proxyMeta,mode=mode}
    return _ENV.setmetatable(storage,proxyMeta)
end

do
    local _old; _old = hookfunction(getrenv().setmetatable,newcclosure(function(Table,Metatable)
        if _ENV.type(Metatable)=="table" then
            local mode = _ENV.rawget(Metatable,"__mode")
            if mode=="kv" or mode=="k" or mode=="v" then
                local trace=acSafeTrace(); local isAC,which=isACTrace(trace)
                if isAC then
                    if not ACState.intercepted[which] then
                        ACState.intercepted[which]=true
                        print(("[ACBypass] Intercepted: %s [%s]"):format(which,mode))
                    end
                    return buildHookedWeakTable(Table,mode,which)
                end
            end
        end
        return _old(Table,Metatable)
    end))
    ACState.hooks.setmetatable = _old
end

do
    local _old; _old = hookfunction(getrenv().getmetatable,newcclosure(function(Table)
        for _,data in _ENV.next, ACState.hookedTables do
            if Table==data.proxy then return {__mode=data.mode} end
        end
        return _old(Table)
    end))
    ACState.hooks.getmetatable = _old
end

