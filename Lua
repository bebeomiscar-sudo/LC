        if rageCfg.enabled and rageCfg.character and rageValid(rageCfg.character) then
            startsync()
        end
    end
end)

-- =============================================
--   ✅ AUTOSHOOT (from source — replaces old)
-- =============================================

local function autoshoot()
    if not rageCfg.enabled or not rageCfg.character or not rageCfg.autoshoot then return end
    if rageCfg.immune then return end
    if rageCfg.voidspam.enabled and rageCfg.voidspam.phase == "hide" then return end

    local weapon     = getweapon()
    local checksling = isSling(weapon)

    eqSlot()

    local lf = FighterController and FighterController.LocalFighter
    if not lf or not lf.EquippedItem then return end

    if not isInfiniteWeapon() then
        if rageCfg.state.reloading or rageCfg.state.outofammo then return end
        if not canuse() then return end
    end

    local targetChar = rageCfg.character
    if not rageValid(targetChar) then return end

    local hitPart = hitpartfromname(targetChar, rageCfg.hitpart)
    if not hitPart then return end

    -- ✅ Shoot position logic (from source)
    local shootPos, targetPos

    if rageCfg.vhState.active and checksling then
        local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        shootPos  = root and root.Position or Vector3.new()
        targetPos = predict(hitPart, shootPos)
    else
        if rageCfg.vhState.active then
            local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            shootPos = myRoot and myRoot.Position or Vector3.new()
        elseif rageCfg.state.csyncactive and rageCfg.orbit.serverpos then
            shootPos = rageCfg.orbit.serverpos
        else
            local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            shootPos   = root and root.Position or Vector3.new()
        end
        targetPos = predict(hitPart, shootPos)
    end

    -- ✅ Build data packet (from source)
    local data = {
        [utf8.char(1)] = {
            [utf8.char(0)] = util:EncodeCFrame(CFrame.new(shootPos, targetPos)),
            [utf8.char(1)] = util:EncodeCFrame(CFrame.new(shootPos, targetPos)),
            [utf8.char(2)] = hitPart,
            [utf8.char(3)] = util:EncodeCFrame(CFrame.new(0.43, 0.25, 0.42)),
        },
    }

    local equipped = lf.EquippedItem
    if equipped and equipped:Get("ObjectID") then
        ragePerf.lastAttackTick = tick()
        local attempts = math.clamp(math.floor(tonumber(rageCfg.shootAttempts) or 1), 1, 3)
        for _ = 1, attempts do
            pcall(function()
                UseItemRemote:FireServer(
                    equipped:Get("ObjectID"),
                    enums:ToEnum("StartShooting"),
                    data,
                    nil
                )
            end)
        end
    end
end

