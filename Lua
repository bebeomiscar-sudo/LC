-- =============================================

local silentConfig = {
    enabled      = false,
    hitChance    = 100,
    prediction   = 0,
    visibleCheck = true,
    teamCheck    = true,
}

local silentConn = nil

local function getSilentTarget()
    local camPos  = workspace.CurrentCamera.CFrame.Position
    local camLook = workspace.CurrentCamera.CFrame.LookVector
    local lf      = getLocalFighter()

    local bestFighter = nil
    local bestAngle   = math.huge

    for _, fighter in pairs(getAllFighters()) do
        pcall(function()
            if fighter == lf then return end
            if not isAlive(fighter) then return end
            if silentConfig.teamCheck and isTeammate(fighter) then return end

            local headPos = getFighterHeadPos(fighter)
            if not headPos then return end

            if silentConfig.visibleCheck then
                local model = fighter.Entity.Model
                if not isVisible(camPos, headPos, model) then return end
            end

            local toEnemy = (headPos - camPos).Unit
            local angle   = Utility and
                Utility:AngleBetweenVectors(camLook, toEnemy) or
                math.acos(math.clamp(camLook:Dot(toEnemy), -1, 1))

            if angle < bestAngle then
                bestAngle   = angle
                bestFighter = fighter
            end
        end)
    end

    return bestFighter
end

local function startSilentAim()
    if silentConn then
        silentConn:Disconnect()
        silentConn = nil
    end

    silentConn = RunService.Heartbeat:Connect(function(dt)
        if not silentConfig.enabled then return end
        if not Utility then return end

        pcall(function()
            -- Hit chance check
            if math.random(1, 100) > silentConfig.hitChance then
                return
            end

            local target = getSilentTarget()
            if not target then return end

            local headPos = getFighterHeadPos(target)
            if not headPos then return end

            local camPos = workspace.CurrentCamera.CFrame.Position

            -- Apply prediction
            local predictedPos = headPos
            if silentConfig.prediction > 0 then
                pcall(function()
                    local vel = target.Entity.RootPart.AssemblyLinearVelocity
                    predictedPos = headPos + vel * (silentConfig.prediction * 0.1)
                end)
            end

            local dir   = (predictedPos - camPos)
            local yaw   = math.atan2(dir.X, -dir.Z)
            local pitch = math.atan2(
                -dir.Y,
                Vector2.new(dir.X, dir.Z).Magnitude
            )

            local rotation = Vector2.new(pitch, yaw)
            local encoded  = Utility:EncodeCameraRotation(rotation)

            UpdateCamRemote:FireServer(encoded, nil)
        end)
    end)
end

local function stopSilentAim()
    if silentConn then
        silentConn:Disconnect()
        silentConn = nil
    end
end

