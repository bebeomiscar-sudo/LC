    local function zeroCooldowns(item)
        for _,field in ipairs(COOLDOWN_FIELDS) do
            if item[field]~=nil then rawset(item,field,0) end
        end
    end

    local function setFastCooldowns()
        pcall(function()
            for _,v in pairs(getgc(true)) do
                if type(v)=="table" then
                    for _,field in ipairs(COOLDOWN_FIELDS) do
                        if rawget(v,field) then rawset(v,field,0.001) end
                    end
                end
            end
        end)
        pcall(function()
            local Modules=ReplicatedStorage:FindFirstChild("Modules");if not Modules then return end
            local ils=Modules:FindFirstChild("ItemLibrary");if not ils then return end
            local ok,IL=pcall(require,ils);if not ok or type(IL)~="table" then return end
            local items=IL.Items or IL.Weapons or IL.Utilities;if type(items)~="table" then return end
            for _,item in pairs(items) do if type(item)=="table" then zeroCooldowns(item) end end
        end)
        print("[FastCooldowns] ✅")
    end

    local function patchWarHorn()
        local ok2,result=pcall(function()
            local Modules=ReplicatedStorage:FindFirstChild("Modules");if not Modules then return false end
            local ils=Modules:FindFirstChild("ItemLibrary");if not ils then return false end
            local ok,IL=pcall(require,ils);if not ok or type(IL)~="table" then return false end
            local items=IL.Items or IL.Weapons or IL.Utilities;if type(items)~="table" then return false end
            local patched=false
            for name,item in pairs(items) do
                if type(item)=="table" then
                    local itemName=item.Name or name
                    if WAR_HORN_KEYS[name] or WAR_HORN_KEYS[itemName] then
                        zeroCooldowns(item);patched=true
                    end
                end
            end
            return patched
        end)
        return ok2 and result or false
    end

    local cooldownLoopTask=nil
    local cooldownCfg={enabled=false,warHornOnly=false,loopInterval=2}

    local function startCooldownLoop()
        cooldownLoopTask=task.spawn(function()
            while cooldownCfg.enabled do
                if cooldownCfg.warHornOnly then patchWarHorn() else setFastCooldowns() end
                task.wait(cooldownCfg.loopInterval)
            end
        end)
    end

