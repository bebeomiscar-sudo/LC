--//               IMMUNE DETECTION (IMPROVED)
--//   Checks both Attachment presence AND fighter data
--// ═══════════════════════════════════════════════════════════

local function checkImmune(plr, char)
    if not plr or not char then return false end
    -- Method 1: HRP attachment (original check)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp and hrp:FindFirstChildOfClass("Attachment") then return true end
    -- Method 2: Fighter immune attribute
    local imm = plr:GetAttribute("Immune") or plr:GetAttribute("IsImmune") or plr:GetAttribute("Invincible")
    if imm == true or imm == 1 then return true end
    -- Method 3: Fighter module data
    local fc = Mod.Fighter
    if fc and type(fc.GetFighter) == "function" then
        local ok, f = pcall(fc.GetFighter, fc, plr)
        if ok and f then
            local isImm = f.Immune or f.IsImmune or f.Invincible
            if isImm == true or isImm == 1 then return true end
        end
    end
    return false
end

RunService.Heartbeat:Connect(function()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local char   = plr.Character
        local immune = char and checkImmune(plr, char)

        if immune and not Perf.immuneList[plr.Name] then
            Perf.immuneList[plr.Name] = true
            for _, cb in ipairs(Perf.onImmune) do cb(plr) end

        elseif not immune and Perf.immuneList[plr.Name] then
            Perf.immuneList[plr.Name] = nil
            for _, cb in ipairs(Perf.onVulnerable) do cb(plr) end
        end
    end
end)

table.insert(Perf.onImmune, function(plr)
    if Cfg.lastPlayer == plr then
        Cfg.immune         = true
        Cfg.voidSpam.phase = nil
        clearVFR()
        stopSync()
    end
end)

table.insert(Perf.onVulnerable, function(plr)
    if Cfg.lastPlayer == plr then
        Cfg.immune = false
        if Cfg.enabled and Cfg.character and validTarget(Cfg.character) then
            startSync()
        end
    end
end)

