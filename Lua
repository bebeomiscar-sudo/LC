local function httpGetRetry(url, retries, delay)
    retries = retries or 8
    delay   = delay   or 3
    for attempt = 1, retries do
        local ok, res = pcall(function() return game:HttpGet(url) end)
        if ok and res and #res > 10 then return res end
        warn(("[Rivals] HTTP attempt %d/%d failed"):format(attempt, retries))
        task.wait(delay)
        delay = math.min(delay + 1, 8)
    end
    return nil
end

