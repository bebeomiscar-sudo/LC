-- ============================================================
--   ▓▓▓  BULLET TRACER SYSTEM  ▓▓▓
-- ============================================================
--[[
    Inspired by the tracer example — fully rebuilt for our UI.
    Features:
    · Line style (2D drawing) + Beam style (3D workspace)
    · Multiple beam textures (Line/Beam/Lightning/Laser etc)
    · Lerp draw speed (bullets travel animation)
    · Fade time per tracer
    · Per-tracer lifetime
    · Outline on line tracers
    · Deduplication (no double tracers per shot)
    · Hook TracerEffect module for auto fire detection
    · Manual fire via UseItem remote hook
]]

local TracerCfg = {
    Enabled      = false,
    Color        = Color3.fromRGB(255, 255, 255),
    Duration     = 3.0,
    FadeTime     = 0.5,
    Size         = 1.0,
    LerpSpeed    = 0,       -- 0 = instant draw, >0 = lerp
    Style        = "Line",  -- Line / Beam / Lightning / Laser / etc
    ShowOutline  = true,
    OutlineColor = Color3.fromRGB(0, 0, 0),
    StartPoint   = "Muzzle", -- Muzzle / Camera / Character
}

local TRACER_STYLES = {"Line","Beam","Lightning","Heartrate","Chain","Glitch","Swirl","Neon","Plasma","Laser"}

local TRACER_TEXTURES = {
    Line      = "",
    Beam      = "rbxassetid://12781852245",
    Lightning = "rbxassetid://446111271",
    Heartrate = "rbxassetid://5830549480",
    Chain     = "rbxassetid://9632168658",
    Glitch    = "rbxassetid://8089467613",
    Swirl     = "rbxassetid://5638168605",
    Neon      = "rbxassetid://6361963422",
    Plasma    = "rbxassetid://8993645509",
    Laser     = "rbxassetid://14549123968",
}

local activeTracers        = {}
local tracerConn           = nil
local tracerHooked         = false
local tracerOldFunc        = nil
local tracerDedup          = {}
local TRACER_DEDUP_INT     = 0.1
local TRACER_DEDUP_EXP     = 1.0
local tracerFrameCount     = 0

local function TracerGetStartPos()
    if TracerCfg.StartPoint == "Muzzle" then
        local mp = GetMuzzlePos()
        if mp then return mp end
    end
    if TracerCfg.StartPoint == "Camera" then
        return cam.CFrame.Position
    end
    -- Character
    local myChar = lp.Character
    local hrp    = myChar and myChar:FindFirstChild("HumanoidRootPart")
    return hrp and hrp.Position or cam.CFrame.Position
end

local function TracerGetDrawEnd(tr, age)
    if TracerCfg.LerpSpeed <= 0 then return tr.EndPos end
    local drawTime = math.max(TracerCfg.LerpSpeed * 0.25, 0.001)
    local progress = math.clamp(age / drawTime, 0, 1)
    return tr.StartPos:Lerp(tr.EndPos, progress)
end

local function TracerMakeLine(startPos, endPos)
    local outline = Drawing.new("Line")
    outline.Thickness    = 4 * TracerCfg.Size
    outline.Color        = TracerCfg.OutlineColor
    outline.Transparency = 1
    outline.Visible      = false

    local line = Drawing.new("Line")
    line.Thickness    = 2 * TracerCfg.Size
    line.Color        = TracerCfg.Color
    line.Transparency = 1
    line.Visible      = false

    table.insert(activeTracers, {
        IsLine      = true,
        Outline     = outline,
        Line        = line,
        StartPos    = startPos,
        EndPos      = endPos,
        Lifetime    = TracerCfg.Duration,
        FadeTime    = TracerCfg.FadeTime,
        CreatedAt   = tick(),
    })
end

local function TracerMakeBeam(startPos, endPos)
    local a0 = Instance.new("Attachment"); a0.Parent = Workspace.Terrain
    local a1 = Instance.new("Attachment"); a1.Parent = Workspace.Terrain

    local beam             = Instance.new("Beam")
    beam.Attachment0       = a0
    beam.Attachment1       = a1
    beam.Color             = ColorSequence.new(TracerCfg.Color)
    local baseW            = TracerCfg.Style == "Laser" and 0.02 or 0.15
    beam.Width0            = baseW * TracerCfg.Size
    beam.Width1            = baseW * TracerCfg.Size
    beam.Transparency      = NumberSequence.new(0)
    beam.FaceCamera        = true
    beam.LightEmission     = 0.8
    beam.LightInfluence    = 0.2
    local tex              = TRACER_TEXTURES[TracerCfg.Style]
    if tex and tex ~= "" then
        beam.Texture       = tex
        beam.TextureLength = 4
        beam.TextureSpeed  = 1
    else
        beam.Texture       = ""
        beam.TextureLength = 1
        beam.TextureSpeed  = 0
    end
    beam.Parent = Workspace.Terrain
    a0.WorldPosition = startPos
    a1.WorldPosition = endPos

    table.insert(activeTracers, {
        IsLine      = false,
        Beam        = beam,
        A0          = a0,
        A1          = a1,
        StartPos    = startPos,
        EndPos      = endPos,
        Lifetime    = TracerCfg.Duration,
        FadeTime    = TracerCfg.FadeTime,
        CreatedAt   = tick(),
    })
end

local function TracerCreate(startPos, endPos)
    if not TracerCfg.Enabled or not startPos or not endPos then return end

    -- Deduplication check
    local function quantize(v)
        return math.floor(v.X*5+0.5)*1e9 + math.floor(v.Y*5+0.5)*1e6 + math.floor(v.Z*5+0.5)*1e3
    end
    local key  = quantize(startPos) + quantize(endPos)*1e-6
    local now  = tick()
    local last = tracerDedup[key]
    if last and (now-last) < TRACER_DEDUP_INT then return end
    tracerDedup[key] = now

    if TracerCfg.Style == "Line" then
        TracerMakeLine(startPos, endPos)
    else
        TracerMakeBeam(startPos, endPos)
    end
end

local function TracerDestroyOne(tr)
    if tr.IsLine then
        if tr.Outline then pcall(tr.Outline.Remove, tr.Outline) end
        if tr.Line    then pcall(tr.Line.Remove,    tr.Line)    end
    else
        if tr.Beam then pcall(tr.Beam.Destroy,    tr.Beam) end
        if tr.A0   then pcall(tr.A0.Destroy,      tr.A0)   end
        if tr.A1   then pcall(tr.A1.Destroy,      tr.A1)   end
    end
end

local function TracerUpdate()
    if #activeTracers == 0 then return end

    tracerFrameCount = tracerFrameCount + 1
    local now = tick()
    local camNow = cam

    -- Prune dedup cache periodically
    if tracerFrameCount % 120 == 0 then
        for k, t in next, tracerDedup do
            if (now-t) > TRACER_DEDUP_EXP then tracerDedup[k]=nil end
        end
    end

    local i = #activeTracers
    while i >= 1 do
        local tr  = activeTracers[i]
        local age = now - tr.CreatedAt

        if age >= tr.Lifetime then
            TracerDestroyOne(tr)
            activeTracers[i] = activeTracers[#activeTracers]
            activeTracers[#activeTracers] = nil
        else
            -- Fade alpha
            local fadeStart = tr.Lifetime - tr.FadeTime
            local alpha     = age >= fadeStart
                and 1 - math.clamp((age-fadeStart)/tr.FadeTime, 0, 1)
                or  1

            local drawEnd = TracerGetDrawEnd(tr, age)

            if tr.IsLine then
                local visible = false
                local s2, onS = camNow:WorldToViewportPoint(tr.StartPos)
                local e2, onE = camNow:WorldToViewportPoint(drawEnd)

                if onS and onE then
                    local sx, sy = s2.X, s2.Y
                    local ex, ey = e2.X, e2.Y
                    if math.abs(sx)<20000 and math.abs(sy)<20000
                    and math.abs(ex)<20000 and math.abs(ey)<20000 then
                        local dx = ex-sx; local dy = ey-sy
                        local len = math.sqrt(dx*dx+dy*dy)
                        if len > 0.1 and len < 3000 then
                            local fvs = Vector2.new(sx,sy)
                            local fve = Vector2.new(ex,ey)

                            if TracerCfg.ShowOutline then
                                tr.Outline.From          = fvs
                                tr.Outline.To            = fve
                                tr.Outline.Transparency  = alpha
                                tr.Outline.Color         = TracerCfg.OutlineColor
                                tr.Outline.Visible       = true
                            else
                                tr.Outline.Visible = false
                            end

                            tr.Line.From         = fvs
                            tr.Line.To           = fve
                            tr.Line.Transparency = alpha
                            tr.Line.Color        = TracerCfg.Color
                            tr.Line.Visible      = true
                            visible = true
                        end
                    end
                end

                if not visible then
                    tr.Outline.Visible = false
                    tr.Line.Visible    = false
                end
            else
                if tr.A0 then tr.A0.WorldPosition = tr.StartPos end
                if tr.A1 then tr.A1.WorldPosition = drawEnd end
                if tr.Beam then
                    tr.Beam.Transparency = NumberSequence.new(1-alpha)
                    tr.Beam.Color        = ColorSequence.new(TracerCfg.Color)
                end
            end
        end

        i = i - 1
    end
end

-- Hook UseItem remote to detect shots
local function TracerHookRemote()
    if tracerHooked then return end
    -- Hook GunModule to intercept shot data
    if GunModule then
        local orig = rawget(GunModule, "StartShooting")
        if orig and orig ~= tracerOldFunc then
            tracerOldFunc = orig
            local ok = pcall(function()
                rawset(GunModule, "StartShooting", function(self2, ...)
                    local results = {orig(self2, ...)}
                    if TracerCfg.Enabled
                    and self2.ClientFighter
                    and self2.ClientFighter.IsLocalPlayer then
                        local sd = results[3]
                        if sd and type(sd) == "table" then
                            local hitPart = sd[utf8.char(2)]
                            if hitPart and hitPart:IsA("BasePart") then
                                local startPos = TracerGetStartPos()
                                local endPos   = hitPart.Position
                                TracerCreate(startPos, endPos)
                            end
                        end
                    end
                    return table.unpack(results)
                end)
            end)
            if ok then
                tracerHooked = true
                print("[Tracer] Hooked via GunModule")
            end
        end
    end
end

local function TracerUnhook()
    if not tracerHooked or not GunModule then return end
    pcall(function()
        if tracerOldFunc then
            rawset(GunModule, "StartShooting", tracerOldFunc)
        end
    end)
    tracerOldFunc = nil
    tracerHooked  = false
end

local function StartTracers()
    TracerHookRemote()
    if not tracerConn then
        tracerConn = Track(RunService.RenderStepped:Connect(TracerUpdate))
    end
end

local function StopTracers()
    TracerUnhook()
    if tracerConn then tracerConn:Disconnect(); tracerConn=nil end
    for _, tr in ipairs(activeTracers) do TracerDestroyOne(tr) end
    activeTracers = {}
end

