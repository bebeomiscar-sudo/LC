local ESPCfg = {
    Enabled=false,TeamCheck=true,ShowBox=true,ShowName=true,
    ShowHealth=true,ShowDist=true,
    BoxColor=Color3.fromRGB(255,80,80),TeamColor=Color3.fromRGB(80,200,80),
    NameColor=Color3.fromRGB(255,255,255),
    MaxDist=1000,Filled=false,FilledOpacity=0.1,
}

local ESPObjects = {}
local EDGES = {{1,2},{2,3},{3,4},{4,1},{5,6},{6,7},{7,8},{8,5},{1,5},{2,6},{3,7},{4,8}}

local function CreateESPForPlayer(player)
    if ESPObjects[player] then return end
    local function NL()
        local l=Drawing.new("Line");l.Thickness=1.5;l.Color=ESPCfg.BoxColor;l.Visible=false;return l
    end
    local lines={}
    for _=1,12 do table.insert(lines,NL()) end
    local fb=Drawing.new("Square");fb.Filled=true;fb.Color=ESPCfg.BoxColor;fb.Transparency=1-ESPCfg.FilledOpacity;fb.Visible=false
    local nl=Drawing.new("Text");nl.Size=14;nl.Center=true;nl.Outline=true;nl.Color=ESPCfg.NameColor;nl.Visible=false;nl.Text=player.DisplayName
    local hl=Drawing.new("Text");hl.Size=12;hl.Center=true;hl.Outline=true;hl.Color=Color3.fromRGB(80,255,80);hl.Visible=false
    local dl=Drawing.new("Text");dl.Size=11;dl.Center=true;dl.Outline=true;dl.Color=Color3.fromRGB(200,200,200);dl.Visible=false
    ESPObjects[player]={Lines=lines,FilledBox=fb,NameLabel=nl,HealthLabel=hl,DistLabel=dl}
end

local function RemoveESPForPlayer(player)
    local obj=ESPObjects[player];if not obj then return end
    for _,l in ipairs(obj.Lines) do pcall(l.Remove,l) end
    pcall(obj.FilledBox.Remove,obj.FilledBox);pcall(obj.NameLabel.Remove,obj.NameLabel)
    pcall(obj.HealthLabel.Remove,obj.HealthLabel);pcall(obj.DistLabel.Remove,obj.DistLabel)
    ESPObjects[player]=nil
end

local function HideESP(obj)
    for _,l in ipairs(obj.Lines) do l.Visible=false end
    obj.FilledBox.Visible=false;obj.NameLabel.Visible=false
    obj.HealthLabel.Visible=false;obj.DistLabel.Visible=false
end

local function GetBoundingBox2D(char)
    local hrp=char:FindFirstChild("HumanoidRootPart");if not hrp then return nil end
    local c=hrp.Position;local hw,hh=1.1,1.5
    local corners={
        c+Vector3.new(-hw,-hh,-hw),c+Vector3.new(hw,-hh,-hw),
        c+Vector3.new(hw,-hh,hw), c+Vector3.new(-hw,-hh,hw),
        c+Vector3.new(-hw,hh,-hw),c+Vector3.new(hw,hh,-hw),
        c+Vector3.new(hw,hh,hw),  c+Vector3.new(-hw,hh,hw),
    }
    local screen={}
    for _,co in ipairs(corners) do
        local sp,on=cam:WorldToViewportPoint(co);if not on then return nil end
        table.insert(screen,Vector2.new(sp.X,sp.Y))
    end
    return screen
end

local function UpdateESP()
    local myHRP=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    for _,player in ipairs(Players:GetPlayers()) do
        if player==lp then continue end
        local obj=ESPObjects[player];if not obj then continue end
        if not ESPCfg.Enabled or not IsValidTarget(player) then HideESP(obj);continue end
        local char=player.Character
        local hrp=char and char:FindFirstChild("HumanoidRootPart")
        local hum=char and char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then HideESP(obj);continue end
        local dist=myHRP and (myHRP.Position-hrp.Position).Magnitude or 0
        if dist>ESPCfg.MaxDist then HideESP(obj);continue end
        local isTeam=SameTeam(player)
        if ESPCfg.TeamCheck and isTeam then HideESP(obj);continue end
        local boxColor=isTeam and ESPCfg.TeamColor or ESPCfg.BoxColor
        local sc=GetBoundingBox2D(char);if not sc then HideESP(obj);continue end
        if ESPCfg.ShowBox then
            for i,edge in ipairs(EDGES) do
                obj.Lines[i].From=sc[edge[1]];obj.Lines[i].To=sc[edge[2]]
                obj.Lines[i].Color=boxColor;obj.Lines[i].Visible=true
            end
        else for _,l in ipairs(obj.Lines) do l.Visible=false end end
        if ESPCfg.Filled and ESPCfg.ShowBox then
            local minX,minY,maxX,maxY=math.huge,math.huge,-math.huge,-math.huge
            for _,s in ipairs(sc) do
                minX=math.min(minX,s.X);minY=math.min(minY,s.Y)
                maxX=math.max(maxX,s.X);maxY=math.max(maxY,s.Y)
            end
            obj.FilledBox.Position=Vector2.new(minX,minY);obj.FilledBox.Size=Vector2.new(maxX-minX,maxY-minY)
            obj.FilledBox.Color=boxColor;obj.FilledBox.Transparency=1-ESPCfg.FilledOpacity;obj.FilledBox.Visible=true
        else obj.FilledBox.Visible=false end
        local top=sc[5];local np=top-Vector2.new(0,18)
        if ESPCfg.ShowName then
            obj.NameLabel.Text=player.DisplayName;obj.NameLabel.Position=np
            obj.NameLabel.Color=ESPCfg.NameColor;obj.NameLabel.Visible=true
        else obj.NameLabel.Visible=false end
        if ESPCfg.ShowHealth then
            local hp=math.floor(hum.Health);local mhp=math.floor(hum.MaxHealth)
            local r=math.clamp(hum.Health/math.max(hum.MaxHealth,1),0,1)
            obj.HealthLabel.Text=hp.." / "..mhp
            obj.HealthLabel.Position=np-Vector2.new(0,14)
            obj.HealthLabel.Color=Color3.fromRGB(math.floor((1-r)*255),math.floor(r*255),0)
            obj.HealthLabel.Visible=true
        else obj.HealthLabel.Visible=false end
        if ESPCfg.ShowDist then
            obj.DistLabel.Text=math.floor(dist).." studs"
            obj.DistLabel.Position=sc[1]+Vector2.new(0,4)
            obj.DistLabel.Visible=true
        else obj.DistLabel.Visible=false end
    end
end

