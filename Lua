local _connections = {}
local function trackConn(c)
    table.insert(_connections, c)
    return c
end
local function cleanupAll()
    for _, c in ipairs(_connections) do
        if c and typeof(c) == "RBXScriptConnection" then
            pcall(function() c:Disconnect() end)
        end
    end
    _connections = {}
end

-- =============================================
--   NON-BLOCKING HTTP GET WITH RETRY
-- =============================================

local function httpGetRetry(url, retries, delay)
    retries = retries or 8
    delay   = delay   or 3
    for attempt = 1, retries do
        local ok, res = pcall(function()
            return game:HttpGet(url)
        end)
        if ok and res and #res > 10 then return res end
        warn(("[Rivals] HTTP attempt %d/%d failed — waiting %ds"):format(attempt, retries, delay))
        task.wait(delay)
        delay = math.min(delay + 1, 8)
    end
    return nil
end

