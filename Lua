local function getNearest3DHead()
    local hrp = getHRP()
    if not hrp then return nil end
    local best, bestD = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer or not plr.Character then continue end
        local head = plr.Character:FindFirstChild("HitboxHead") or plr.Character:FindFirstChild("Head")
        if not head then continue end
        local d = (head.Position - hrp.Position).Magnitude
        if d < bestD then best = head bestD = d end
    end
    return best
end

local function getTargetHead()
    if Cfg.character and Cfg.character.Parent then
        local hum = Cfg.character:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 then
            return Cfg.character:FindFirstChild("HitboxHead")
                or Cfg.character:FindFirstChild("Head")
        end
    end
    return getNearest3DHead()
end

local function startSlingTP()
    if SlingState.conn then return end
    SlingState.conn = Workspace.DescendantAdded:Connect(function(obj)
        local valid = (
            obj.Name == "Slingshot"      or
            obj.Name == "CoreProjectile" or
            obj.Name == "OuterProjectile"
        )
        if not valid then return end
        if not (obj:IsA("BasePart") or obj:IsA("Model")) then return end

        task.spawn(function()
            task.wait(0.06)
            local part = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart")
            if not part then return end
            pcall(function() part.CanTouch = true end)
            for _ = 1, 60 do
                if not part.Parent or not part:IsDescendantOf(Workspace) then break end
                local head = getTargetHead()
                if head and head:IsA("BasePart") and head.Parent and head:IsDescendantOf(Workspace) then
                    pcall(firetouchinterest, head, part, 0)
                    pcall(firetouchinterest, head, part, 1)
                end
                task.wait()
            end
        end)
    end)
end

local function stopSlingTP()
    if SlingState.conn then
        SlingState.conn:Disconnect()
        SlingState.conn = nil
    end
end

local function updateSling()
    local slingOn  = isSling(getWeaponName())
    local hasTarget = Cfg.enabled and Cfg.character ~= nil

    if slingOn then
        if not SlingState.enabled then
            SlingState.enabled = true
            startSlingTP()
        end
        if getgenv().InstanceSetUnderground then
            getgenv().InstanceSetUnderground(true)
        end
        VH.active = hasTarget
        if hasTarget and not Cfg.state.csyncActive then
            startSync()
        elseif not hasTarget and Cfg.state.csyncActive and not Cfg.enabled then
            stopSync()
        end
    else
        if SlingState.enabled then
            SlingState.enabled = false
            stopSlingTP()
        end
        if not (getgenv().InstanceAntiAimUnderground) then
            if getgenv().InstanceSetUnderground then
                getgenv().InstanceSetUnderground(false)
            end
        end
        VH.active = false
    end
end

