local function RageIsValidTarget(player)
    if not player or player == lp then return false end
    local char = player.Character
    if not char or not char:IsDescendantOf(Workspace) then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if hum:GetState() == Enum.HumanoidStateType.Dead then return false end
    if not char:FindFirstChild("HumanoidRootPart") then return false end
    if RC.TeamCheck and SameTeam(player) then return false end
    return true
end

local function RageFindNearest()
    local cursorPos = UserInputService:GetMouseLocation()
    local best, bestDist = nil, math.huge
    local myHRP = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    for _, p in ipairs(Players:GetPlayers()) do
        if not RageIsValidTarget(p) then continue end
        local char = p.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        if myHRP and (myHRP.Position - root.Position).Magnitude > RC.MaxDist then continue end
        local sp, onScreen = cam:WorldToViewportPoint(root.Position)
        if not onScreen then continue end
        local d = (Vector2.new(sp.X, sp.Y) - cursorPos).Magnitude
        if d < bestDist then bestDist=d;best=char end
    end
    return best
end

local function RageSetTarget(char)
    if not char then return end
    local p = Players:GetPlayerFromCharacter(char)
    RC.Target.Character = char
    RC.Target.Player    = p
    RC.Target.Enabled   = true
    RC.Target.Immune    = RageCheckImmune(char)
    if RC.Target.Immune then
        RageIndicator.Color = Color3.fromRGB(180, 0, 255)
    else
        RageIndicator.Color = Color3.fromRGB(255, 50, 50)
        RageStartOrbit()
    end
end

local function RageClearTarget()
    RageStopOrbit()
    RC.Target.Character = nil
    RC.Target.Player    = nil
    RC.Target.Enabled   = false
    RC.Target.Immune    = false
    RC.Target.Manual    = false
    RageIndicator.Visible        = false
    RageIndicatorOutline.Visible = false
    RageIndicator.Color = Color3.fromRGB(255, 50, 50)
    rageKillStartAt = nil
end

-- ============================================================
--   VOID SPAM TICK
-- ============================================================

local function RageTickVoidSpam()
    if not RC.VoidSpam.Enabled then return end
    local now     = tick()
    local elapsed = now - RC.VoidSpam.LastSwitch
    local vs      = RC.VoidSpam

    if vs.Phase == "shoot" then
        if elapsed >= vs.Duration then
            vs.Phase      = "hide"
            vs.Duration   = RandBetween(vs.HideMin, vs.HideMax)
            vs.LastSwitch = now
        end
    elseif vs.Phase == "hide" then
        if elapsed >= vs.Duration then
            vs.Phase      = "shoot"
            vs.Duration   = RandBetween(vs.ShootMin, vs.ShootMax)
            vs.LastSwitch = now
        end
    else
        vs.Phase      = "shoot"
        vs.Duration   = RandBetween(vs.ShootMin, vs.ShootMax)
        vs.LastSwitch = now
    end
end

local function RageIsHiding()
    if RC.State.Reloading then return true end
    if RC.State.OutOfAmmo and not RageIsInfiniteWeapon() then return true end
    if RC.VoidSpam.Enabled and RC.VoidSpam.Phase == "hide" then return true end
    return false
end

-- ============================================================
--   ORBIT (CSYNC) — Improved with attack offsets
-- ============================================================

function RageStopOrbit()
    if RC.Orbit.Connection then
        RC.Orbit.Connection:Disconnect()
        RC.Orbit.Connection = nil
    end
    RC.State.CsyncActive = false
    RC.Orbit.Active      = false
    ClearVoidSnap()
    RC.VoidSpam.Phase    = nil

    -- Restore saved position
    if RC.Orbit.SavedPos then
        local myChar = lp.Character
        local hrp    = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if hrp then
            pcall(function() hrp.CFrame = RC.Orbit.SavedPos end)
        end
        RC.Orbit.SavedPos = nil
    end
    RC.Orbit.ServerPos = nil
end

function RageStartOrbit()
    if RC.State.CsyncActive then return end
    if RC.Target.Immune then return end
    if not RC.Target.Character then return end
    if not RageIsValidTarget(RC.Target.Player) then return end

    RC.State.CsyncActive = true
    RC.Orbit.Active      = true

    -- Save current position
    local myChar = lp.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if myRoot and not RC.Orbit.SavedPos then
        RC.Orbit.SavedPos = myRoot.CFrame
    end

    -- Set orbit params from attack config
    local atkCfg = RageGetAtkCfg()
    RC.Orbit.Height = atkCfg.height or 1
    RC.Orbit.Radius = atkCfg.radius or 0

    RC.Orbit.Connection = Track(RunService.Heartbeat:Connect(function(dt)
        if not RC.State.CsyncActive then return end
        if RC.Target.Immune then RageStopOrbit(); return end
        if not RC.Target.Character or not RageIsValidTarget(RC.Target.Player) then
            RageClearTarget(); return
        end

        local myChar2 = lp.Character
        local myRoot2 = myChar2 and myChar2:FindFirstChild("HumanoidRootPart")
        if not myRoot2 then return end

        RageTickVoidSpam()
        RageTickAmmo()

        local weapon = RageGetWeaponName()
        local isSling = RageIsSling(weapon)

        -- Handle hiding phases
        if not isSling and RageIsHiding() then
            local hrp = myChar2 and myChar2:FindFirstChild("HumanoidRootPart")
            if hrp then
                SnapToVoid(hrp)
            else
                local rx = math.random(-10000, 10000)
                local rz = math.random(-10000, 10000)
                RC.Orbit.ServerPos = Vector3.new(rx, -99999999, rz)
                pcall(function() myRoot2.CFrame = CFrame.new(RC.Orbit.ServerPos) end)
            end
            return
        end

        -- Slingshot: position above target
        if isSling then
            local tgtRoot = RC.Target.Character:FindFirstChild("HumanoidRootPart")
            if tgtRoot then
                local flat = Vector3.new(tgtRoot.CFrame.LookVector.X, 0, tgtRoot.CFrame.LookVector.Z)
                if flat.Magnitude > 0.01 then flat = flat.Unit end
                RC.Orbit.ServerPos = tgtRoot.Position + Vector3.new(0, 15, 0) + (flat * 5)
            end
        else
            -- Normal orbit calculation
            local tgtRoot = RC.Target.Character:FindFirstChild("HumanoidRootPart")
            if not tgtRoot then return end

            RC.Orbit.Angle = RC.Orbit.Angle + (RC.Orbit.Speed * dt)
            local atkCfg2  = RageGetAtkCfg()
            RC.Orbit.Height = atkCfg2.height or 1
            RC.Orbit.Radius = atkCfg2.radius or 0

            local basePos = RageOrbBase(tgtRoot)
            local offset  = Vector3.new(
                math.cos(RC.Orbit.Angle) * RC.Orbit.Radius,
                RC.Orbit.Height,
                math.sin(RC.Orbit.Angle) * RC.Orbit.Radius
            )
            RC.Orbit.ServerPos = basePos + offset
        end

        -- Apply position
        if RC.Orbit.ServerPos then
            local dist = (RC.Orbit.ServerPos - myRoot2.Position).Magnitude
            if dist < 2000 then
                RC.Orbit.SavedPos = myRoot2.CFrame
                pcall(function() myRoot2.CFrame = CFrame.new(RC.Orbit.ServerPos) end)
            end
        end
    end))
end

-- ============================================================
--   AUTO SHOOT — Main fire function
-- ============================================================

local function RageAutoShoot()
    -- Phase gates
    local weapon  = RageGetWeaponName()
    local isSling = RageIsSling(weapon)
    if not isSling and RageIsHiding() then return end
    if RC.Target.Immune then return end
    if not RC.Target.Enabled or not RC.Target.Character then return end
    if not RageIsValidTarget(RC.Target.Player) then return end

    local lf, item = RageGetEquipped()
    if not lf or not item then return end

    -- Ammo check
    if not RageIsInfiniteWeapon() then
        if RC.State.Reloading or RC.State.OutOfAmmo then
            -- Auto reload
            pcall(function()
                local oid = item:Get("ObjectID")
                if oid then
                    ReplicatedStorage.Remotes.Replication.Fighter.UseItem:FireServer(
                        oid, EnumsModule:ToEnum("Reloading"), {}, nil
                    )
                end
            end)
            return
        end
    end

    local char    = RC.Target.Character
    local hitPart = GetBestPart(char, RC.HitPart)
    if not hitPart then return end

    -- Determine shoot position
    local shootPos
    if RC.State.CsyncActive and RC.Orbit.ServerPos then
        shootPos = RC.Orbit.ServerPos
    else
        local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        shootPos = myRoot and myRoot.Position or cam.CFrame.Position
    end

    -- Predict target position
    local targetPos = RagePredict(hitPart, shootPos)

    local data = {
        [utf8.char(1)] = {
            [utf8.char(0)] = UtilityModule:EncodeCFrame(CFrame.new(shootPos, targetPos)),
            [utf8.char(1)] = UtilityModule:EncodeCFrame(CFrame.new(shootPos, targetPos)),
            [utf8.char(2)] = hitPart,
            [utf8.char(3)] = UtilityModule:EncodeCFrame(CFrame.new(0.43, 0.25, 0.42)),
        },
    }

    local oid = item:Get("ObjectID")
    if not oid then return end

    rageLastAttackTick = tick()
    if not rageKillStartAt then rageKillStartAt = tick() end

    local attempts = math.clamp(RC.ShootAttempts, 1, 3)
    for _ = 1, attempts do
        pcall(function()
            ReplicatedStorage.Remotes.Replication.Fighter.UseItem:FireServer(
                oid, EnumsModule:ToEnum("StartShooting"), data, nil
            )
        end)
    end

    -- Double tap
    if RC.DoubleTap then
        if rageDTTask then task.cancel(rageDTTask); rageDTTask=nil end
        local snapPart  = hitPart
        local snapChar  = char
        local snapOid   = oid
        local snapShoot = shootPos
        rageDTTask = task.delay(RC.DoubleTapDelay, function()
            rageDTTask = nil
            if not RC.Enabled or not RC.DoubleTap then return end
            if not snapPart or not snapPart.Parent then return end
            if not snapChar or not snapChar:IsDescendantOf(Workspace) then return end
            local hum2 = snapChar:FindFirstChildOfClass("Humanoid")
            if not hum2 or hum2.Health <= 0 then return end
            local off = Vector3.new(math.random(-5,5)*0.01,math.random(-5,5)*0.01,math.random(-5,5)*0.01)
            local tPos2 = snapPart.Position
            local data2 = {
                [utf8.char(1)] = {
                    [utf8.char(0)] = UtilityModule:EncodeCFrame(CFrame.new(snapShoot+off, tPos2)),
                    [utf8.char(1)] = UtilityModule:EncodeCFrame(CFrame.new(snapShoot+off, tPos2)),
                    [utf8.char(2)] = snapPart,
                    [utf8.char(3)] = UtilityModule:EncodeCFrame(CFrame.new(0.43, 0.25, 0.42)),
                },
            }
            pcall(function()
                ReplicatedStorage.Remotes.Replication.Fighter.UseItem:FireServer(
                    snapOid, EnumsModule:ToEnum("StartShooting"), data2, nil
                )
            end)
        end)
    end
end

-- ============================================================
--   RAGEBOT HUD — Phase-aware status display
-- ============================================================

local function RageGetHudInfo()
    local now = tick()

    -- Idle
    if not RC.Enabled then
        return "● Ragebot: OFF", "", Color3.fromRGB(120,120,120), Color3.fromRGB(80,80,80)
    end

    -- Reloading
    if RC.State.Reloading then
        return "🔄 RELOADING", "weapon empty — refilling", Color3.fromRGB(255,200,50), Color3.fromRGB(255,200,50)
    end

    -- Immune
    if RC.Target.Immune then
        local nm = RC.Target.Player and RC.Target.Player.Name or "target"
        return "🛡 IMMUNE", nm .. " is invincible", Color3.fromRGB(180,0,255), Color3.fromRGB(180,0,255)
    end

    -- VoidSpam hiding
    if RC.VoidSpam.Enabled and RC.VoidSpam.Phase == "hide" then
        local det = ""
        if RC.VoidSpam.ShootMin and RC.VoidSpam.HideMin then
            det = string.format("atk %.1fs · hide %.1fs", RC.VoidSpam.ShootMin, RC.VoidSpam.HideMin)
        end
        return "⬇ HIDING", det, Color3.fromRGB(80,160,255), Color3.fromRGB(80,160,255)
    end

    -- Attacking
    if RC.Target.Enabled and RC.Target.Character and RC.State.CsyncActive then
        local nm = RC.Target.Player and RC.Target.Player.Name or "???"
        local elapsed = now - (rageKillStartAt or now)
        local hum = RC.Target.Character:FindFirstChildOfClass("Humanoid")
        local hp  = hum and math.floor(hum.Health) or 0
        return
            string.format("⚡ ATTACKING (%s) · %.1fs", nm, elapsed),
            string.format("%.0f hp", hp),
            Color3.fromRGB(255,80,60),
            Color3.fromRGB(255,80,60)
    end

    -- Ready / locked
    if RC.Target.Enabled and RC.Target.Character then
        local nm  = RC.Target.Player and RC.Target.Player.Name or "???"
        local hum = RC.Target.Character:FindFirstChildOfClass("Humanoid")
        local hp  = hum and math.floor(hum.Health) or 0
        return
            string.format("● READY — %s", nm),
            string.format("%.0f hp", hp),
            Color3.fromRGB(80,255,120),
            Color3.fromRGB(80,255,120)
    end

    return "● Idle", "", Color3.fromRGB(180,180,180), Color3.fromRGB(100,80,255)
end

local function UpdateRageHUD()
    if not rageHudVisible then
        RageHudBg.Visible     = false
        RageHudStroke.Visible = false
        RageHudLine1.Visible  = false
        RageHudLine2.Visible  = false
        return
    end

    local vp    = cam.ViewportSize
    local halfW = RageHudCfg.Width / 2
    local halfH = RageHudCfg.Height / 2
    local hudX  = (vp.X/2) - halfW + RageHudCfg.OffsetX
    local hudY  = RageHudCfg.OffsetY

    RageHudBg.Position     = Vector2.new(hudX, hudY)
    RageHudStroke.Position = Vector2.new(hudX, hudY)

    local line1, line2, textColor, strokeColor = RageGetHudInfo()

    RageHudLine1.Text     = line1
    RageHudLine1.Color    = textColor
    RageHudLine1.Position = Vector2.new((vp.X/2)+RageHudCfg.OffsetX, hudY+halfH-14)

    RageHudLine2.Text     = line2
    RageHudLine2.Color    = Color3.fromRGB(180,180,180)
    RageHudLine2.Position = Vector2.new((vp.X/2)+RageHudCfg.OffsetX, hudY+halfH+1)
    RageHudLine2.Visible  = line2 ~= "" and RC.Enabled

    RageHudStroke.Color = strokeColor

    local show = RC.Enabled
    RageHudBg.Visible     = show
    RageHudStroke.Visible = show
    RageHudLine1.Visible  = show
end

-- ============================================================
--   INDICATOR POSITION (target head)
-- ============================================================

local function UpdateRageIndicator()
    if not RC.Target.Enabled or not RC.Target.Character then
        RageIndicator.Visible        = false
        RageIndicatorOutline.Visible = false
        return
    end
    local head = RC.Target.Character:FindFirstChild("Head")
    if not head then
        RageIndicator.Visible        = false
        RageIndicatorOutline.Visible = false
        return
    end
    local sp, onScreen = cam:WorldToViewportPoint(head.Position)
    if not onScreen then
        RageIndicator.Visible        = false
        RageIndicatorOutline.Visible = false
        return
    end
    local pos = Vector2.new(sp.X, sp.Y - 20)
    RageIndicator.Position        = pos
    RageIndicatorOutline.Position = pos
    RageIndicator.Visible         = true
    RageIndicatorOutline.Visible  = true
end

-- ============================================================
--   RAGEBOT MAIN HEARTBEAT
-- ============================================================

local rageConn = nil

local function StartRagebot()
    if rageConn then rageConn:Disconnect(); rageConn=nil end

    -- Init void spam
    RC.VoidSpam.Phase      = "shoot"
    RC.VoidSpam.LastSwitch = tick()
    RC.VoidSpam.Duration   = RandBetween(RC.VoidSpam.ShootMin, RC.VoidSpam.ShootMax)

    rageConn = Track(RunService.Heartbeat:Connect(function()
        if not RC.Enabled then return end

        RageTickAmmo()
        RageTickImmunity()
        RageUpdateVel()

        -- Auto target
        if RC.AutoTarget and not RC.Target.Manual then
            if not RC.Target.Enabled or not RC.Target.Character
            or not RageIsValidTarget(RC.Target.Player) then
                local newTarget = RageFindNearest()
                if newTarget then
                    if RC.Target.Enabled then RageStopOrbit() end
                    RageSetTarget(newTarget)
                end
            end
        end

        -- Validate current target
        if RC.Target.Enabled and RC.Target.Character then
            if not RageIsValidTarget(RC.Target.Player) then
                RageClearTarget()
                return
            end
            -- Auto shoot
            if RC.AutoShoot and not RC.Target.Immune then
                RageAutoShoot()
            end
        end
    end))
end

local function StopRagebot()
    if rageConn then rageConn:Disconnect(); rageConn=nil end
    if rageDTTask then task.cancel(rageDTTask); rageDTTask=nil end
    RageStopOrbit()
    ClearVoidSnap()
    RageClearTarget()
    RC.Enabled = false
end

