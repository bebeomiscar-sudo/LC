    local function drawSkeleton(obj, char, hum)
        local cfg = GC.Skeleton
        if not cfg.Enable then
            for _, l in pairs(obj.skel.lines)    do l.Visible=false end
            for _, l in pairs(obj.skel.outlines) do l.Visible=false end
            return
        end
        local bones = (hum.RigType == Enum.HumanoidRigType.R15) and R15_BONES or R6_BONES
        local c1 = cfg.Color  or Color3.fromRGB(255,255,255)
        local c2 = cfg.Color2 or c1
        local th = cfg.Thickness or 1
        for i = 1, 15 do
            local set = bones[i]
            local ln  = obj.skel.lines[i]
            local ol  = obj.skel.outlines[i]
            if set then
                local pA = char:FindFirstChild(set[1])
                local pB = char:FindFirstChild(set[2])
                if pA and pB then
                    local va, aOk = w2esp(pA.Position)
                    local vb, bOk = w2esp(pB.Position)
                    if aOk and bOk then
                        local p2 = Vector2.new(va.X, va.Y)
                        local ep = Vector2.new(vb.X, vb.Y)
                        ol.Visible=true ol.From=p2 ol.To=ep ol.Thickness=th+2 ol.Color=Color3.new(0,0,0)
                        ln.Visible=true ln.From=p2 ln.To=ep ln.Color=lerpc(c1,c2,0.5) ln.Thickness=th
                    else
                        ln.Visible=false ol.Visible=false
                    end
                else
                    ln.Visible=false ol.Visible=false
                end
            else
                ln.Visible=false ol.Visible=false
            end
        end
    end

    local function drawHealthBar(obj, hum, sz, pos, dt)
        local cfg = GC.Box.Healthbar
        if not (cfg and cfg.Enable) then
            obj.bars.outline.Visible = false
            for _, l in pairs(obj.bars.hp) do l.Visible=false end
            return
        end
        local target = math.clamp(hum.Health/hum.MaxHealth, 0, 1)
        local last   = obj.bars.lastHp or target
        local ls     = (GC.ESP and GC.ESP.HealthLerpSpeed) or 32
        obj.bars.lastHp = last + (target - last) * math.min(1, dt * ls)
        local lerped    = obj.bars.lastHp
        local h         = math.ceil(sz.Y * lerped)
        local hpx       = pos.X - 5
        local hpyStart  = pos.Y + (sz.Y - h)

        obj.bars.outline.Visible  = true
        obj.bars.outline.Position = Vector2.new(hpx-1, pos.Y-1)
        obj.bars.outline.Size     = Vector2.new(3, sz.Y+2)
        obj.bars.outline.Color    = Color3.new(0,0,0)
        obj.bars.outline.Filled   = false

        local segs = math.clamp(math.floor(h/2), 10, 50)
        for i = 1, 50 do
            local ln = obj.bars.hp[i]
            if i <= segs then
                local segH  = h / segs
                local yoff  = (i-1) * segH
                local pct   = 1 - ((yoff+(sz.Y-h))/sz.Y)
                ln.Visible  = true
                ln.From     = Vector2.new(hpx, hpyStart+yoff)
                ln.To       = Vector2.new(hpx+1, hpyStart+yoff)
                ln.Color    = hpColor(pct)
                ln.Thickness = math.max(segH, 1)
            else
                ln.Visible = false
            end
        end
    end

