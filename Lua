local function tickAmmo()
    if isInfiniteWeapon() then
        config.state.outofammo       = false
        config.state.reloading       = false
        config.state.reloadStartedAt = 0
        return
    end
    local current,_,melee = getammo()
    local wasOut = config.state.outofammo
    config.state.outofammo = (not melee) and (tonumber(current) or 0)<=0
    local reloading = itemReload()
    if reloading and not config.state.reloading then
        config.state.reloadStartedAt = tick()
    end
    if not reloading then config.state.reloadStartedAt=0 end
    config.state.reloading = reloading

    -- Transition logic
    if config.state.outofammo and not wasOut then
        if isSling(getweapon()) then config.voidspam.phase="hide" end
    elseif not config.state.outofammo and wasOut then
        if config.voidspam.enabled then
            config.voidspam.phase           = "shoot"
            config.voidspam.lastswitch      = tick()
            config.voidspam.currentduration = RandBetween(config.voidspam.shoot_min,config.voidspam.shoot_max)
        end
    end
end

-- ============================================================
--   RAGEBOT VOIDSPAM TICK (from example)
-- ============================================================

local function tickVoidSpam()
    if not config.voidspam.enabled then return end
    local now     = tick()
    local elapsed = now - config.voidspam.lastswitch
    local vs      = config.voidspam

    if vs.phase=="shoot" then
        if elapsed>=vs.currentduration then
            vs.phase           = "hide"
            vs.currentduration = RandBetween(vs.hide_min,vs.hide_max)
            vs.lastswitch      = now
        end
    elseif vs.phase=="hide" then
        if elapsed>=vs.currentduration then
            vs.phase           = "shoot"
            vs.currentduration = RandBetween(vs.shoot_min,vs.shoot_max)
            vs.lastswitch      = now
        end
    else
        vs.phase           = "shoot"
        vs.currentduration = RandBetween(vs.shoot_min,vs.shoot_max)
        vs.lastswitch      = now
    end
end

-- ============================================================
--   RAGEBOT AUTO-SHOOT (from example — no double tap)
-- ============================================================

local function autoshoot()
    if not config.target.enabled or not config.target.character or not config.target.autoshoot then return end
    if config.target.immune then return end
    if config.voidspam.enabled and config.voidspam.phase=="hide" then return end
    if isSling(getweapon()) and vhState.active then return end

    eqSlot()

    if not localfighter or not localfighter.EquippedItem then return end
    if not isInfiniteWeapon() then
        if config.state.reloading or config.state.outofammo then return end
        if not canuse() then return end
    end

    local targetChar = config.target.character
    if not validChar(targetChar) then return end

    local hitPart = hitpartfromname(targetChar, config.target.hitpart)
    if not hitPart then return end

    -- Shoot position: use orbit serverpos, or local HRP position
    local shootPos
    if vhState.active then
        local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        shootPos = hrp and hrp.Position or Vector3.new()
    elseif config.orbit.serverpos then
        shootPos = config.orbit.serverpos
    else
        local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        shootPos = hrp and hrp.Position or Vector3.new()
    end

    local targetPos = predict(hitPart, shootPos)

    -- Build shot data (exact format from example)
    local data = {
        [utf8.char(1)] = {
            [utf8.char(0)] = UtilityModule:EncodeCFrame(CFrame.new(shootPos, targetPos)),
            [utf8.char(1)] = UtilityModule:EncodeCFrame(CFrame.new(shootPos, targetPos)),
            [utf8.char(2)] = hitPart,
            [utf8.char(3)] = UtilityModule:EncodeCFrame(CFrame.new(0.43, 0.25, 0.42)),
        },
    }

    local equipped = localfighter.EquippedItem
    if equipped and equipped:Get("ObjectID") then
        ragePerf.lastAttackTick = tick()
        local attempts = math.clamp(math.floor(tonumber(config.target.shootAttempts) or 1), 1, 3)
        for _ = 1, attempts do
            pcall(function()
                UseItemRemote:FireServer(
                    equipped:Get("ObjectID"),
                    EnumsModule:ToEnum("StartShooting"),
                    data,
                    nil
                )
            end)
        end
    end
end

