    local function drawskeleton_esp(p, box, char, hum, size, position)
        local cfg = GC.Skeleton
        if not cfg.Enable then
            for _, ln in pairs(box.skeleton.lines)   do ln.Visible = false end
            for _, ol in pairs(box.skeleton.outlines) do ol.Visible = false end
            return
        end
        local bones = (hum.RigType == Enum.HumanoidRigType.R15) and r15bones or r6bones
        local c1 = cfg.Color  or Color3.fromRGB(255,255,255)
        local c2 = cfg.Color2 or c1
        local th = cfg.Thickness or 1
        for i = 1, 15 do
            local boneset = bones[i]
            local ln = box.skeleton.lines[i]
            local ol = box.skeleton.outlines[i]
            if boneset then
                local pA = char:FindFirstChild(boneset[1])
                local pB = char:FindFirstChild(boneset[2])
                if pA and pB then
                    local va, aOk = worldToEspScreen(pA.Position)
                    local vb, bOk = worldToEspScreen(pB.Position)
                    if aOk and bOk then
                        local p2  = Vector2.new(va.X, va.Y)
                        local ep  = Vector2.new(vb.X, vb.Y)
                        ol.Visible   = true
                        ol.From      = p2
                        ol.To        = ep
                        ol.Thickness = th + 2
                        ol.Color     = Color3.new(0, 0, 0)
                        ln.Visible   = true
                        ln.From      = p2
                        ln.To        = ep
                        ln.Color     = lerpcolor(c1, c2, 0.5)
                        ln.Thickness = th
                    else
                        ln.Visible = false
                        ol.Visible = false
                    end
                else
                    ln.Visible = false
                    ol.Visible = false
                end
            else
                ln.Visible = false
                ol.Visible = false
            end
        end
    end

    local function drawhealthbar_esp(p, box, hum, size, position, dt)
        local cfg = GC.Box.Healthbar
        if not (cfg and cfg.Enable) then
            box.bars.hp_outline.Visible = false
            for _, ln in pairs(box.bars.hp_bars) do ln.Visible = false end
            return
        end
        local target = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
        local last   = box.bars.last_hp or target
        local ls     = (GC.ESP and GC.ESP.HealthLerpSpeed) or 32
        box.bars.last_hp = last + (target - last) * math.min(1, dt * ls)
        local lerped  = box.bars.last_hp
        local h       = math.ceil(size.Y * lerped)
        local hpx     = position.X - 5
        local hpystart = position.Y + (size.Y - h)
        box.bars.hp_outline.Visible  = true
        box.bars.hp_outline.Position = Vector2.new(hpx - 1, position.Y - 1)
        box.bars.hp_outline.Size     = Vector2.new(3, size.Y + 2)
        box.bars.hp_outline.Color    = Color3.new(0, 0, 0)
        box.bars.hp_outline.Filled   = false
        local segments = math.clamp(math.floor(h / 2), 10, 50)
        for i = 1, 50 do
            local ln = box.bars.hp_bars[i]
            if i <= segments then
                local segH   = h / segments
                local yoff   = (i - 1) * segH
                local pospct = 1 - ((yoff + (size.Y - h)) / size.Y)
                ln.Visible   = true
                ln.From      = Vector2.new(hpx, hpystart + yoff)
                ln.To        = Vector2.new(hpx + 1, hpystart + yoff)
                ln.Color     = hpcolor(pospct)
                ln.Thickness = math.max(segH, 1)
            else
                ln.Visible = false
            end
        end
    end

