local function tickAmmo()
    if isInfiniteWeapon() then
        rageConfig.state.outofammo=false; rageConfig.state.reloading=false
        rageConfig.state.reloadStartedAt=0; return
    end
    local cur,_,melee=getammo(); local wasOut=rageConfig.state.outofammo
    rageConfig.state.outofammo=not melee and (tonumber(cur) or 0)<=0
    local reloading=itemReload()
    if reloading and not rageConfig.state.reloading then rageConfig.state.reloadStartedAt=tick()
    elseif not reloading then rageConfig.state.reloadStartedAt=0 end
    rageConfig.state.reloading=reloading
    if rageConfig.state.outofammo and not wasOut then
        if isSling(getweapon()) then rageConfig.voidspam.phase="hide" end
    elseif not rageConfig.state.outofammo and wasOut then
        if rageConfig.voidspam.enabled then
            rageConfig.voidspam.phase="shoot"; rageConfig.voidspam.lastswitch=tick()
        end
    end
end

