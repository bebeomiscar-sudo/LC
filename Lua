local function inLive(targetPlr)
    if not targetPlr then return false end
    local live = ws:FindFirstChild("Live")
    if not live then return false end
    if live:FindFirstChild(targetPlr.Name) then return true end
    local char = targetPlr.Character
    if char and (char.Parent==live or char:IsDescendantOf(live)) then return true end
    return false
end

local function liveMatch()
    if not lp then return false end
    for _,key in ipairs(SPAWN_SAFE_ATTRS) do
        local v=lp:GetAttribute(key)
        if v==true or v==1 or v=="true" then return false end
    end
    local char=lp.Character; if not char then return false end
    local hum=char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health<=0 then return false end
    for _,key in ipairs(DUEL_STATE_ATTRS) do
        local v=lp:GetAttribute(key)
        if v==true or v==1 or v=="true" then return true end
    end
    if inLive(lp) then return true end
    local fc=FighterController
    if fc and fc.LocalFighter and fc.LocalFighter.Entity and fc.LocalFighter.Entity.Parent then return true end
    return false
end

