local function RageDesyncAttack(targetChar)
    if not targetChar then return end
    local targetHead = targetChar:FindFirstChild("Head")
    if not targetHead then return end
    local dummy = GetDesyncPart()
    pcall(function() dummy.CFrame = targetHead.CFrame * CFrame.new(0,-5,0) end)
end

local function RageDesyncStop()
    rageDesyncActive = false
    local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if myRoot and rageDesyncPart and rageDesyncPart.Parent then
        pcall(function() rageDesyncPart.CFrame = myRoot.CFrame end)
    end
    if rageDesyncPart then
        pcall(function() rageDesyncPart:Destroy() end)
        rageDesyncPart = nil
    end
end

-- Helpers
local RRay = RaycastParams.new()
RRay.FilterType = Enum.RaycastFilterType.Exclude

local function GetEquipped()
    if not FighterController then return nil,nil end
    local lf = FighterController.LocalFighter
    if not lf then return nil,nil end
    local item = lf.EquippedItem
    if not item then return nil,nil end
    return lf, item
end

local function IsInfiniteWeapon(item)
    if not item then return false end
    local ok, r = pcall(function()
        local maxAmmo = item:Get("MaxAmmo")
        return maxAmmo==nil or maxAmmo<=0 or maxAmmo==math.huge
    end)
    return ok and r or false
end

local function GetAmmoState(lf, item)
    if not lf or not item then return false,false,false end
    local isMelee, outOfAmmo, isReloading = false, false, false
    pcall(function()
        local ammo    = item:Get("Ammo")
        local maxAmmo = item:Get("MaxAmmo")
        if maxAmmo==nil or maxAmmo<=0 then isMelee=true
        else outOfAmmo=(tonumber(ammo) or 0)<=0 end
    end)
    pcall(function()
        isReloading = lf:GetState()=="Reloading"
                   or (lf.State and lf.State.Value=="Reloading")
    end)
    return isMelee, outOfAmmo, isReloading
end

local function TriggerReload(item)
    pcall(function()
        local objectId = item:Get("ObjectID")
        if objectId then
            UseItemRemote:FireServer(objectId,EnumsModule:ToEnum("Reloading"),{},nil)
        end
    end)
end

local function PredictTarget(hitPart, shootFrom)
    local targetPos = hitPart.Position
    pcall(function()
        local hrp = hitPart.Parent and hitPart.Parent:FindFirstChild("HumanoidRootPart")
        if hrp then targetPos = targetPos + hrp.AssemblyLinearVelocity * RageCfg.Prediction end
    end)
    return targetPos
end

local function RageGetTarget()
    local myChar = lp.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end

    if RageCfg.PriorityPlayer ~= "None" then
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name==RageCfg.PriorityPlayer or p.DisplayName==RageCfg.PriorityPlayer then
                if not IsValidTarget(p) then break end
                if RageCfg.TeamCheck and SameTeam(p) then break end
                if RageCfg.AntiKatana and katanaUsers[p] then break end
                return p.Character
            end
        end
    end

    local best, bestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if not IsValidTarget(p) then continue end
        if RageCfg.TeamCheck and SameTeam(p) then continue end
        if RageCfg.AntiKatana and katanaUsers[p] then continue end
        local char = p.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        local dist = (myHRP.Position - hrp.Position).Magnitude
        if dist > RageCfg.MaxDist then continue end
        if RageCfg.VisCheck and not IsVisible(cam.CFrame.Position, hrp) then continue end
        if dist < bestDist then bestDist=dist;best=char end
    end
    return best
end

local function SetupAntiKatana()
    pcall(function()
        for _, p in ipairs(Players:GetPlayers()) do
            if p == lp then continue end
            task.spawn(function()
                while p.Parent do
                    local char = p.Character
                    if char then
                        local hum = char:FindFirstChildOfClass("Humanoid")
                        if hum then
                            local animator = hum:FindFirstChildOfClass("Animator")
                            if animator then
                                for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                                    local name = track.Name:lower()
                                    if name:find("katana") or name:find("spin") or name:find("deflect") then
                                        katanaUsers[p] = true
                                        task.delay(1.5,function() katanaUsers[p]=nil end)
                                        break
                                    end
                                end
                            end
                        end
                    end
                    task.wait(0.2)
                end
            end)
        end
    end)
end

local function RageWallbangPoint(origin, targetPos, targetChar)
    RRay.FilterDescendantsInstances = {lp.Character, targetChar}
    local function canSee(sp)
        local hit = Workspace:Raycast(sp, targetPos-sp, RRay)
        return hit==nil or hit.Instance:IsDescendantOf(targetChar)
    end
    if canSee(origin) then return origin, nil end
    for _, off in ipairs(RageCfg.Vectors) do
        local sp = origin + off
        if canSee(sp) then return sp, off.Y end
    end
    return nil, nil
end

local function AutoShoot(item, lf, targetChar)
    if not item or not lf or not targetChar then return end
    local isMelee, outOfAmmo, isReloading = GetAmmoState(lf, item)
    if not IsInfiniteWeapon(item) and not isMelee then
        if isReloading then return end
        if outOfAmmo then TriggerReload(item);RageCfg.OutOfAmmo=true;return end
    end
    RageCfg.OutOfAmmo = false
    local targetHead = targetChar:FindFirstChild(RageCfg.HitPart)
                    or targetChar:FindFirstChild("Head")
    if not targetHead then return end
    local hum = targetChar:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return end
    local myRoot   = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    local shootPos = (rageServerPos ~= Vector3.new()) and rageServerPos or cam.CFrame.Position
    local manipPos, _ = RageWallbangPoint(shootPos, targetHead.Position, targetChar)
    local finalShoot  = manipPos or shootPos
    local targetPos   = PredictTarget(targetHead, finalShoot)
    local rel         = CFrame.new(0.43, 0.25, 0.42)
    local data = {
        [utf8.char(1)] = {
            [utf8.char(0)] = UtilityModule:EncodeCFrame(CFrame.new(finalShoot,targetPos)),
            [utf8.char(1)] = UtilityModule:EncodeCFrame(CFrame.new(targetPos,finalShoot)),
            [utf8.char(2)] = targetHead,
            [utf8.char(3)] = UtilityModule:EncodeCFrame(rel),
        },
    }
    local objectId = item:Get("ObjectID")
    if not objectId then return end
    local attempts = math.clamp(RageCfg.ShootAttempts, 1, 3)
    for _ = 1, attempts do
        pcall(function()
            UseItemRemote:FireServer(objectId,EnumsModule:ToEnum("StartShooting"),data,nil)
        end)
    end
    if RageCfg.DoubleTap then
        task.delay(RageCfg.DoubleTapDelay, function()
            if not targetHead or not targetHead.Parent then return end
            local hum2 = targetChar:FindFirstChildOfClass("Humanoid")
            if not hum2 or hum2.Health<=0 then return end
            local offset = Vector3.new(math.random(-5,5)*0.01,math.random(-5,5)*0.01,math.random(-5,5)*0.01)
            local data2 = {
                [utf8.char(1)] = {
                    [utf8.char(0)] = UtilityModule:EncodeCFrame(CFrame.new(finalShoot+offset,targetPos)),
                    [utf8.char(1)] = UtilityModule:EncodeCFrame(CFrame.new(targetPos,finalShoot+offset)),
                    [utf8.char(2)] = targetHead,
                    [utf8.char(3)] = UtilityModule:EncodeCFrame(rel),
                },
            }
            pcall(function()
                UseItemRemote:FireServer(objectId,EnumsModule:ToEnum("StartShooting"),data2,nil)
            end)
        end)
    end
    if TracerCfg.Enabled then
        CreateTracer(GetMuzzlePosition() or cam.CFrame.Position, targetPos)
    end
end

local function StartOrbit(targetChar)
    if rageOrbitConn then rageOrbitConn:Disconnect();rageOrbitConn=nil end
    if not targetChar then return end
    rageOrbitAngle = 0
    rageOrbitConn  = Track(RunService.Heartbeat:Connect(function(dt)
        if not RageCfg.OrbitEnabled or not RageCfg.Enabled then
            rageOrbitConn:Disconnect();rageOrbitConn=nil;return
        end
        local tc = targetChar
        if not tc or not tc.Parent then rageOrbitConn:Disconnect();rageOrbitConn=nil;return end
        local targetHRP = tc:FindFirstChild("HumanoidRootPart")
        if not targetHRP then return end
        rageOrbitAngle = rageOrbitAngle + (RageCfg.OrbitSpeed * dt)
        local offset = Vector3.new(
            math.cos(rageOrbitAngle)*RageCfg.OrbitRadius,
            RageCfg.OrbitHeight,
            math.sin(rageOrbitAngle)*RageCfg.OrbitRadius
        )
        rageServerPos = targetHRP.Position + offset
        local myChar = lp.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if myRoot then
            local newCF = CFrame.new(rageServerPos)
            if (newCF.Position - myRoot.Position).Magnitude < 2000 then
                pcall(function() myRoot.CFrame = newCF end)
            end
        end
    end))
end

local function StopOrbit()
    if rageOrbitConn then rageOrbitConn:Disconnect();rageOrbitConn=nil end
    rageServerPos = Vector3.new()
end

local function TickVoidSpam()
    if not RageCfg.VoidSpamEnabled then return false end
    local now     = tick()
    local elapsed = now - rageVoidLastSwitch
    if rageVoidPhase == "shoot" then
        RageCfg.Phase = "attacking"
        if elapsed >= rageVoidCurrentDur then
            rageVoidPhase      = "hide"
            rageVoidCurrentDur = RandRange(RageCfg.VoidHideMin, RageCfg.VoidHideMax)
            rageVoidLastSwitch = now
        end
    elseif rageVoidPhase == "hide" then
        RageCfg.Phase = "hiding"
        local myChar = lp.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if myRoot then
            rageServerPos = Vector3.new(math.random(-10000,10000),-99999,math.random(-10000,10000))
            pcall(function() myRoot.CFrame = CFrame.new(rageServerPos) end)
        end
        if elapsed >= rageVoidCurrentDur then
            rageVoidPhase      = "shoot"
            rageVoidCurrentDur = RandRange(RageCfg.VoidShootMin, RageCfg.VoidShootMax)
            rageVoidLastSwitch = now
        end
        return true
    end
    return false
end

local function StartRagebot()
    if rageConn then rageConn:Disconnect();rageConn=nil end
    rageRunning        = false
    rageVoidPhase      = "shoot"
    rageVoidLastSwitch = tick()
    rageVoidCurrentDur = RandRange(RageCfg.VoidShootMin, RageCfg.VoidShootMax)
    SetupAntiKatana()

    rageConn = Track(RunService.Heartbeat:Connect(function(dt)
        if not RageCfg.Enabled or rageRunning then return end
        local lf, item = GetEquipped()
        if not lf or not item then RageCfg.Phase="idle";return end
        local targetChar = RageGetTarget()
        if not targetChar then
            RageCfg.Phase="idle"
            if rageOrbitConn then StopOrbit() end
            return
        end
        if RageCfg.OrbitEnabled and not rageOrbitConn then StartOrbit(targetChar) end
        local inHide = TickVoidSpam()
        if inHide then return end
        rageRunning = true
        task.spawn(function()
            task.delay(5, function()
                if rageRunning then
                    rageRunning=false;pcall(RageDesyncStop)
                    warn("[Ragebot] Timeout safety triggered")
                end
            end)
            local ok, err2 = pcall(function()
                if not RageCfg.VoidSpamEnabled then
                    RageCfg.Phase="hiding"
                    RageDesyncHide()
                    task.wait(RageCfg.HideRange)
                    if not targetChar or not targetChar.Parent then RageCfg.Phase="idle";RageDesyncStop();return end
                    local hum2 = targetChar:FindFirstChildOfClass("Humanoid")
                    if not hum2 or hum2.Health<=0 then RageCfg.Phase="idle";RageDesyncStop();return end
                    RageCfg.Phase="attacking"
                    RageDesyncAttack(targetChar)
                    task.wait(0.05)
                end
                if RageCfg.AutoShoot then AutoShoot(item, lf, targetChar) end
                task.wait(RageCfg.AttackRange)
                if not RageCfg.VoidSpamEnabled then RageDesyncStop() end
            end)
            if not ok then warn("[Ragebot] Error: "..tostring(err2));pcall(RageDesyncStop) end
            RageCfg.Phase="idle";rageRunning=false
        end)
    end))
end

local function StopRagebot()
    if rageConn then rageConn:Disconnect();rageConn=nil end
    StopOrbit()
    pcall(RageDesyncStop)
    RageCfg.Enabled=false;RageCfg.Phase="idle"
    rageRunning=false;rageVoidPhase="shoot"
    katanaUsers={}
end

